Dialogue: 0,0:00:35.94,0:00:40.61,Default,,0000,0000,0000,,誰が殺されてやるか
Dialogue: 0,0:00:40.61,0:00:42.61,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:45.61,0:00:49.62,Default,,0000,0000,0000,,本当に 砂漠なんだな
Dialogue: 0,0:00:49.62,0:00:54.32,Default,,0000,0000,0000,,んっ スゥー
Dialogue: 0,0:00:56.79,0:01:00.46,Default,,0000,0000,0000,,あっ あっ うわっ! あ!
Dialogue: 0,0:01:00.46,0:01:04.30,Default,,0000,0000,0000,,がっ! あっ
Dialogue: 0,0:01:04.30,0:01:07.97,Default,,0000,0000,0000,,あっ なんだ? こいつ
Dialogue: 0,0:01:04.30,0:01:07.97,Default,,0000,0000,0000,,あっ あっ うわ!
Dialogue: 0,0:01:07.97,0:01:10.47,Default,,0000,0000,0000,,あっ! ハッ!
Dialogue: 0,0:01:14.14,0:01:17.48,Default,,0000,0000,0000,,嫌だ
Dialogue: 0,0:01:14.14,0:01:17.48,Default,,0000,0000,0000,,あっ あっ あっ あっ あっ
Dialogue: 0,0:01:17.48,0:01:19.48,Default,,0000,0000,0000,,嫌だ!
Dialogue: 0,0:01:26.82,0:01:28.82,Default,,0000,0000,0000,,あっ! ハァ
Dialogue: 0,0:01:35.43,0:01:37.43,Default,,0000,0000,0000,,なんなんだよ?
Dialogue: 0,0:01:37.43,0:01:40.77,Default,,0000,0000,0000,,俺に どうしろってんだよ
Dialogue: 0,0:01:40.77,0:01:45.94,Default,,0000,0000,0000,,答えてくれよ ナツキ・スバル!
Dialogue: 0,0:01:45.94,0:01:49.11,Default,,0000,0000,0000,,あっ? あっ あっ あっ あっ!
Dialogue: 0,0:01:45.94,0:01:49.11,Default,,0000,0000,0000,,あっ あっ あっ
Dialogue: 0,0:01:49.11,0:01:51.78,Default,,0000,0000,0000,,やだ やだ やだ!
Dialogue: 0,0:01:49.11,0:01:51.78,Default,,0000,0000,0000,,あ! あっ あっ!
Dialogue: 0,0:01:51.78,0:01:54.45,Default,,0000,0000,0000,,うわ! あ!
Dialogue: 0,0:01:54.45,0:01:57.95,Default,,0000,0000,0000,,誰か 誰か助けて!
Dialogue: 0,0:02:05.63,0:02:08.13,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:02:08.13,0:02:11.97,Default,,0000,0000,0000,,うっ あっ ゴホッ ゴホッ ゴホッ!
Dialogue: 0,0:02:11.97,0:02:14.77,Default,,0000,0000,0000,,ペッ! ハァ
Dialogue: 0,0:02:17.80,0:02:20.81,Default,,0000,0000,0000,,ハァ んっ
Dialogue: 0,0:02:20.81,0:02:24.14,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:24.14,0:02:27.31,Default,,0000,0000,0000,,砂漠の地下?
Dialogue: 0,0:02:27.31,0:02:30.32,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:02:30.32,0:02:33.02,Default,,0000,0000,0000,,あっ あっ?
Dialogue: 0,0:02:38.09,0:02:41.26,Default,,0000,0000,0000,,やばい やばい やばい やばい!
Dialogue: 0,0:02:41.26,0:02:46.27,Default,,0000,0000,0000,,なんなんだ? なんなんだ?
Dialogue: 0,0:02:41.26,0:02:46.27,Default,,0000,0000,0000,,なんなんだよ!
Dialogue: 0,0:04:27.30,0:04:29.30,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:04:33.41,0:04:36.01,Default,,0000,0000,0000,,これで 3枚目
Dialogue: 0,0:04:38.75,0:04:44.75,Default,,0000,0000,0000,,んっ どんくらいたった?
Dialogue: 0,0:04:38.75,0:04:44.75,Default,,0000,0000,0000,,3時間か 4時間か
Dialogue: 0,0:04:44.75,0:04:49.76,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:04:49.76,0:04:53.76,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:04:53.76,0:04:56.76,Default,,0000,0000,0000,,あっ うっ!
Dialogue: 0,0:04:56.76,0:05:00.93,Default,,0000,0000,0000,,つっ くっ くそ!
Dialogue: 0,0:05:00.93,0:05:03.94,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:05:06.44,0:05:09.94,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:05:09.94,0:05:14.05,Default,,0000,0000,0000,,あっ? あっ? あっ んっ
Dialogue: 0,0:05:20.79,0:05:25.79,Default,,0000,0000,0000,,フッ フッ! フン! フン! フン!
Dialogue: 0,0:05:25.79,0:05:29.30,Default,,0000,0000,0000,,フゥフゥ ざけんな
Dialogue: 0,0:05:29.30,0:05:33.30,Default,,0000,0000,0000,,なんで なんで 邪魔すんだよ!
Dialogue: 0,0:05:35.40,0:05:40.57,Default,,0000,0000,0000,,なっ!
Dialogue: 0,0:05:35.40,0:05:40.57,Default,,0000,0000,0000,,ふざ てめえ 冗談じゃねえぞ!
Dialogue: 0,0:05:40.57,0:05:43.08,Default,,0000,0000,0000,,ハァハァハァ
Dialogue: 0,0:05:43.08,0:05:45.98,Default,,0000,0000,0000,,ハァ はっ?
Dialogue: 0,0:05:53.75,0:05:59.46,Default,,0000,0000,0000,,さんざん 逃げて
Dialogue: 0,0:05:53.75,0:05:59.46,Default,,0000,0000,0000,,逃げて 逃げて
Dialogue: 0,0:06:03.76,0:06:08.77,Default,,0000,0000,0000,,もういい 殺してやる
Dialogue: 0,0:06:08.77,0:06:10.77,Default,,0000,0000,0000,,ハハハ!
Dialogue: 0,0:06:10.77,0:06:14.27,Default,,0000,0000,0000,,ハッ ハハハハ ハハハハ
Dialogue: 0,0:06:14.27,0:06:17.61,Default,,0000,0000,0000,,ハハッ ハッ ハァ
Dialogue: 0,0:06:17.61,0:06:22.95,Default,,0000,0000,0000,,誰だか知らねえが
Dialogue: 0,0:06:22.95,0:06:27.79,Default,,0000,0000,0000,,殺してやる 絶対に殺してやる
Dialogue: 0,0:06:27.79,0:06:32.89,Default,,0000,0000,0000,,殺す 殺す 殺す
Dialogue: 0,0:06:32.89,0:06:37.73,Default,,0000,0000,0000,,殺す 殺す 殺す 殺す
Dialogue: 0,0:06:37.73,0:06:41.90,Default,,0000,0000,0000,,殺す 殺す 殺す
Dialogue: 0,0:06:41.90,0:06:50.41,Default,,0000,0000,0000,,殺す 殺す 殺す 殺す!
Dialogue: 0,0:06:50.41,0:06:53.58,Default,,0000,0000,0000,,ハハッ! ハァハァ
Dialogue: 0,0:06:53.58,0:06:56.58,Default,,0000,0000,0000,,ハァハァハァ
Dialogue: 0,0:06:56.58,0:07:00.09,Default,,0000,0000,0000,,ハァハァ はっ?
Dialogue: 0,0:07:05.76,0:07:08.76,Default,,0000,0000,0000,,あっ あっ あっ
Dialogue: 0,0:07:08.76,0:07:10.93,Default,,0000,0000,0000,,ああ あっ ああ ハァハァ
Dialogue: 0,0:07:10.93,0:07:15.27,Default,,0000,0000,0000,,うっ! オエッ! ゴホッ ゴホッ ゴホッ!
Dialogue: 0,0:07:15.27,0:07:21.27,Default,,0000,0000,0000,,ハァハァハァ んっ
Dialogue: 0,0:07:21.27,0:07:25.28,Default,,0000,0000,0000,,シャウラは犯人じゃなかったか
Dialogue: 0,0:07:25.28,0:07:28.61,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:07:28.61,0:07:32.79,Default,,0000,0000,0000,,ベアトリスとメィリィは子どもだ
Dialogue: 0,0:07:28.61,0:07:32.79,Default,,0000,0000,0000,,どうとでもなる
Dialogue: 0,0:07:32.79,0:07:35.89,Default,,0000,0000,0000,,エミリアは 俺への警戒が薄かった
Dialogue: 0,0:07:35.89,0:07:40.06,Default,,0000,0000,0000,,そういう意味で危険なのは ラムとエキドナか
Dialogue: 0,0:07:40.06,0:07:42.06,Default,,0000,0000,0000,,ユリウスのやつも
Dialogue: 0,0:07:42.06,0:07:46.23,Default,,0000,0000,0000,,俺と無関係のところで 死んでくれてると助かるんだが
Dialogue: 0,0:07:46.23,0:07:48.23,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:07:54.91,0:07:56.91,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:08:06.25,0:08:09.42,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:08:09.42,0:08:11.42,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:08:22.10,0:08:26.31,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:08:29.44,0:08:32.45,Default,,0000,0000,0000,,見当たらねえのは エミリアとベアトリス
Dialogue: 0,0:08:32.45,0:08:34.38,Default,,0000,0000,0000,,あいつらの どっちかが 俺を
Dialogue: 0,0:08:34.38,0:08:36.38,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:08:38.38,0:08:41.89,Default,,0000,0000,0000,,お前かよ
Dialogue: 0,0:08:53.73,0:08:58.24,Default,,0000,0000,0000,,ついてくんな! お前と 遊んでる暇なんかねえんだよ!
Dialogue: 0,0:08:58.24,0:09:02.24,Default,,0000,0000,0000,,生き残ってるやつを ぶっ殺さなきゃならねえんだ!
Dialogue: 0,0:09:02.24,0:09:04.24,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:09:04.24,0:09:09.08,Default,,0000,0000,0000,,お前が邪魔をするってんなら!
Dialogue: 0,0:09:09.08,0:09:13.75,Default,,0000,0000,0000,,ハァ ハッ ハハハハ ハハッ ハハハ
Dialogue: 0,0:09:13.75,0:09:15.76,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:09:21.43,0:09:26.10,Default,,0000,0000,0000,,あっ うっ くそ!
Dialogue: 0,0:09:21.43,0:09:26.10,Default,,0000,0000,0000,,くそ! くそ くそ くそ!
Dialogue: 0,0:09:26.10,0:09:29.10,Default,,0000,0000,0000,,なんなんだ? なんなんだよ!?
Dialogue: 0,0:09:29.10,0:09:34.04,Default,,0000,0000,0000,,お前も お前以外のやつらも!
Dialogue: 0,0:09:29.10,0:09:34.04,Default,,0000,0000,0000,,死体も! 生きてるやつも!
Dialogue: 0,0:09:34.04,0:09:37.21,Default,,0000,0000,0000,,一体 何 考えて どうしたいんだよ!?
Dialogue: 0,0:09:37.21,0:09:40.38,Default,,0000,0000,0000,,お前らのことなんか 1人も知るもんかよ!
Dialogue: 0,0:09:40.38,0:09:44.38,Default,,0000,0000,0000,,みんなが みんな 自分の事情 押しつけやがって!
Dialogue: 0,0:09:44.38,0:09:47.22,Default,,0000,0000,0000,,お前らが 自分のことで 手いっぱいなら
Dialogue: 0,0:09:47.22,0:09:49.89,Default,,0000,0000,0000,,俺だって! ハァ
Dialogue: 0,0:09:49.89,0:09:53.56,Default,,0000,0000,0000,,俺のことで 手いっぱいなんだよ!
Dialogue: 0,0:10:01.40,0:10:05.57,Default,,0000,0000,0000,,俺のことなんか 放っておいてくれよ
Dialogue: 0,0:10:05.57,0:10:10.24,Default,,0000,0000,0000,,独りぼっちで 見捨てていてくれよ!
Dialogue: 0,0:10:16.42,0:10:18.58,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:10:16.42,0:10:18.58,Default,,0000,0000,0000,,クワー!
Dialogue: 0,0:10:18.58,0:10:24.26,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:10:18.58,0:10:24.26,Default,,0000,0000,0000,,痛っ! お前 あっ あっ!
Dialogue: 0,0:10:24.26,0:10:26.59,Default,,0000,0000,0000,,んっ うっ! ハァ
Dialogue: 0,0:10:26.59,0:10:28.93,Default,,0000,0000,0000,,あっ あっ あ!
Dialogue: 0,0:10:28.93,0:10:30.93,Default,,0000,0000,0000,,クワッ!
Dialogue: 0,0:10:34.10,0:10:38.27,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:10:40.27,0:10:44.11,Default,,0000,0000,0000,,うっ うっ! えっ?
Dialogue: 0,0:10:44.11,0:10:46.95,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:10:46.95,0:10:50.95,Default,,0000,0000,0000,,嫌だ 嫌だ! 死にたくない!
Dialogue: 0,0:10:50.95,0:10:53.29,Default,,0000,0000,0000,,クワッ! クワー!
Dialogue: 0,0:10:50.95,0:10:53.29,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:10:53.29,0:10:57.49,Default,,0000,0000,0000,,とかげ!
Dialogue: 0,0:10:59.63,0:11:05.46,Default,,0000,0000,0000,,あっ! ハァハァ ハァハァ
Dialogue: 0,0:11:18.48,0:11:22.82,Default,,0000,0000,0000,,なんなんだ?
Dialogue: 0,0:11:22.82,0:11:26.02,Default,,0000,0000,0000,,お前は なんなんだよ?
Dialogue: 0,0:11:28.49,0:11:33.26,Default,,0000,0000,0000,,次 当ててみなよ 英雄
Dialogue: 0,0:11:40.10,0:11:42.10,Default,,0000,0000,0000,,スバル!
Dialogue: 0,0:11:40.10,0:11:42.10,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:42.10,0:11:44.60,Default,,0000,0000,0000,,ねえ スバルってば 大丈夫なの?
Dialogue: 0,0:11:44.60,0:11:47.27,Default,,0000,0000,0000,,エミ リア
Dialogue: 0,0:11:47.27,0:11:53.28,Default,,0000,0000,0000,,ほんとに よかった
Dialogue: 0,0:11:47.27,0:11:53.28,Default,,0000,0000,0000,,すごく心配したんだから
Dialogue: 0,0:11:53.28,0:11:55.95,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:11:55.95,0:11:58.28,Default,,0000,0000,0000,,スバル?
Dialogue: 0,0:11:55.95,0:11:58.28,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:11:58.28,0:12:00.29,Default,,0000,0000,0000,,どうしたの?
Dialogue: 0,0:12:00.29,0:12:04.29,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:00.29,0:12:04.29,Default,,0000,0000,0000,,寝ぼけているみたいかしら
Dialogue: 0,0:12:04.29,0:12:06.29,Default,,0000,0000,0000,,ベティーたちに心配かけたわりに
Dialogue: 0,0:12:06.29,0:12:09.96,Default,,0000,0000,0000,,悠長なことなのよ
Dialogue: 0,0:12:06.29,0:12:09.96,Default,,0000,0000,0000,,クワー
Dialogue: 0,0:12:06.29,0:12:09.96,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:09.96,0:12:13.97,Default,,0000,0000,0000,,お前 んっ!
Dialogue: 0,0:12:09.96,0:12:13.97,Default,,0000,0000,0000,,クゥ?
Dialogue: 0,0:12:13.97,0:12:16.30,Default,,0000,0000,0000,,なんだか 釈然としないかしら
Dialogue: 0,0:12:16.30,0:12:20.14,Default,,0000,0000,0000,,スバルを見つけたのは ベティーとエミリアの手柄のはずなのよ
Dialogue: 0,0:12:20.14,0:12:22.31,Default,,0000,0000,0000,,フフッ すねないの
Dialogue: 0,0:12:22.31,0:12:26.61,Default,,0000,0000,0000,,いいじゃない スバルとパトラッシュちゃん すごく仲よしで
Dialogue: 0,0:12:29.82,0:12:33.59,Default,,0000,0000,0000,,ねえ スバル 本当に 体調は 大丈夫なの?
Dialogue: 0,0:12:33.59,0:12:37.26,Default,,0000,0000,0000,,ああ 大丈夫 大丈夫 ノープロだよ
Dialogue: 0,0:12:37.26,0:12:39.59,Default,,0000,0000,0000,,たぶん 疲れが たまってたんだろうね
Dialogue: 0,0:12:39.59,0:12:42.43,Default,,0000,0000,0000,,寝落ちなんて よくある話だからさ
Dialogue: 0,0:12:42.43,0:12:46.27,Default,,0000,0000,0000,,そう でも 疲れてるなら ちゃんと言ってね?
Dialogue: 0,0:12:46.27,0:12:48.57,Default,,0000,0000,0000,,無理は 禁物なんだから
Dialogue: 0,0:12:52.27,0:12:54.61,Default,,0000,0000,0000,,かなり リスキーになるが
Dialogue: 0,0:12:54.61,0:12:58.11,Default,,0000,0000,0000,,今回は 記憶喪失のことを 打ち明けずにいく
Dialogue: 0,0:12:58.11,0:13:02.95,Default,,0000,0000,0000,,俺が殺される理由と記憶喪失が 関係してるか 確かめたい
Dialogue: 0,0:13:02.95,0:13:06.29,Default,,0000,0000,0000,,正直 覚えられてちゃ 不都合なことがあるから
Dialogue: 0,0:13:06.29,0:13:10.79,Default,,0000,0000,0000,,殺すって線はあっても 何かを忘れたから殺される ってのは
Dialogue: 0,0:13:10.79,0:13:15.29,Default,,0000,0000,0000,,考えにくい気がするが あっ えっ?
Dialogue: 0,0:13:15.29,0:13:19.30,Default,,0000,0000,0000,,スバル また 眉間に しわが寄ってるわよ
Dialogue: 0,0:13:21.30,0:13:25.80,Default,,0000,0000,0000,,一体 どうしたら この子と そんな距離感になるんだよ
Dialogue: 0,0:13:25.80,0:13:27.81,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:13:27.81,0:13:32.14,Default,,0000,0000,0000,,あの2人の死体は 見つからなかった でも
Dialogue: 0,0:13:37.42,0:13:40.75,Default,,0000,0000,0000,,あの声は 2人のじゃなかった
Dialogue: 0,0:13:40.75,0:13:42.76,Default,,0000,0000,0000,,つうか ここの連中の誰とも
Dialogue: 0,0:13:42.76,0:13:45.76,Default,,0000,0000,0000,,バルス
Dialogue: 0,0:13:42.76,0:13:45.76,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:45.76,0:13:49.09,Default,,0000,0000,0000,,ぼけっとしていないで 水くみぐらい 手伝いなさい
Dialogue: 0,0:13:49.09,0:13:53.27,Default,,0000,0000,0000,,あっとと 悪い
Dialogue: 0,0:13:49.09,0:13:53.27,Default,,0000,0000,0000,,上の書庫で寝ていたらしいわね
Dialogue: 0,0:13:53.27,0:13:56.27,Default,,0000,0000,0000,,あまり ばかなまねをするのは やめなさい
Dialogue: 0,0:13:56.27,0:13:58.27,Default,,0000,0000,0000,,周りに迷惑がかかるから
Dialogue: 0,0:13:58.27,0:14:03.44,Default,,0000,0000,0000,,ああ 反省してる
Dialogue: 0,0:13:58.27,0:14:03.44,Default,,0000,0000,0000,,お前にも 心配かけて悪かったな
Dialogue: 0,0:14:03.44,0:14:05.78,Default,,0000,0000,0000,,ラムが バルスの心配? なんのために?
Dialogue: 0,0:14:05.78,0:14:08.28,Default,,0000,0000,0000,,身を案じるためにかな
Dialogue: 0,0:14:05.78,0:14:08.28,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:14:08.28,0:14:10.78,Default,,0000,0000,0000,,グッモーニンっす お師様!
Dialogue: 0,0:14:08.28,0:14:10.78,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:14:10.78,0:14:15.62,Default,,0000,0000,0000,,昨日は よく寝れたっすか?
Dialogue: 0,0:14:10.78,0:14:15.62,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:14:15.62,0:14:18.12,Default,,0000,0000,0000,,ちなみに あしは よく寝たっす!
Dialogue: 0,0:14:18.12,0:14:20.63,Default,,0000,0000,0000,,昔の夢とか見ちゃったっすよ!
Dialogue: 0,0:14:20.63,0:14:24.63,Default,,0000,0000,0000,,あしと お師様と かか様と それから
Dialogue: 0,0:14:20.63,0:14:24.63,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:14:24.63,0:14:27.97,Default,,0000,0000,0000,,あ わかった わかった!
Dialogue: 0,0:14:24.63,0:14:27.97,Default,,0000,0000,0000,,そのうち聞いてやるから
Dialogue: 0,0:14:27.97,0:14:32.14,Default,,0000,0000,0000,,ところで お前 今朝の俺を見て なんか 気付かないか?
Dialogue: 0,0:14:32.14,0:14:34.41,Default,,0000,0000,0000,,今朝のお師様?
Dialogue: 0,0:14:34.41,0:14:38.91,Default,,0000,0000,0000,,いつもどおり 色男っす!
Dialogue: 0,0:14:34.41,0:14:38.91,Default,,0000,0000,0000,,プロポーズ 400年待ちっす!
Dialogue: 0,0:14:38.91,0:14:41.25,Default,,0000,0000,0000,,気の長え話だな
Dialogue: 0,0:14:41.25,0:14:44.25,Default,,0000,0000,0000,,何もないんならいいんだけどさ
Dialogue: 0,0:14:41.25,0:14:44.25,Default,,0000,0000,0000,,そっすか?
Dialogue: 0,0:14:44.25,0:14:46.45,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:44.25,0:14:46.45,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:14:49.09,0:14:51.42,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:14:51.42,0:14:54.43,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:54.43,0:14:57.60,Default,,0000,0000,0000,,んっ! ハァ
Dialogue: 0,0:14:57.60,0:15:01.80,Default,,0000,0000,0000,,シャウラ ちょっと頼みがある
Dialogue: 0,0:14:57.60,0:15:01.80,Default,,0000,0000,0000,,へっ? なんすか?
Dialogue: 0,0:15:03.77,0:15:06.44,Default,,0000,0000,0000,,ユリウス
Dialogue: 0,0:15:06.44,0:15:11.24,Default,,0000,0000,0000,,昨日の夜のことで話がしたい
Dialogue: 0,0:15:06.44,0:15:11.24,Default,,0000,0000,0000,,1対1の差しでな
Dialogue: 0,0:15:14.61,0:15:17.45,Default,,0000,0000,0000,,昨夜のことか
Dialogue: 0,0:15:17.45,0:15:22.45,Default,,0000,0000,0000,,あの話は あの場で終わったものと 思っていたが 君は違うと?
Dialogue: 0,0:15:22.45,0:15:27.56,Default,,0000,0000,0000,,ああ 違うね 全然 全く
Dialogue: 0,0:15:22.45,0:15:27.56,Default,,0000,0000,0000,,俺は 納得しちゃいねえよ
Dialogue: 0,0:15:29.80,0:15:33.57,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:15:29.80,0:15:33.57,Default,,0000,0000,0000,,納得か
Dialogue: 0,0:15:33.57,0:15:36.07,Default,,0000,0000,0000,,なるほど 君らしい言い分だ
Dialogue: 0,0:15:36.07,0:15:39.74,Default,,0000,0000,0000,,しかし それは いささか 勝手がすぎるのでは?
Dialogue: 0,0:15:39.74,0:15:42.91,Default,,0000,0000,0000,,お前だって 納得してるって面じゃねえだろ
Dialogue: 0,0:15:42.91,0:15:46.41,Default,,0000,0000,0000,,2人そろって イライラしたもんを 腹に抱えてるってのに
Dialogue: 0,0:15:46.41,0:15:50.08,Default,,0000,0000,0000,,平然としてろってか?
Dialogue: 0,0:15:46.41,0:15:50.08,Default,,0000,0000,0000,,できるかよ
Dialogue: 0,0:15:50.08,0:15:53.75,Default,,0000,0000,0000,,ならば 一体 他に どんな選択肢がある?
Dialogue: 0,0:15:53.75,0:15:57.26,Default,,0000,0000,0000,,私の思いは 昨夜も告げたとおりだ
Dialogue: 0,0:15:57.26,0:16:00.26,Default,,0000,0000,0000,,そして それ以上 話すこともない
Dialogue: 0,0:16:00.26,0:16:02.26,Default,,0000,0000,0000,,君とアナスタシア様
Dialogue: 0,0:16:02.26,0:16:06.43,Default,,0000,0000,0000,,エキドナとの密通に 私は まるで 気付けなかったのだから
Dialogue: 0,0:16:06.43,0:16:10.44,Default,,0000,0000,0000,,あっ 俺とエキドナとの密通?
Dialogue: 0,0:16:10.44,0:16:13.94,Default,,0000,0000,0000,,君に悪意がなかったことは わかっている
Dialogue: 0,0:16:13.94,0:16:17.61,Default,,0000,0000,0000,,エキドナとも 十分とは言えないが 言葉を交わした
Dialogue: 0,0:16:17.61,0:16:19.95,Default,,0000,0000,0000,,彼女は 信用できる
Dialogue: 0,0:16:19.95,0:16:23.95,Default,,0000,0000,0000,,いや 彼女を信じる以外に すべはない
Dialogue: 0,0:16:23.95,0:16:26.45,Default,,0000,0000,0000,,アナスタシア様を お救いするには
Dialogue: 0,0:16:26.45,0:16:30.79,Default,,0000,0000,0000,,その可能性に 懸ける以外にないんだ
Dialogue: 0,0:16:26.45,0:16:30.79,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:16:30.79,0:16:37.23,Default,,0000,0000,0000,,取り戻せたところで あの方が
Dialogue: 0,0:16:30.79,0:16:37.23,Default,,0000,0000,0000,,私を覚えていなかったとしても
Dialogue: 0,0:16:37.23,0:16:40.57,Default,,0000,0000,0000,,なん だよ
Dialogue: 0,0:16:40.57,0:16:46.27,Default,,0000,0000,0000,,後生だ これ以上 君の前で
Dialogue: 0,0:16:40.57,0:16:46.27,Default,,0000,0000,0000,,私を惨めにしないでほしい
Dialogue: 0,0:16:50.58,0:16:54.75,Default,,0000,0000,0000,,昨夜の話と言われ 少し おびえたよ
Dialogue: 0,0:16:54.75,0:16:59.08,Default,,0000,0000,0000,,君が謝罪を口にしたら どうするべきかと
Dialogue: 0,0:16:59.08,0:17:02.76,Default,,0000,0000,0000,,俺が謝ったら?
Dialogue: 0,0:17:02.76,0:17:07.93,Default,,0000,0000,0000,,そのときは 私は 君に
Dialogue: 0,0:17:02.76,0:17:07.93,Default,,0000,0000,0000,,なんと答えたのだろうね
Dialogue: 0,0:17:07.93,0:17:11.03,Default,,0000,0000,0000,,それも もう わからないことだが
Dialogue: 0,0:17:19.94,0:17:23.24,Default,,0000,0000,0000,,ハァー ハァ
Dialogue: 0,0:17:25.28,0:17:29.78,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:17:25.28,0:17:29.78,Default,,0000,0000,0000,,お師様 あれでよかったんすか?
Dialogue: 0,0:17:29.78,0:17:35.05,Default,,0000,0000,0000,,ああ あの分だと ユリウスは
Dialogue: 0,0:17:29.78,0:17:35.05,Default,,0000,0000,0000,,書庫のこととは無関係っぽいな
Dialogue: 0,0:17:35.05,0:17:39.06,Default,,0000,0000,0000,,ただ また 昨日の俺に対する 不信感が募ったぞ
Dialogue: 0,0:17:39.06,0:17:43.73,Default,,0000,0000,0000,,よくわかんねえっすけど あしは お師様のお役に立てたっすか?
Dialogue: 0,0:17:43.73,0:17:45.73,Default,,0000,0000,0000,,ああ 立った 立った
Dialogue: 0,0:17:45.73,0:17:50.74,Default,,0000,0000,0000,,お前が そばにいてくれたおかげで
Dialogue: 0,0:17:45.73,0:17:50.74,Default,,0000,0000,0000,,安心して ユリウスと向き合えたよ
Dialogue: 0,0:17:50.74,0:17:54.91,Default,,0000,0000,0000,,エヘヘヘヘヘヘ!
Dialogue: 0,0:17:50.74,0:17:54.91,Default,,0000,0000,0000,,そしたら よかったっす!
Dialogue: 0,0:17:54.91,0:17:56.91,Default,,0000,0000,0000,,じゃあ じゃあ じゃあ お師様 お師様!
Dialogue: 0,0:17:56.91,0:18:01.58,Default,,0000,0000,0000,,ご褒美に あしのことを ギュッと抱き締めてほしいっす!
Dialogue: 0,0:18:01.58,0:18:04.25,Default,,0000,0000,0000,,それは やだ
Dialogue: 0,0:18:01.58,0:18:04.25,Default,,0000,0000,0000,,え! ひどいっす!
Dialogue: 0,0:18:04.25,0:18:06.92,Default,,0000,0000,0000,,お師様 ご褒美のレベルを 逸脱しなかったら
Dialogue: 0,0:18:06.92,0:18:09.76,Default,,0000,0000,0000,,あしの言うことを 聞いてくれるって言ったっすよ!
Dialogue: 0,0:18:09.76,0:18:13.43,Default,,0000,0000,0000,,そのお願いは 俺の純情を超えている
Dialogue: 0,0:18:09.76,0:18:13.43,Default,,0000,0000,0000,,え!
Dialogue: 0,0:18:13.43,0:18:19.26,Default,,0000,0000,0000,,結局 お前 一体 何してて
Dialogue: 0,0:18:13.43,0:18:19.26,Default,,0000,0000,0000,,誰に狙われたんだよ?
Dialogue: 0,0:18:19.26,0:18:21.77,Default,,0000,0000,0000,,ナツキ・スバル
Dialogue: 0,0:18:21.77,0:18:26.44,Default,,0000,0000,0000,,煮詰まってきたな
Dialogue: 0,0:18:21.77,0:18:26.44,Default,,0000,0000,0000,,パトラッシュに相談したい気分だ
Dialogue: 0,0:18:26.44,0:18:28.94,Default,,0000,0000,0000,,え! 地竜にっすか?
Dialogue: 0,0:18:28.94,0:18:31.28,Default,,0000,0000,0000,,あいつ あし にらむから 好きじゃないっす!
Dialogue: 0,0:18:31.28,0:18:34.71,Default,,0000,0000,0000,,お前 パトラッシュの悪口は許さねえぞ
Dialogue: 0,0:18:34.71,0:18:37.72,Default,,0000,0000,0000,,この世の誰の悪口が許される 世界になったとしても
Dialogue: 0,0:18:37.72,0:18:40.39,Default,,0000,0000,0000,,パトラッシュの悪口だけは 俺が許さねえ!
Dialogue: 0,0:18:40.39,0:18:44.39,Default,,0000,0000,0000,,お師様 あの地竜に どんだけ骨抜きにされてんすか?
Dialogue: 0,0:18:44.39,0:18:49.56,Default,,0000,0000,0000,,つうわけで 俺と お前も
Dialogue: 0,0:18:44.39,0:18:49.56,Default,,0000,0000,0000,,ここで解散だ またあとでな
Dialogue: 0,0:18:49.56,0:18:53.40,Default,,0000,0000,0000,,あっ うえ!? ご褒美も なあなあにされたっす!
Dialogue: 0,0:18:53.40,0:18:55.57,Default,,0000,0000,0000,,でも あしは くじけねえっす
Dialogue: 0,0:18:55.57,0:18:57.74,Default,,0000,0000,0000,,お師様にとって 都合のいい女
Dialogue: 0,0:18:57.74,0:19:00.44,Default,,0000,0000,0000,,それが あしの存在意義っすから!
Dialogue: 0,0:19:02.41,0:19:07.41,Default,,0000,0000,0000,,そこまでする価値が ナツキ・スバルの どこにあるんだよ
Dialogue: 0,0:19:07.41,0:19:11.22,Default,,0000,0000,0000,,んっ? お師様?
Dialogue: 0,0:19:07.41,0:19:11.22,Default,,0000,0000,0000,,あ くそ!
Dialogue: 0,0:19:14.25,0:19:16.59,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:16.59,0:19:21.26,Default,,0000,0000,0000,,都合のいい女とか そんなこと 考えなくていい
Dialogue: 0,0:19:21.26,0:19:23.60,Default,,0000,0000,0000,,俺が悪かった
Dialogue: 0,0:19:23.60,0:19:26.60,Default,,0000,0000,0000,,お師様
Dialogue: 0,0:19:28.77,0:19:32.87,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:28.77,0:19:32.87,Default,,0000,0000,0000,,お前がいてくれて助かった
Dialogue: 0,0:19:32.87,0:19:35.71,Default,,0000,0000,0000,,そんだけだ
Dialogue: 0,0:19:35.71,0:19:38.04,Default,,0000,0000,0000,,お師様
Dialogue: 0,0:19:38.04,0:19:42.38,Default,,0000,0000,0000,,んっ ついに あしのこと
Dialogue: 0,0:19:42.38,0:19:44.38,Default,,0000,0000,0000,,愛してくれる気に
Dialogue: 0,0:19:42.38,0:19:44.38,Default,,0000,0000,0000,,いっ!?
Dialogue: 0,0:19:44.38,0:19:46.49,Default,,0000,0000,0000,,ぐえっ!
Dialogue: 0,0:19:44.38,0:19:46.49,Default,,0000,0000,0000,,純情超え!
Dialogue: 0,0:19:57.06,0:19:59.06,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:59.06,0:20:02.07,Default,,0000,0000,0000,,あいつらの態度が うそだったとしたら
Dialogue: 0,0:20:02.07,0:20:05.90,Default,,0000,0000,0000,,もう 何を信じていいのか わからねえよ
Dialogue: 0,0:20:05.90,0:20:08.41,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:20:08.41,0:20:12.41,Default,,0000,0000,0000,,結局 信じられるのは パトラッシュだけと
Dialogue: 0,0:20:12.41,0:20:17.58,Default,,0000,0000,0000,,いっそ パトラッシュと俺だけの楽園で
Dialogue: 0,0:20:12.41,0:20:17.58,Default,,0000,0000,0000,,暮らしたほうが幸せなんじゃ
Dialogue: 0,0:20:17.58,0:20:20.59,Default,,0000,0000,0000,,ああ 聞いちゃった!
Dialogue: 0,0:20:17.58,0:20:20.59,Default,,0000,0000,0000,,うえっ!?
Dialogue: 0,0:20:20.59,0:20:22.75,Default,,0000,0000,0000,,ウフフ!
Dialogue: 0,0:20:22.75,0:20:26.76,Default,,0000,0000,0000,,お兄さん パトラッシュちゃんと 遠くへ逃げたいんだ?
Dialogue: 0,0:20:26.76,0:20:30.60,Default,,0000,0000,0000,,そんなの聞いたら ベアトリスちゃんや お姉さんが泣いちゃうんだから
Dialogue: 0,0:20:30.60,0:20:33.10,Default,,0000,0000,0000,,クオリティーの低い冗句だ
Dialogue: 0,0:20:33.10,0:20:36.94,Default,,0000,0000,0000,,いろんな意味で忘れてくれ
Dialogue: 0,0:20:33.10,0:20:36.94,Default,,0000,0000,0000,,はいはい
Dialogue: 0,0:20:36.94,0:20:41.77,Default,,0000,0000,0000,,でも 別に それが お兄さんの本心でも 笑ったりしないわよ?
Dialogue: 0,0:20:41.77,0:20:46.45,Default,,0000,0000,0000,,私だって 魔獣ちゃんたちと ずっと暮らしてたって 話したでしょ?
Dialogue: 0,0:20:46.45,0:20:51.28,Default,,0000,0000,0000,,魔獣ちゃん
Dialogue: 0,0:20:46.45,0:20:51.28,Default,,0000,0000,0000,,おおかみ少女みたいな話か?
Dialogue: 0,0:20:51.28,0:20:55.29,Default,,0000,0000,0000,,ウフフ!
Dialogue: 0,0:20:51.28,0:20:55.29,Default,,0000,0000,0000,,それ 昨日も言ってたわよね
Dialogue: 0,0:20:55.29,0:20:57.62,Default,,0000,0000,0000,,ママが厳しかったのよ
Dialogue: 0,0:20:57.62,0:21:01.79,Default,,0000,0000,0000,,それと 一緒にいることの多かった エルザが だらしなかったから
Dialogue: 0,0:21:01.79,0:21:04.80,Default,,0000,0000,0000,,私が いろいろ やらなくちゃ ならなかったのよね
Dialogue: 0,0:21:04.80,0:21:08.30,Default,,0000,0000,0000,,あ 待て 待て!
Dialogue: 0,0:21:04.80,0:21:08.30,Default,,0000,0000,0000,,次から次へと パンクする!
Dialogue: 0,0:21:08.30,0:21:11.97,Default,,0000,0000,0000,,今は忙しいんだ
Dialogue: 0,0:21:08.30,0:21:11.97,Default,,0000,0000,0000,,シャウラとでも遊んでてくれ
Dialogue: 0,0:21:11.97,0:21:13.97,Default,,0000,0000,0000,,半裸のお姉さん?
Dialogue: 0,0:21:13.97,0:21:18.31,Default,,0000,0000,0000,,それもいいんだけど 今は お兄さんに用があるのよ
Dialogue: 0,0:21:18.31,0:21:20.31,Default,,0000,0000,0000,,俺に?
Dialogue: 0,0:21:20.31,0:21:22.31,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:21:25.98,0:21:28.82,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:28.82,0:21:31.32,Default,,0000,0000,0000,,昨日の夜の話だけど
Dialogue: 0,0:21:31.32,0:21:34.63,Default,,0000,0000,0000,,私は どのくらい 真に受けていいのかしら?
Dialogue: 0,0:21:39.10,0:21:41.60,Default,,0000,0000,0000,,いって あっ?
Dialogue: 0,0:21:43.94,0:21:47.61,Default,,0000,0000,0000,,なんだ? これ あっ
Dialogue: 0,0:21:47.61,0:21:50.31,Default,,0000,0000,0000,,あっ あっ?
Dialogue: 0,0:21:55.78,0:21:58.12,Default,,0000,0000,0000,,うそだ
Dialogue: 0,0:21:58.12,0:22:00.95,Default,,0000,0000,0000,,うそだ うそだ うそだ! うそだ!
Dialogue: 0,0:22:00.95,0:22:03.96,Default,,0000,0000,0000,,メィリィ! ハァ おい メィリィ!
Dialogue: 0,0:22:03.96,0:22:07.46,Default,,0000,0000,0000,,ハァハァハァ メィリィ! メィリィ!
Dialogue: 0,0:22:07.46,0:22:10.96,Default,,0000,0000,0000,,くそ! ハァ
Dialogue: 0,0:22:10.96,0:22:13.80,Default,,0000,0000,0000,,ハァ くそ! くそ!
Dialogue: 0,0:22:13.80,0:22:18.30,Default,,0000,0000,0000,,ハッ! あっ ハァ
Dialogue: 0,0:22:18.30,0:22:20.31,Default,,0000,0000,0000,,俺が
Dialogue: 0,0:22:23.98,0:22:26.14,Default,,0000,0000,0000,,殺した?
Dialogue: 0,0:22:26.14,0:22:30.65,Default,,0000,0000,0000,,なんで 俺が そんな
Dialogue: 0,0:22:30.65,0:22:32.85,Default,,0000,0000,0000,,うっ! あっ
Dialogue: 0,0:22:37.26,0:22:39.93,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:22:39.93,0:22:45.60,Default,,0000,0000,0000,,ハァ ハァハァ ハァハァ
Dialogue: 0,0:22:45.60,0:22:50.00,Default,,0000,0000,0000,,ハァハァ ハァハァハァ
