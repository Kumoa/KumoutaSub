Dialogue: 0,0:00:36.07,0:00:40.07,Default,,0000,0000,0000,,恐らく 誰も信じたりしないだろう
Dialogue: 0,0:00:43.08,0:00:46.41,Default,,0000,0000,0000,,初めまして 賢人会の皆々様
Dialogue: 0,0:00:46.41,0:00:48.42,Default,,0000,0000,0000,,俺の名前は ナツキ・スバル
Dialogue: 0,0:00:48.42,0:00:52.09,Default,,0000,0000,0000,,ロズワール邸の下男にして こちらにおわす王候補
Dialogue: 0,0:00:52.09,0:00:55.59,Default,,0000,0000,0000,,エミリア様の 一の騎士!
Dialogue: 0,0:00:55.59,0:01:00.09,Default,,0000,0000,0000,,ほう あのような騎士がね
Dialogue: 0,0:01:00.09,0:01:04.00,Default,,0000,0000,0000,,いやいや ありえんだろ
Dialogue: 0,0:02:47.40,0:02:49.57,Default,,0000,0000,0000,,名乗る名なんざねえよ
Dialogue: 0,0:02:49.57,0:02:54.41,Default,,0000,0000,0000,,俺は ただの棒振りだ
Dialogue: 0,0:02:54.41,0:02:56.41,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:03:04.75,0:03:06.75,Default,,0000,0000,0000,,なんだ? お前
Dialogue: 0,0:03:06.75,0:03:10.09,Default,,0000,0000,0000,,俺に 剣 投げ渡すなんざ 死にてえのか?
Dialogue: 0,0:03:10.09,0:03:13.59,Default,,0000,0000,0000,,無手の相手に 斬りかかるような不粋
Dialogue: 0,0:03:13.59,0:03:15.60,Default,,0000,0000,0000,,騎士として 恥ずべき行為だ
Dialogue: 0,0:03:15.60,0:03:17.93,Default,,0000,0000,0000,,かっ! 笑わせやがる!
Dialogue: 0,0:03:17.93,0:03:23.77,Default,,0000,0000,0000,,その言葉 後悔しないことだ!
Dialogue: 0,0:03:17.93,0:03:23.77,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:03:23.77,0:03:26.61,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:03:23.77,0:03:26.61,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:03:23.77,0:03:26.61,Default,,0000,0000,0000,,なっ!
Dialogue: 0,0:03:26.61,0:03:29.28,Default,,0000,0000,0000,,俺が なんも持ってねえだ?
Dialogue: 0,0:03:29.28,0:03:32.61,Default,,0000,0000,0000,,よく見ろ お前
Dialogue: 0,0:03:29.28,0:03:32.61,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:03:32.61,0:03:34.88,Default,,0000,0000,0000,,木の 枝?
Dialogue: 0,0:03:34.88,0:03:37.55,Default,,0000,0000,0000,,違えよ 箸だ 箸
Dialogue: 0,0:03:37.55,0:03:40.22,Default,,0000,0000,0000,,つまみ食うのに持ち歩いてんだよ
Dialogue: 0,0:03:37.55,0:03:40.22,Default,,0000,0000,0000,,んっ くっ! うぅ
Dialogue: 0,0:03:40.22,0:03:43.72,Default,,0000,0000,0000,,いちばん いい角度に いちばん いい速さで
Dialogue: 0,0:03:43.72,0:03:48.39,Default,,0000,0000,0000,,いちばん いい感じに いちばん うまく振り回せば
Dialogue: 0,0:03:48.39,0:03:52.90,Default,,0000,0000,0000,,箸だろうと 斬れねえもんなんかねえよ!
Dialogue: 0,0:03:52.90,0:03:55.07,Default,,0000,0000,0000,,かっ!
Dialogue: 0,0:03:52.90,0:03:55.07,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:03:55.07,0:03:58.91,Default,,0000,0000,0000,,ハハッ!
Dialogue: 0,0:03:55.07,0:03:58.91,Default,,0000,0000,0000,,がはっ! ぐっ ハッ!
Dialogue: 0,0:03:58.91,0:04:01.41,Default,,0000,0000,0000,,いぃ やっ!
Dialogue: 0,0:03:58.91,0:04:01.41,Default,,0000,0000,0000,,ぐっ!
Dialogue: 0,0:04:03.41,0:04:06.75,Default,,0000,0000,0000,,ヘヘヘヘヘ!
Dialogue: 0,0:04:06.75,0:04:10.58,Default,,0000,0000,0000,,おらららららららららら!
Dialogue: 0,0:04:06.75,0:04:10.58,Default,,0000,0000,0000,,うっ! フッ! ぐぅ!
Dialogue: 0,0:04:10.58,0:04:13.75,Default,,0000,0000,0000,,ららららららら! だぁ!
Dialogue: 0,0:04:13.75,0:04:16.42,Default,,0000,0000,0000,,くっ! うらっ!
Dialogue: 0,0:04:16.42,0:04:19.59,Default,,0000,0000,0000,,ユリウス!
Dialogue: 0,0:04:16.42,0:04:19.59,Default,,0000,0000,0000,,ジワルド!
Dialogue: 0,0:04:19.59,0:04:22.60,Default,,0000,0000,0000,,フッ! ハッ!
Dialogue: 0,0:04:22.60,0:04:26.93,Default,,0000,0000,0000,,俺の剣は 光も斬るぜ? お前
Dialogue: 0,0:04:26.93,0:04:28.94,Default,,0000,0000,0000,,ジワルドー!
Dialogue: 0,0:04:30.94,0:04:35.38,Default,,0000,0000,0000,,くあっ! ゲヘヘヘヘヘ! ヘヘヘヘヘヘヘヘヘヘ
Dialogue: 0,0:04:30.94,0:04:35.38,Default,,0000,0000,0000,,くっ! ハッ!
Dialogue: 0,0:04:35.38,0:04:37.71,Default,,0000,0000,0000,,がっ! ぐはっ!
Dialogue: 0,0:04:35.38,0:04:37.71,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:04:37.71,0:04:39.88,Default,,0000,0000,0000,,おら おらおら おらおら!
Dialogue: 0,0:04:37.71,0:04:39.88,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:04:39.88,0:04:41.88,Default,,0000,0000,0000,,ハッ ジワルド! ジワルド!
Dialogue: 0,0:04:41.88,0:04:44.55,Default,,0000,0000,0000,,よく狙え お前!
Dialogue: 0,0:04:44.55,0:04:48.22,Default,,0000,0000,0000,,それじゃ 色男も取り戻せねえぞ お前!
Dialogue: 0,0:04:48.22,0:04:52.23,Default,,0000,0000,0000,,ジワルド! ジワルド! ジワルド! ジワルド!
Dialogue: 0,0:04:48.22,0:04:52.23,Default,,0000,0000,0000,,ヘヘヘヘヘヘヘ
Dialogue: 0,0:04:52.23,0:04:54.56,Default,,0000,0000,0000,,ジワルド! んっ
Dialogue: 0,0:04:54.56,0:04:57.73,Default,,0000,0000,0000,,アナスタシアさん! もう
Dialogue: 0,0:04:54.56,0:04:57.73,Default,,0000,0000,0000,,うっ んっ!
Dialogue: 0,0:04:57.73,0:05:01.07,Default,,0000,0000,0000,,ジワルド あっ
Dialogue: 0,0:05:01.07,0:05:05.07,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:05:01.07,0:05:05.07,Default,,0000,0000,0000,,うぅ!
Dialogue: 0,0:05:01.07,0:05:05.07,Default,,0000,0000,0000,,あっ! アナスタシア様!
Dialogue: 0,0:05:05.07,0:05:07.07,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:05:05.07,0:05:07.07,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:05:07.07,0:05:10.08,Default,,0000,0000,0000,,うぅっ!
Dialogue: 0,0:05:07.07,0:05:10.08,Default,,0000,0000,0000,,おい! ヘッ!
Dialogue: 0,0:05:10.08,0:05:13.08,Default,,0000,0000,0000,,今のは お前 俺好みじゃねえか!
Dialogue: 0,0:05:13.08,0:05:15.58,Default,,0000,0000,0000,,そそるぜ? お前
Dialogue: 0,0:05:13.08,0:05:15.58,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:05:15.58,0:05:18.42,Default,,0000,0000,0000,,そこをどけ!
Dialogue: 0,0:05:18.42,0:05:21.09,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:05:21.09,0:05:25.93,Default,,0000,0000,0000,,はぁ!
Dialogue: 0,0:05:21.09,0:05:25.93,Default,,0000,0000,0000,,ヘヘッ! んっ?
Dialogue: 0,0:05:25.93,0:05:29.43,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:05:29.43,0:05:33.60,Default,,0000,0000,0000,,なんだ? これ
Dialogue: 0,0:05:29.43,0:05:33.60,Default,,0000,0000,0000,,笑わせんなよ お前
Dialogue: 0,0:05:33.60,0:05:37.20,Default,,0000,0000,0000,,本気でやって これなら とんだ期待外れだ
Dialogue: 0,0:05:37.20,0:05:41.37,Default,,0000,0000,0000,,つまんねえな お前
Dialogue: 0,0:05:37.20,0:05:41.37,Default,,0000,0000,0000,,私は
Dialogue: 0,0:05:41.37,0:05:44.38,Default,,0000,0000,0000,,女のとこ 行きたきゃ 行かせてやんよ
Dialogue: 0,0:05:44.38,0:05:48.05,Default,,0000,0000,0000,,柔っけえ膝でも借りて 泣いて甘えろ
Dialogue: 0,0:05:48.05,0:05:50.72,Default,,0000,0000,0000,,出来損ないの不細工剣士が!
Dialogue: 0,0:05:50.72,0:05:53.02,Default,,0000,0000,0000,,ぐっ! がっ!
Dialogue: 0,0:05:55.39,0:05:58.06,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:05:55.39,0:05:58.06,Default,,0000,0000,0000,,寝ろ
Dialogue: 0,0:05:58.06,0:06:00.23,Default,,0000,0000,0000,,うっ! うっ ぐっ
Dialogue: 0,0:06:00.23,0:06:02.23,Default,,0000,0000,0000,,がはっ!
Dialogue: 0,0:06:05.73,0:06:08.57,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:05.73,0:06:08.57,Default,,0000,0000,0000,,さて
Dialogue: 0,0:06:05.73,0:06:08.57,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:08.57,0:06:12.07,Default,,0000,0000,0000,,次は
Dialogue: 0,0:06:12.07,0:06:14.57,Default,,0000,0000,0000,,1つだけ 聞いておきたいんだけど
Dialogue: 0,0:06:14.57,0:06:17.58,Default,,0000,0000,0000,,あなたを 一歩でも動かせば いいんじゃなかったの?
Dialogue: 0,0:06:17.58,0:06:20.91,Default,,0000,0000,0000,,すごく走り回ってたけど
Dialogue: 0,0:06:17.58,0:06:20.91,Default,,0000,0000,0000,,真に受けんなよ
Dialogue: 0,0:06:20.91,0:06:23.58,Default,,0000,0000,0000,,かっけえノリで言っただけだぜ お前
Dialogue: 0,0:06:23.58,0:06:30.26,Default,,0000,0000,0000,,わかんだろ? わかんねえか
Dialogue: 0,0:06:23.58,0:06:30.26,Default,,0000,0000,0000,,女だもんな 激マブだもんな
Dialogue: 0,0:06:30.26,0:06:32.26,Default,,0000,0000,0000,,今晩 つきあえよ お前
Dialogue: 0,0:06:32.26,0:06:34.86,Default,,0000,0000,0000,,ごめん ちょっと 何 言ってるのか わかんない
Dialogue: 0,0:06:34.86,0:06:38.70,Default,,0000,0000,0000,,それに 私は きっと あなたと 戦っても 勝てないと思うの
Dialogue: 0,0:06:38.70,0:06:41.87,Default,,0000,0000,0000,,エッ エミリア?
Dialogue: 0,0:06:41.87,0:06:46.21,Default,,0000,0000,0000,,あなたは すごく強そう
Dialogue: 0,0:06:41.87,0:06:46.21,Default,,0000,0000,0000,,それは 見てて わかりました
Dialogue: 0,0:06:46.21,0:06:49.71,Default,,0000,0000,0000,,だけど 私たちは 試験を 乗り越えなきゃいけないの
Dialogue: 0,0:06:49.71,0:06:53.71,Default,,0000,0000,0000,,だから 勝てる方法を 用意してください
Dialogue: 0,0:06:49.71,0:06:53.71,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:53.71,0:06:56.88,Default,,0000,0000,0000,,一歩でも あなたを 動かせたら 私たちの勝ち
Dialogue: 0,0:06:56.88,0:06:59.05,Default,,0000,0000,0000,,それで勝負しましょう
Dialogue: 0,0:06:59.05,0:07:02.22,Default,,0000,0000,0000,,だめ?
Dialogue: 0,0:06:59.05,0:07:02.22,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:07:02.22,0:07:05.73,Default,,0000,0000,0000,,かぁ! いいな!
Dialogue: 0,0:07:02.22,0:07:05.73,Default,,0000,0000,0000,,嫌いじゃねえぞ お前
Dialogue: 0,0:07:05.73,0:07:09.56,Default,,0000,0000,0000,,トリーシャ以来の大ばかだぜ お前!
Dialogue: 0,0:07:05.73,0:07:09.56,Default,,0000,0000,0000,,気に入った!
Dialogue: 0,0:07:09.56,0:07:15.07,Default,,0000,0000,0000,,一歩でも動かせたら
Dialogue: 0,0:07:09.56,0:07:15.07,Default,,0000,0000,0000,,お前の勝ちにしてやんよ!
Dialogue: 0,0:07:09.56,0:07:15.07,Default,,0000,0000,0000,,うん
Dialogue: 0,0:07:15.07,0:07:17.90,Default,,0000,0000,0000,,2人を お願い
Dialogue: 0,0:07:15.07,0:07:17.90,Default,,0000,0000,0000,,手当てしてあげて
Dialogue: 0,0:07:17.90,0:07:20.74,Default,,0000,0000,0000,,まっ 待った!
Dialogue: 0,0:07:17.90,0:07:20.74,Default,,0000,0000,0000,,さっきの見たろ?
Dialogue: 0,0:07:20.74,0:07:22.94,Default,,0000,0000,0000,,無策で行っても
Dialogue: 0,0:07:20.74,0:07:22.94,Default,,0000,0000,0000,,アイスブランド・アーツ
Dialogue: 0,0:07:30.58,0:07:33.59,Default,,0000,0000,0000,,アイシクル・ライン
Dialogue: 0,0:07:33.59,0:07:37.02,Default,,0000,0000,0000,,大丈夫
Dialogue: 0,0:07:33.59,0:07:37.02,Default,,0000,0000,0000,,私も 本気でいってみるから
Dialogue: 0,0:07:37.02,0:07:40.69,Default,,0000,0000,0000,,激マブな面して したたかじゃねえか お前
Dialogue: 0,0:07:40.69,0:07:43.03,Default,,0000,0000,0000,,やれることを 精いっぱいやるのが
Dialogue: 0,0:07:43.03,0:07:46.53,Default,,0000,0000,0000,,私の騎士様から教わったやり方
Dialogue: 0,0:07:43.03,0:07:46.53,Default,,0000,0000,0000,,なの!
Dialogue: 0,0:07:46.53,0:07:49.70,Default,,0000,0000,0000,,ハッ! ヘヘヘヘヘヘ アハハハハ!
Dialogue: 0,0:07:49.70,0:07:52.41,Default,,0000,0000,0000,,アハハハハ! アハハハハハハハ!
Dialogue: 0,0:07:56.88,0:08:00.71,Default,,0000,0000,0000,,えい! やっ!
Dialogue: 0,0:08:00.71,0:08:03.05,Default,,0000,0000,0000,,かっ!
Dialogue: 0,0:08:03.05,0:08:06.72,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:08:03.05,0:08:06.72,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:08:06.72,0:08:08.72,Default,,0000,0000,0000,,えい!
Dialogue: 0,0:08:08.72,0:08:13.23,Default,,0000,0000,0000,,2人とも無事かしら
Dialogue: 0,0:08:08.72,0:08:13.23,Default,,0000,0000,0000,,でも
Dialogue: 0,0:08:08.72,0:08:13.23,Default,,0000,0000,0000,,わかってる
Dialogue: 0,0:08:13.23,0:08:17.06,Default,,0000,0000,0000,,んっ! ヘッ
Dialogue: 0,0:08:17.06,0:08:20.07,Default,,0000,0000,0000,,動かねえ
Dialogue: 0,0:08:20.07,0:08:23.74,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:08:23.74,0:08:27.91,Default,,0000,0000,0000,,うっ! やっ! あっ!
Dialogue: 0,0:08:23.74,0:08:27.91,Default,,0000,0000,0000,,うっ! フッ ハッ! たっ!
Dialogue: 0,0:08:27.91,0:08:31.24,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:08:31.24,0:08:33.25,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:08:36.68,0:08:40.35,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:08:36.68,0:08:40.35,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:08:36.68,0:08:40.35,Default,,0000,0000,0000,,フッ ヘッ!
Dialogue: 0,0:08:40.35,0:08:43.19,Default,,0000,0000,0000,,フッ! たっ! おら! ハッ!
Dialogue: 0,0:08:40.35,0:08:43.19,Default,,0000,0000,0000,,フッ! やっ!
Dialogue: 0,0:08:43.19,0:08:45.19,Default,,0000,0000,0000,,ヘヘヘヘ! ヘヘヘヘ!
Dialogue: 0,0:08:43.19,0:08:45.19,Default,,0000,0000,0000,,うんしょ! うんしょ!
Dialogue: 0,0:08:48.03,0:08:50.70,Default,,0000,0000,0000,,ヘヘッ!
Dialogue: 0,0:08:50.70,0:08:54.03,Default,,0000,0000,0000,,うんしょ!
Dialogue: 0,0:08:50.70,0:08:54.03,Default,,0000,0000,0000,,おっ?
Dialogue: 0,0:08:50.70,0:08:54.03,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:08:54.03,0:08:56.24,Default,,0000,0000,0000,,うら!
Dialogue: 0,0:08:59.37,0:09:02.21,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:08:59.37,0:09:02.21,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:08:59.37,0:09:02.21,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:09:02.21,0:09:05.01,Default,,0000,0000,0000,,ペッ! 隙あり!
Dialogue: 0,0:09:10.05,0:09:12.05,Default,,0000,0000,0000,,なっ
Dialogue: 0,0:09:10.05,0:09:12.05,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:09:12.05,0:09:17.06,Default,,0000,0000,0000,,役得 役得!
Dialogue: 0,0:09:12.05,0:09:17.06,Default,,0000,0000,0000,,これしきのことで 怒んじゃ
Dialogue: 0,0:09:17.06,0:09:19.06,Default,,0000,0000,0000,,とりゃ!
Dialogue: 0,0:09:26.23,0:09:29.57,Default,,0000,0000,0000,,ぐお!! いってえ!
Dialogue: 0,0:09:29.57,0:09:31.57,Default,,0000,0000,0000,,なっ 何 考えてんだ? お前!
Dialogue: 0,0:09:31.57,0:09:34.67,Default,,0000,0000,0000,,普通 あんなまねされたら 動き 鈍んだろうが!
Dialogue: 0,0:09:34.67,0:09:37.51,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:09:34.67,0:09:37.51,Default,,0000,0000,0000,,体に触られただけでしょう?
Dialogue: 0,0:09:37.51,0:09:39.51,Default,,0000,0000,0000,,あなた 隙だらけだったもの
Dialogue: 0,0:09:39.51,0:09:42.18,Default,,0000,0000,0000,,ざっけんな!
Dialogue: 0,0:09:39.51,0:09:42.18,Default,,0000,0000,0000,,どういう育ち方してんだ!
Dialogue: 0,0:09:42.18,0:09:46.02,Default,,0000,0000,0000,,親は 何してやがったんだ!?
Dialogue: 0,0:09:42.18,0:09:46.02,Default,,0000,0000,0000,,何か 変なこと 言った?
Dialogue: 0,0:09:46.02,0:09:48.35,Default,,0000,0000,0000,,おい! この激マブ なんとかしろ!
Dialogue: 0,0:09:48.35,0:09:51.02,Default,,0000,0000,0000,,外 歩かせんな!
Dialogue: 0,0:09:48.35,0:09:51.02,Default,,0000,0000,0000,,お前 付き人だろうが!
Dialogue: 0,0:09:51.02,0:09:53.03,Default,,0000,0000,0000,,お前のほうこそ ふざけんじゃねえ!
Dialogue: 0,0:09:53.03,0:09:55.03,Default,,0000,0000,0000,,なんてまねしやがる!
Dialogue: 0,0:09:53.03,0:09:55.03,Default,,0000,0000,0000,,ぬぬぬぬぬぬぬ
Dialogue: 0,0:09:55.03,0:09:57.70,Default,,0000,0000,0000,,この変態野郎!
Dialogue: 0,0:09:55.03,0:09:57.70,Default,,0000,0000,0000,,くそ野郎! 大罪司教!
Dialogue: 0,0:09:57.70,0:10:00.20,Default,,0000,0000,0000,,ぶっ殺すぞ!
Dialogue: 0,0:09:57.70,0:10:00.20,Default,,0000,0000,0000,,スバル 落ち着くのよ!
Dialogue: 0,0:10:00.20,0:10:02.87,Default,,0000,0000,0000,,気持ちは わかるけど 見るかしら
Dialogue: 0,0:10:02.87,0:10:07.37,Default,,0000,0000,0000,,んっ あっ!
Dialogue: 0,0:10:02.87,0:10:07.37,Default,,0000,0000,0000,,一歩どころじゃなく 動いてる
Dialogue: 0,0:10:07.37,0:10:11.71,Default,,0000,0000,0000,,あっ ほんとね!
Dialogue: 0,0:10:07.37,0:10:11.71,Default,,0000,0000,0000,,やった! 私の勝ち!
Dialogue: 0,0:10:11.71,0:10:14.38,Default,,0000,0000,0000,,どんな経緯であれ 勝ちは勝ちだ
Dialogue: 0,0:10:14.38,0:10:16.88,Default,,0000,0000,0000,,さあ どうする?
Dialogue: 0,0:10:16.88,0:10:21.55,Default,,0000,0000,0000,,あ しかたねえ
Dialogue: 0,0:10:16.88,0:10:21.55,Default,,0000,0000,0000,,言ったことは言ったことだ
Dialogue: 0,0:10:21.55,0:10:23.89,Default,,0000,0000,0000,,えっ 認めるのか?
Dialogue: 0,0:10:23.89,0:10:27.06,Default,,0000,0000,0000,,お前 俺を なんだと思ってやがんだ?
Dialogue: 0,0:10:27.06,0:10:31.40,Default,,0000,0000,0000,,ここで食い下がったら 俺の株が下がんだろうが お前
Dialogue: 0,0:10:31.40,0:10:33.90,Default,,0000,0000,0000,,現時点で 株なんか 下がりようがないくらい
Dialogue: 0,0:10:33.90,0:10:37.74,Default,,0000,0000,0000,,最低の負け方してるぞ
Dialogue: 0,0:10:33.90,0:10:37.74,Default,,0000,0000,0000,,るせえよ 雑魚が!
Dialogue: 0,0:10:37.74,0:10:40.91,Default,,0000,0000,0000,,とにかく その激マブの勝ちだ
Dialogue: 0,0:10:40.91,0:10:43.74,Default,,0000,0000,0000,,通してやるよ しょうがあんめえ
Dialogue: 0,0:10:43.74,0:10:45.75,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:10:49.92,0:10:54.25,Default,,0000,0000,0000,,で? 次は 雑魚がやんのか?
Dialogue: 0,0:10:49.92,0:10:54.25,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:10:54.25,0:10:57.76,Default,,0000,0000,0000,,それとも ジャリ2人の どっかかよ?
Dialogue: 0,0:10:57.76,0:11:01.09,Default,,0000,0000,0000,,塔にいんのが 全部で 7人
Dialogue: 0,0:11:01.09,0:11:06.27,Default,,0000,0000,0000,,抜けたのが お前の女が まず1人
Dialogue: 0,0:11:01.09,0:11:06.27,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:11:06.27,0:11:10.77,Default,,0000,0000,0000,,次は 誰が 俺を抜いてくれんだ?
Dialogue: 0,0:11:10.77,0:11:13.94,Default,,0000,0000,0000,,なあ お前よ
Dialogue: 0,0:11:13.94,0:11:17.61,Default,,0000,0000,0000,,それで すごすごと 逃げ帰ってきたわけね
Dialogue: 0,0:11:17.61,0:11:20.61,Default,,0000,0000,0000,,辛辣っすね 姉様
Dialogue: 0,0:11:20.61,0:11:22.62,Default,,0000,0000,0000,,やめなさい そのしゃべり方
Dialogue: 0,0:11:22.62,0:11:26.12,Default,,0000,0000,0000,,そこで寝てる娘の お師匠様説が 真実みを帯びるわよ
Dialogue: 0,0:11:26.12,0:11:29.12,Default,,0000,0000,0000,,それは やばいな 気を付ける
Dialogue: 0,0:11:29.12,0:11:32.12,Default,,0000,0000,0000,,惨敗ね でも エミリア様だけは
Dialogue: 0,0:11:32.12,0:11:35.73,Default,,0000,0000,0000,,相手のお眼鏡にかなった
Dialogue: 0,0:11:32.12,0:11:35.73,Default,,0000,0000,0000,,ええ 勝てたの
Dialogue: 0,0:11:35.73,0:11:40.07,Default,,0000,0000,0000,,やっぱり 私だけでも上に
Dialogue: 0,0:11:35.73,0:11:40.07,Default,,0000,0000,0000,,いや やめといたほうが
Dialogue: 0,0:11:40.07,0:11:43.07,Default,,0000,0000,0000,,ほら あれだ 危ない
Dialogue: 0,0:11:43.07,0:11:45.07,Default,,0000,0000,0000,,すごく気を付けるわよ?
Dialogue: 0,0:11:45.07,0:11:47.91,Default,,0000,0000,0000,,危ない
Dialogue: 0,0:11:45.07,0:11:47.91,Default,,0000,0000,0000,,危ないわね
Dialogue: 0,0:11:45.07,0:11:47.91,Default,,0000,0000,0000,,危ないのよ
Dialogue: 0,0:11:47.91,0:11:49.91,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:11:47.91,0:11:49.91,Default,,0000,0000,0000,,ハハハハ
Dialogue: 0,0:11:49.91,0:11:53.75,Default,,0000,0000,0000,,ユリウスのやつ へこみ過ぎなきゃいいけどな
Dialogue: 0,0:11:53.75,0:11:56.75,Default,,0000,0000,0000,,心配?
Dialogue: 0,0:11:53.75,0:11:56.75,Default,,0000,0000,0000,,どうだろ
Dialogue: 0,0:11:56.75,0:12:03.92,Default,,0000,0000,0000,,心配は まあ 心配なんだろうけど
Dialogue: 0,0:11:56.75,0:12:03.92,Default,,0000,0000,0000,,そんな簡単でもないかな
Dialogue: 0,0:12:03.92,0:12:08.26,Default,,0000,0000,0000,,それに なんで あいつは ああまでして
Dialogue: 0,0:12:08.26,0:12:10.60,Default,,0000,0000,0000,,ユリウスを助けようとしたんだ?
Dialogue: 0,0:12:10.60,0:12:14.60,Default,,0000,0000,0000,,お2人のことも心配だけど 試験が どうなるのかも 大事よ
Dialogue: 0,0:12:14.60,0:12:18.27,Default,,0000,0000,0000,,乗り越えられなければ レムを取り戻す手段に届かない
Dialogue: 0,0:12:18.27,0:12:22.44,Default,,0000,0000,0000,,あの試験官 はっきり言って 化け物みたいに強い
Dialogue: 0,0:12:22.44,0:12:24.61,Default,,0000,0000,0000,,ラインハルト級かもしれない
Dialogue: 0,0:12:24.61,0:12:27.28,Default,,0000,0000,0000,,うん それぐらい強かったと思う
Dialogue: 0,0:12:27.28,0:12:30.45,Default,,0000,0000,0000,,地上最強と並び立つなんて 言われてるのは
Dialogue: 0,0:12:30.45,0:12:32.79,Default,,0000,0000,0000,,今の世界じゃ 各国 1人ずつよ
Dialogue: 0,0:12:32.79,0:12:35.55,Default,,0000,0000,0000,,ラインハルトが 王国最強で
Dialogue: 0,0:12:35.55,0:12:38.56,Default,,0000,0000,0000,,他の3国にも それぞれ 最強がいるってことか
Dialogue: 0,0:12:38.56,0:12:40.56,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:12:40.56,0:12:46.73,Default,,0000,0000,0000,,ヴォラキア帝国一将 青き雷光
Dialogue: 0,0:12:40.56,0:12:46.73,Default,,0000,0000,0000,,セシルス・セグムント
Dialogue: 0,0:12:46.73,0:12:50.40,Default,,0000,0000,0000,,グステコ聖王国の狂皇子
Dialogue: 0,0:12:50.40,0:12:55.41,Default,,0000,0000,0000,,それから
Dialogue: 0,0:12:50.40,0:12:55.41,Default,,0000,0000,0000,,カララギ都市国家の礼賛者 ハリベル
Dialogue: 0,0:12:55.41,0:12:57.74,Default,,0000,0000,0000,,どれも 棒振りの特徴と違うわね
Dialogue: 0,0:12:57.74,0:13:01.58,Default,,0000,0000,0000,,服装だけは カララギの民族衣装だったかしら
Dialogue: 0,0:13:01.58,0:13:03.92,Default,,0000,0000,0000,,箸も使いこなしていたのよ
Dialogue: 0,0:13:03.92,0:13:07.92,Default,,0000,0000,0000,,本来の使い方と違いすぎて 使いこなしてたって 言っていいもんか
Dialogue: 0,0:13:07.92,0:13:11.09,Default,,0000,0000,0000,,あっ お兄さんたち ちょっといい?
Dialogue: 0,0:13:07.92,0:13:11.09,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:13:11.09,0:13:15.09,Default,,0000,0000,0000,,うん あう んっ
Dialogue: 0,0:13:15.09,0:13:19.10,Default,,0000,0000,0000,,お師様 独りにしないで
Dialogue: 0,0:13:19.10,0:13:21.77,Default,,0000,0000,0000,,もう 寂しいのは嫌っす
Dialogue: 0,0:13:21.77,0:13:24.60,Default,,0000,0000,0000,,出ばなに 切なくなるようなこと 言うの やめろ!
Dialogue: 0,0:13:24.60,0:13:28.77,Default,,0000,0000,0000,,本当は起きてんだろ? お前
Dialogue: 0,0:13:24.60,0:13:28.77,Default,,0000,0000,0000,,ちぇっす
Dialogue: 0,0:13:28.77,0:13:31.28,Default,,0000,0000,0000,,フッ んっ!
Dialogue: 0,0:13:31.28,0:13:35.21,Default,,0000,0000,0000,,あれ?
Dialogue: 0,0:13:31.28,0:13:35.21,Default,,0000,0000,0000,,なんで こんな所にいるんすか?
Dialogue: 0,0:13:35.21,0:13:38.22,Default,,0000,0000,0000,,確か あしたちは お師様の劇的なひらめきで
Dialogue: 0,0:13:38.22,0:13:40.22,Default,,0000,0000,0000,,試験 突破して
Dialogue: 0,0:13:40.22,0:13:42.56,Default,,0000,0000,0000,,夢っすか?
Dialogue: 0,0:13:40.22,0:13:42.56,Default,,0000,0000,0000,,現実だよ
Dialogue: 0,0:13:42.56,0:13:46.39,Default,,0000,0000,0000,,そこで お師様が あしを抱き締めて
Dialogue: 0,0:13:46.39,0:13:49.90,Default,,0000,0000,0000,,「もう 離さない」って 笑いかけて
Dialogue: 0,0:13:46.39,0:13:49.90,Default,,0000,0000,0000,,それは夢だな!
Dialogue: 0,0:13:49.90,0:13:53.40,Default,,0000,0000,0000,,2つ目の試験が始まった途端 気絶したんだよ
Dialogue: 0,0:13:53.40,0:13:55.73,Default,,0000,0000,0000,,気絶? あしが?
Dialogue: 0,0:13:55.73,0:13:59.24,Default,,0000,0000,0000,,そんな みっともないこと あるわけないじゃないっすか
Dialogue: 0,0:13:59.24,0:14:02.41,Default,,0000,0000,0000,,覚えてないのか?
Dialogue: 0,0:13:59.24,0:14:02.41,Default,,0000,0000,0000,,長い階段 上がって
Dialogue: 0,0:14:02.41,0:14:05.58,Default,,0000,0000,0000,,白い部屋に入って
Dialogue: 0,0:14:02.41,0:14:05.58,Default,,0000,0000,0000,,ふんふん
Dialogue: 0,0:14:05.58,0:14:09.42,Default,,0000,0000,0000,,剣を抜いたら 景色が変わって 人影が現れて
Dialogue: 0,0:14:09.42,0:14:13.09,Default,,0000,0000,0000,,ふんふんふん
Dialogue: 0,0:14:09.42,0:14:13.09,Default,,0000,0000,0000,,赤い髪に 青い目の
Dialogue: 0,0:14:13.09,0:14:16.26,Default,,0000,0000,0000,,自分のことを棒振りって言って
Dialogue: 0,0:14:13.09,0:14:16.26,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:14:16.26,0:14:18.59,Default,,0000,0000,0000,,ひゃ!!
Dialogue: 0,0:14:16.26,0:14:18.59,Default,,0000,0000,0000,,あ痛!
Dialogue: 0,0:14:16.26,0:14:18.59,Default,,0000,0000,0000,,ぐっ 痛い 痛い 痛い 痛い!
Dialogue: 0,0:14:18.59,0:14:20.59,Default,,0000,0000,0000,,おっ 思い出したのか!?
Dialogue: 0,0:14:20.59,0:14:23.26,Default,,0000,0000,0000,,ななななな なんで あいつが ここにいるっすか!
Dialogue: 0,0:14:23.26,0:14:25.43,Default,,0000,0000,0000,,生きてたっす!
Dialogue: 0,0:14:23.26,0:14:27.43,Default,,0000,0000,0000,,やっぱり 殺しても 死なないやつだったっす!
Dialogue: 0,0:14:27.43,0:14:31.44,Default,,0000,0000,0000,,はぁ? お前 何を
Dialogue: 0,0:14:27.43,0:14:31.44,Default,,0000,0000,0000,,棒振り! 棒振りレイドっす!
Dialogue: 0,0:14:31.44,0:14:33.77,Default,,0000,0000,0000,,あの鬼畜! 悪魔!
Dialogue: 0,0:14:33.77,0:14:35.71,Default,,0000,0000,0000,,また あしの胸 ずばずば もむために
Dialogue: 0,0:14:35.71,0:14:38.88,Default,,0000,0000,0000,,生きて帰ってきたんすよ!
Dialogue: 0,0:14:35.71,0:14:38.88,Default,,0000,0000,0000,,くっ! くっ くっ
Dialogue: 0,0:14:38.88,0:14:42.21,Default,,0000,0000,0000,,レイド? レイドって 確か
Dialogue: 0,0:14:38.88,0:14:42.21,Default,,0000,0000,0000,,うっ! うぅ
Dialogue: 0,0:14:42.21,0:14:46.55,Default,,0000,0000,0000,,レイド・アストレア 初代の剣聖よ
Dialogue: 0,0:14:42.21,0:14:46.55,Default,,0000,0000,0000,,うぅ!
Dialogue: 0,0:14:46.55,0:14:48.89,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:14:46.55,0:14:48.89,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:48.89,0:14:52.39,Default,,0000,0000,0000,,ユリウス! 寝てるとこ悪い!
Dialogue: 0,0:14:52.39,0:14:55.89,Default,,0000,0000,0000,,あいつの正体が わかった
Dialogue: 0,0:14:52.39,0:14:55.89,Default,,0000,0000,0000,,お前の知恵が
Dialogue: 0,0:14:57.90,0:15:00.00,Default,,0000,0000,0000,,あの ばか野郎!
Dialogue: 0,0:15:06.74,0:15:12.41,Default,,0000,0000,0000,,今度は
Dialogue: 0,0:15:06.74,0:15:12.41,Default,,0000,0000,0000,,遊びじゃ済まされねえぞ お前
Dialogue: 0,0:15:12.41,0:15:14.41,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:15:14.41,0:15:18.92,Default,,0000,0000,0000,,ルグニカ王国 近衛騎士団所属 ユリウス・ユークリウス
Dialogue: 0,0:15:18.92,0:15:21.92,Default,,0000,0000,0000,,その つまんねえ肩書 名乗ってる間は
Dialogue: 0,0:15:21.92,0:15:26.26,Default,,0000,0000,0000,,俺の遊び相手にもなんねえよ
Dialogue: 0,0:15:26.26,0:15:29.76,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:15:26.26,0:15:29.76,Default,,0000,0000,0000,,ふぁ
Dialogue: 0,0:15:26.26,0:15:29.76,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:15:29.76,0:15:33.77,Default,,0000,0000,0000,,はぁ!
Dialogue: 0,0:15:29.76,0:15:33.77,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:15:33.77,0:15:36.54,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:15:33.77,0:15:36.54,Default,,0000,0000,0000,,くっ!
Dialogue: 0,0:15:33.77,0:15:36.54,Default,,0000,0000,0000,,つまんねえな
Dialogue: 0,0:15:36.54,0:15:40.54,Default,,0000,0000,0000,,お手本どおりか? お前!
Dialogue: 0,0:15:36.54,0:15:40.54,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:15:40.54,0:15:43.54,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:15:40.54,0:15:43.54,Default,,0000,0000,0000,,うおっ! ぐっ!
Dialogue: 0,0:15:43.54,0:15:45.54,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:15:43.54,0:15:45.54,Default,,0000,0000,0000,,うっ! ぐっ! うっ!
Dialogue: 0,0:15:45.54,0:15:49.55,Default,,0000,0000,0000,,くっ!
Dialogue: 0,0:15:45.54,0:15:49.55,Default,,0000,0000,0000,,ほらよ!
Dialogue: 0,0:15:45.54,0:15:49.55,Default,,0000,0000,0000,,くっ ハッ!
Dialogue: 0,0:15:49.55,0:15:52.55,Default,,0000,0000,0000,,うい!
Dialogue: 0,0:15:52.55,0:15:56.22,Default,,0000,0000,0000,,ぐっ! くっ ぐっ
Dialogue: 0,0:15:56.22,0:15:59.39,Default,,0000,0000,0000,,かっ! 情けねえな お前
Dialogue: 0,0:15:59.39,0:16:01.89,Default,,0000,0000,0000,,剣 持って どんだけだよ お前
Dialogue: 0,0:15:59.39,0:16:01.89,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:16:01.89,0:16:05.90,Default,,0000,0000,0000,,俺は 剣 持って 3か月しか たってねえぞ お前
Dialogue: 0,0:16:05.90,0:16:07.90,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:16:18.08,0:16:21.91,Default,,0000,0000,0000,,私は 今 ここで あなたを
Dialogue: 0,0:16:21.91,0:16:25.58,Default,,0000,0000,0000,,ばか言えよ お前
Dialogue: 0,0:16:21.91,0:16:25.58,Default,,0000,0000,0000,,できるかよ お前に
Dialogue: 0,0:16:25.58,0:16:28.75,Default,,0000,0000,0000,,できねえよ お前にゃ
Dialogue: 0,0:16:28.75,0:16:31.09,Default,,0000,0000,0000,,んっ! うっ! くっ!
Dialogue: 0,0:16:31.09,0:16:35.53,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:16:31.09,0:16:35.53,Default,,0000,0000,0000,,届くまで振れねえ!
Dialogue: 0,0:16:31.09,0:16:35.53,Default,,0000,0000,0000,,届くまで振ってねえ!
Dialogue: 0,0:16:35.53,0:16:38.03,Default,,0000,0000,0000,,ぐあっ! あっ
Dialogue: 0,0:16:35.53,0:16:38.03,Default,,0000,0000,0000,,足りねえんだよ! お前
Dialogue: 0,0:16:38.03,0:16:41.03,Default,,0000,0000,0000,,ここは お前の来る所じゃねえんだよ!
Dialogue: 0,0:16:41.03,0:16:45.44,Default,,0000,0000,0000,,役者が違えんだよ!
Dialogue: 0,0:16:41.03,0:16:45.44,Default,,0000,0000,0000,,お呼びじゃねえんだよ!
Dialogue: 0,0:16:50.54,0:16:53.71,Default,,0000,0000,0000,,誰も お前なんざ 見てねえよ
Dialogue: 0,0:16:53.71,0:16:55.88,Default,,0000,0000,0000,,くっ!
Dialogue: 0,0:16:53.71,0:16:55.88,Default,,0000,0000,0000,,期待しちゃいねえよ
Dialogue: 0,0:16:55.88,0:16:59.55,Default,,0000,0000,0000,,俺が遊んでやってると思って 甘えてくんな!
Dialogue: 0,0:16:59.55,0:17:03.56,Default,,0000,0000,0000,,んっ ぐはっ! うっ!
Dialogue: 0,0:16:59.55,0:17:03.56,Default,,0000,0000,0000,,うっ うっ
Dialogue: 0,0:17:03.56,0:17:08.06,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:17:03.56,0:17:08.06,Default,,0000,0000,0000,,かっ! こらえんのかよ
Dialogue: 0,0:17:08.06,0:17:10.73,Default,,0000,0000,0000,,ますます つまんねえな お前
Dialogue: 0,0:17:10.73,0:17:14.73,Default,,0000,0000,0000,,んっ くっ! うっ! ハァハァ
Dialogue: 0,0:17:22.91,0:17:25.71,Default,,0000,0000,0000,,今の私には
Dialogue: 0,0:17:27.75,0:17:29.75,Default,,0000,0000,0000,,この強さが
Dialogue: 0,0:17:31.75,0:17:36.02,Default,,0000,0000,0000,,唯一の んっ はぁ!
Dialogue: 0,0:17:36.02,0:17:39.86,Default,,0000,0000,0000,,迷いが剣に出たぜ お前
Dialogue: 0,0:17:39.86,0:17:43.70,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:17:39.86,0:17:43.70,Default,,0000,0000,0000,,天剣に至る資格なし
Dialogue: 0,0:17:43.70,0:17:50.04,Default,,0000,0000,0000,,お前にゃ
Dialogue: 0,0:17:43.70,0:17:50.04,Default,,0000,0000,0000,,子分の立場も やれねえよ
Dialogue: 0,0:17:50.04,0:17:52.04,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:18:00.55,0:18:03.22,Default,,0000,0000,0000,,お前の強さは 俺の目が知ってる!
Dialogue: 0,0:18:03.22,0:18:05.22,Default,,0000,0000,0000,,俺の恥が知ってる!
Dialogue: 0,0:18:05.22,0:18:08.05,Default,,0000,0000,0000,,誰が忘れたとしてもだ
Dialogue: 0,0:18:08.05,0:18:10.72,Default,,0000,0000,0000,,ユリウス!
Dialogue: 0,0:18:30.91,0:18:36.52,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:18:36.52,0:18:43.36,Default,,0000,0000,0000,,んっ ハァハァ ハァハァ
Dialogue: 0,0:18:43.36,0:18:47.53,Default,,0000,0000,0000,,んっ ハァハァハァ
Dialogue: 0,0:18:47.53,0:18:52.36,Default,,0000,0000,0000,,揺れるものだな
Dialogue: 0,0:18:47.53,0:18:52.36,Default,,0000,0000,0000,,んっ 気付いたのか
Dialogue: 0,0:18:52.36,0:18:56.54,Default,,0000,0000,0000,,私は 君に背負われて?
Dialogue: 0,0:18:52.36,0:18:56.54,Default,,0000,0000,0000,,んっ そうだ
Dialogue: 0,0:18:56.54,0:18:59.71,Default,,0000,0000,0000,,言っとくが この短時間で 2回目だぞ これ
Dialogue: 0,0:18:59.71,0:19:02.37,Default,,0000,0000,0000,,二度と やりたくねえって思った 30分後に
Dialogue: 0,0:19:02.37,0:19:06.21,Default,,0000,0000,0000,,また やらされてる俺の気持ち お前に わかるか?
Dialogue: 0,0:19:06.21,0:19:09.55,Default,,0000,0000,0000,,どうりで 乗り心地が悪いはずだ
Dialogue: 0,0:19:09.55,0:19:12.25,Default,,0000,0000,0000,,お前 振り落とされたいの?
Dialogue: 0,0:19:23.40,0:19:26.57,Default,,0000,0000,0000,,アナスタシア様は ご無事だろうか?
Dialogue: 0,0:19:26.57,0:19:29.23,Default,,0000,0000,0000,,命に別状はない お前のほうが
Dialogue: 0,0:19:29.23,0:19:33.24,Default,,0000,0000,0000,,よっぽど 死にかけたぐらいだよ
Dialogue: 0,0:19:29.23,0:19:33.24,Default,,0000,0000,0000,,あれ相手に
Dialogue: 0,0:19:33.24,0:19:36.01,Default,,0000,0000,0000,,つか あの眼帯野郎が 誰だか知ったら驚くぞ
Dialogue: 0,0:19:36.01,0:19:38.34,Default,,0000,0000,0000,,レイド・アストレア
Dialogue: 0,0:19:36.01,0:19:38.34,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:38.34,0:19:41.85,Default,,0000,0000,0000,,よくわかったじゃねえか
Dialogue: 0,0:19:38.34,0:19:41.85,Default,,0000,0000,0000,,こっちは シャウラが知っててな
Dialogue: 0,0:19:41.85,0:19:45.52,Default,,0000,0000,0000,,棒振りを自称された時点で 思うところはあったが
Dialogue: 0,0:19:45.52,0:19:47.52,Default,,0000,0000,0000,,確信が持てなくてね
Dialogue: 0,0:19:47.52,0:19:50.52,Default,,0000,0000,0000,,伝えられず すまない
Dialogue: 0,0:19:47.52,0:19:50.52,Default,,0000,0000,0000,,いや
Dialogue: 0,0:19:53.36,0:19:57.36,Default,,0000,0000,0000,,んっ ユリウス
Dialogue: 0,0:19:57.36,0:20:02.37,Default,,0000,0000,0000,,戻ったら わかっちまうことだから
Dialogue: 0,0:19:57.36,0:20:02.37,Default,,0000,0000,0000,,先に言っとくが
Dialogue: 0,0:20:02.37,0:20:07.04,Default,,0000,0000,0000,,お前とアナスタシアさんが倒れたあとに エミリアが 試験を突破した
Dialogue: 0,0:20:07.04,0:20:09.88,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:20:07.04,0:20:09.88,Default,,0000,0000,0000,,ただ あれだ
Dialogue: 0,0:20:09.88,0:20:13.05,Default,,0000,0000,0000,,力比べで あいつを ぶっ倒したってわけじゃない
Dialogue: 0,0:20:13.05,0:20:15.38,Default,,0000,0000,0000,,いろんな偶然が味方したのと
Dialogue: 0,0:20:15.38,0:20:19.05,Default,,0000,0000,0000,,あっ エミリアが その
Dialogue: 0,0:20:15.38,0:20:19.05,Default,,0000,0000,0000,,特殊だったからだ
Dialogue: 0,0:20:19.05,0:20:23.39,Default,,0000,0000,0000,,だから なんつうか
Dialogue: 0,0:20:19.05,0:20:23.39,Default,,0000,0000,0000,,気負うなよ?
Dialogue: 0,0:20:23.39,0:20:25.72,Default,,0000,0000,0000,,気負う?
Dialogue: 0,0:20:25.72,0:20:28.56,Default,,0000,0000,0000,,エミリア様が 試験を越えられたのであれば
Dialogue: 0,0:20:28.56,0:20:32.06,Default,,0000,0000,0000,,剣聖レイドは 越えられない障害では 決してない
Dialogue: 0,0:20:32.06,0:20:34.23,Default,,0000,0000,0000,,それが わかったのは 大きな収穫だ
Dialogue: 0,0:20:34.23,0:20:38.40,Default,,0000,0000,0000,,おっ おう そうだ
Dialogue: 0,0:20:34.23,0:20:38.40,Default,,0000,0000,0000,,そうなんだよ
Dialogue: 0,0:20:38.40,0:20:40.71,Default,,0000,0000,0000,,それが わかってくれりゃいい
Dialogue: 0,0:20:43.08,0:20:45.91,Default,,0000,0000,0000,,そろそろ 下ろしてもらえるだろうか
Dialogue: 0,0:20:45.91,0:20:49.92,Default,,0000,0000,0000,,いつまでも 君に背負われたままだと 悪酔いしそうだ
Dialogue: 0,0:20:49.92,0:20:53.92,Default,,0000,0000,0000,,けが人を歩かせたなんて ばれたら 俺が エミリアたんに叱られる
Dialogue: 0,0:20:53.92,0:20:58.42,Default,,0000,0000,0000,,目は覚めた 自分で下りられる
Dialogue: 0,0:20:53.92,0:20:58.42,Default,,0000,0000,0000,,突っ張っても今更だぞ
Dialogue: 0,0:20:58.42,0:21:01.43,Default,,0000,0000,0000,,背負われてるところは さっき 全員に見られてる
Dialogue: 0,0:21:01.43,0:21:05.10,Default,,0000,0000,0000,,気絶してたシャウラと アナスタシアさんだけは見てないけどな
Dialogue: 0,0:21:05.10,0:21:07.10,Default,,0000,0000,0000,,ならば それが理由だ
Dialogue: 0,0:21:05.10,0:21:07.10,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:21:07.10,0:21:09.10,Default,,0000,0000,0000,,アナスタシア様に こんな姿を
Dialogue: 0,0:21:09.10,0:21:11.27,Default,,0000,0000,0000,,取って付けたようなこと 言うなよ
Dialogue: 0,0:21:11.27,0:21:14.27,Default,,0000,0000,0000,,下ろしてくれ
Dialogue: 0,0:21:11.27,0:21:14.27,Default,,0000,0000,0000,,お前な そもそも
Dialogue: 0,0:21:14.27,0:21:16.44,Default,,0000,0000,0000,,下ろしてくれと 言っているだろう!
Dialogue: 0,0:21:14.27,0:21:16.44,Default,,0000,0000,0000,,ちょ おい
Dialogue: 0,0:21:16.44,0:21:19.95,Default,,0000,0000,0000,,ばか! うっ!
Dialogue: 0,0:21:16.44,0:21:19.95,Default,,0000,0000,0000,,ぐっ! うっ!
Dialogue: 0,0:21:19.95,0:21:23.62,Default,,0000,0000,0000,,くっ くっ くっ
Dialogue: 0,0:21:23.62,0:21:26.95,Default,,0000,0000,0000,,お前 ばか野郎!
Dialogue: 0,0:21:23.62,0:21:26.95,Default,,0000,0000,0000,,一体 何 考えてんだ!
Dialogue: 0,0:21:26.95,0:21:29.96,Default,,0000,0000,0000,,来なくていい!
Dialogue: 0,0:21:26.95,0:21:29.96,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:26.95,0:21:29.96,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:21:31.96,0:21:35.56,Default,,0000,0000,0000,,1人で立てる
Dialogue: 0,0:21:35.56,0:21:37.56,Default,,0000,0000,0000,,手を借りる必要は
Dialogue: 0,0:21:39.73,0:21:42.93,Default,,0000,0000,0000,,ない!
Dialogue: 0,0:21:39.73,0:21:42.93,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:49.24,0:21:54.08,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:21:49.24,0:21:54.08,Default,,0000,0000,0000,,言ったとおりだろう?
Dialogue: 0,0:21:54.08,0:21:58.42,Default,,0000,0000,0000,,1人で立つことくらい 訳のないことだ
Dialogue: 0,0:21:58.42,0:22:04.59,Default,,0000,0000,0000,,少し 時間はかかりそうだが
Dialogue: 0,0:21:58.42,0:22:04.59,Default,,0000,0000,0000,,君の手を煩わせる必要はない
Dialogue: 0,0:22:04.59,0:22:08.93,Default,,0000,0000,0000,,できれば 先に 説明してきてくれないだろうか
Dialogue: 0,0:22:08.93,0:22:11.93,Default,,0000,0000,0000,,弁明は 私自身でする
Dialogue: 0,0:22:11.93,0:22:15.10,Default,,0000,0000,0000,,君は あくまで 私が見つかったことだけ
Dialogue: 0,0:22:15.10,0:22:18.44,Default,,0000,0000,0000,,伝えてくれればいい んっ
Dialogue: 0,0:22:18.44,0:22:23.28,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:22:18.44,0:22:23.28,Default,,0000,0000,0000,,あ くそ! くそ くそ くそ!
Dialogue: 0,0:22:23.28,0:22:27.45,Default,,0000,0000,0000,,ばか野郎!
Dialogue: 0,0:22:23.28,0:22:27.45,Default,,0000,0000,0000,,俺も お前も 大ばか野郎だ!
Dialogue: 0,0:22:27.45,0:22:29.45,Default,,0000,0000,0000,,んっ なんのつもり
Dialogue: 0,0:22:27.45,0:22:29.45,Default,,0000,0000,0000,,うるせえ!
Dialogue: 0,0:22:29.45,0:22:31.45,Default,,0000,0000,0000,,何が 1人で立てるだ!
Dialogue: 0,0:22:31.45,0:22:34.55,Default,,0000,0000,0000,,へっぴり腰なのが 丸見えなんだよ!
Dialogue: 0,0:22:34.55,0:22:37.89,Default,,0000,0000,0000,,途中から勝てないって わかってたんだろ?
Dialogue: 0,0:22:37.89,0:22:40.39,Default,,0000,0000,0000,,殴られて 蹴られて 倒されて
Dialogue: 0,0:22:40.39,0:22:43.06,Default,,0000,0000,0000,,それでも 向かっていくしか なかったんだろ!?
Dialogue: 0,0:22:43.06,0:22:46.40,Default,,0000,0000,0000,,それしか 吐き出す方法が なかったんだろうが!
Dialogue: 0,0:22:46.40,0:22:48.57,Default,,0000,0000,0000,,こっちは 誰かさんのおかげで
Dialogue: 0,0:22:48.57,0:22:51.74,Default,,0000,0000,0000,,とっくのとうに 身に染みてんだよ!
Dialogue: 0,0:22:51.74,0:22:56.24,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:22:51.74,0:22:56.24,Default,,0000,0000,0000,,あっ んっ
Dialogue: 0,0:22:56.24,0:22:59.41,Default,,0000,0000,0000,,お前の腹の底が わかってるなんて
Dialogue: 0,0:22:59.41,0:23:02.25,Default,,0000,0000,0000,,知ったような口は利かねえよ
Dialogue: 0,0:23:02.25,0:23:06.08,Default,,0000,0000,0000,,けど 今 お前が 1人で この階段を
Dialogue: 0,0:23:06.08,0:23:08.42,Default,,0000,0000,0000,,長ったらしい この階段を
Dialogue: 0,0:23:08.42,0:23:11.92,Default,,0000,0000,0000,,1人っきりで 下りる必要なんかねえんだ
Dialogue: 0,0:23:11.92,0:23:15.59,Default,,0000,0000,0000,,肩ぐらい貸してやるし 貸しだとも思わない
Dialogue: 0,0:23:15.59,0:23:19.26,Default,,0000,0000,0000,,あのとき 俺は
Dialogue: 0,0:23:19.26,0:23:24.97,Default,,0000,0000,0000,,だから お前を この階段に
Dialogue: 0,0:23:19.26,0:23:24.97,Default,,0000,0000,0000,,1人きりにしてやるもんか
Dialogue: 0,0:23:33.45,0:23:37.22,Default,,0000,0000,0000,,スバル
Dialogue: 0,0:23:33.45,0:23:37.22,Default,,0000,0000,0000,,なんだ?
Dialogue: 0,0:23:37.22,0:23:40.92,Default,,0000,0000,0000,,すまない
Dialogue: 0,0:23:37.22,0:23:40.92,Default,,0000,0000,0000,,チッ うるせえ
Dialogue: 0,0:23:48.06,0:23:51.23,Default,,0000,0000,0000,,恐らく
Dialogue: 0,0:23:51.23,0:23:54.40,Default,,0000,0000,0000,,誰も信じたりしないだろう
Dialogue: 0,0:23:54.40,0:23:59.07,Default,,0000,0000,0000,,あの瞬間 王城の大広間にいた全員を
Dialogue: 0,0:23:59.07,0:24:01.24,Default,,0000,0000,0000,,敵に回した 大ぼら吹き
Dialogue: 0,0:24:01.24,0:24:03.58,Default,,0000,0000,0000,,言い切った当人さえも
Dialogue: 0,0:24:03.58,0:24:07.58,Default,,0000,0000,0000,,どこか浮ついた感情と 勢い任せであることを
Dialogue: 0,0:24:07.58,0:24:09.75,Default,,0000,0000,0000,,隠しきれずにいた発言
Dialogue: 0,0:24:09.75,0:24:18.92,Default,,0000,0000,0000,,それに ただ1人
Dialogue: 0,0:24:18.92,0:24:22.93,Default,,0000,0000,0000,,感銘を受けた男がいたことなど
