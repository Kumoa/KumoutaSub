Dialogue: 0,0:00:41.31,0:00:44.81,Default,,0000,0000,0000,,バルス! いつまで寝ているの?
Dialogue: 0,0:00:44.81,0:00:46.98,Default,,0000,0000,0000,,いいかげん 起きなさい バルス!
Dialogue: 0,0:00:46.98,0:00:48.98,Default,,0000,0000,0000,,ぼろろっか! あっ
Dialogue: 0,0:00:48.98,0:00:50.98,Default,,0000,0000,0000,,あっ ここは
Dialogue: 0,0:00:50.98,0:00:53.32,Default,,0000,0000,0000,,無風で この気温の低さ
Dialogue: 0,0:00:50.98,0:00:53.32,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:00:53.32,0:00:55.66,Default,,0000,0000,0000,,恐らく 地下でしょうね
Dialogue: 0,0:00:53.32,0:00:55.66,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:55.66,0:00:59.66,Default,,0000,0000,0000,,ラムか ここが地下って
Dialogue: 0,0:00:59.66,0:01:01.66,Default,,0000,0000,0000,,砂丘の地下よ
Dialogue: 0,0:01:01.66,0:01:05.50,Default,,0000,0000,0000,,分断される前の ベアトリス様のお言葉を信じるなら
Dialogue: 0,0:01:05.50,0:01:07.67,Default,,0000,0000,0000,,空間のゆがみが原因でしょうね
Dialogue: 0,0:01:07.67,0:01:10.34,Default,,0000,0000,0000,,それに吹っ飛ばされたってわけか
Dialogue: 0,0:01:10.34,0:01:14.67,Default,,0000,0000,0000,,って 分断?
Dialogue: 0,0:01:10.34,0:01:14.67,Default,,0000,0000,0000,,あっ そうだ! 他のみんなは?
Dialogue: 0,0:01:14.67,0:01:17.34,Default,,0000,0000,0000,,なんで 俺と お前だけが一緒に
Dialogue: 0,0:01:17.34,0:01:20.65,Default,,0000,0000,0000,,それを バルスが言うの?
Dialogue: 0,0:01:17.34,0:01:20.65,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:01:36.80,0:01:40.13,Default,,0000,0000,0000,,エミリア様やベアトリス様の姿は 見えない
Dialogue: 0,0:01:40.13,0:01:43.47,Default,,0000,0000,0000,,とんだドジを踏んだものね
Dialogue: 0,0:01:40.13,0:01:43.47,Default,,0000,0000,0000,,んっ 言ってる場合か!
Dialogue: 0,0:01:43.47,0:01:48.31,Default,,0000,0000,0000,,今は みんなと 違う レムだ
Dialogue: 0,0:01:43.47,0:01:48.31,Default,,0000,0000,0000,,バルス
Dialogue: 0,0:01:48.31,0:01:51.98,Default,,0000,0000,0000,,みんなと合流もだが いちばんは レムだ!
Dialogue: 0,0:01:51.98,0:01:53.98,Default,,0000,0000,0000,,あいつは 今 動けない!
Dialogue: 0,0:01:53.98,0:01:58.15,Default,,0000,0000,0000,,早く 早く見つけなきゃ!
Dialogue: 0,0:01:53.98,0:01:58.15,Default,,0000,0000,0000,,バルス 落ち着きなさい
Dialogue: 0,0:01:58.15,0:02:01.49,Default,,0000,0000,0000,,落ち着け?
Dialogue: 0,0:01:58.15,0:02:01.49,Default,,0000,0000,0000,,できるかよ そんなこと!
Dialogue: 0,0:02:01.49,0:02:03.49,Default,,0000,0000,0000,,お前は レムが危なくても 平気なのかよ!?
Dialogue: 0,0:02:03.49,0:02:05.83,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:02:03.49,0:02:05.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:03.49,0:02:05.83,Default,,0000,0000,0000,,そんなわけないでしょう!
Dialogue: 0,0:02:05.83,0:02:07.83,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:02:09.83,0:02:12.33,Default,,0000,0000,0000,,悪い ごめん ほんとに
Dialogue: 0,0:02:12.33,0:02:16.67,Default,,0000,0000,0000,,今のは 俺が ばかで 最低だった
Dialogue: 0,0:02:16.67,0:02:19.01,Default,,0000,0000,0000,,いつものことよ
Dialogue: 0,0:02:19.01,0:02:21.67,Default,,0000,0000,0000,,それに レムとの薄いつながりは感じるわ
Dialogue: 0,0:02:21.67,0:02:26.68,Default,,0000,0000,0000,,どこにいるかは わからないけど
Dialogue: 0,0:02:21.67,0:02:26.68,Default,,0000,0000,0000,,少なくとも 命だけは無事よ
Dialogue: 0,0:02:26.68,0:02:29.85,Default,,0000,0000,0000,,そうか 双子同士の共感覚!
Dialogue: 0,0:02:29.85,0:02:32.79,Default,,0000,0000,0000,,ナツキ君も 目ぇ覚めたみたいやね
Dialogue: 0,0:02:32.79,0:02:35.96,Default,,0000,0000,0000,,アナスタシアさんと パトラッシュ
Dialogue: 0,0:02:35.96,0:02:38.96,Default,,0000,0000,0000,,勝手に パトラッシュちゃん 借りて ごめんな
Dialogue: 0,0:02:38.96,0:02:44.13,Default,,0000,0000,0000,,さすがのうちも 1人で
Dialogue: 0,0:02:38.96,0:02:44.13,Default,,0000,0000,0000,,見て回るんは心細かったんよ
Dialogue: 0,0:02:44.13,0:02:46.63,Default,,0000,0000,0000,,それは 別にいいんだけど
Dialogue: 0,0:02:46.63,0:02:50.47,Default,,0000,0000,0000,,ラムは 一度も 2人きりだなんて 言った覚えはないわ
Dialogue: 0,0:02:50.47,0:02:53.31,Default,,0000,0000,0000,,周囲は どうでしたか?
Dialogue: 0,0:02:50.47,0:02:53.31,Default,,0000,0000,0000,,あかんね
Dialogue: 0,0:02:53.31,0:02:56.64,Default,,0000,0000,0000,,近くには 出口も 他の子らも 見当たらへん
Dialogue: 0,0:02:56.64,0:03:00.31,Default,,0000,0000,0000,,ここいらに飛ばされたんは うちたち3人
Dialogue: 0,0:03:00.31,0:03:02.98,Default,,0000,0000,0000,,と
Dialogue: 0,0:03:00.31,0:03:02.98,Default,,0000,0000,0000,,パトラッシュちゃんだけみたいやな
Dialogue: 0,0:03:02.98,0:03:06.82,Default,,0000,0000,0000,,俺たちだけ?
Dialogue: 0,0:03:02.98,0:03:06.82,Default,,0000,0000,0000,,嘆いてても しかたないわ
Dialogue: 0,0:03:06.82,0:03:12.66,Default,,0000,0000,0000,,役立たずのバルスも起きたことだし
Dialogue: 0,0:03:06.82,0:03:12.66,Default,,0000,0000,0000,,レムやエミリア様を捜しましょう
Dialogue: 0,0:03:12.66,0:03:17.00,Default,,0000,0000,0000,,捜すったって
Dialogue: 0,0:03:12.66,0:03:17.00,Default,,0000,0000,0000,,チーム編成に 悪意を感じるぞ!
Dialogue: 0,0:03:17.00,0:03:20.40,Default,,0000,0000,0000,,戦えるやつがいねえじゃねえか!
Dialogue: 0,0:05:02.64,0:05:08.64,Default,,0000,0000,0000,,風は 来てるような
Dialogue: 0,0:05:02.64,0:05:08.64,Default,,0000,0000,0000,,来てないような
Dialogue: 0,0:05:08.64,0:05:11.31,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:05:08.64,0:05:11.31,Default,,0000,0000,0000,,バルスは 精霊とは話せないの?
Dialogue: 0,0:05:11.31,0:05:13.98,Default,,0000,0000,0000,,微精霊の道案内人か
Dialogue: 0,0:05:13.98,0:05:16.98,Default,,0000,0000,0000,,俺の場合 ベア子とのつながりが強すぎて
Dialogue: 0,0:05:16.98,0:05:19.65,Default,,0000,0000,0000,,微精霊を びびらしちまうんだよな
Dialogue: 0,0:05:19.65,0:05:24.16,Default,,0000,0000,0000,,ベアトリス様のお情けで生まれた 半人前の術師だものね
Dialogue: 0,0:05:24.16,0:05:27.99,Default,,0000,0000,0000,,まあ 期待してなかったわ
Dialogue: 0,0:05:24.16,0:05:27.99,Default,,0000,0000,0000,,ぐぬぬ
Dialogue: 0,0:05:27.99,0:05:30.00,Default,,0000,0000,0000,,ナツキ君
Dialogue: 0,0:05:27.99,0:05:30.00,Default,,0000,0000,0000,,ああ?
Dialogue: 0,0:05:30.00,0:05:32.60,Default,,0000,0000,0000,,今は 気丈に隠してるけど
Dialogue: 0,0:05:32.60,0:05:36.94,Default,,0000,0000,0000,,ラムさん ナツキ君が起きる前 飛ばれて すぐは
Dialogue: 0,0:05:36.94,0:05:40.94,Default,,0000,0000,0000,,レムさんが見当たらなくて かなり取り乱しとったんよ
Dialogue: 0,0:05:40.94,0:05:43.61,Default,,0000,0000,0000,,そうか
Dialogue: 0,0:05:40.94,0:05:43.61,Default,,0000,0000,0000,,せやから
Dialogue: 0,0:05:43.61,0:05:47.45,Default,,0000,0000,0000,,ナツキ君は ラムさんの精神安定に役立ってる
Dialogue: 0,0:05:47.45,0:05:50.45,Default,,0000,0000,0000,,役立たずとはちゃうよ
Dialogue: 0,0:05:47.45,0:05:50.45,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:53.62,0:05:55.62,Default,,0000,0000,0000,,分かれ道だ
Dialogue: 0,0:05:55.62,0:05:59.79,Default,,0000,0000,0000,,せいぜい悩めといった風情ね
Dialogue: 0,0:05:55.62,0:05:59.79,Default,,0000,0000,0000,,どうするの?
Dialogue: 0,0:05:59.79,0:06:02.30,Default,,0000,0000,0000,,俺の知識だと こういうときは
Dialogue: 0,0:06:02.30,0:06:05.63,Default,,0000,0000,0000,,右を選べって フロイトが言ってた
Dialogue: 0,0:06:02.30,0:06:05.63,Default,,0000,0000,0000,,誰やのん?
Dialogue: 0,0:06:05.63,0:06:10.14,Default,,0000,0000,0000,,行動学的に 人間は 無意識に 左を選びやすいんだとよ
Dialogue: 0,0:06:10.14,0:06:14.47,Default,,0000,0000,0000,,なんで 右を確かめたいってのが 俺のジャスティスだ
Dialogue: 0,0:06:14.47,0:06:16.81,Default,,0000,0000,0000,,ずいぶんと フロイトを信用しているのね
Dialogue: 0,0:06:16.81,0:06:18.81,Default,,0000,0000,0000,,だから 誰やのん?
Dialogue: 0,0:06:28.99,0:06:30.99,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:06:34.26,0:06:36.26,Default,,0000,0000,0000,,扉?
Dialogue: 0,0:06:36.26,0:06:40.27,Default,,0000,0000,0000,,でかいし 分厚そうだ
Dialogue: 0,0:06:36.26,0:06:40.27,Default,,0000,0000,0000,,動かせそうか?
Dialogue: 0,0:06:40.27,0:06:44.10,Default,,0000,0000,0000,,完全に塞いどるようやし 難しいやろね
Dialogue: 0,0:06:44.10,0:06:46.27,Default,,0000,0000,0000,,ただ ナツキ君
Dialogue: 0,0:06:46.27,0:06:49.11,Default,,0000,0000,0000,,なんで これを扉やなんて思うん?
Dialogue: 0,0:06:49.11,0:06:53.61,Default,,0000,0000,0000,,うちには ただの鉄の壁にしか 見えんのやけど
Dialogue: 0,0:06:49.11,0:06:53.61,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:06:53.61,0:06:57.62,Default,,0000,0000,0000,,そうね ラムにも 邪魔な鉄くずにしか見えないわ
Dialogue: 0,0:06:57.62,0:06:59.62,Default,,0000,0000,0000,,えっ? あっ いや
Dialogue: 0,0:06:59.62,0:07:02.62,Default,,0000,0000,0000,,ただ なんとなく 扉ってふうに思って
Dialogue: 0,0:07:05.46,0:07:07.46,Default,,0000,0000,0000,,うおっ!
Dialogue: 0,0:07:09.63,0:07:14.13,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:07:09.63,0:07:14.13,Default,,0000,0000,0000,,今のって ナツキ君 なんかしたん?
Dialogue: 0,0:07:14.13,0:07:18.81,Default,,0000,0000,0000,,なんかって
Dialogue: 0,0:07:14.13,0:07:18.81,Default,,0000,0000,0000,,見てただろ? 触っただけだよ
Dialogue: 0,0:07:18.81,0:07:22.14,Default,,0000,0000,0000,,なんもしてねえし 俺にも わからねえよ
Dialogue: 0,0:07:22.14,0:07:25.65,Default,,0000,0000,0000,,行くわよ
Dialogue: 0,0:07:22.14,0:07:25.65,Default,,0000,0000,0000,,あっ パトラッシュ?
Dialogue: 0,0:07:27.65,0:07:31.82,Default,,0000,0000,0000,,お前が 俺たちを守ろうとしてることは わかってるよ
Dialogue: 0,0:07:31.82,0:07:35.09,Default,,0000,0000,0000,,でも この状況下で 安全圏なんてない
Dialogue: 0,0:07:35.09,0:07:37.92,Default,,0000,0000,0000,,どっかで 火中のくりを拾う覚悟がいる
Dialogue: 0,0:07:37.92,0:07:40.93,Default,,0000,0000,0000,,今が そのときなんだ
Dialogue: 0,0:07:40.93,0:07:44.76,Default,,0000,0000,0000,,尻に敷かれているわね
Dialogue: 0,0:07:44.76,0:07:48.27,Default,,0000,0000,0000,,女の子を尻に敷くぐらいなら
Dialogue: 0,0:07:48.27,0:07:50.94,Default,,0000,0000,0000,,自分が敷かれたほうが ずっと ましだね
Dialogue: 0,0:07:50.94,0:07:53.61,Default,,0000,0000,0000,,嫌らしい
Dialogue: 0,0:07:50.94,0:07:53.61,Default,,0000,0000,0000,,そういう意味じゃねえよ!
Dialogue: 0,0:07:53.61,0:07:55.61,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:07:59.61,0:08:03.78,Default,,0000,0000,0000,,これで 2枚目
Dialogue: 0,0:07:59.61,0:08:03.78,Default,,0000,0000,0000,,それも また 消えやがった
Dialogue: 0,0:08:03.78,0:08:07.79,Default,,0000,0000,0000,,行く手を遮らない扉なんて なんの意味があるんだ?
Dialogue: 0,0:08:07.79,0:08:10.29,Default,,0000,0000,0000,,あっ どうした?
Dialogue: 0,0:08:07.79,0:08:10.29,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:10.29,0:08:12.46,Default,,0000,0000,0000,,さあ?
Dialogue: 0,0:08:10.29,0:08:14.46,Default,,0000,0000,0000,,ここまで出くわしてないから 実感ないけど
Dialogue: 0,0:08:14.46,0:08:17.63,Default,,0000,0000,0000,,もしかすると 魔獣よけかもしらんね
Dialogue: 0,0:08:17.63,0:08:22.13,Default,,0000,0000,0000,,すなみみず 砂蚯蚓の巣穴に つながっている
Dialogue: 0,0:08:17.63,0:08:22.13,Default,,0000,0000,0000,,可能性も ゼロではないでしょうし
Dialogue: 0,0:08:22.13,0:08:24.80,Default,,0000,0000,0000,,魔獣のみを通さない 結界の類いかと
Dialogue: 0,0:08:24.80,0:08:28.31,Default,,0000,0000,0000,,うげっ!
Dialogue: 0,0:08:24.80,0:08:28.31,Default,,0000,0000,0000,,だとしたら マジで やばいな
Dialogue: 0,0:08:32.25,0:08:36.55,Default,,0000,0000,0000,,フゥフゥ フゥフゥ
Dialogue: 0,0:08:40.25,0:08:45.26,Default,,0000,0000,0000,,ハァハァハァ
Dialogue: 0,0:08:45.26,0:08:49.60,Default,,0000,0000,0000,,んっ 体が やけに重くないか?
Dialogue: 0,0:08:49.60,0:08:52.43,Default,,0000,0000,0000,,ハァ んっ
Dialogue: 0,0:08:52.43,0:08:55.43,Default,,0000,0000,0000,,なんて 弱音 吐いてる場合じゃねえ
Dialogue: 0,0:08:55.43,0:09:00.27,Default,,0000,0000,0000,,ちょっと歩きにくいけど 大したことじゃないな
Dialogue: 0,0:09:00.27,0:09:02.61,Default,,0000,0000,0000,,このペースでいけば 意外と ゴールも近いんじゃ
Dialogue: 0,0:09:02.61,0:09:05.28,Default,,0000,0000,0000,,チッ! バルス
Dialogue: 0,0:09:02.61,0:09:05.28,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:09:02.61,0:09:05.28,Default,,0000,0000,0000,,うるさい
Dialogue: 0,0:09:05.28,0:09:07.28,Default,,0000,0000,0000,,えっ? ああ おう
Dialogue: 0,0:09:07.28,0:09:11.78,Default,,0000,0000,0000,,とはいえ ただ黙ってるってのも 芸がないと思うんだが
Dialogue: 0,0:09:11.78,0:09:14.29,Default,,0000,0000,0000,,楽しむために歩いているの?
Dialogue: 0,0:09:14.29,0:09:16.96,Default,,0000,0000,0000,,目的を思い出しなさい
Dialogue: 0,0:09:14.29,0:09:16.96,Default,,0000,0000,0000,,そりゃ
Dialogue: 0,0:09:16.96,0:09:19.29,Default,,0000,0000,0000,,ナツキ君 もうええやん
Dialogue: 0,0:09:16.96,0:09:19.29,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:09:19.29,0:09:23.63,Default,,0000,0000,0000,,こんな状況や
Dialogue: 0,0:09:19.29,0:09:23.63,Default,,0000,0000,0000,,心が ささくれ立っとるときは
Dialogue: 0,0:09:23.63,0:09:27.13,Default,,0000,0000,0000,,誰と どんな話 しても ええ結果にならんから
Dialogue: 0,0:09:27.13,0:09:30.14,Default,,0000,0000,0000,,なっ?
Dialogue: 0,0:09:27.13,0:09:30.14,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:09:36.91,0:09:42.92,Default,,0000,0000,0000,,うっ! うっ! んっ くそが!
Dialogue: 0,0:09:36.91,0:09:42.92,Default,,0000,0000,0000,,ここにきて なんなんだよ?
Dialogue: 0,0:09:42.92,0:09:45.75,Default,,0000,0000,0000,,3つ目の扉も素通りさせて
Dialogue: 0,0:09:45.75,0:09:48.25,Default,,0000,0000,0000,,どうして 今更 邪魔しに来やがる?
Dialogue: 0,0:09:48.25,0:09:51.92,Default,,0000,0000,0000,,くっそ! くそ! くそが!
Dialogue: 0,0:09:51.92,0:09:55.93,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:09:51.92,0:09:55.93,Default,,0000,0000,0000,,ナツキ君 その辺にしとき
Dialogue: 0,0:09:55.93,0:09:58.43,Default,,0000,0000,0000,,ここは もう 行き止まりなんよ
Dialogue: 0,0:09:58.43,0:10:01.93,Default,,0000,0000,0000,,言われなくても それぐらい わかってんだよ!
Dialogue: 0,0:10:01.93,0:10:03.94,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:10:05.94,0:10:08.77,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:10:05.94,0:10:08.77,Default,,0000,0000,0000,,チッ!
Dialogue: 0,0:10:08.77,0:10:12.95,Default,,0000,0000,0000,,おい さっきから お前 ほんとに なんのつもりだ?
Dialogue: 0,0:10:12.95,0:10:15.62,Default,,0000,0000,0000,,別に
Dialogue: 0,0:10:12.95,0:10:15.62,Default,,0000,0000,0000,,「別に」じゃねえよ!
Dialogue: 0,0:10:15.62,0:10:18.28,Default,,0000,0000,0000,,なんのつもりだって 聞いてんだよ!
Dialogue: 0,0:10:18.28,0:10:21.29,Default,,0000,0000,0000,,人が必死こいてんのに チクチク チクチク!
Dialogue: 0,0:10:21.29,0:10:24.79,Default,,0000,0000,0000,,聞こえてんだよ!
Dialogue: 0,0:10:21.29,0:10:24.79,Default,,0000,0000,0000,,なんのつもりだ? あっ!?
Dialogue: 0,0:10:24.79,0:10:27.63,Default,,0000,0000,0000,,ちょちょちょ
Dialogue: 0,0:10:24.79,0:10:27.63,Default,,0000,0000,0000,,落ち着きって 2人とも
Dialogue: 0,0:10:27.63,0:10:30.30,Default,,0000,0000,0000,,そないに本気で言い合いなんて
Dialogue: 0,0:10:27.63,0:10:30.30,Default,,0000,0000,0000,,黙ってろ!
Dialogue: 0,0:10:30.30,0:10:34.30,Default,,0000,0000,0000,,今 俺とラムが話してんだろうが!
Dialogue: 0,0:10:34.30,0:10:37.80,Default,,0000,0000,0000,,おら 言いたいことがあるなら 言ってみろや!
Dialogue: 0,0:10:37.80,0:10:39.81,Default,,0000,0000,0000,,聞いてやるからよ!
Dialogue: 0,0:10:39.81,0:10:43.64,Default,,0000,0000,0000,,ずいぶんと バルスは 先に進むのに熱心なのね
Dialogue: 0,0:10:43.64,0:10:48.15,Default,,0000,0000,0000,,当たり前だろうが! なんのために ここまで来たと思ってんだ
Dialogue: 0,0:10:48.15,0:10:50.15,Default,,0000,0000,0000,,賢者に会うために
Dialogue: 0,0:10:48.15,0:10:50.15,Default,,0000,0000,0000,,違うわ
Dialogue: 0,0:10:50.15,0:10:53.49,Default,,0000,0000,0000,,ここに来たのは 賢者に 会うためじゃない
Dialogue: 0,0:10:50.15,0:10:53.49,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:10:53.49,0:10:56.82,Default,,0000,0000,0000,,ここに来たのは レムのことを目覚めさせるためよ
Dialogue: 0,0:10:56.82,0:10:58.82,Default,,0000,0000,0000,,うっ あっ
Dialogue: 0,0:10:58.82,0:11:02.33,Default,,0000,0000,0000,,ラムは レムを
Dialogue: 0,0:10:58.82,0:11:02.33,Default,,0000,0000,0000,,妹を思い出すために来た
Dialogue: 0,0:11:02.33,0:11:05.16,Default,,0000,0000,0000,,それなのに 今は何をしているの?
Dialogue: 0,0:11:05.16,0:11:09.00,Default,,0000,0000,0000,,レムもいないのに こんな場所で のらりくらり
Dialogue: 0,0:11:09.00,0:11:12.67,Default,,0000,0000,0000,,ふざけないで
Dialogue: 0,0:11:09.00,0:11:12.67,Default,,0000,0000,0000,,んっ ふざけてなんかねえよ!
Dialogue: 0,0:11:12.67,0:11:15.34,Default,,0000,0000,0000,,こうなっちまったんなら しかたねえだろ
Dialogue: 0,0:11:15.34,0:11:17.84,Default,,0000,0000,0000,,どうして ここに落ちたとき
Dialogue: 0,0:11:17.84,0:11:21.68,Default,,0000,0000,0000,,バルスは レムじゃなく ラムをつかまえたの?
Dialogue: 0,0:11:17.84,0:11:21.68,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:11:21.68,0:11:24.18,Default,,0000,0000,0000,,どうせ 目先のことで 手いっぱいなんでしょう
Dialogue: 0,0:11:24.18,0:11:26.85,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:11:24.18,0:11:26.85,Default,,0000,0000,0000,,バルスは いつも そうなのよ
Dialogue: 0,0:11:26.85,0:11:30.69,Default,,0000,0000,0000,,エミリア様やベアトリス様のことで 頭が いっぱいで
Dialogue: 0,0:11:30.69,0:11:34.96,Default,,0000,0000,0000,,なんて男なの
Dialogue: 0,0:11:30.69,0:11:34.96,Default,,0000,0000,0000,,レムが かわいそうだわ
Dialogue: 0,0:11:30.69,0:11:34.96,Default,,0000,0000,0000,,黙れ
Dialogue: 0,0:11:34.96,0:11:37.96,Default,,0000,0000,0000,,レムは バルスのこと 信じてたんじゃないの?
Dialogue: 0,0:11:37.96,0:11:40.63,Default,,0000,0000,0000,,黙れよ!
Dialogue: 0,0:11:37.96,0:11:40.63,Default,,0000,0000,0000,,いいえ 黙らない!
Dialogue: 0,0:11:40.63,0:11:44.14,Default,,0000,0000,0000,,バルスは 本当は レムのことなんて どうでもいいんでしょ!?
Dialogue: 0,0:11:44.14,0:11:46.47,Default,,0000,0000,0000,,ふざけるな!!
Dialogue: 0,0:11:46.47,0:11:48.81,Default,,0000,0000,0000,,あっ! んっ
Dialogue: 0,0:11:48.81,0:11:51.81,Default,,0000,0000,0000,,インビジブルプロヴィデンス
Dialogue: 0,0:11:59.49,0:12:01.49,Default,,0000,0000,0000,,くっ!
Dialogue: 0,0:12:03.49,0:12:06.49,Default,,0000,0000,0000,,ハァ ふざけるな
Dialogue: 0,0:12:03.49,0:12:06.49,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:12:06.49,0:12:08.66,Default,,0000,0000,0000,,お前が悪い!
Dialogue: 0,0:12:08.66,0:12:12.00,Default,,0000,0000,0000,,お前が! お前が! お前が!
Dialogue: 0,0:12:12.00,0:12:15.00,Default,,0000,0000,0000,,くたばれ くそ女!
Dialogue: 0,0:12:12.00,0:12:15.00,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:12:15.00,0:12:18.67,Default,,0000,0000,0000,,お前が レムと そっくりな顔してると思うと
Dialogue: 0,0:12:18.67,0:12:21.84,Default,,0000,0000,0000,,へどが出る! ハァ
Dialogue: 0,0:12:21.84,0:12:24.34,Default,,0000,0000,0000,,あっ!? 聞こえねえよ!
Dialogue: 0,0:12:24.34,0:12:30.02,Default,,0000,0000,0000,,言いたいことがあるんなら
Dialogue: 0,0:12:24.34,0:12:30.02,Default,,0000,0000,0000,,はっきり
Dialogue: 0,0:12:24.34,0:12:30.02,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:12:30.02,0:12:32.92,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:12:30.02,0:12:32.92,Default,,0000,0000,0000,,ラッ
Dialogue: 0,0:12:35.96,0:12:39.46,Default,,0000,0000,0000,,うっ! んっ 魔法!
Dialogue: 0,0:12:39.46,0:12:42.96,Default,,0000,0000,0000,,てめえ もう 泣いて謝っても遅えぞ!
Dialogue: 0,0:12:42.96,0:12:45.80,Default,,0000,0000,0000,,それは こっちのせりふだわ
Dialogue: 0,0:12:45.80,0:12:49.30,Default,,0000,0000,0000,,バルスなんて レムに会わせる価値もない
Dialogue: 0,0:12:49.30,0:12:51.97,Default,,0000,0000,0000,,輪切りになって ここで朽ちなさい
Dialogue: 0,0:12:51.97,0:12:54.14,Default,,0000,0000,0000,,言ってろ!
Dialogue: 0,0:12:54.14,0:12:56.14,Default,,0000,0000,0000,,はい そこまでや
Dialogue: 0,0:12:59.15,0:13:03.15,Default,,0000,0000,0000,,ハッ かはっ! くっ
Dialogue: 0,0:12:59.15,0:13:03.15,Default,,0000,0000,0000,,もう 止められへんし
Dialogue: 0,0:13:03.15,0:13:07.65,Default,,0000,0000,0000,,どっちが有用か 見比べた結果やから 堪忍な?
Dialogue: 0,0:13:07.65,0:13:11.66,Default,,0000,0000,0000,,くっ くっ
Dialogue: 0,0:13:07.65,0:13:11.66,Default,,0000,0000,0000,,お前 なんで
Dialogue: 0,0:13:11.66,0:13:15.16,Default,,0000,0000,0000,,え?
Dialogue: 0,0:13:11.66,0:13:15.16,Default,,0000,0000,0000,,ナツキ君が それ 言うん?
Dialogue: 0,0:13:11.66,0:13:15.16,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:13:15.16,0:13:19.50,Default,,0000,0000,0000,,あのままやったらあかんと思うて 手伝ってあげたんやないの
Dialogue: 0,0:13:19.50,0:13:21.50,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:13:19.50,0:13:21.50,Default,,0000,0000,0000,,それとも
Dialogue: 0,0:13:21.50,0:13:26.51,Default,,0000,0000,0000,,獲物 横取りされて
Dialogue: 0,0:13:21.50,0:13:26.51,Default,,0000,0000,0000,,我慢ならんから うちを狙うん?
Dialogue: 0,0:13:26.51,0:13:31.01,Default,,0000,0000,0000,,いいさ
Dialogue: 0,0:13:26.51,0:13:31.01,Default,,0000,0000,0000,,今 お前の口車に乗ってやるよ
Dialogue: 0,0:13:31.01,0:13:35.45,Default,,0000,0000,0000,,うん それでええよ あっ
Dialogue: 0,0:13:35.45,0:13:39.12,Default,,0000,0000,0000,,賢い 賢い!
Dialogue: 0,0:13:35.45,0:13:39.12,Default,,0000,0000,0000,,うちも ほっとしたわ
Dialogue: 0,0:13:39.12,0:13:41.12,Default,,0000,0000,0000,,じゃあ はい
Dialogue: 0,0:13:41.12,0:13:45.12,Default,,0000,0000,0000,,仲直りと こっから先も よろしゅうねの握手
Dialogue: 0,0:13:45.12,0:13:47.13,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:13:47.13,0:13:50.30,Default,,0000,0000,0000,,ナツキ君? どないしたん?
Dialogue: 0,0:13:50.30,0:13:54.80,Default,,0000,0000,0000,,いや なんでもねえよ
Dialogue: 0,0:13:58.47,0:14:00.47,Default,,0000,0000,0000,,そしたら
Dialogue: 0,0:14:00.47,0:14:02.47,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:14:05.64,0:14:07.65,Default,,0000,0000,0000,,あっ うっ!
Dialogue: 0,0:14:10.82,0:14:15.65,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:10.82,0:14:15.65,Default,,0000,0000,0000,,あっ あっ あっ あっ あ!!
Dialogue: 0,0:14:15.65,0:14:18.49,Default,,0000,0000,0000,,あっ あっ 離せ! 離せ!!
Dialogue: 0,0:14:18.49,0:14:22.66,Default,,0000,0000,0000,,嫌や! うち 死にたない!
Dialogue: 0,0:14:18.49,0:14:22.66,Default,,0000,0000,0000,,あっ あっ あっ あ!
Dialogue: 0,0:14:22.66,0:14:26.50,Default,,0000,0000,0000,,もう 死んでんだよ!
Dialogue: 0,0:14:22.66,0:14:26.50,Default,,0000,0000,0000,,助かるわけねえだろ!?
Dialogue: 0,0:14:26.50,0:14:28.83,Default,,0000,0000,0000,,この ばか! くそが!
Dialogue: 0,0:14:28.83,0:14:32.27,Default,,0000,0000,0000,,とっとと死ねよ!
Dialogue: 0,0:14:28.83,0:14:32.27,Default,,0000,0000,0000,,嫌!
Dialogue: 0,0:14:32.27,0:14:35.61,Default,,0000,0000,0000,,ハァハァハァ
Dialogue: 0,0:14:35.61,0:14:38.44,Default,,0000,0000,0000,,あっ あっ あ!
Dialogue: 0,0:14:35.61,0:14:38.44,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:14:38.44,0:14:41.78,Default,,0000,0000,0000,,ハァハァ ハァハァ ハァハァハァ
Dialogue: 0,0:14:41.78,0:14:46.62,Default,,0000,0000,0000,,ハァハァハァ うっ! ハァハァハァ
Dialogue: 0,0:14:46.62,0:14:49.82,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:14:52.63,0:14:56.13,Default,,0000,0000,0000,,置いて かないで
Dialogue: 0,0:14:56.13,0:14:59.97,Default,,0000,0000,0000,,ハァハァ うぅ
Dialogue: 0,0:15:02.64,0:15:05.14,Default,,0000,0000,0000,,オエッ! ゴホゴホッ!
Dialogue: 0,0:15:05.14,0:15:08.14,Default,,0000,0000,0000,,ラムだ ラムの魔法だ
Dialogue: 0,0:15:08.14,0:15:12.65,Default,,0000,0000,0000,,あの くそ女 生きてやがった
Dialogue: 0,0:15:18.65,0:15:23.32,Default,,0000,0000,0000,,パトラッシュ お前は無事だったのか
Dialogue: 0,0:15:23.32,0:15:26.83,Default,,0000,0000,0000,,ラムは死んだのか?
Dialogue: 0,0:15:26.83,0:15:29.66,Default,,0000,0000,0000,,いや いい 乗せてくれ
Dialogue: 0,0:15:29.66,0:15:32.77,Default,,0000,0000,0000,,んっ? 聞いてんのか? おい!
Dialogue: 0,0:15:32.77,0:15:37.77,Default,,0000,0000,0000,,こっち来い! この野郎!
Dialogue: 0,0:15:32.77,0:15:37.77,Default,,0000,0000,0000,,俺を なんだと思ってやがる?
Dialogue: 0,0:15:37.77,0:15:42.61,Default,,0000,0000,0000,,ハァハァハァ
Dialogue: 0,0:15:42.61,0:15:46.41,Default,,0000,0000,0000,,こいつ やっと 人の話を
Dialogue: 0,0:15:42.61,0:15:46.41,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:52.28,0:15:54.62,Default,,0000,0000,0000,,はっ?
Dialogue: 0,0:15:54.62,0:15:56.62,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:15:56.62,0:15:59.83,Default,,0000,0000,0000,,ケケケケケケケケ
Dialogue: 0,0:16:13.81,0:16:16.31,Default,,0000,0000,0000,,バルス バルス!
Dialogue: 0,0:16:16.31,0:16:19.14,Default,,0000,0000,0000,,いいかげん 起きないと まぶたを焼き切るわよ
Dialogue: 0,0:16:19.14,0:16:22.65,Default,,0000,0000,0000,,んっ ハッ! あっ
Dialogue: 0,0:16:22.65,0:16:24.82,Default,,0000,0000,0000,,俺は
Dialogue: 0,0:16:24.82,0:16:28.49,Default,,0000,0000,0000,,うっ うっ!
Dialogue: 0,0:16:24.82,0:16:28.49,Default,,0000,0000,0000,,バルス
Dialogue: 0,0:16:24.82,0:16:28.49,Default,,0000,0000,0000,,ゴホゴホッ!
Dialogue: 0,0:16:28.49,0:16:30.99,Default,,0000,0000,0000,,ハァハァ うぅ
Dialogue: 0,0:16:28.49,0:16:30.99,Default,,0000,0000,0000,,情けないわね
Dialogue: 0,0:16:30.99,0:16:33.43,Default,,0000,0000,0000,,あっ ハァ
Dialogue: 0,0:16:30.99,0:16:33.43,Default,,0000,0000,0000,,かむんじゃないわよ
Dialogue: 0,0:16:37.76,0:16:42.27,Default,,0000,0000,0000,,ゲホッ! ハァ 悪い もう 大丈夫
Dialogue: 0,0:16:42.27,0:16:45.60,Default,,0000,0000,0000,,そう? 満足できたみたいで よかったでちゅね
Dialogue: 0,0:16:45.60,0:16:48.77,Default,,0000,0000,0000,,んっ お前な
Dialogue: 0,0:16:45.60,0:16:48.77,Default,,0000,0000,0000,,よかったわ!
Dialogue: 0,0:16:45.60,0:16:48.77,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:16:48.77,0:16:51.94,Default,,0000,0000,0000,,ナツキ君も 目ぇ覚めたみたいやね
Dialogue: 0,0:16:48.77,0:16:51.94,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:16:51.94,0:16:53.95,Default,,0000,0000,0000,,おかげさまで
Dialogue: 0,0:16:53.95,0:16:56.62,Default,,0000,0000,0000,,周囲は どうでしたか?
Dialogue: 0,0:16:53.95,0:16:56.62,Default,,0000,0000,0000,,あかんね
Dialogue: 0,0:16:56.62,0:17:00.12,Default,,0000,0000,0000,,近くには 出口も 他の子らも 見当たらへん
Dialogue: 0,0:17:00.12,0:17:03.96,Default,,0000,0000,0000,,ナツキ君? どないしたん?
Dialogue: 0,0:17:03.96,0:17:08.13,Default,,0000,0000,0000,,なあ 瘴気ってのは 一体 なんなんだ?
Dialogue: 0,0:17:08.13,0:17:11.96,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:17:08.13,0:17:11.96,Default,,0000,0000,0000,,ここも 砂丘の一部なんだろ?
Dialogue: 0,0:17:11.96,0:17:14.80,Default,,0000,0000,0000,,瘴気が漂ってるって 話だったよな?
Dialogue: 0,0:17:14.80,0:17:17.97,Default,,0000,0000,0000,,瘴気というのは 要は 汚染されたマナのことよ
Dialogue: 0,0:17:17.97,0:17:19.97,Default,,0000,0000,0000,,汚染されたマナ?
Dialogue: 0,0:17:19.97,0:17:23.98,Default,,0000,0000,0000,,放っておくと 身も 心も むしばまれるって話やけど
Dialogue: 0,0:17:23.98,0:17:27.15,Default,,0000,0000,0000,,対応策は?
Dialogue: 0,0:17:23.98,0:17:27.15,Default,,0000,0000,0000,,うちらのゲートが
Dialogue: 0,0:17:27.15,0:17:30.82,Default,,0000,0000,0000,,マナを取り込むこと自体は 自然なことやから
Dialogue: 0,0:17:30.82,0:17:36.12,Default,,0000,0000,0000,,できるとしたら 瘴気の濃いとこに
Dialogue: 0,0:17:30.82,0:17:36.12,Default,,0000,0000,0000,,近づかないようにするだけやね
Dialogue: 0,0:17:38.42,0:17:40.43,Default,,0000,0000,0000,,あれが瘴気の影響
Dialogue: 0,0:17:40.43,0:17:44.33,Default,,0000,0000,0000,,なら この先 進んだら また
Dialogue: 0,0:17:40.43,0:17:44.33,Default,,0000,0000,0000,,いや
Dialogue: 0,0:17:48.10,0:17:50.60,Default,,0000,0000,0000,,バルス?
Dialogue: 0,0:17:48.10,0:17:50.60,Default,,0000,0000,0000,,行こう
Dialogue: 0,0:17:59.45,0:18:03.95,Default,,0000,0000,0000,,んっ 左だ 左に進もう
Dialogue: 0,0:18:05.95,0:18:07.95,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:07.95,0:18:11.96,Default,,0000,0000,0000,,アナスタシアさん ここ 天井 低いから 気を付けてくれ
Dialogue: 0,0:18:11.96,0:18:14.63,Default,,0000,0000,0000,,うん わかったわ ありがと
Dialogue: 0,0:18:14.63,0:18:18.63,Default,,0000,0000,0000,,ラム ちょっと足場が悪いぞ
Dialogue: 0,0:18:14.63,0:18:18.63,Default,,0000,0000,0000,,注意してくれ
Dialogue: 0,0:18:18.63,0:18:20.63,Default,,0000,0000,0000,,ええ わかったわ
Dialogue: 0,0:18:20.63,0:18:25.64,Default,,0000,0000,0000,,寒かったら すぐ言えよ
Dialogue: 0,0:18:20.63,0:18:25.64,Default,,0000,0000,0000,,俺のマントでよければ 貸すから
Dialogue: 0,0:18:25.64,0:18:28.97,Default,,0000,0000,0000,,なっ なんだよ?
Dialogue: 0,0:18:25.64,0:18:28.97,Default,,0000,0000,0000,,どうしたんだ?
Dialogue: 0,0:18:28.97,0:18:32.58,Default,,0000,0000,0000,,そっちこそ その薄気味悪い 気遣いは なんなの?
Dialogue: 0,0:18:32.58,0:18:36.25,Default,,0000,0000,0000,,なんのたくらみがあるの?
Dialogue: 0,0:18:32.58,0:18:36.25,Default,,0000,0000,0000,,なんも たくらんじゃいねえよ
Dialogue: 0,0:18:36.25,0:18:40.42,Default,,0000,0000,0000,,ただ 俺は お前たちに 健やかでいてほしいだけで
Dialogue: 0,0:18:40.42,0:18:43.09,Default,,0000,0000,0000,,嫌らしい
Dialogue: 0,0:18:40.42,0:18:43.09,Default,,0000,0000,0000,,嫌らしくねえよ!
Dialogue: 0,0:18:43.09,0:18:45.76,Default,,0000,0000,0000,,別に やってること ユリウスと変わんねえだろ
Dialogue: 0,0:18:45.76,0:18:48.76,Default,,0000,0000,0000,,やって ユリウスは自然やけど
Dialogue: 0,0:18:48.76,0:18:53.43,Default,,0000,0000,0000,,ナツキ君のは不健全? 不自然やし
Dialogue: 0,0:18:48.76,0:18:53.43,Default,,0000,0000,0000,,不健全って言った!?
Dialogue: 0,0:18:53.43,0:18:56.27,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:56.27,0:18:58.94,Default,,0000,0000,0000,,なんや 変なにおいがしてこうへん?
Dialogue: 0,0:18:58.94,0:19:02.94,Default,,0000,0000,0000,,何かが燃えてるにおいね
Dialogue: 0,0:18:58.94,0:19:02.94,Default,,0000,0000,0000,,におい?
Dialogue: 0,0:19:02.94,0:19:05.94,Default,,0000,0000,0000,,俺が見てくる んっ
Dialogue: 0,0:19:05.94,0:19:09.28,Default,,0000,0000,0000,,何かあったら バルスをおとりにするわ!
Dialogue: 0,0:19:09.28,0:19:12.78,Default,,0000,0000,0000,,恨まないようになさい!
Dialogue: 0,0:19:09.28,0:19:12.78,Default,,0000,0000,0000,,そのときは呪わせてくれ!
Dialogue: 0,0:19:16.62,0:19:19.12,Default,,0000,0000,0000,,あっ んっ?
Dialogue: 0,0:19:19.12,0:19:21.33,Default,,0000,0000,0000,,なっ! あ!
Dialogue: 0,0:19:23.63,0:19:26.33,Default,,0000,0000,0000,,あっ! あっ あ! ぐっ!
Dialogue: 0,0:19:29.64,0:19:32.57,Default,,0000,0000,0000,,うわ!
Dialogue: 0,0:19:32.57,0:19:35.57,Default,,0000,0000,0000,,あっ! えっ? あっ
Dialogue: 0,0:19:35.57,0:19:37.88,Default,,0000,0000,0000,,ちょちょ ちょちょ ちょちょちょ!
Dialogue: 0,0:19:40.25,0:19:42.25,Default,,0000,0000,0000,,うげっ! ペッ!
Dialogue: 0,0:19:42.25,0:19:45.75,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:19:56.60,0:19:58.60,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:20:04.77,0:20:07.44,Default,,0000,0000,0000,,ハァハァ ハァハァ ハァハァ
Dialogue: 0,0:20:11.28,0:20:14.45,Default,,0000,0000,0000,,うっ! くっ
