Dialogue: 0,0:00:46.75,0:00:49.35,Default,,0000,0000,0000,,蒼ちゃん
Dialogue: 0,0:02:31.45,0:02:33.45,Default,,0000,0000,0000,,んっ うぅ
Dialogue: 0,0:02:35.42,0:02:38.09,Default,,0000,0000,0000,,あんた 七影蝶が見えるの?
Dialogue: 0,0:02:38.09,0:02:41.43,Default,,0000,0000,0000,,あのあと 結局 うやむやにされたけど
Dialogue: 0,0:02:41.43,0:02:45.43,Default,,0000,0000,0000,,あの蝶は 何だったんだろう? 感想は?
Dialogue: 0,0:02:45.43,0:02:47.43,Default,,0000,0000,0000,,おいしくない
Dialogue: 0,0:02:45.43,0:02:47.43,Default,,0000,0000,0000,,あんだと?
Dialogue: 0,0:02:47.43,0:02:49.94,Default,,0000,0000,0000,,あっ ごめん 本音がこぼれた
Dialogue: 0,0:02:49.94,0:02:52.44,Default,,0000,0000,0000,,フォローしてない!
Dialogue: 0,0:02:52.44,0:02:55.28,Default,,0000,0000,0000,,蒼ちゃんは 昼前には来るじゃろて
Dialogue: 0,0:02:55.28,0:02:57.94,Default,,0000,0000,0000,,冷たいものでも食べて 待っとるとええ
Dialogue: 0,0:02:57.94,0:02:59.91,Default,,0000,0000,0000,,ありがとうございます
Dialogue: 0,0:03:05.95,0:03:08.62,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:03:08.62,0:03:10.59,Default,,0000,0000,0000,,最後の1個じゃよ
Dialogue: 0,0:03:13.96,0:03:15.96,Default,,0000,0000,0000,,あっ ちょっと待って!
Dialogue: 0,0:03:15.96,0:03:19.47,Default,,0000,0000,0000,,蒼のこと聞きたいの?
Dialogue: 0,0:03:19.47,0:03:21.47,Default,,0000,0000,0000,,えっ な なんで?
Dialogue: 0,0:03:21.47,0:03:25.14,Default,,0000,0000,0000,,最近 よく 一緒にいるみたいだから
Dialogue: 0,0:03:25.14,0:03:27.81,Default,,0000,0000,0000,,空門家のお役目って どんなの?
Dialogue: 0,0:03:27.81,0:03:30.81,Default,,0000,0000,0000,,知らない
Dialogue: 0,0:03:27.81,0:03:30.81,Default,,0000,0000,0000,,えっ 島のことなのに?
Dialogue: 0,0:03:30.81,0:03:34.91,Default,,0000,0000,0000,,山の祭事の間は 夜の山に入っちゃいけないから
Dialogue: 0,0:03:34.91,0:03:37.42,Default,,0000,0000,0000,,蒼も そんなこと言ってたな
Dialogue: 0,0:03:40.75,0:03:45.43,Default,,0000,0000,0000,,鳥白島には 昔 御三家と 呼ばれている家があったの
Dialogue: 0,0:03:45.43,0:03:49.26,Default,,0000,0000,0000,,空門家と鳴瀬家 あと もう一つは
Dialogue: 0,0:03:49.26,0:03:52.60,Default,,0000,0000,0000,,よく覚えてないけど 空門家だけ昔から ずっと
Dialogue: 0,0:03:52.60,0:03:54.60,Default,,0000,0000,0000,,お役目を続けてるみたい
Dialogue: 0,0:03:54.60,0:03:58.10,Default,,0000,0000,0000,,待って! 今 さらっと 鳴瀬家って言わなかった?
Dialogue: 0,0:03:58.10,0:04:00.77,Default,,0000,0000,0000,,しろはの家だよな?
Dialogue: 0,0:03:58.10,0:04:00.77,Default,,0000,0000,0000,,昔の話
Dialogue: 0,0:04:00.77,0:04:03.11,Default,,0000,0000,0000,,今は なんの役目もないから
Dialogue: 0,0:04:03.11,0:04:05.78,Default,,0000,0000,0000,,ふわぁ
Dialogue: 0,0:04:05.78,0:04:11.45,Default,,0000,0000,0000,,空の空門 海の鳴瀬
Dialogue: 0,0:04:05.78,0:04:11.45,Default,,0000,0000,0000,,山の なんちゃらってね
Dialogue: 0,0:04:11.45,0:04:13.45,Default,,0000,0000,0000,,ふん
Dialogue: 0,0:04:13.45,0:04:17.32,Default,,0000,0000,0000,,珍しいわね しろはが 誰かと一緒にいるなんて
Dialogue: 0,0:04:30.80,0:04:33.37,Default,,0000,0000,0000,,あの 昨日の夜のことだけどさ
Dialogue: 0,0:04:33.37,0:04:36.88,Default,,0000,0000,0000,,何のこと? 私 昨日の夜は 早く寝ちゃったわよ
Dialogue: 0,0:04:36.88,0:04:39.71,Default,,0000,0000,0000,,幻でも見たんじゃない?
Dialogue: 0,0:04:36.88,0:04:39.71,Default,,0000,0000,0000,,幻
Dialogue: 0,0:04:39.71,0:04:42.88,Default,,0000,0000,0000,,確かに 俺が見た蒼は 幻想的だったし
Dialogue: 0,0:04:42.88,0:04:45.05,Default,,0000,0000,0000,,すげえ きれいで神々しかったな
Dialogue: 0,0:04:45.05,0:04:47.89,Default,,0000,0000,0000,,き きれいで神々しい?
Dialogue: 0,0:04:47.89,0:04:52.39,Default,,0000,0000,0000,,そ そんなこと言われたって う うれしくなんかないわよ
Dialogue: 0,0:04:52.39,0:04:54.39,Default,,0000,0000,0000,,やっぱ 蒼なんじゃん
Dialogue: 0,0:04:54.39,0:04:58.06,Default,,0000,0000,0000,,って 言うと思うわよ!
Dialogue: 0,0:04:54.39,0:04:58.06,Default,,0000,0000,0000,,もし 私だったら
Dialogue: 0,0:04:58.06,0:05:00.40,Default,,0000,0000,0000,,もう少し 上手に 嘘ついてくれないか?
Dialogue: 0,0:05:00.40,0:05:05.24,Default,,0000,0000,0000,,だまされてもやれない
Dialogue: 0,0:05:00.40,0:05:05.24,Default,,0000,0000,0000,,う 嘘じゃありません!
Dialogue: 0,0:05:05.24,0:05:08.24,Default,,0000,0000,0000,,本当です!
Dialogue: 0,0:05:05.24,0:05:08.24,Default,,0000,0000,0000,,本当に本当なんです!
Dialogue: 0,0:05:08.24,0:05:12.75,Default,,0000,0000,0000,,とと とにかく あんたは もう 夜の山に入らないで!
Dialogue: 0,0:05:12.75,0:05:15.08,Default,,0000,0000,0000,,これは この島の しきた
Dialogue: 0,0:05:15.08,0:05:17.58,Default,,0000,0000,0000,,ふわぁ
Dialogue: 0,0:05:17.58,0:05:21.25,Default,,0000,0000,0000,,この タイミングで あくびしちゃうか
Dialogue: 0,0:05:21.25,0:05:24.76,Default,,0000,0000,0000,,まぁ お前の寝不足の理由は はっきりしたな
Dialogue: 0,0:05:24.76,0:05:27.76,Default,,0000,0000,0000,,う ヤバい 電池切れそう
Dialogue: 0,0:05:27.76,0:05:30.10,Default,,0000,0000,0000,,俺の膝 貸してやろうか?
Dialogue: 0,0:05:30.10,0:05:32.60,Default,,0000,0000,0000,,じゃあ ちょっとだけお願い
Dialogue: 0,0:05:32.60,0:05:34.60,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:05:42.24,0:05:45.41,Default,,0000,0000,0000,,マジか
Dialogue: 0,0:05:45.41,0:05:47.88,Default,,0000,0000,0000,,ください なっ?
Dialogue: 0,0:05:47.88,0:05:50.75,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:47.88,0:05:50.75,Default,,0000,0000,0000,,むっ
Dialogue: 0,0:05:50.75,0:05:52.72,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:54.75,0:05:57.42,Default,,0000,0000,0000,,帰るぞ 天善
Dialogue: 0,0:05:54.75,0:05:57.42,Default,,0000,0000,0000,,うんまい棒 買わなくて
Dialogue: 0,0:05:57.42,0:06:01.59,Default,,0000,0000,0000,,ここは 見て見ぬふりを するっていうのが 男の友情ってやつだ
Dialogue: 0,0:06:01.59,0:06:03.60,Default,,0000,0000,0000,,あばよ ダチ公 幸せにな!
Dialogue: 0,0:06:03.60,0:06:07.27,Default,,0000,0000,0000,,天善 ダッシュ!
Dialogue: 0,0:06:03.60,0:06:07.27,Default,,0000,0000,0000,,サ!
Dialogue: 0,0:06:07.27,0:06:11.04,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:06:07.27,0:06:11.04,Default,,0000,0000,0000,,ごちそうさまでした
Dialogue: 0,0:06:13.27,0:06:15.27,Default,,0000,0000,0000,,えっ な なに?
Dialogue: 0,0:06:15.27,0:06:18.28,Default,,0000,0000,0000,,夜の山 近づかないほうがいいよ
Dialogue: 0,0:06:18.28,0:06:22.35,Default,,0000,0000,0000,,蒼が そう言ってるんだから きっと そのほうがいいと思う
Dialogue: 0,0:06:33.69,0:06:36.50,Default,,0000,0000,0000,,本当に どこででも寝るな
Dialogue: 0,0:06:47.21,0:06:49.38,Default,,0000,0000,0000,,う うぅん
Dialogue: 0,0:06:49.38,0:06:51.38,Default,,0000,0000,0000,,ポッ キュ!
Dialogue: 0,0:06:51.38,0:06:53.88,Default,,0000,0000,0000,,あっ これは ヤバいやつだ
Dialogue: 0,0:06:56.05,0:06:58.05,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:07:02.56,0:07:06.89,Default,,0000,0000,0000,,ん
Dialogue: 0,0:07:02.56,0:07:06.89,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:07:06.89,0:07:09.06,Default,,0000,0000,0000,,え なに この状況!
Dialogue: 0,0:07:09.06,0:07:11.73,Default,,0000,0000,0000,,顔 近い! いろいろ柔らかいし
Dialogue: 0,0:07:11.73,0:07:14.23,Default,,0000,0000,0000,,なんか いい匂いがする!
Dialogue: 0,0:07:14.23,0:07:16.74,Default,,0000,0000,0000,,んっ ん にへ
Dialogue: 0,0:07:18.74,0:07:21.74,Default,,0000,0000,0000,,あの これは
Dialogue: 0,0:07:21.74,0:07:25.58,Default,,0000,0000,0000,,どうぞ ごゆるりと
Dialogue: 0,0:07:25.58,0:07:28.08,Default,,0000,0000,0000,,んっ ん
Dialogue: 0,0:07:28.08,0:07:31.08,Default,,0000,0000,0000,,ふわぁ あっ ふぅ
Dialogue: 0,0:07:31.08,0:07:34.22,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:07:31.08,0:07:34.22,Default,,0000,0000,0000,,おはよう
Dialogue: 0,0:07:34.22,0:07:38.22,Default,,0000,0000,0000,,うわぁっ!!
Dialogue: 0,0:07:34.22,0:07:38.22,Default,,0000,0000,0000,,なななな なんで なんで!?
Dialogue: 0,0:07:38.22,0:07:42.06,Default,,0000,0000,0000,,わ 私 最初は 女の子が欲しいです!!
Dialogue: 0,0:07:42.06,0:07:44.56,Default,,0000,0000,0000,,落ち着いて!
Dialogue: 0,0:07:42.06,0:07:44.56,Default,,0000,0000,0000,,ご 強引なのは 嫌いじゃないけど
Dialogue: 0,0:07:44.56,0:07:48.07,Default,,0000,0000,0000,,でも ここ 外なんだから!
Dialogue: 0,0:07:44.56,0:07:48.07,Default,,0000,0000,0000,,だから 落ち着いて
Dialogue: 0,0:07:48.07,0:07:51.07,Default,,0000,0000,0000,,お前が 一方的に 抱きしめてるから 今
Dialogue: 0,0:07:51.07,0:07:53.91,Default,,0000,0000,0000,,へっ? あっ
Dialogue: 0,0:07:53.91,0:07:55.91,Default,,0000,0000,0000,,うわぁ 離せぇ!!
Dialogue: 0,0:07:55.91,0:07:57.88,Default,,0000,0000,0000,,お前が離せぇ!!
Dialogue: 0,0:07:55.91,0:07:57.88,Default,,0000,0000,0000,,ポン!
Dialogue: 0,0:08:00.58,0:08:03.25,Default,,0000,0000,0000,,えっと なんか ごめん
Dialogue: 0,0:08:03.25,0:08:05.42,Default,,0000,0000,0000,,いや いいけど
Dialogue: 0,0:08:05.42,0:08:08.59,Default,,0000,0000,0000,,やっぱ 昨日の夜も お役目で夜更かし?
Dialogue: 0,0:08:08.59,0:08:11.09,Default,,0000,0000,0000,,まぁ そんなとこ
Dialogue: 0,0:08:08.59,0:08:11.09,Default,,0000,0000,0000,,じゃあ 今夜も?
Dialogue: 0,0:08:11.09,0:08:15.93,Default,,0000,0000,0000,,もういっぺん言っておくけど 夜の山に入ってきちゃダメよ
Dialogue: 0,0:08:15.93,0:08:18.80,Default,,0000,0000,0000,,これは あんたのためを 思って言ってるんだからね
Dialogue: 0,0:08:20.77,0:08:23.54,Default,,0000,0000,0000,,と言われたけど 来てしまった
Dialogue: 0,0:08:28.77,0:08:30.74,Default,,0000,0000,0000,,蒼?
Dialogue: 0,0:08:36.55,0:08:39.32,Default,,0000,0000,0000,,そういや 蒼は この蝶に触って
Dialogue: 0,0:08:42.22,0:08:44.39,Default,,0000,0000,0000,,どうして こんなことに
Dialogue: 0,0:08:44.39,0:08:48.56,Default,,0000,0000,0000,,返してくれ 妻を 娘を
Dialogue: 0,0:08:48.56,0:08:52.73,Default,,0000,0000,0000,,なぜ私だけが生き残った
Dialogue: 0,0:08:52.73,0:08:55.57,Default,,0000,0000,0000,,この苦しみから解放してくれ
Dialogue: 0,0:08:55.57,0:09:01.24,Default,,0000,0000,0000,,今 行くから 私も
Dialogue: 0,0:08:55.57,0:09:01.24,Default,,0000,0000,0000,,お前たちのところに
Dialogue: 0,0:09:01.24,0:09:03.58,Default,,0000,0000,0000,,体が勝手に動く
Dialogue: 0,0:09:03.58,0:09:07.58,Default,,0000,0000,0000,,なんだよ これ
Dialogue: 0,0:09:03.58,0:09:07.58,Default,,0000,0000,0000,,でも これで
Dialogue: 0,0:09:07.58,0:09:10.35,Default,,0000,0000,0000,,ああ 楽になれる
Dialogue: 0,0:09:22.09,0:09:25.36,Default,,0000,0000,0000,,羽依里!! の バカ!
Dialogue: 0,0:09:28.27,0:09:31.04,Default,,0000,0000,0000,,ハァ ハァ ハァ
Dialogue: 0,0:09:33.34,0:09:35.34,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:09:33.34,0:09:35.34,Default,,0000,0000,0000,,はぁ
Dialogue: 0,0:09:35.34,0:09:38.34,Default,,0000,0000,0000,,夜の山に入っちゃダメって 言ったでしょ!
Dialogue: 0,0:09:38.34,0:09:41.18,Default,,0000,0000,0000,,あ 蒼? 俺
Dialogue: 0,0:09:41.18,0:09:45.28,Default,,0000,0000,0000,,七影蝶に触ったせいで 他人の記憶が混ざったのよ
Dialogue: 0,0:09:47.35,0:09:50.52,Default,,0000,0000,0000,,七影蝶って なんなんだ?
Dialogue: 0,0:09:50.52,0:09:55.86,Default,,0000,0000,0000,,蝶の形をした
Dialogue: 0,0:09:50.52,0:09:55.86,Default,,0000,0000,0000,,未練を残した人の記憶の残滓よ
Dialogue: 0,0:09:55.86,0:09:59.87,Default,,0000,0000,0000,,触れれば その人の記憶を 追体験することになるわ
Dialogue: 0,0:09:59.87,0:10:05.20,Default,,0000,0000,0000,,この蝶は 感受性の強い人とか
Dialogue: 0,0:09:59.87,0:10:05.20,Default,,0000,0000,0000,,動物じゃないと見えないのに
Dialogue: 0,0:10:05.20,0:10:10.38,Default,,0000,0000,0000,,蒼 お前のお役目って
Dialogue: 0,0:10:05.20,0:10:10.38,Default,,0000,0000,0000,,いったい何なんだ?
Dialogue: 0,0:10:10.38,0:10:13.71,Default,,0000,0000,0000,,迷っている七影蝶を集めて
Dialogue: 0,0:10:13.71,0:10:16.05,Default,,0000,0000,0000,,還るべき場所に導く
Dialogue: 0,0:10:16.05,0:10:18.38,Default,,0000,0000,0000,,それが 空門のお役目よ
Dialogue: 0,0:10:18.38,0:10:21.55,Default,,0000,0000,0000,,ここまで来たら もう1人で帰れるでしょ?
Dialogue: 0,0:10:21.55,0:10:23.72,Default,,0000,0000,0000,,蒼は まだ帰らないのか?
Dialogue: 0,0:10:23.72,0:10:26.73,Default,,0000,0000,0000,,私は お役目の続き
Dialogue: 0,0:10:26.73,0:10:29.40,Default,,0000,0000,0000,,夜の山の怖さ 身をもって知ったでしょ?
Dialogue: 0,0:10:29.40,0:10:33.57,Default,,0000,0000,0000,,もう近づかないで
Dialogue: 0,0:10:29.40,0:10:33.57,Default,,0000,0000,0000,,ちょっと待ってくれ!
Dialogue: 0,0:10:33.57,0:10:36.57,Default,,0000,0000,0000,,なに?
Dialogue: 0,0:10:33.57,0:10:36.57,Default,,0000,0000,0000,,しち なんたら蝶って
Dialogue: 0,0:10:36.57,0:10:40.24,Default,,0000,0000,0000,,蒼も触ってたよな?
Dialogue: 0,0:10:36.57,0:10:40.24,Default,,0000,0000,0000,,お前は大丈夫なのか?
Dialogue: 0,0:10:40.24,0:10:45.41,Default,,0000,0000,0000,,私は ずっと触れてきてるから
Dialogue: 0,0:10:40.24,0:10:45.41,Default,,0000,0000,0000,,それなりに耐性ができてるのよ
Dialogue: 0,0:10:45.41,0:10:48.75,Default,,0000,0000,0000,,それもお役目?
Dialogue: 0,0:10:48.75,0:10:53.09,Default,,0000,0000,0000,,私には どうしても探さなきゃ いけない記憶があるの
Dialogue: 0,0:10:53.09,0:10:55.79,Default,,0000,0000,0000,,危ないことまでして 探さなきゃいけないものなのか?
Dialogue: 0,0:11:05.77,0:11:09.77,Default,,0000,0000,0000,,ねぇ 明日 ちょっと時間もらえる?
Dialogue: 0,0:11:17.78,0:11:19.78,Default,,0000,0000,0000,,ここよ
Dialogue: 0,0:11:19.78,0:11:21.78,Default,,0000,0000,0000,,蒼よ!
Dialogue: 0,0:11:21.78,0:11:24.58,Default,,0000,0000,0000,,入るわね!
Dialogue: 0,0:11:26.79,0:11:28.79,Default,,0000,0000,0000,,失礼します
Dialogue: 0,0:11:30.79,0:11:33.59,Default,,0000,0000,0000,,来たわよ 藍
Dialogue: 0,0:11:30.79,0:11:33.59,Default,,0000,0000,0000,,藍?
Dialogue: 0,0:11:33.59,0:11:37.26,Default,,0000,0000,0000,,うん 空門藍
Dialogue: 0,0:11:33.59,0:11:37.26,Default,,0000,0000,0000,,私の双子のお姉ちゃんよ
Dialogue: 0,0:11:37.26,0:11:39.23,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:11:42.77,0:11:48.11,Default,,0000,0000,0000,,今日は 藍ちゃんとこだね
Dialogue: 0,0:11:42.77,0:11:48.11,Default,,0000,0000,0000,,恐らく検診じゃろうて
Dialogue: 0,0:11:48.11,0:11:51.44,Default,,0000,0000,0000,,今日は 友達が お見舞いに来てくれたわよ
Dialogue: 0,0:11:51.44,0:11:53.45,Default,,0000,0000,0000,,前に話したの覚えてる?
Dialogue: 0,0:11:53.45,0:11:56.95,Default,,0000,0000,0000,,ほら 亡くなった 加藤のおばあちゃんの親戚
Dialogue: 0,0:11:56.95,0:12:01.62,Default,,0000,0000,0000,,藍はね 昔に ちょっと事故に遭って
Dialogue: 0,0:12:01.62,0:12:04.29,Default,,0000,0000,0000,,それ以来 ずっと 眠り続けているの
Dialogue: 0,0:12:04.29,0:12:07.46,Default,,0000,0000,0000,,えっと
Dialogue: 0,0:12:04.29,0:12:07.46,Default,,0000,0000,0000,,昨日の夜 言ったでしょ?
Dialogue: 0,0:12:07.46,0:12:10.96,Default,,0000,0000,0000,,どうしても探さなきゃいけない 記憶があるって
Dialogue: 0,0:12:10.96,0:12:13.97,Default,,0000,0000,0000,,それ 藍の記憶なの
Dialogue: 0,0:12:13.97,0:12:19.14,Default,,0000,0000,0000,,この島には 長い間
Dialogue: 0,0:12:13.97,0:12:19.14,Default,,0000,0000,0000,,眠り続けていた人を
Dialogue: 0,0:12:19.14,0:12:22.81,Default,,0000,0000,0000,,目覚めさせた 不思議な蝶々の 昔話があるって
Dialogue: 0,0:12:22.81,0:12:25.98,Default,,0000,0000,0000,,加藤のおばあちゃんが 教えてくれたのよ
Dialogue: 0,0:12:25.98,0:12:27.98,Default,,0000,0000,0000,,うちの ばあさんが?
Dialogue: 0,0:12:27.98,0:12:31.15,Default,,0000,0000,0000,,私を元気づけるための 作り話かもしれない
Dialogue: 0,0:12:31.15,0:12:34.72,Default,,0000,0000,0000,,でも 空門家のお役目のことや
Dialogue: 0,0:12:34.72,0:12:39.56,Default,,0000,0000,0000,,七影蝶のことを考えたら 嘘だとも思えなくって
Dialogue: 0,0:12:39.56,0:12:43.73,Default,,0000,0000,0000,,だから 私は お役目をしながら 七影蝶に触れて
Dialogue: 0,0:12:43.73,0:12:47.90,Default,,0000,0000,0000,,藍の記憶を探してる ふわぁ
Dialogue: 0,0:12:47.90,0:12:49.90,Default,,0000,0000,0000,,眠いのか?
Dialogue: 0,0:12:47.90,0:12:49.90,Default,,0000,0000,0000,,ごめん
Dialogue: 0,0:12:49.90,0:12:53.24,Default,,0000,0000,0000,,少しだけ 眠ってもいい?
Dialogue: 0,0:12:53.24,0:12:59.91,Default,,0000,0000,0000,,ああ もちろん
Dialogue: 0,0:12:53.24,0:12:59.91,Default,,0000,0000,0000,,30分くらいしたら 起こして
Dialogue: 0,0:13:19.43,0:13:22.77,Default,,0000,0000,0000,,よっ こんばんは!
Dialogue: 0,0:13:19.43,0:13:22.77,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:22.77,0:13:25.60,Default,,0000,0000,0000,,イナリも よっ!
Dialogue: 0,0:13:22.77,0:13:25.60,Default,,0000,0000,0000,,ポン!
Dialogue: 0,0:13:25.60,0:13:29.28,Default,,0000,0000,0000,,私 山に入らないように 言ったわよね?
Dialogue: 0,0:13:29.28,0:13:31.94,Default,,0000,0000,0000,,言われたけど 入らないとは 俺 言ってない
Dialogue: 0,0:13:31.94,0:13:34.41,Default,,0000,0000,0000,,どうして わからないの?
Dialogue: 0,0:13:31.94,0:13:34.41,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:13:34.41,0:13:37.58,Default,,0000,0000,0000,,七影蝶を探すのは 本当に危険なのよ!
Dialogue: 0,0:13:37.58,0:13:39.59,Default,,0000,0000,0000,,だからだよ
Dialogue: 0,0:13:39.59,0:13:42.76,Default,,0000,0000,0000,,お前が 危ないことを してるのなら せめて
Dialogue: 0,0:13:42.76,0:13:44.92,Default,,0000,0000,0000,,近くにいられたらなって 思ったんだ
Dialogue: 0,0:13:44.92,0:13:47.09,Default,,0000,0000,0000,,あっ えっと
Dialogue: 0,0:13:47.09,0:13:50.10,Default,,0000,0000,0000,,あっ はっはん つまり あれね!
Dialogue: 0,0:13:50.10,0:13:52.77,Default,,0000,0000,0000,,私に惚れちゃった?
Dialogue: 0,0:13:52.77,0:13:56.44,Default,,0000,0000,0000,,そうだな 少なからず 惚れてるんだと思う
Dialogue: 0,0:13:56.44,0:13:59.61,Default,,0000,0000,0000,,え! えっ あの 本気?
Dialogue: 0,0:13:59.61,0:14:03.28,Default,,0000,0000,0000,,迷惑?
Dialogue: 0,0:13:59.61,0:14:03.28,Default,,0000,0000,0000,,す 少なからず
Dialogue: 0,0:14:03.28,0:14:05.95,Default,,0000,0000,0000,,ちょっと ショックなんだけど
Dialogue: 0,0:14:05.95,0:14:10.45,Default,,0000,0000,0000,,だって 私は今 そういうことに かまけてらんないし
Dialogue: 0,0:14:10.45,0:14:14.29,Default,,0000,0000,0000,,藍の七影蝶を 探すことしか考えらんない
Dialogue: 0,0:14:14.29,0:14:17.96,Default,,0000,0000,0000,,うん だったら 1人より 2人のほうがいいんじゃないか?
Dialogue: 0,0:14:17.96,0:14:20.46,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:14:17.96,0:14:22.96,Default,,0000,0000,0000,,島の人間は しきたりとかで 夜の山に入らないけど
Dialogue: 0,0:14:22.96,0:14:25.63,Default,,0000,0000,0000,,俺は 島の人間じゃない
Dialogue: 0,0:14:25.63,0:14:27.90,Default,,0000,0000,0000,,だから 蒼を手伝うことができる
Dialogue: 0,0:14:31.14,0:14:34.41,Default,,0000,0000,0000,,わ わかったわよ
Dialogue: 0,0:14:34.41,0:14:38.74,Default,,0000,0000,0000,,たぶん ここで ダメって言っても 勝手についてきそうだし
Dialogue: 0,0:14:38.74,0:14:43.42,Default,,0000,0000,0000,,そのかわり 私のそばから 離れないって約束して
Dialogue: 0,0:14:43.42,0:14:45.38,Default,,0000,0000,0000,,わかった
Dialogue: 0,0:14:48.59,0:14:51.72,Default,,0000,0000,0000,,絶対に お前のそばから離れない
Dialogue: 0,0:14:51.72,0:14:53.73,Default,,0000,0000,0000,,はう
Dialogue: 0,0:14:56.10,0:14:59.93,Default,,0000,0000,0000,,こうして 俺と蒼と イナリでの
Dialogue: 0,0:14:59.93,0:15:03.94,Default,,0000,0000,0000,,藍の七影蝶探しが始まった
Dialogue: 0,0:16:21.75,0:16:25.92,Default,,0000,0000,0000,,迷い橘 空門の御神木よ
Dialogue: 0,0:16:25.92,0:16:30.26,Default,,0000,0000,0000,,橘の木は 本当なら 夏の前に花をつけるけど
Dialogue: 0,0:16:30.26,0:16:32.59,Default,,0000,0000,0000,,この木は 少し遅れるの
Dialogue: 0,0:16:32.59,0:16:36.40,Default,,0000,0000,0000,,現世と 少し ずれた場所 少し ずれた時間
Dialogue: 0,0:16:36.40,0:16:41.27,Default,,0000,0000,0000,,常世との境目にあるとして 御神木になったらしいわ
Dialogue: 0,0:16:53.58,0:16:56.58,Default,,0000,0000,0000,,この木が 花を 咲かせている間しか
Dialogue: 0,0:16:56.58,0:16:59.59,Default,,0000,0000,0000,,吊り灯籠で七影蝶を導けないの
Dialogue: 0,0:16:59.59,0:17:04.42,Default,,0000,0000,0000,,それが 山の祭事の期間ってことか
Dialogue: 0,0:17:04.42,0:17:07.79,Default,,0000,0000,0000,,うん
Dialogue: 0,0:17:10.76,0:17:15.10,Default,,0000,0000,0000,,それでね のみきなんて 顔を真っ赤にさせて 黙っちゃったの
Dialogue: 0,0:17:15.10,0:17:18.27,Default,,0000,0000,0000,,なぁ いつも眠ってる藍に 話しかけるのって
Dialogue: 0,0:17:18.27,0:17:23.61,Default,,0000,0000,0000,,どういう効果があるんだ?
Dialogue: 0,0:17:18.27,0:17:23.61,Default,,0000,0000,0000,,ん 睡眠学習みたいなもの?
Dialogue: 0,0:17:23.61,0:17:28.11,Default,,0000,0000,0000,,藍が目を覚ましたとき 私の話したことを 覚えていたら
Dialogue: 0,0:17:28.11,0:17:30.45,Default,,0000,0000,0000,,いつも一緒にいたことに なるかなって
Dialogue: 0,0:17:30.45,0:17:35.02,Default,,0000,0000,0000,,あっ そうだ! せっかくだし あんたも 藍に 何か話してあげて
Dialogue: 0,0:17:35.02,0:17:38.69,Default,,0000,0000,0000,,じゃあ せっかくだし 自己紹介から
Dialogue: 0,0:17:38.69,0:17:43.70,Default,,0000,0000,0000,,蒼の こ 恋人の
Dialogue: 0,0:17:38.69,0:17:43.70,Default,,0000,0000,0000,,鷹原羽依里といいます!
Dialogue: 0,0:17:43.70,0:17:46.70,Default,,0000,0000,0000,,な なんで 恋人なのよ!
Dialogue: 0,0:17:43.70,0:17:46.70,Default,,0000,0000,0000,,まだでしょ!
Dialogue: 0,0:17:46.70,0:17:50.54,Default,,0000,0000,0000,,睡眠学習で 外堀を埋めていこうと思って
Dialogue: 0,0:17:50.54,0:17:54.54,Default,,0000,0000,0000,,まぁ あんたに そう言ってもらえるの
Dialogue: 0,0:17:54.54,0:17:56.71,Default,,0000,0000,0000,,その うれしいわよ
Dialogue: 0,0:17:56.71,0:18:00.71,Default,,0000,0000,0000,,私も あんたのことは ちゃんと好きになってるし
Dialogue: 0,0:18:00.71,0:18:04.22,Default,,0000,0000,0000,,蒼
Dialogue: 0,0:18:00.71,0:18:04.22,Default,,0000,0000,0000,,でも ごめん
Dialogue: 0,0:18:04.22,0:18:10.22,Default,,0000,0000,0000,,藍が眠り続けてるのに
Dialogue: 0,0:18:04.22,0:18:10.22,Default,,0000,0000,0000,,私だけ幸せになれない
Dialogue: 0,0:18:10.22,0:18:12.56,Default,,0000,0000,0000,,ずるいことを言うようだけど
Dialogue: 0,0:18:12.56,0:18:16.06,Default,,0000,0000,0000,,藍が目を覚ますまで 待ってほしい
Dialogue: 0,0:18:16.06,0:18:19.40,Default,,0000,0000,0000,,まいったな
Dialogue: 0,0:18:16.06,0:18:19.40,Default,,0000,0000,0000,,ごめん
Dialogue: 0,0:18:19.40,0:18:23.07,Default,,0000,0000,0000,,藍の記憶探し もう手伝いじゃなくなったよ
Dialogue: 0,0:18:23.07,0:18:26.07,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:18:23.07,0:18:28.07,Default,,0000,0000,0000,,藍が目を覚ましたら 蒼と恋人になれるんだろ?
Dialogue: 0,0:18:28.07,0:18:31.58,Default,,0000,0000,0000,,なら それは もう俺の目標だ
Dialogue: 0,0:18:31.58,0:18:34.71,Default,,0000,0000,0000,,そ そうなっちゃうのかな?
Dialogue: 0,0:18:34.71,0:18:38.18,Default,,0000,0000,0000,,ああ 俄然やる気になった
Dialogue: 0,0:18:40.72,0:18:44.22,Default,,0000,0000,0000,,6月に エース ミムラが 故障で離脱してから
Dialogue: 0,0:18:44.22,0:18:48.56,Default,,0000,0000,0000,,あの 鏡子さん ちょっと 聞きたいことがあるんですけど
Dialogue: 0,0:18:48.56,0:18:52.23,Default,,0000,0000,0000,,何かしら?
Dialogue: 0,0:18:48.56,0:18:52.23,Default,,0000,0000,0000,,この島に 眠り続けていた人を
Dialogue: 0,0:18:52.23,0:18:56.57,Default,,0000,0000,0000,,目覚めさせる 不思議な蝶の昔話が あったって聞いたんですけど
Dialogue: 0,0:18:56.57,0:18:58.74,Default,,0000,0000,0000,,七影蝶のこと?
Dialogue: 0,0:18:58.74,0:19:00.74,Default,,0000,0000,0000,,嘘! 本が残ってるの?
Dialogue: 0,0:19:00.74,0:19:05.24,Default,,0000,0000,0000,,らしい! 鏡子さんに頼んで 蔵から出してもらってる
Dialogue: 0,0:19:05.24,0:19:09.25,Default,,0000,0000,0000,,そっか 加藤の おばあちゃんの蔵なら納得ね
Dialogue: 0,0:19:09.25,0:19:11.75,Default,,0000,0000,0000,,明日 うち 来る?
Dialogue: 0,0:19:09.25,0:19:11.75,Default,,0000,0000,0000,,うん 行く!
Dialogue: 0,0:19:11.75,0:19:15.42,Default,,0000,0000,0000,,よし なんか今夜は やる気が出てきたわ!
Dialogue: 0,0:19:15.42,0:19:18.42,Default,,0000,0000,0000,,おぅ 頑張ろう!
Dialogue: 0,0:19:15.42,0:19:18.42,Default,,0000,0000,0000,,ポン!
Dialogue: 0,0:19:18.42,0:19:21.26,Default,,0000,0000,0000,,ふわぁ あふぅ
Dialogue: 0,0:19:21.26,0:19:24.43,Default,,0000,0000,0000,,ねむ
Dialogue: 0,0:19:21.26,0:19:24.43,Default,,0000,0000,0000,,そろそろ限界みたいだな
Dialogue: 0,0:19:24.43,0:19:28.43,Default,,0000,0000,0000,,まだまだ イナリ 次
Dialogue: 0,0:19:28.43,0:19:30.60,Default,,0000,0000,0000,,ポン
Dialogue: 0,0:19:30.60,0:19:32.87,Default,,0000,0000,0000,,手 つないで帰ろうか?
Dialogue: 0,0:19:32.87,0:19:36.38,Default,,0000,0000,0000,,んっ それも いいかもね
Dialogue: 0,0:19:36.38,0:19:38.54,Default,,0000,0000,0000,,えっ マジで?
Dialogue: 0,0:19:38.54,0:19:41.38,Default,,0000,0000,0000,,あれ? 今 私 なんか言った?
Dialogue: 0,0:19:41.38,0:19:45.38,Default,,0000,0000,0000,,たぶん 本音が漏れた
Dialogue: 0,0:19:41.38,0:19:45.38,Default,,0000,0000,0000,,そっ そそそ そんな ここ外よ!
Dialogue: 0,0:19:45.38,0:19:47.39,Default,,0000,0000,0000,,いくらなんでも
Dialogue: 0,0:19:47.39,0:19:50.72,Default,,0000,0000,0000,,最初は 枕があるとこじゃないと
Dialogue: 0,0:19:50.72,0:19:53.39,Default,,0000,0000,0000,,あっ ごめん 漏れてなかったみたいだ
Dialogue: 0,0:19:53.39,0:19:57.06,Default,,0000,0000,0000,,でも 限界なのはわかったから 帰ろう
Dialogue: 0,0:19:59.73,0:20:01.70,Default,,0000,0000,0000,,う うん
Dialogue: 0,0:20:14.75,0:20:18.08,Default,,0000,0000,0000,,魔王怨殺光龍波!
Dialogue: 0,0:20:18.08,0:20:21.92,Default,,0000,0000,0000,,えっ? まおう えんさつ?
Dialogue: 0,0:20:21.92,0:20:23.92,Default,,0000,0000,0000,,何をしてるの?
Dialogue: 0,0:20:23.92,0:20:26.76,Default,,0000,0000,0000,,うみちゃん?
Dialogue: 0,0:20:23.92,0:20:26.76,Default,,0000,0000,0000,,何度も起こしたのに
Dialogue: 0,0:20:26.76,0:20:28.93,Default,,0000,0000,0000,,もう 朝ご飯ないから
Dialogue: 0,0:20:28.93,0:20:32.43,Default,,0000,0000,0000,,ごめん
Dialogue: 0,0:20:28.93,0:20:32.43,Default,,0000,0000,0000,,なんで起きれなかったんだろう?
Dialogue: 0,0:20:32.43,0:20:35.40,Default,,0000,0000,0000,,夜遊びばっかりしてるからだよ フン!
Dialogue: 0,0:20:38.44,0:20:40.81,Default,,0000,0000,0000,,七影蝶?
Dialogue: 0,0:20:43.94,0:20:46.95,Default,,0000,0000,0000,,羽依里くん
Dialogue: 0,0:20:43.94,0:20:46.95,Default,,0000,0000,0000,,はい
Dialogue: 0,0:20:46.95,0:20:51.12,Default,,0000,0000,0000,,お客さんよ
Dialogue: 0,0:20:46.95,0:20:51.12,Default,,0000,0000,0000,,あっ あの
Dialogue: 0,0:20:51.12,0:20:54.62,Default,,0000,0000,0000,,おじゃましてます
Dialogue: 0,0:20:54.62,0:20:57.29,Default,,0000,0000,0000,,なんで緊張してるの?
Dialogue: 0,0:20:57.29,0:21:00.63,Default,,0000,0000,0000,,男の子の部屋に入るなんて 初めてだから
Dialogue: 0,0:21:00.63,0:21:04.13,Default,,0000,0000,0000,,それに いきなり 布団 敷いてあったし
Dialogue: 0,0:21:04.13,0:21:07.13,Default,,0000,0000,0000,,待って 鏡子さんや うみちゃんがいるのに
Dialogue: 0,0:21:07.13,0:21:11.14,Default,,0000,0000,0000,,俺が何をすると?
Dialogue: 0,0:21:07.13,0:21:11.14,Default,,0000,0000,0000,,あっ そ そうよね!
Dialogue: 0,0:21:11.14,0:21:13.47,Default,,0000,0000,0000,,アハハハハ
Dialogue: 0,0:21:13.47,0:21:16.98,Default,,0000,0000,0000,,それより これ 鏡子さんが見つけてくれた本
Dialogue: 0,0:21:16.98,0:21:21.45,Default,,0000,0000,0000,,古すぎて 何を書いてるのか 全然 読めなかった
Dialogue: 0,0:21:26.32,0:21:28.82,Default,,0000,0000,0000,,天保時代の文献ね
Dialogue: 0,0:21:28.82,0:21:31.49,Default,,0000,0000,0000,,わかるのか?
Dialogue: 0,0:21:28.82,0:21:31.49,Default,,0000,0000,0000,,七影蝶に触れると
Dialogue: 0,0:21:31.49,0:21:34.39,Default,,0000,0000,0000,,その人の記憶を 追体験しちゃうでしょ
Dialogue: 0,0:21:34.39,0:21:37.40,Default,,0000,0000,0000,,だから いろんな知識を 得ることもできるのよ
Dialogue: 0,0:21:37.40,0:21:40.23,Default,,0000,0000,0000,,それ すごくないか?
Dialogue: 0,0:21:37.40,0:21:40.23,Default,,0000,0000,0000,,前にも言ったでしょ?
Dialogue: 0,0:21:40.23,0:21:42.33,Default,,0000,0000,0000,,私 結構 物知りだって
Dialogue: 0,0:21:47.24,0:21:52.08,Default,,0000,0000,0000,,嘘 これ 眠っている体に 七影蝶を戻す方法が書かれてる!
Dialogue: 0,0:21:52.08,0:21:54.91,Default,,0000,0000,0000,,マジで?
Dialogue: 0,0:21:52.08,0:21:54.91,Default,,0000,0000,0000,,うん ずっと私が
Dialogue: 0,0:21:54.91,0:21:58.58,Default,,0000,0000,0000,,探していた知識! やった!
Dialogue: 0,0:21:58.58,0:22:02.25,Default,,0000,0000,0000,,あっ 蒼
Dialogue: 0,0:21:58.58,0:22:02.25,Default,,0000,0000,0000,,ちょ いろいろ当たってるから
Dialogue: 0,0:22:02.25,0:22:07.76,Default,,0000,0000,0000,,あっ ご ごめん!
Dialogue: 0,0:22:02.25,0:22:07.76,Default,,0000,0000,0000,,ちょっと 興奮しすぎたみたい
Dialogue: 0,0:22:07.76,0:22:10.43,Default,,0000,0000,0000,,うん まぁ うれしかったから いいけど
Dialogue: 0,0:22:10.43,0:22:14.77,Default,,0000,0000,0000,,で その方法って?
Dialogue: 0,0:22:10.43,0:22:14.77,Default,,0000,0000,0000,,あっ えっと
Dialogue: 0,0:22:14.77,0:22:19.60,Default,,0000,0000,0000,,藍の七影蝶を見つけて 呂の字にて
Dialogue: 0,0:22:19.60,0:22:22.44,Default,,0000,0000,0000,,ろのじ?
Dialogue: 0,0:22:19.60,0:22:22.44,Default,,0000,0000,0000,,と とにかく
Dialogue: 0,0:22:22.44,0:22:26.61,Default,,0000,0000,0000,,藍の七影蝶さえ見つけられたら 全部 解決するわ
Dialogue: 0,0:22:26.61,0:22:28.78,Default,,0000,0000,0000,,そうだな
Dialogue: 0,0:22:28.78,0:22:32.75,Default,,0000,0000,0000,,羽依里 ありがとう
