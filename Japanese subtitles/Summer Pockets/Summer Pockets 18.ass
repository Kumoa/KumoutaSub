Dialogue: 0,0:00:39.51,0:00:42.18,Default,,0000,0000,0000,,こら さぼってないで起きなさい
Dialogue: 0,0:00:42.18,0:00:44.98,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:47.01,0:00:49.18,Default,,0000,0000,0000,,あぁ 瞳じゃない
Dialogue: 0,0:00:49.18,0:00:52.02,Default,,0000,0000,0000,,鏡子 また居眠り
Dialogue: 0,0:00:52.02,0:00:55.02,Default,,0000,0000,0000,,あれ 私 寝てたかな?
Dialogue: 0,0:00:55.02,0:00:57.02,Default,,0000,0000,0000,,ガッツリ寝てたわよ
Dialogue: 0,0:00:57.02,0:00:59.19,Default,,0000,0000,0000,,んっ あ
Dialogue: 0,0:00:59.19,0:01:03.36,Default,,0000,0000,0000,,寝てるのか起きてるのか わからなくなってきて
Dialogue: 0,0:01:03.36,0:01:07.70,Default,,0000,0000,0000,,自分が蝶なのか人なのか
Dialogue: 0,0:01:03.36,0:01:07.70,Default,,0000,0000,0000,,なにそれ
Dialogue: 0,0:01:07.70,0:01:11.70,Default,,0000,0000,0000,,知らない? そういう故事
Dialogue: 0,0:01:07.70,0:01:11.70,Default,,0000,0000,0000,,知らないし
Dialogue: 0,0:01:11.70,0:01:14.54,Default,,0000,0000,0000,,文学少女のうんちくなんて 聞きたくない
Dialogue: 0,0:01:14.54,0:01:19.55,Default,,0000,0000,0000,,もう 瞳は口が悪いなぁ フフッ
Dialogue: 0,0:01:19.55,0:01:21.55,Default,,0000,0000,0000,,で どうしたの? 急に
Dialogue: 0,0:01:21.55,0:01:24.55,Default,,0000,0000,0000,,うん 鏡子にお願いがあるの
Dialogue: 0,0:01:24.55,0:01:26.89,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:01:24.55,0:01:28.89,Default,,0000,0000,0000,,いつか あなたの前に 女の子が現れるわ
Dialogue: 0,0:01:28.89,0:01:32.83,Default,,0000,0000,0000,,いつか? 女の子?
Dialogue: 0,0:01:28.89,0:01:32.83,Default,,0000,0000,0000,,漠然としてるね
Dialogue: 0,0:01:32.83,0:01:36.50,Default,,0000,0000,0000,,でも 会えばわかるから この子のことだって
Dialogue: 0,0:01:36.50,0:01:38.67,Default,,0000,0000,0000,,うん わかった
Dialogue: 0,0:01:38.67,0:01:42.47,Default,,0000,0000,0000,,女の子が現れる
Dialogue: 0,0:01:38.67,0:01:42.47,Default,,0000,0000,0000,,会えばわかるんだね
Dialogue: 0,0:01:53.18,0:01:55.35,Default,,0000,0000,0000,,うみゅ
Dialogue: 0,0:01:55.35,0:01:57.35,Default,,0000,0000,0000,,いらっしゃい
Dialogue: 0,0:01:57.35,0:02:00.69,Default,,0000,0000,0000,,えっと お名前は?
Dialogue: 0,0:02:00.69,0:02:02.69,Default,,0000,0000,0000,,うみ
Dialogue: 0,0:02:02.69,0:02:06.69,Default,,0000,0000,0000,,うみちゃんね さっ 上がって
Dialogue: 0,0:02:06.69,0:02:08.86,Default,,0000,0000,0000,,それと もう一つ
Dialogue: 0,0:02:08.86,0:02:11.70,Default,,0000,0000,0000,,あなたは きっと 男の子にも 会うことになるわ
Dialogue: 0,0:02:11.70,0:02:15.54,Default,,0000,0000,0000,,鷹原羽依里です はじめまして
Dialogue: 0,0:02:15.54,0:02:19.87,Default,,0000,0000,0000,,こちらこそ はじめまして
Dialogue: 0,0:02:15.54,0:02:19.87,Default,,0000,0000,0000,,岬鏡子です
Dialogue: 0,0:02:19.87,0:02:21.88,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:02:21.88,0:02:25.98,Default,,0000,0000,0000,,鏡子には 二人のことを 見守ってあげてほしいの
Dialogue: 0,0:04:12.19,0:04:16.52,Default,,0000,0000,0000,,「羽」に未来の 「未」で 羽未ちゃんですって
Dialogue: 0,0:04:16.52,0:04:19.19,Default,,0000,0000,0000,,へぇ なんか かっこいいな
Dialogue: 0,0:04:19.19,0:04:22.70,Default,,0000,0000,0000,,よろしくな うみちゃん
Dialogue: 0,0:04:19.19,0:04:22.70,Default,,0000,0000,0000,,ちゃん ゆな
Dialogue: 0,0:04:22.70,0:04:25.87,Default,,0000,0000,0000,,えっ 俺はだめなの?
Dialogue: 0,0:04:22.70,0:04:25.87,Default,,0000,0000,0000,,めっ
Dialogue: 0,0:04:25.87,0:04:29.17,Default,,0000,0000,0000,,フフッ あら? そういえば
Dialogue: 0,0:04:31.54,0:04:35.14,Default,,0000,0000,0000,,「羽」の字は 羽依里くんと おそろいね
Dialogue: 0,0:04:35.14,0:04:37.31,Default,,0000,0000,0000,,えっと じゃあ うみ?
Dialogue: 0,0:04:37.31,0:04:39.48,Default,,0000,0000,0000,,うん
Dialogue: 0,0:04:39.48,0:04:43.38,Default,,0000,0000,0000,,フッ ひと夏の間 よろしくな
Dialogue: 0,0:04:45.32,0:04:47.42,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:04:45.32,0:04:47.42,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:04:54.66,0:04:58.00,Default,,0000,0000,0000,,物がこう 多いですね
Dialogue: 0,0:04:58.00,0:05:00.83,Default,,0000,0000,0000,,おばあちゃんの 収集癖がすごくてねぇ
Dialogue: 0,0:05:00.83,0:05:05.00,Default,,0000,0000,0000,,珍しいものを見たら すぐ手元に 置いておきたくなるみたいで
Dialogue: 0,0:05:05.00,0:05:08.34,Default,,0000,0000,0000,,その整理のために 俺が呼ばれたわけですね
Dialogue: 0,0:05:08.34,0:05:10.34,Default,,0000,0000,0000,,ホント 来てくれて助かるわ
Dialogue: 0,0:05:10.34,0:05:12.51,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:05:10.34,0:05:12.51,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:12.51,0:05:14.85,Default,,0000,0000,0000,,フフッ そろそろ夕飯の時間ね
Dialogue: 0,0:05:14.85,0:05:16.85,Default,,0000,0000,0000,,でも ごめんね
Dialogue: 0,0:05:16.85,0:05:21.69,Default,,0000,0000,0000,,私の料理は個性的で よそ様に出せるような 代物じゃないの
Dialogue: 0,0:05:21.69,0:05:24.19,Default,,0000,0000,0000,,坂を下ったところに 食堂があるわ
Dialogue: 0,0:05:24.19,0:05:27.19,Default,,0000,0000,0000,,うみちゃんも一緒に 連れていってもらえるかな
Dialogue: 0,0:05:31.96,0:05:33.97,Default,,0000,0000,0000,,まいどあり
Dialogue: 0,0:05:35.97,0:05:38.47,Default,,0000,0000,0000,,うぷっ
Dialogue: 0,0:05:35.97,0:05:38.47,Default,,0000,0000,0000,,それじゃ 帰るか
Dialogue: 0,0:05:46.65,0:05:49.32,Default,,0000,0000,0000,,しっかり つかまってろよ
Dialogue: 0,0:05:49.32,0:05:51.32,Default,,0000,0000,0000,,しゅっぱつ!
Dialogue: 0,0:06:00.49,0:06:02.66,Default,,0000,0000,0000,,あれ?
Dialogue: 0,0:06:02.66,0:06:09.34,Default,,0000,0000,0000,,ハァ ふっ
Dialogue: 0,0:06:02.66,0:06:09.34,Default,,0000,0000,0000,,まさかガス欠とはなぁ ハァ
Dialogue: 0,0:06:09.34,0:06:12.00,Default,,0000,0000,0000,,おっ
Dialogue: 0,0:06:12.00,0:06:15.17,Default,,0000,0000,0000,,おぉ! さすが田舎だなぁ
Dialogue: 0,0:06:15.17,0:06:17.51,Default,,0000,0000,0000,,ほし?
Dialogue: 0,0:06:17.51,0:06:20.35,Default,,0000,0000,0000,,あぁ 星だ いっぱい見えるな
Dialogue: 0,0:06:20.35,0:06:22.35,Default,,0000,0000,0000,,みえる
Dialogue: 0,0:06:22.35,0:06:25.65,Default,,0000,0000,0000,,んっ んっ?
Dialogue: 0,0:06:28.02,0:06:30.02,Default,,0000,0000,0000,,誰?
Dialogue: 0,0:06:30.02,0:06:35.29,Default,,0000,0000,0000,,えっと 俺は 鷹原羽依里
Dialogue: 0,0:06:30.02,0:06:35.29,Default,,0000,0000,0000,,こっちは
Dialogue: 0,0:06:30.02,0:06:35.29,Default,,0000,0000,0000,,うみ
Dialogue: 0,0:06:35.29,0:06:37.80,Default,,0000,0000,0000,,うみ
Dialogue: 0,0:06:35.29,0:06:37.80,Default,,0000,0000,0000,,うん
Dialogue: 0,0:06:37.80,0:06:39.80,Default,,0000,0000,0000,,君は?
Dialogue: 0,0:06:39.80,0:06:41.80,Default,,0000,0000,0000,,しろは
Dialogue: 0,0:06:41.80,0:06:44.80,Default,,0000,0000,0000,,しろは 名前? 名字?
Dialogue: 0,0:06:44.80,0:06:48.47,Default,,0000,0000,0000,,なまえ
Dialogue: 0,0:06:48.47,0:06:50.48,Default,,0000,0000,0000,,どうして わかったの?
Dialogue: 0,0:06:50.48,0:06:52.48,Default,,0000,0000,0000,,わかったのか?
Dialogue: 0,0:06:56.82,0:07:00.82,Default,,0000,0000,0000,,しろは は こんなところで何してたんだ?
Dialogue: 0,0:07:00.82,0:07:02.99,Default,,0000,0000,0000,,泳いでた
Dialogue: 0,0:07:00.82,0:07:02.99,Default,,0000,0000,0000,,それは
Dialogue: 0,0:07:02.99,0:07:06.66,Default,,0000,0000,0000,,見れば わかったけど
Dialogue: 0,0:07:02.99,0:07:06.66,Default,,0000,0000,0000,,なんで こんな時間に?
Dialogue: 0,0:07:06.66,0:07:09.33,Default,,0000,0000,0000,,明かりも少ないし 危ないと思うんだ
Dialogue: 0,0:07:09.33,0:07:12.33,Default,,0000,0000,0000,,誰もいないプールで 足でもつったら 大変だしな
Dialogue: 0,0:07:12.33,0:07:14.50,Default,,0000,0000,0000,,せめて 人がいる時間に
Dialogue: 0,0:07:12.33,0:07:14.50,Default,,0000,0000,0000,,こい
Dialogue: 0,0:07:14.50,0:07:16.50,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:07:14.50,0:07:16.50,Default,,0000,0000,0000,,どすこい!
Dialogue: 0,0:07:16.50,0:07:18.50,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:07:23.68,0:07:25.68,Default,,0000,0000,0000,,変な子だったな
Dialogue: 0,0:07:25.68,0:07:28.35,Default,,0000,0000,0000,,きれいだった
Dialogue: 0,0:07:28.35,0:07:31.02,Default,,0000,0000,0000,,そうだな
Dialogue: 0,0:07:31.02,0:07:35.29,Default,,0000,0000,0000,,祖母の遺品整理の 手伝いに訪れた 鳥白島
Dialogue: 0,0:07:35.29,0:07:39.79,Default,,0000,0000,0000,,俺の17歳の夏休みは こうして始まった
Dialogue: 0,0:07:43.80,0:07:45.80,Default,,0000,0000,0000,,おなかすいた
Dialogue: 0,0:07:45.80,0:07:48.80,Default,,0000,0000,0000,,何か作ろうか リクエストあるか?
Dialogue: 0,0:07:48.80,0:07:51.30,Default,,0000,0000,0000,,うん
Dialogue: 0,0:07:51.30,0:07:53.31,Default,,0000,0000,0000,,ちゃーはん
Dialogue: 0,0:07:53.31,0:07:56.81,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:07:56.81,0:07:58.91,Default,,0000,0000,0000,,どうだ? うまいか?
Dialogue: 0,0:08:01.31,0:08:03.32,Default,,0000,0000,0000,,ななてん
Dialogue: 0,0:08:01.31,0:08:03.32,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:08:03.32,0:08:06.32,Default,,0000,0000,0000,,何点満点中の?
Dialogue: 0,0:08:03.32,0:08:06.32,Default,,0000,0000,0000,,ひゃく
Dialogue: 0,0:08:06.32,0:08:08.49,Default,,0000,0000,0000,,傷つくくらい低いな
Dialogue: 0,0:08:08.49,0:08:10.49,Default,,0000,0000,0000,,もう いらない
Dialogue: 0,0:08:13.33,0:08:15.33,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:08:19.00,0:08:21.67,Default,,0000,0000,0000,,ごめんね 整理がついてなくて
Dialogue: 0,0:08:21.67,0:08:24.00,Default,,0000,0000,0000,,俺の出番は まだってことですね
Dialogue: 0,0:08:24.00,0:08:27.67,Default,,0000,0000,0000,,そうだ もしよければ うみちゃんと遊んであげて
Dialogue: 0,0:08:27.67,0:08:29.68,Default,,0000,0000,0000,,はあ
Dialogue: 0,0:08:29.68,0:08:31.68,Default,,0000,0000,0000,,やることがなくなった 俺は
Dialogue: 0,0:08:31.68,0:08:34.78,Default,,0000,0000,0000,,うみと一緒に島を回って
Dialogue: 0,0:08:34.78,0:08:39.29,Default,,0000,0000,0000,,たった数日で たくさんの 出会いをすることになった
Dialogue: 0,0:08:39.29,0:08:43.79,Default,,0000,0000,0000,,みんな ちょっと変わっているが 気のいいやつらばかりで
Dialogue: 0,0:08:43.79,0:08:48.63,Default,,0000,0000,0000,,新しい場所 新しい友達 新しい夏
Dialogue: 0,0:08:48.63,0:08:53.47,Default,,0000,0000,0000,,ここでなら 新しい自分に なれるかもしれない
Dialogue: 0,0:09:22.66,0:09:24.83,Default,,0000,0000,0000,,うみ リベンジチャーハンだ
Dialogue: 0,0:09:24.83,0:09:26.93,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:09:32.10,0:09:34.11,Default,,0000,0000,0000,,はちてん
Dialogue: 0,0:09:36.11,0:09:38.11,Default,,0000,0000,0000,,かへっ
Dialogue: 0,0:09:40.11,0:09:42.45,Default,,0000,0000,0000,,チャーハンの作り方ねぇ
Dialogue: 0,0:09:42.45,0:09:45.45,Default,,0000,0000,0000,,そうだな
Dialogue: 0,0:09:42.45,0:09:45.45,Default,,0000,0000,0000,,私の記憶の中で言うなら
Dialogue: 0,0:09:45.45,0:09:48.12,Default,,0000,0000,0000,,しろはのチャーハンが いちばんおいしかった
Dialogue: 0,0:09:48.12,0:09:50.62,Default,,0000,0000,0000,,しろはのチャーハン?
Dialogue: 0,0:09:50.62,0:09:53.79,Default,,0000,0000,0000,,しろはの家は 昔 食堂をやってたんだ
Dialogue: 0,0:09:53.79,0:09:58.13,Default,,0000,0000,0000,,あぁ しろはのチャーハンは その店の味を受け継いでいる
Dialogue: 0,0:09:58.13,0:10:00.43,Default,,0000,0000,0000,,のどかだな
Dialogue: 0,0:09:58.13,0:10:00.43,Default,,0000,0000,0000,,わっ!?
Dialogue: 0,0:10:02.64,0:10:06.31,Default,,0000,0000,0000,,こんにちは
Dialogue: 0,0:10:02.64,0:10:06.31,Default,,0000,0000,0000,,うん
Dialogue: 0,0:10:06.31,0:10:08.81,Default,,0000,0000,0000,,しろは 釣りなんてするんだな
Dialogue: 0,0:10:08.81,0:10:11.31,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:10:11.31,0:10:14.48,Default,,0000,0000,0000,,今日は 潮の具合が よくないだけだし
Dialogue: 0,0:10:14.48,0:10:16.98,Default,,0000,0000,0000,,釣った魚は どうするんだ?
Dialogue: 0,0:10:16.98,0:10:20.65,Default,,0000,0000,0000,,食べる それが礼儀だし
Dialogue: 0,0:10:20.65,0:10:23.32,Default,,0000,0000,0000,,ひいてる
Dialogue: 0,0:10:20.65,0:10:23.32,Default,,0000,0000,0000,,あっ ヒット! あっ
Dialogue: 0,0:10:23.32,0:10:25.32,Default,,0000,0000,0000,,あっ あっ
Dialogue: 0,0:10:27.33,0:10:30.50,Default,,0000,0000,0000,,はっ!
Dialogue: 0,0:10:30.50,0:10:32.50,Default,,0000,0000,0000,,たべるの?
Dialogue: 0,0:10:32.50,0:10:35.50,Default,,0000,0000,0000,,れ 礼儀だし
Dialogue: 0,0:10:32.50,0:10:35.50,Default,,0000,0000,0000,,無理はよくない
Dialogue: 0,0:10:35.50,0:10:37.67,Default,,0000,0000,0000,,ア アメフラシは珍味だし
Dialogue: 0,0:10:37.67,0:10:41.84,Default,,0000,0000,0000,,1時間くらい煮込めば アワビみたいになる といいな
Dialogue: 0,0:10:41.84,0:10:45.95,Default,,0000,0000,0000,,願望かよ 釣りざお貸してくれる?
Dialogue: 0,0:10:48.01,0:10:50.52,Default,,0000,0000,0000,,鳥白の海を なめないほうがいいと思う
Dialogue: 0,0:10:50.52,0:10:54.02,Default,,0000,0000,0000,,素人が簡単に釣れるような 潮じゃないし
Dialogue: 0,0:10:54.02,0:10:56.02,Default,,0000,0000,0000,,ヒット
Dialogue: 0,0:10:54.02,0:10:56.02,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:10:58.02,0:11:01.23,Default,,0000,0000,0000,,プロ?
Dialogue: 0,0:10:58.02,0:11:01.23,Default,,0000,0000,0000,,いや ビギナーです
Dialogue: 0,0:10:58.02,0:11:01.23,Default,,0000,0000,0000,,クッ
Dialogue: 0,0:11:03.20,0:11:07.20,Default,,0000,0000,0000,,やってみたいのか?
Dialogue: 0,0:11:03.20,0:11:07.20,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:07.20,0:11:09.20,Default,,0000,0000,0000,,うん
Dialogue: 0,0:11:12.54,0:11:15.37,Default,,0000,0000,0000,,ヒット
Dialogue: 0,0:11:12.54,0:11:15.37,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:11:12.54,0:11:15.37,Default,,0000,0000,0000,,おっ!
Dialogue: 0,0:11:15.37,0:11:17.38,Default,,0000,0000,0000,,あぁ!
Dialogue: 0,0:11:19.55,0:11:21.71,Default,,0000,0000,0000,,お!
Dialogue: 0,0:11:21.71,0:11:24.88,Default,,0000,0000,0000,,神
Dialogue: 0,0:11:21.71,0:11:24.88,Default,,0000,0000,0000,,うみです
Dialogue: 0,0:11:24.88,0:11:28.19,Default,,0000,0000,0000,,できた
Dialogue: 0,0:11:24.88,0:11:28.19,Default,,0000,0000,0000,,おぉ!
Dialogue: 0,0:11:31.06,0:11:34.83,Default,,0000,0000,0000,,おぉ!
Dialogue: 0,0:11:31.06,0:11:34.83,Default,,0000,0000,0000,,刺身 すごいコリコリしてるな!
Dialogue: 0,0:11:34.83,0:11:37.16,Default,,0000,0000,0000,,釣りたてだもの
Dialogue: 0,0:11:34.83,0:11:37.16,Default,,0000,0000,0000,,はむっ
Dialogue: 0,0:11:37.16,0:11:40.83,Default,,0000,0000,0000,,うみ うまいか?
Dialogue: 0,0:11:40.83,0:11:42.84,Default,,0000,0000,0000,,きゅうじゅうごてん!
Dialogue: 0,0:11:42.84,0:11:45.84,Default,,0000,0000,0000,,口に合ったのならよかった
Dialogue: 0,0:11:45.84,0:11:47.84,Default,,0000,0000,0000,,そうだ
Dialogue: 0,0:11:45.84,0:11:47.84,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:11:47.84,0:11:50.18,Default,,0000,0000,0000,,チャーハンの作り方 教えてくれないか?
Dialogue: 0,0:11:50.18,0:11:52.34,Default,,0000,0000,0000,,えっ いきなりなに?
Dialogue: 0,0:11:52.34,0:11:55.45,Default,,0000,0000,0000,,うみに うまいと言わせる チャーハンが作りたくてさ
Dialogue: 0,0:11:57.52,0:12:00.52,Default,,0000,0000,0000,,チャーハンに大切なのは熱量
Dialogue: 0,0:12:00.52,0:12:03.19,Default,,0000,0000,0000,,まず 中華鍋を用意して
Dialogue: 0,0:12:00.52,0:12:03.19,Default,,0000,0000,0000,,待て
Dialogue: 0,0:12:03.19,0:12:05.69,Default,,0000,0000,0000,,うちには 普通のフライパンしかないんだけど
Dialogue: 0,0:12:05.69,0:12:08.53,Default,,0000,0000,0000,,じゃあ無理
Dialogue: 0,0:12:05.69,0:12:08.53,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:12:08.53,0:12:11.03,Default,,0000,0000,0000,,チャーハンなめないで
Dialogue: 0,0:12:08.53,0:12:11.03,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:12:11.03,0:12:13.03,Default,,0000,0000,0000,,かぞくでごはん
Dialogue: 0,0:12:11.03,0:12:13.03,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:12:13.03,0:12:15.03,Default,,0000,0000,0000,,えっ? 家族?
Dialogue: 0,0:12:15.03,0:12:18.24,Default,,0000,0000,0000,,うん いっかだんらんみたい
Dialogue: 0,0:12:20.87,0:12:23.71,Default,,0000,0000,0000,,一家団らんとか よくわからない
Dialogue: 0,0:12:23.71,0:12:25.71,Default,,0000,0000,0000,,うちは両親がいないから
Dialogue: 0,0:12:25.71,0:12:28.71,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:12:25.71,0:12:28.71,Default,,0000,0000,0000,,そろそろ帰る
Dialogue: 0,0:12:28.71,0:12:32.52,Default,,0000,0000,0000,,あっ あぁ そうか? そうするか?
Dialogue: 0,0:12:36.66,0:12:39.99,Default,,0000,0000,0000,,じゃあ しろは 魚 ごちそうさまな
Dialogue: 0,0:12:39.99,0:12:42.70,Default,,0000,0000,0000,,うん さよなら
Dialogue: 0,0:12:48.17,0:12:52.17,Default,,0000,0000,0000,,なあ 本当は しろはと もうちょっと 遊びたかったんじゃないのか?
Dialogue: 0,0:12:52.17,0:12:55.01,Default,,0000,0000,0000,,へき
Dialogue: 0,0:12:52.17,0:12:55.01,Default,,0000,0000,0000,,お前 子どもなんだから
Dialogue: 0,0:12:55.01,0:12:57.18,Default,,0000,0000,0000,,もっと やりたいこと素直に言えよ
Dialogue: 0,0:12:57.18,0:13:00.35,Default,,0000,0000,0000,,子どもは 我慢とか しなくていいんだからな
Dialogue: 0,0:13:00.35,0:13:02.35,Default,,0000,0000,0000,,ん
Dialogue: 0,0:13:21.87,0:13:24.20,Default,,0000,0000,0000,,鏡子さん どうかしたんですか?
Dialogue: 0,0:13:24.20,0:13:26.71,Default,,0000,0000,0000,,羽依里くん 一人?
Dialogue: 0,0:13:26.71,0:13:28.71,Default,,0000,0000,0000,,はい ちょっと散歩に
Dialogue: 0,0:13:28.71,0:13:30.88,Default,,0000,0000,0000,,どうかしたんですか?
Dialogue: 0,0:13:30.88,0:13:33.88,Default,,0000,0000,0000,,うみちゃんがいないのよ
Dialogue: 0,0:13:30.88,0:13:33.88,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:13:47.49,0:13:49.50,Default,,0000,0000,0000,,静かな家にいた
Dialogue: 0,0:13:49.50,0:13:52.50,Default,,0000,0000,0000,,おとーさんが ただいまと言わなくなって
Dialogue: 0,0:13:52.50,0:13:55.00,Default,,0000,0000,0000,,もうどのくらいかわからない
Dialogue: 0,0:13:55.00,0:13:57.67,Default,,0000,0000,0000,,この家では
Dialogue: 0,0:13:57.67,0:14:01.17,Default,,0000,0000,0000,,ただ寂しさを増やすだけの 言葉だから
Dialogue: 0,0:14:10.85,0:14:13.19,Default,,0000,0000,0000,,こんなところにいたのか
Dialogue: 0,0:14:10.85,0:14:13.19,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:13.19,0:14:17.52,Default,,0000,0000,0000,,おとーさん
Dialogue: 0,0:14:13.19,0:14:17.52,Default,,0000,0000,0000,,違う 俺は おとーさんじゃない
Dialogue: 0,0:14:17.52,0:14:19.53,Default,,0000,0000,0000,,ん
Dialogue: 0,0:14:19.53,0:14:21.69,Default,,0000,0000,0000,,お父さんに会いたいのか?
Dialogue: 0,0:14:21.69,0:14:25.20,Default,,0000,0000,0000,,おとーさんは いそがしいから
Dialogue: 0,0:14:25.20,0:14:29.03,Default,,0000,0000,0000,,そりゃあ お父さんは 働くのが仕事だからな
Dialogue: 0,0:14:29.03,0:14:31.04,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:31.04,0:14:34.14,Default,,0000,0000,0000,,おとーさん むかしに はなしてくれた
Dialogue: 0,0:14:34.14,0:14:39.14,Default,,0000,0000,0000,,むかし たくさん がんばったことがあるけどしっぱいしたって
Dialogue: 0,0:14:39.14,0:14:41.31,Default,,0000,0000,0000,,そこから にげてしまったのを
Dialogue: 0,0:14:41.31,0:14:45.15,Default,,0000,0000,0000,,こうかいしてた
Dialogue: 0,0:14:41.31,0:14:45.15,Default,,0000,0000,0000,,逃げた
Dialogue: 0,0:14:45.15,0:14:48.99,Default,,0000,0000,0000,,わたしも にげた
Dialogue: 0,0:14:45.15,0:14:48.99,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:14:48.99,0:14:52.16,Default,,0000,0000,0000,,やさしくしてくれたひとも いたのに
Dialogue: 0,0:14:52.16,0:14:54.83,Default,,0000,0000,0000,,しんぱいしてくれたひとも いたのに
Dialogue: 0,0:14:54.83,0:14:58.50,Default,,0000,0000,0000,,にげた だから ここにいる
Dialogue: 0,0:14:58.50,0:15:03.40,Default,,0000,0000,0000,,あやまりたいのに もう あやまれない
Dialogue: 0,0:15:07.51,0:15:09.51,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:13.51,0:15:17.35,Default,,0000,0000,0000,,もう にげたくない
Dialogue: 0,0:15:17.35,0:15:19.52,Default,,0000,0000,0000,,うみ
Dialogue: 0,0:15:19.52,0:15:24.19,Default,,0000,0000,0000,,あぁ そうだな
Dialogue: 0,0:15:24.19,0:15:27.03,Default,,0000,0000,0000,,もう 夏から逃げたくないよな
Dialogue: 0,0:15:27.03,0:15:29.03,Default,,0000,0000,0000,,うん
Dialogue: 0,0:15:31.03,0:15:33.63,Default,,0000,0000,0000,,帰ろう 鏡子さんも心配してる
Dialogue: 0,0:15:33.63,0:15:35.80,Default,,0000,0000,0000,,うん
Dialogue: 0,0:15:35.80,0:15:39.14,Default,,0000,0000,0000,,でも どうして 外に出たりしたんだ?
Dialogue: 0,0:15:39.14,0:15:42.81,Default,,0000,0000,0000,,おとーさん いなかったから
Dialogue: 0,0:15:42.81,0:15:47.31,Default,,0000,0000,0000,,おとーさんゆな って えっ 俺を捜してたのか?
Dialogue: 0,0:15:47.31,0:15:49.32,Default,,0000,0000,0000,,ん
Dialogue: 0,0:15:49.32,0:15:51.32,Default,,0000,0000,0000,,どうして俺を?
Dialogue: 0,0:15:54.15,0:15:56.82,Default,,0000,0000,0000,,にげたく ないから
Dialogue: 0,0:15:56.82,0:15:59.16,Default,,0000,0000,0000,,いっしょに いてほしい
Dialogue: 0,0:15:59.16,0:16:01.46,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:16:10.84,0:16:13.34,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:16:13.34,0:16:15.34,Default,,0000,0000,0000,,みんないる
Dialogue: 0,0:16:15.34,0:16:17.34,Default,,0000,0000,0000,,うみちゃん!?
Dialogue: 0,0:16:19.35,0:16:21.35,Default,,0000,0000,0000,,よかった
Dialogue: 0,0:16:21.35,0:16:24.02,Default,,0000,0000,0000,,しんぱいかけて ごめんなさい
Dialogue: 0,0:16:24.02,0:16:27.35,Default,,0000,0000,0000,,無事だったらいいのよ
Dialogue: 0,0:16:27.35,0:16:30.36,Default,,0000,0000,0000,,みんな うみのためにありがとう
Dialogue: 0,0:16:36.63,0:16:38.96,Default,,0000,0000,0000,,お前さ やりたいことないか?
Dialogue: 0,0:16:38.96,0:16:40.97,Default,,0000,0000,0000,,やりたいこと?
Dialogue: 0,0:16:40.97,0:16:43.30,Default,,0000,0000,0000,,せっかく こんな島まで来たんだし
Dialogue: 0,0:16:43.30,0:16:46.14,Default,,0000,0000,0000,,夏の思い出でも作って帰ろうぜ
Dialogue: 0,0:16:46.14,0:16:49.31,Default,,0000,0000,0000,,やりたいこと
Dialogue: 0,0:16:49.31,0:16:52.31,Default,,0000,0000,0000,,おかーさん
Dialogue: 0,0:16:49.31,0:16:52.31,Default,,0000,0000,0000,,んっ? ままごとか?
Dialogue: 0,0:16:52.31,0:16:55.81,Default,,0000,0000,0000,,この年で それは ちょっとハードル高いな
Dialogue: 0,0:16:55.81,0:16:57.82,Default,,0000,0000,0000,,ちがう
Dialogue: 0,0:16:55.81,0:16:57.82,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:16:57.82,0:17:00.82,Default,,0000,0000,0000,,おかーさんといっしょに したいこと ある
Dialogue: 0,0:17:00.82,0:17:04.66,Default,,0000,0000,0000,,よし お前のお母さん 鏡子さんに呼んでもらって
Dialogue: 0,0:17:04.66,0:17:09.33,Default,,0000,0000,0000,,島に来てもらうか?
Dialogue: 0,0:17:04.66,0:17:09.33,Default,,0000,0000,0000,,ううん ない
Dialogue: 0,0:17:09.33,0:17:11.33,Default,,0000,0000,0000,,いない
Dialogue: 0,0:17:11.33,0:17:13.67,Default,,0000,0000,0000,,おかーさん もう いない
Dialogue: 0,0:17:13.67,0:17:16.17,Default,,0000,0000,0000,,そか
Dialogue: 0,0:17:18.50,0:17:20.84,Default,,0000,0000,0000,,探してみるか
Dialogue: 0,0:17:18.50,0:17:20.84,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:17:20.84,0:17:23.34,Default,,0000,0000,0000,,おかーさん 探してみるか?
Dialogue: 0,0:17:23.34,0:17:25.34,Default,,0000,0000,0000,,さがす?
Dialogue: 0,0:17:25.34,0:17:27.85,Default,,0000,0000,0000,,うみのお母さんに なってくれる人だ
Dialogue: 0,0:17:36.29,0:17:38.29,Default,,0000,0000,0000,,また来た
Dialogue: 0,0:17:38.29,0:17:41.46,Default,,0000,0000,0000,,えっと ちょっと 話を聞いてほしいんだ
Dialogue: 0,0:17:41.46,0:17:43.63,Default,,0000,0000,0000,,シーッ!
Dialogue: 0,0:17:43.63,0:17:45.63,Default,,0000,0000,0000,,えっと
Dialogue: 0,0:17:45.63,0:17:50.14,Default,,0000,0000,0000,,そう うみちゃんも お母さんいないんだ
Dialogue: 0,0:17:50.14,0:17:52.47,Default,,0000,0000,0000,,あっ ごめん 無神経だった
Dialogue: 0,0:17:52.47,0:17:55.97,Default,,0000,0000,0000,,ねぇ どうして あなたが ここまでしてるの?
Dialogue: 0,0:17:55.97,0:18:00.31,Default,,0000,0000,0000,,あいつがさ
Dialogue: 0,0:17:55.97,0:18:00.31,Default,,0000,0000,0000,,逃げたくないって言ったんだ
Dialogue: 0,0:18:00.31,0:18:02.48,Default,,0000,0000,0000,,逃げたくない?
Dialogue: 0,0:18:02.48,0:18:05.82,Default,,0000,0000,0000,,何からとか そういうのは 聞かなかったけど
Dialogue: 0,0:18:05.82,0:18:08.82,Default,,0000,0000,0000,,俺は この島に逃げてきたんだ
Dialogue: 0,0:18:08.82,0:18:11.32,Default,,0000,0000,0000,,地元で 嫌なことがあったから
Dialogue: 0,0:18:11.32,0:18:15.66,Default,,0000,0000,0000,,いろんなことを忘れたくて ここに来た
Dialogue: 0,0:18:15.66,0:18:20.17,Default,,0000,0000,0000,,なのに あんな小さいやつが 逃げたくないって言うんだ
Dialogue: 0,0:18:20.17,0:18:22.33,Default,,0000,0000,0000,,だから 手伝ってやりたくなった
Dialogue: 0,0:18:22.33,0:18:26.00,Default,,0000,0000,0000,,スイカバー
Dialogue: 0,0:18:22.33,0:18:26.00,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:18:26.00,0:18:28.67,Default,,0000,0000,0000,,私が食べたいときに 持ってきてほしい
Dialogue: 0,0:18:28.67,0:18:30.68,Default,,0000,0000,0000,,それをしたら?
Dialogue: 0,0:18:30.68,0:18:32.78,Default,,0000,0000,0000,,スイカバー分のお母さんをする
Dialogue: 0,0:18:32.78,0:18:35.45,Default,,0000,0000,0000,,そういう契約で どう?
Dialogue: 0,0:18:35.45,0:18:37.45,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:18:37.45,0:18:40.62,Default,,0000,0000,0000,,えっ!
Dialogue: 0,0:18:37.45,0:18:40.62,Default,,0000,0000,0000,,ありがとう!
Dialogue: 0,0:18:37.45,0:18:40.62,Default,,0000,0000,0000,,ふひっ!?
Dialogue: 0,0:18:40.62,0:18:42.79,Default,,0000,0000,0000,,うみ 喜べ!
Dialogue: 0,0:18:42.79,0:18:44.79,Default,,0000,0000,0000,,しろはが お母さんになってくれるってさ!
Dialogue: 0,0:18:44.79,0:18:47.46,Default,,0000,0000,0000,,こ こんにちは
Dialogue: 0,0:18:47.46,0:18:49.46,Default,,0000,0000,0000,,うぴ
Dialogue: 0,0:18:47.46,0:18:51.80,Default,,0000,0000,0000,,おいおい こんにちはって言われたら 何て返すんだ?
Dialogue: 0,0:18:51.80,0:18:53.80,Default,,0000,0000,0000,,こぴ
Dialogue: 0,0:18:53.80,0:18:56.97,Default,,0000,0000,0000,,悪い どうも 人見知りが発動してるみたい
Dialogue: 0,0:18:56.97,0:18:59.14,Default,,0000,0000,0000,,あれ? しろは?
Dialogue: 0,0:18:59.14,0:19:01.97,Default,,0000,0000,0000,,はぴ?
Dialogue: 0,0:18:59.14,0:19:01.97,Default,,0000,0000,0000,,緊張してる?
Dialogue: 0,0:19:01.97,0:19:04.48,Default,,0000,0000,0000,,き 緊張なんてしてないし
Dialogue: 0,0:19:04.48,0:19:08.98,Default,,0000,0000,0000,,ただ 小さい子に何て言えばいいか わからないだけで
Dialogue: 0,0:19:08.98,0:19:10.98,Default,,0000,0000,0000,,うん
Dialogue: 0,0:19:10.98,0:19:14.65,Default,,0000,0000,0000,,これ
Dialogue: 0,0:19:10.98,0:19:14.65,Default,,0000,0000,0000,,税込み189円ね
Dialogue: 0,0:19:14.65,0:19:19.32,Default,,0000,0000,0000,,でも この12色の色鉛筆と一緒なら セット価格1,000円でいいわよ
Dialogue: 0,0:19:19.32,0:19:21.83,Default,,0000,0000,0000,,買った!
Dialogue: 0,0:19:19.32,0:19:21.83,Default,,0000,0000,0000,,まいどあり!
Dialogue: 0,0:19:23.83,0:19:27.50,Default,,0000,0000,0000,,蒼 ありがとう!
Dialogue: 0,0:19:27.50,0:19:30.17,Default,,0000,0000,0000,,ああ ずいぶんと急いじゃって
Dialogue: 0,0:19:30.17,0:19:33.11,Default,,0000,0000,0000,,おとーさん 頑張ってるね
Dialogue: 0,0:19:33.11,0:19:37.28,Default,,0000,0000,0000,,うみ 楽しい夏休みを始めようか
Dialogue: 0,0:19:33.11,0:19:37.28,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:19:37.28,0:19:39.28,Default,,0000,0000,0000,,これは 魔法の絵日記だ
Dialogue: 0,0:19:39.28,0:19:41.61,Default,,0000,0000,0000,,これで うみのやりたいことを書いたら
Dialogue: 0,0:19:41.61,0:19:44.45,Default,,0000,0000,0000,,それが 本当になる
Dialogue: 0,0:19:41.61,0:19:44.45,Default,,0000,0000,0000,,すごい!
Dialogue: 0,0:19:44.45,0:19:47.85,Default,,0000,0000,0000,,ほ 本当に そんな絵日記があるの?
Dialogue: 0,0:19:44.45,0:19:47.85,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:19:58.96,0:20:03.80,Default,,0000,0000,0000,,くけ! くけ くけ!
Dialogue: 0,0:19:58.96,0:20:03.80,Default,,0000,0000,0000,,すごい! まほうのえにっきだ!
Dialogue: 0,0:20:03.80,0:20:06.97,Default,,0000,0000,0000,,すごい
Dialogue: 0,0:20:03.80,0:20:06.97,Default,,0000,0000,0000,,くけけ くけ!
Dialogue: 0,0:20:06.97,0:20:08.97,Default,,0000,0000,0000,,なあ うみ
Dialogue: 0,0:20:06.97,0:20:08.97,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:20:08.97,0:20:11.64,Default,,0000,0000,0000,,おかーさんのケツァルコアトルは 見たくないか?
Dialogue: 0,0:20:11.64,0:20:13.65,Default,,0000,0000,0000,,おぉ!
Dialogue: 0,0:20:11.64,0:20:13.65,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:20:13.65,0:20:15.95,Default,,0000,0000,0000,,あわわ
Dialogue: 0,0:20:21.82,0:20:24.49,Default,,0000,0000,0000,,くけ! けぇ! けっけぇ!
Dialogue: 0,0:20:24.49,0:20:26.66,Default,,0000,0000,0000,,くけ!
Dialogue: 0,0:20:24.49,0:20:26.66,Default,,0000,0000,0000,,わっ! わ!
Dialogue: 0,0:20:26.66,0:20:30.96,Default,,0000,0000,0000,,じゃあ この調子で 明日からの日記書いちゃえ
Dialogue: 0,0:20:28.66,0:20:30.96,Default,,0000,0000,0000,,うん!
Dialogue: 0,0:20:39.67,0:20:42.51,Default,,0000,0000,0000,,ここ つかんでみて
Dialogue: 0,0:20:39.67,0:20:42.51,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:20:42.51,0:20:46.01,Default,,0000,0000,0000,,じゃあ ちょっと 目をつぶってみて
Dialogue: 0,0:20:42.51,0:20:46.01,Default,,0000,0000,0000,,ん
Dialogue: 0,0:20:48.51,0:20:51.68,Default,,0000,0000,0000,,はい 開けていいよ
Dialogue: 0,0:20:51.68,0:20:53.69,Default,,0000,0000,0000,,わっ!? わ!
Dialogue: 0,0:20:53.69,0:20:56.69,Default,,0000,0000,0000,,不思議でしょ?
Dialogue: 0,0:20:53.69,0:20:56.69,Default,,0000,0000,0000,,まほうだ!
Dialogue: 0,0:20:56.69,0:20:58.69,Default,,0000,0000,0000,,ウフフ そうかもね
Dialogue: 0,0:20:58.69,0:21:02.19,Default,,0000,0000,0000,,まほう おしえて! おか お
Dialogue: 0,0:21:02.19,0:21:04.53,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:21:04.53,0:21:07.93,Default,,0000,0000,0000,,おかーさん て よんでもいい?
Dialogue: 0,0:21:09.87,0:21:11.87,Default,,0000,0000,0000,,う うん
Dialogue: 0,0:21:11.87,0:21:16.71,Default,,0000,0000,0000,,あっ おかーさん
Dialogue: 0,0:21:11.87,0:21:16.71,Default,,0000,0000,0000,,う うん
Dialogue: 0,0:21:16.71,0:21:19.01,Default,,0000,0000,0000,,エヘヘ
Dialogue: 0,0:21:21.88,0:21:24.05,Default,,0000,0000,0000,,すごいとんだ!
Dialogue: 0,0:21:24.05,0:21:27.39,Default,,0000,0000,0000,,紙飛行機を飛ばすコツは 優しく フワッとだ
Dialogue: 0,0:21:27.39,0:21:30.22,Default,,0000,0000,0000,,あんなに ながくとぶの はじめてみた!
Dialogue: 0,0:21:30.22,0:21:32.49,Default,,0000,0000,0000,,いちばんか?
Dialogue: 0,0:21:30.22,0:21:32.49,Default,,0000,0000,0000,,うん いちばん!
Dialogue: 0,0:21:32.49,0:21:34.69,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:32.49,0:21:34.69,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:21:37.66,0:21:39.67,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:21:37.66,0:21:39.67,Default,,0000,0000,0000,,フフン
Dialogue: 0,0:21:39.67,0:21:41.67,Default,,0000,0000,0000,,おかーさんのかみひこーき すごい!
Dialogue: 0,0:21:41.67,0:21:47.17,Default,,0000,0000,0000,,私のハイパーマスタングスペシャル・ディメンションⅣ
Dialogue: 0,0:21:41.67,0:21:47.17,Default,,0000,0000,0000,,マークⅢのほうがよく飛ぶし
Dialogue: 0,0:21:47.17,0:21:49.68,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:21:47.17,0:21:49.68,Default,,0000,0000,0000,,ん
Dialogue: 0,0:21:53.51,0:21:55.68,Default,,0000,0000,0000,,ニヤッ
Dialogue: 0,0:21:55.68,0:21:57.85,Default,,0000,0000,0000,,カッチーン
Dialogue: 0,0:21:57.85,0:22:02.19,Default,,0000,0000,0000,,スーパーマスタングファイア・コズミックモード レベルⅦがあるし
Dialogue: 0,0:22:02.19,0:22:04.69,Default,,0000,0000,0000,,まだ本気だなんて 俺は言ってないぜ
Dialogue: 0,0:22:04.69,0:22:06.69,Default,,0000,0000,0000,,んっ
