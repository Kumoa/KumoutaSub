Dialogue: 0,0:00:44.18,0:00:46.88,Default,,0000,0000,0000,,おかえり
Dialogue: 0,0:00:55.36,0:00:57.86,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:01:03.70,0:01:06.37,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:01:03.70,0:01:06.37,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:01:06.37,0:01:09.37,Default,,0000,0000,0000,,おいしいよ
Dialogue: 0,0:01:06.37,0:01:09.37,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:01:09.37,0:01:11.37,Default,,0000,0000,0000,,そ そうですか
Dialogue: 0,0:01:15.04,0:01:17.04,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:03:04.88,0:03:09.22,Default,,0000,0000,0000,,蔵のほうは まだいいよ
Dialogue: 0,0:03:04.88,0:03:09.22,Default,,0000,0000,0000,,今日も遊んで来たら?
Dialogue: 0,0:03:09.22,0:03:13.39,Default,,0000,0000,0000,,遊んで来たらって 言われてもなぁ
Dialogue: 0,0:03:35.18,0:03:37.35,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:03:44.36,0:03:46.63,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:03:44.36,0:03:46.63,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:03:50.53,0:03:55.87,Default,,0000,0000,0000,,あ えっと じゃ じゃあ
Dialogue: 0,0:03:55.87,0:03:59.21,Default,,0000,0000,0000,,ま 待って
Dialogue: 0,0:03:55.87,0:03:59.21,Default,,0000,0000,0000,,えっ? 俺?
Dialogue: 0,0:03:59.21,0:04:02.88,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:03:59.21,0:04:02.88,Default,,0000,0000,0000,,なに?
Dialogue: 0,0:04:11.55,0:04:13.55,Default,,0000,0000,0000,,ありがとう
Dialogue: 0,0:04:13.55,0:04:17.56,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:04:13.55,0:04:17.56,Default,,0000,0000,0000,,あの 前 プールで
Dialogue: 0,0:04:17.56,0:04:21.63,Default,,0000,0000,0000,,そのとおりにしたら 少し うまく泳げたから
Dialogue: 0,0:04:23.90,0:04:25.87,Default,,0000,0000,0000,,じゃあ
Dialogue: 0,0:04:23.90,0:04:25.87,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:04:42.98,0:04:45.65,Default,,0000,0000,0000,,ほらほら あの人よ
Dialogue: 0,0:04:42.98,0:04:45.65,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:04:45.65,0:04:48.66,Default,,0000,0000,0000,,木戸のおばあちゃんが 言ってた
Dialogue: 0,0:04:51.82,0:04:54.83,Default,,0000,0000,0000,,堕天使
Dialogue: 0,0:04:51.82,0:04:54.83,Default,,0000,0000,0000,,ルシファーですわ
Dialogue: 0,0:04:54.83,0:04:56.83,Default,,0000,0000,0000,,そんな出来事はない!
Dialogue: 0,0:04:56.83,0:04:58.83,Default,,0000,0000,0000,,キャー!
Dialogue: 0,0:04:58.83,0:05:01.17,Default,,0000,0000,0000,,ふぅ ん?
Dialogue: 0,0:05:19.02,0:05:21.02,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:21.02,0:05:23.12,Default,,0000,0000,0000,,思ったより遠かったな
Dialogue: 0,0:05:28.86,0:05:30.86,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:05:49.52,0:05:53.69,Default,,0000,0000,0000,,おい!
Dialogue: 0,0:05:49.52,0:05:53.69,Default,,0000,0000,0000,,んっ? むぎゅ!?
Dialogue: 0,0:05:53.69,0:05:55.69,Default,,0000,0000,0000,,むぎゅ?
Dialogue: 0,0:05:55.69,0:05:58.36,Default,,0000,0000,0000,,そんなところで何してるんだ?
Dialogue: 0,0:05:58.36,0:06:01.03,Default,,0000,0000,0000,,探し物です!
Dialogue: 0,0:06:01.03,0:06:03.36,Default,,0000,0000,0000,,何探してるの?
Dialogue: 0,0:06:03.36,0:06:06.70,Default,,0000,0000,0000,,自分です
Dialogue: 0,0:06:06.70,0:06:11.57,Default,,0000,0000,0000,,それと やりたいことを探しています!
Dialogue: 0,0:06:14.21,0:06:16.71,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:16.71,0:06:20.38,Default,,0000,0000,0000,,そんなところにいたら 危ないと思うぞ!
Dialogue: 0,0:06:20.38,0:06:24.55,Default,,0000,0000,0000,,むぎゅ 危なくないですよ
Dialogue: 0,0:06:24.55,0:06:27.72,Default,,0000,0000,0000,,落ちたら 死んじゃうかもしれないけど?
Dialogue: 0,0:06:27.72,0:06:30.06,Default,,0000,0000,0000,,死にませんよ
Dialogue: 0,0:06:30.06,0:06:32.06,Default,,0000,0000,0000,,君は 無敵なの?
Dialogue: 0,0:06:32.06,0:06:34.53,Default,,0000,0000,0000,,ムテキです!
Dialogue: 0,0:06:37.63,0:06:40.47,Default,,0000,0000,0000,,うらやましいな
Dialogue: 0,0:06:40.47,0:06:43.97,Default,,0000,0000,0000,,一昨日から島に 滞在している鷹原羽依里くん
Dialogue: 0,0:06:43.97,0:06:45.97,Default,,0000,0000,0000,,役場にお越しください
Dialogue: 0,0:06:55.48,0:06:59.49,Default,,0000,0000,0000,,遅いぞ
Dialogue: 0,0:06:55.48,0:06:59.49,Default,,0000,0000,0000,,お前 まさか 裸狩り!?
Dialogue: 0,0:06:59.49,0:07:01.49,Default,,0000,0000,0000,,変な呼び方は やめろ
Dialogue: 0,0:07:01.49,0:07:03.66,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:07:01.49,0:07:03.66,Default,,0000,0000,0000,,私には 野村美希という
Dialogue: 0,0:07:03.66,0:07:06.83,Default,,0000,0000,0000,,ちゃんとした名前がある
Dialogue: 0,0:07:03.66,0:07:06.83,Default,,0000,0000,0000,,この前 撃ってきたのは
Dialogue: 0,0:07:06.83,0:07:09.00,Default,,0000,0000,0000,,そのゴツい水鉄砲か?
Dialogue: 0,0:07:09.00,0:07:12.00,Default,,0000,0000,0000,,うむ ハイドログラディエーター改だ
Dialogue: 0,0:07:12.00,0:07:17.84,Default,,0000,0000,0000,,あぁ 俺も昔は ウォーターソルジャーの
Dialogue: 0,0:07:12.00,0:07:17.84,Default,,0000,0000,0000,,異名をとっていたことがあってな
Dialogue: 0,0:07:17.84,0:07:22.18,Default,,0000,0000,0000,,なんだ その恥ずかしい名前は
Dialogue: 0,0:07:22.18,0:07:24.68,Default,,0000,0000,0000,,おう 来たな
Dialogue: 0,0:07:26.85,0:07:28.85,Default,,0000,0000,0000,,お前は
Dialogue: 0,0:07:28.85,0:07:32.02,Default,,0000,0000,0000,,フッ 自己紹介が まだだったな
Dialogue: 0,0:07:32.02,0:07:35.02,Default,,0000,0000,0000,,俺の名は 三谷良 ぶぎゃあ!
Dialogue: 0,0:07:37.99,0:07:40.99,Default,,0000,0000,0000,,公共の場で裸になるなと 言っているだろ
Dialogue: 0,0:07:40.99,0:07:44.33,Default,,0000,0000,0000,,来て早々 見苦しいものを 見せてしまったな
Dialogue: 0,0:07:44.33,0:07:47.00,Default,,0000,0000,0000,,改めて 野村美希だ
Dialogue: 0,0:07:47.00,0:07:49.00,Default,,0000,0000,0000,,みんなから のみきと呼ばれている
Dialogue: 0,0:07:49.00,0:07:52.51,Default,,0000,0000,0000,,俺は 三谷良一
Dialogue: 0,0:07:49.00,0:07:52.51,Default,,0000,0000,0000,,よろしくな 羽依里
Dialogue: 0,0:07:52.51,0:07:54.67,Default,,0000,0000,0000,,お おぉ よろしく
Dialogue: 0,0:07:54.67,0:07:57.01,Default,,0000,0000,0000,,で なんなんだ?
Dialogue: 0,0:07:57.01,0:08:00.68,Default,,0000,0000,0000,,うむ 今夜 集まりがあるんだ
Dialogue: 0,0:07:57.01,0:08:00.68,Default,,0000,0000,0000,,集まり?
Dialogue: 0,0:08:00.68,0:08:02.85,Default,,0000,0000,0000,,羽依里の歓迎会だ
Dialogue: 0,0:08:02.85,0:08:06.19,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:08:02.85,0:08:06.19,Default,,0000,0000,0000,,俺 ちょっと旅行に来ただけだぞ
Dialogue: 0,0:08:06.19,0:08:12.02,Default,,0000,0000,0000,,遠慮すんなよ
Dialogue: 0,0:08:06.19,0:08:12.02,Default,,0000,0000,0000,,鳥白島は 客人には 温かいんだぜ
Dialogue: 0,0:08:12.02,0:08:17.03,Default,,0000,0000,0000,,この島に長く滞在する旅行客は
Dialogue: 0,0:08:12.02,0:08:17.03,Default,,0000,0000,0000,,渡りの人と言われていてな
Dialogue: 0,0:08:17.03,0:08:20.87,Default,,0000,0000,0000,,まあ とにかく歓待するのが ならわしなんだ
Dialogue: 0,0:08:20.87,0:08:24.20,Default,,0000,0000,0000,,黙って歓迎されろってことだ
Dialogue: 0,0:08:24.20,0:08:26.21,Default,,0000,0000,0000,,ありがとう
Dialogue: 0,0:08:26.21,0:08:29.88,Default,,0000,0000,0000,,決まりだな
Dialogue: 0,0:08:26.21,0:08:29.88,Default,,0000,0000,0000,,そういえば 天善は どうした?
Dialogue: 0,0:08:29.88,0:08:34.48,Default,,0000,0000,0000,,ああ あいつなら 山に籠ってるんじゃないか?
Dialogue: 0,0:08:34.48,0:08:36.55,Default,,0000,0000,0000,,山に籠る?
Dialogue: 0,0:08:40.32,0:08:43.49,Default,,0000,0000,0000,,私たちは 歓迎会の準備があってな
Dialogue: 0,0:08:43.49,0:08:46.49,Default,,0000,0000,0000,,悪いが 天善を 呼びに行ってくれないか?
Dialogue: 0,0:08:46.49,0:08:49.26,Default,,0000,0000,0000,,俺 顔知らないぞ
Dialogue: 0,0:08:58.00,0:09:00.17,Default,,0000,0000,0000,,失礼します
Dialogue: 0,0:09:00.17,0:09:02.68,Default,,0000,0000,0000,,誰もいない
Dialogue: 0,0:09:00.17,0:09:02.68,Default,,0000,0000,0000,,ふん!
Dialogue: 0,0:09:02.68,0:09:07.35,Default,,0000,0000,0000,,うわぁ!
Dialogue: 0,0:09:02.68,0:09:07.35,Default,,0000,0000,0000,,ふん! ふんっ!
Dialogue: 0,0:09:07.35,0:09:11.85,Default,,0000,0000,0000,,あの
Dialogue: 0,0:09:07.35,0:09:11.85,Default,,0000,0000,0000,,ふんっ! む 誰だ?
Dialogue: 0,0:09:11.85,0:09:15.62,Default,,0000,0000,0000,,あっ ち ちわ
Dialogue: 0,0:09:19.19,0:09:22.19,Default,,0000,0000,0000,,はっ!
Dialogue: 0,0:09:19.19,0:09:22.19,Default,,0000,0000,0000,,はぁ!
Dialogue: 0,0:09:22.19,0:09:25.87,Default,,0000,0000,0000,,エクセレントだ!
Dialogue: 0,0:09:22.19,0:09:25.87,Default,,0000,0000,0000,,えいっ!
Dialogue: 0,0:09:25.87,0:09:29.04,Default,,0000,0000,0000,,てい!
Dialogue: 0,0:09:25.87,0:09:29.04,Default,,0000,0000,0000,,うっ あっ
Dialogue: 0,0:09:29.04,0:09:32.94,Default,,0000,0000,0000,,ほぉ まんざら素人というわけでも ないようだな
Dialogue: 0,0:09:32.94,0:09:35.61,Default,,0000,0000,0000,,いや 普通に素人だが
Dialogue: 0,0:09:35.61,0:09:38.81,Default,,0000,0000,0000,,ならば こちらも本気でいこうか
Dialogue: 0,0:09:41.28,0:09:44.45,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:09:41.28,0:09:44.45,Default,,0000,0000,0000,,今まで そんなものをつけて!
Dialogue: 0,0:09:44.45,0:09:46.95,Default,,0000,0000,0000,,こいつを外すのは いつ以来だろうな
Dialogue: 0,0:09:46.95,0:09:49.96,Default,,0000,0000,0000,,軽い 今なら空も飛べるぞ
Dialogue: 0,0:09:49.96,0:09:52.12,Default,,0000,0000,0000,,なにを馬鹿なことをしているんだ
Dialogue: 0,0:09:52.12,0:09:55.46,Default,,0000,0000,0000,,むっ もう時間か?
Dialogue: 0,0:09:52.12,0:09:55.46,Default,,0000,0000,0000,,みんな待っているぞ
Dialogue: 0,0:09:55.46,0:09:57.46,Default,,0000,0000,0000,,ところで彼は誰だ?
Dialogue: 0,0:09:57.46,0:09:59.63,Default,,0000,0000,0000,,今更?
Dialogue: 0,0:09:59.63,0:10:02.34,Default,,0000,0000,0000,,鳥白島へ!
Dialogue: 0,0:09:59.63,0:10:02.34,Default,,0000,0000,0000,,ようこそ!
Dialogue: 0,0:10:04.30,0:10:07.14,Default,,0000,0000,0000,,ウェル カム トゥ トリシロ島 アイランド!
Dialogue: 0,0:10:07.14,0:10:10.14,Default,,0000,0000,0000,,ど どうも あざっす
Dialogue: 0,0:10:10.14,0:10:14.31,Default,,0000,0000,0000,,はじめまして 空門蒼よ
Dialogue: 0,0:10:10.14,0:10:14.31,Default,,0000,0000,0000,,アオでいいわ
Dialogue: 0,0:10:14.31,0:10:16.48,Default,,0000,0000,0000,,よろしくね
Dialogue: 0,0:10:16.48,0:10:19.99,Default,,0000,0000,0000,,あら?
Dialogue: 0,0:10:16.48,0:10:19.99,Default,,0000,0000,0000,,こちらこそ よろし く
Dialogue: 0,0:10:19.99,0:10:22.32,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:10:22.32,0:10:26.99,Default,,0000,0000,0000,,六波羅探題!
Dialogue: 0,0:10:22.32,0:10:26.99,Default,,0000,0000,0000,,鷹原羽依里だ!
Dialogue: 0,0:10:22.32,0:10:26.99,Default,,0000,0000,0000,,「はら」しか合ってねえだろ!
Dialogue: 0,0:10:26.99,0:10:30.00,Default,,0000,0000,0000,,なんだ 知り合いかよ
Dialogue: 0,0:10:26.99,0:10:30.00,Default,,0000,0000,0000,,いつの間に?
Dialogue: 0,0:10:30.00,0:10:33.67,Default,,0000,0000,0000,,え あ いや
Dialogue: 0,0:10:30.00,0:10:33.67,Default,,0000,0000,0000,,たまたま ちょっとね
Dialogue: 0,0:10:33.67,0:10:38.00,Default,,0000,0000,0000,,と ところでさ お前らって その どういう
Dialogue: 0,0:10:38.00,0:10:41.67,Default,,0000,0000,0000,,私たちは この島の少年団の執行部よ
Dialogue: 0,0:10:41.67,0:10:46.51,Default,,0000,0000,0000,,執行部といっても
Dialogue: 0,0:10:41.67,0:10:46.51,Default,,0000,0000,0000,,あっ 同世代の学生なんて
Dialogue: 0,0:10:46.51,0:10:50.68,Default,,0000,0000,0000,,俺たち以外ほとんどいないだろう
Dialogue: 0,0:10:46.51,0:10:50.68,Default,,0000,0000,0000,,うんうん
Dialogue: 0,0:10:50.68,0:10:52.85,Default,,0000,0000,0000,,食べ物で遊ぶな
Dialogue: 0,0:10:52.85,0:10:55.02,Default,,0000,0000,0000,,しろはは?
Dialogue: 0,0:10:52.85,0:10:55.02,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:10:55.02,0:10:59.53,Default,,0000,0000,0000,,しろは?
Dialogue: 0,0:10:55.02,0:10:59.53,Default,,0000,0000,0000,,あれ? 彼女も同世代 だよな?
Dialogue: 0,0:10:59.53,0:11:01.53,Default,,0000,0000,0000,,ああ 鳴瀬のことか
Dialogue: 0,0:11:01.53,0:11:04.53,Default,,0000,0000,0000,,いきなり名前呼びするから びっくりしたぞ
Dialogue: 0,0:11:04.53,0:11:07.70,Default,,0000,0000,0000,,知り合いなのか?
Dialogue: 0,0:11:04.53,0:11:07.70,Default,,0000,0000,0000,,いや 知り合いってほどじゃ
Dialogue: 0,0:11:07.70,0:11:12.04,Default,,0000,0000,0000,,なのに名前呼び?
Dialogue: 0,0:11:07.70,0:11:12.04,Default,,0000,0000,0000,,しろはが名字だと思ってた
Dialogue: 0,0:11:12.04,0:11:16.21,Default,,0000,0000,0000,,しろはは
Dialogue: 0,0:11:12.04,0:11:16.21,Default,,0000,0000,0000,,一言で言うと つきあいが悪い
Dialogue: 0,0:11:16.21,0:11:18.21,Default,,0000,0000,0000,,シャイだからな
Dialogue: 0,0:11:18.21,0:11:21.41,Default,,0000,0000,0000,,変なチョッカイ出しちゃダメよ
Dialogue: 0,0:11:18.21,0:11:21.41,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:11:24.55,0:11:26.72,Default,,0000,0000,0000,,何よ 「えっ」って
Dialogue: 0,0:11:26.72,0:11:29.89,Default,,0000,0000,0000,,もしかして すでに
Dialogue: 0,0:11:26.72,0:11:29.89,Default,,0000,0000,0000,,何もしてない!
Dialogue: 0,0:11:29.89,0:11:33.36,Default,,0000,0000,0000,,ちょっと会っただけだ
Dialogue: 0,0:11:29.89,0:11:33.36,Default,,0000,0000,0000,,ふん
Dialogue: 0,0:11:33.36,0:11:35.36,Default,,0000,0000,0000,,しろはは 来ないのか?
Dialogue: 0,0:11:35.36,0:11:38.63,Default,,0000,0000,0000,,うん 声は かけたんだけどね
Dialogue: 0,0:11:49.34,0:11:52.04,Default,,0000,0000,0000,,遅れる 遅れる!
Dialogue: 0,0:11:54.01,0:11:56.85,Default,,0000,0000,0000,,おはよう うみちゃん
Dialogue: 0,0:11:54.01,0:11:56.85,Default,,0000,0000,0000,,朝から お出かけ?
Dialogue: 0,0:11:56.85,0:11:59.69,Default,,0000,0000,0000,,はい ラジオ体操です
Dialogue: 0,0:11:59.69,0:12:02.52,Default,,0000,0000,0000,,あっ 朝ご飯作ってあるので
Dialogue: 0,0:12:02.52,0:12:04.86,Default,,0000,0000,0000,,うん ありがと
Dialogue: 0,0:12:04.86,0:12:07.16,Default,,0000,0000,0000,,食べたら 片づけておいてくださいね
Dialogue: 0,0:12:09.70,0:12:12.90,Default,,0000,0000,0000,,いってきます!
Dialogue: 0,0:12:09.70,0:12:12.90,Default,,0000,0000,0000,,いってらっしゃい
Dialogue: 0,0:12:22.37,0:12:25.08,Default,,0000,0000,0000,,しっかし あっついな
Dialogue: 0,0:12:37.69,0:12:39.69,Default,,0000,0000,0000,,おぉ
Dialogue: 0,0:12:39.69,0:12:41.86,Default,,0000,0000,0000,,いらっしゃい
Dialogue: 0,0:12:41.86,0:12:45.53,Default,,0000,0000,0000,,今日も暑いね
Dialogue: 0,0:12:41.86,0:12:45.53,Default,,0000,0000,0000,,そうですね
Dialogue: 0,0:12:45.53,0:12:47.53,Default,,0000,0000,0000,,かき氷でも食うかの?
Dialogue: 0,0:12:47.53,0:12:49.80,Default,,0000,0000,0000,,あっ はい いただきます
Dialogue: 0,0:12:56.71,0:12:59.88,Default,,0000,0000,0000,,はい 100万円
Dialogue: 0,0:12:56.71,0:12:59.88,Default,,0000,0000,0000,,おぉ
Dialogue: 0,0:12:59.88,0:13:02.05,Default,,0000,0000,0000,,本当に言うんだ
Dialogue: 0,0:13:05.22,0:13:09.39,Default,,0000,0000,0000,,そこは暑いだで 座敷で食べるとええよ
Dialogue: 0,0:13:09.39,0:13:11.39,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:13:11.39,0:13:15.06,Default,,0000,0000,0000,,扇風機があるから 涼しいでの
Dialogue: 0,0:13:15.06,0:13:17.63,Default,,0000,0000,0000,,あっ じゃあ お言葉に甘えて
Dialogue: 0,0:13:30.08,0:13:32.34,Default,,0000,0000,0000,,え?
Dialogue: 0,0:13:39.85,0:13:42.02,Default,,0000,0000,0000,,うわ!
Dialogue: 0,0:13:39.85,0:13:42.02,Default,,0000,0000,0000,,ひっ!
Dialogue: 0,0:13:42.02,0:13:45.36,Default,,0000,0000,0000,,ひゃあ!!
Dialogue: 0,0:13:45.36,0:13:48.86,Default,,0000,0000,0000,,ねぇ どういうことかしら?
Dialogue: 0,0:13:48.86,0:13:53.37,Default,,0000,0000,0000,,いや どうと言われましても
Dialogue: 0,0:13:48.86,0:13:53.37,Default,,0000,0000,0000,,これは 事故かと
Dialogue: 0,0:13:53.37,0:13:58.87,Default,,0000,0000,0000,,へぇ 着替え中の女の子が
Dialogue: 0,0:13:53.37,0:13:58.87,Default,,0000,0000,0000,,いる部屋の扉を勝手に開けて
Dialogue: 0,0:13:58.87,0:14:03.04,Default,,0000,0000,0000,,いきなり かき氷をぶっかけるのが事故と?
Dialogue: 0,0:14:03.04,0:14:07.88,Default,,0000,0000,0000,,いや 違うんだ
Dialogue: 0,0:14:03.04,0:14:07.88,Default,,0000,0000,0000,,かき氷は その 驚いて
Dialogue: 0,0:14:07.88,0:14:10.05,Default,,0000,0000,0000,,うんうん わかるわ
Dialogue: 0,0:14:10.05,0:14:13.72,Default,,0000,0000,0000,,扉を開けたら そこには下着姿の女の子
Dialogue: 0,0:14:13.72,0:14:17.72,Default,,0000,0000,0000,,そりゃあ 驚くわよねぇ で?
Dialogue: 0,0:14:17.72,0:14:22.73,Default,,0000,0000,0000,,俺 男子校だから
Dialogue: 0,0:14:17.72,0:14:22.73,Default,,0000,0000,0000,,露出の多い女に免疫なくて
Dialogue: 0,0:14:22.73,0:14:25.40,Default,,0000,0000,0000,,だから隠さないと まずいと思う一心で
Dialogue: 0,0:14:25.40,0:14:28.23,Default,,0000,0000,0000,,あ なるほど
Dialogue: 0,0:14:28.23,0:14:33.81,Default,,0000,0000,0000,,だから氷をね
Dialogue: 0,0:14:28.23,0:14:33.81,Default,,0000,0000,0000,,って なんだ そりゃあ!!
Dialogue: 0,0:14:33.81,0:14:38.14,Default,,0000,0000,0000,,すみません! っていうか なんで駄菓子屋で下着姿に?
Dialogue: 0,0:14:38.14,0:14:40.15,Default,,0000,0000,0000,,そういう趣味?
Dialogue: 0,0:14:40.15,0:14:43.15,Default,,0000,0000,0000,,あんた 絶対反省してないでしょ
Dialogue: 0,0:14:43.15,0:14:45.82,Default,,0000,0000,0000,,ここ 私のバイト先
Dialogue: 0,0:14:45.82,0:14:49.15,Default,,0000,0000,0000,,あ
Dialogue: 0,0:14:45.82,0:14:49.15,Default,,0000,0000,0000,,あ もう
Dialogue: 0,0:14:49.15,0:14:51.82,Default,,0000,0000,0000,,下着が濡れて気持ち悪い
Dialogue: 0,0:14:51.82,0:14:56.33,Default,,0000,0000,0000,,申し訳ない お詫びに俺に かき氷をぶっかけてください!
Dialogue: 0,0:14:56.33,0:14:59.50,Default,,0000,0000,0000,,はぁ? 何それ 意味わかんない
Dialogue: 0,0:14:59.50,0:15:04.34,Default,,0000,0000,0000,,目には目を 的な感じで ハンムラビるしかないかと
Dialogue: 0,0:15:04.34,0:15:08.14,Default,,0000,0000,0000,,へぇ そうくる
Dialogue: 0,0:15:04.34,0:15:08.14,Default,,0000,0000,0000,,そうきちゃうんだぁ?
Dialogue: 0,0:15:10.68,0:15:14.51,Default,,0000,0000,0000,,それじゃいくわよ 覚悟はいい?
Dialogue: 0,0:15:14.51,0:15:17.52,Default,,0000,0000,0000,,どんとこい!
Dialogue: 0,0:15:14.51,0:15:17.52,Default,,0000,0000,0000,,せの!
Dialogue: 0,0:15:19.52,0:15:22.52,Default,,0000,0000,0000,,ひょお!
Dialogue: 0,0:15:19.52,0:15:22.52,Default,,0000,0000,0000,,アハハハハ!
Dialogue: 0,0:15:22.52,0:15:27.53,Default,,0000,0000,0000,,うっ! きゃ!
Dialogue: 0,0:15:22.52,0:15:27.53,Default,,0000,0000,0000,,なんで投げ返してんのよ!
Dialogue: 0,0:15:27.53,0:15:30.20,Default,,0000,0000,0000,,だって 思ったより冷たかったから
Dialogue: 0,0:15:30.20,0:15:32.53,Default,,0000,0000,0000,,いっ!?
Dialogue: 0,0:15:30.20,0:15:32.53,Default,,0000,0000,0000,,この
Dialogue: 0,0:15:32.53,0:15:34.50,Default,,0000,0000,0000,,目には目をよ!
Dialogue: 0,0:15:34.50,0:15:37.34,Default,,0000,0000,0000,,ちょ ちょっと まっ
Dialogue: 0,0:15:37.34,0:15:39.34,Default,,0000,0000,0000,,た
Dialogue: 0,0:15:39.34,0:15:42.34,Default,,0000,0000,0000,,ひょお 目が!? 目が!!
Dialogue: 0,0:15:42.34,0:15:45.18,Default,,0000,0000,0000,,ふふん
Dialogue: 0,0:15:45.18,0:15:50.18,Default,,0000,0000,0000,,ひゃあ!!
Dialogue: 0,0:15:45.18,0:15:50.18,Default,,0000,0000,0000,,どこぶっかけてんのよ!
Dialogue: 0,0:15:50.18,0:15:54.19,Default,,0000,0000,0000,,ひょお!
Dialogue: 0,0:15:50.18,0:15:54.19,Default,,0000,0000,0000,,こ こら そこはダメだろ!
Dialogue: 0,0:15:54.19,0:15:56.19,Default,,0000,0000,0000,,わっ ひゃあ!
Dialogue: 0,0:15:54.19,0:15:58.69,Default,,0000,0000,0000,,ちょちょちょ ちょっと どさくさまぎれに どこ触ってんのよ!
Dialogue: 0,0:15:58.69,0:16:01.53,Default,,0000,0000,0000,,ひょお!
Dialogue: 0,0:15:58.69,0:16:01.53,Default,,0000,0000,0000,,そっちこそ どこ触ってんだよ!
Dialogue: 0,0:16:01.53,0:16:03.50,Default,,0000,0000,0000,,ひゃあ!
Dialogue: 0,0:16:07.20,0:16:11.37,Default,,0000,0000,0000,,ったく ひどい目に遭った
Dialogue: 0,0:16:11.37,0:16:14.21,Default,,0000,0000,0000,,えっ!? うわぁ! あっ?
Dialogue: 0,0:16:14.21,0:16:17.21,Default,,0000,0000,0000,,そこの露出狂
Dialogue: 0,0:16:14.21,0:16:17.21,Default,,0000,0000,0000,,海水浴場以外で
Dialogue: 0,0:16:17.21,0:16:21.71,Default,,0000,0000,0000,,服を脱ぐことは禁止されている
Dialogue: 0,0:16:17.21,0:16:21.71,Default,,0000,0000,0000,,速やかに服を着ろ
Dialogue: 0,0:16:21.71,0:16:24.38,Default,,0000,0000,0000,,い いったい どこから?
Dialogue: 0,0:16:24.38,0:16:27.05,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:16:24.38,0:16:27.05,Default,,0000,0000,0000,,次は当てる
Dialogue: 0,0:16:27.05,0:16:30.56,Default,,0000,0000,0000,,き 着ます 着ます!
Dialogue: 0,0:16:27.05,0:16:30.56,Default,,0000,0000,0000,,すぐ着ます!
Dialogue: 0,0:16:33.13,0:16:35.63,Default,,0000,0000,0000,,ただいま
Dialogue: 0,0:16:35.63,0:16:37.63,Default,,0000,0000,0000,,おかえりなきゃい!?
Dialogue: 0,0:16:37.63,0:16:41.47,Default,,0000,0000,0000,,あん?
Dialogue: 0,0:16:37.63,0:16:41.47,Default,,0000,0000,0000,,なんで また体を さらしてるんですか!
Dialogue: 0,0:16:41.47,0:16:44.14,Default,,0000,0000,0000,,ちょっと かき氷をぶっかけ合って
Dialogue: 0,0:16:44.14,0:16:46.81,Default,,0000,0000,0000,,意味が わからない!
Dialogue: 0,0:16:46.81,0:16:51.01,Default,,0000,0000,0000,,お風呂沸いてますから さっさと入ってきてください
Dialogue: 0,0:16:53.65,0:16:55.98,Default,,0000,0000,0000,,ふぃ
Dialogue: 0,0:16:55.98,0:17:01.82,Default,,0000,0000,0000,,たった3日なのに
Dialogue: 0,0:16:55.98,0:17:01.82,Default,,0000,0000,0000,,いろいろありすぎだろ この島
Dialogue: 0,0:17:01.82,0:17:05.52,Default,,0000,0000,0000,,俺 なんで この島に 来たんだっけ?
Dialogue: 0,0:17:09.16,0:17:12.83,Default,,0000,0000,0000,,あの また少し 出てきたいんですけど
Dialogue: 0,0:17:12.83,0:17:15.50,Default,,0000,0000,0000,,うん? 聞いたよ
Dialogue: 0,0:17:15.50,0:17:18.34,Default,,0000,0000,0000,,少年団のみんなと 仲よくなったんだってね
Dialogue: 0,0:17:18.34,0:17:20.67,Default,,0000,0000,0000,,ええ まあ
Dialogue: 0,0:17:20.67,0:17:24.68,Default,,0000,0000,0000,,よかった
Dialogue: 0,0:17:20.67,0:17:24.68,Default,,0000,0000,0000,,羽依里くんが楽しそうで
Dialogue: 0,0:17:24.68,0:17:30.18,Default,,0000,0000,0000,,あの なんか すみません
Dialogue: 0,0:17:24.68,0:17:30.18,Default,,0000,0000,0000,,全然 お手伝いできてなくって
Dialogue: 0,0:17:30.18,0:17:33.99,Default,,0000,0000,0000,,ん まあ ぼちぼち お願いするよ
Dialogue: 0,0:17:33.99,0:17:36.66,Default,,0000,0000,0000,,ぼちぼち ですか?
Dialogue: 0,0:17:36.66,0:17:39.16,Default,,0000,0000,0000,,うん
Dialogue: 0,0:17:39.16,0:17:44.66,Default,,0000,0000,0000,,そうだ 俺が ここに来たのは
Dialogue: 0,0:17:39.16,0:17:44.66,Default,,0000,0000,0000,,鏡子さんに呼ばれたからだ
Dialogue: 0,0:17:44.66,0:17:48.67,Default,,0000,0000,0000,,いや それは口実だ
Dialogue: 0,0:17:48.67,0:17:52.84,Default,,0000,0000,0000,,とにかく俺は どこかへ逃げたかったんだ
Dialogue: 0,0:17:52.84,0:17:56.01,Default,,0000,0000,0000,,やりたいことを 探しています!
Dialogue: 0,0:18:13.19,0:18:15.56,Default,,0000,0000,0000,,あれ?
Dialogue: 0,0:18:21.53,0:18:23.50,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:18:26.04,0:18:28.51,Default,,0000,0000,0000,,こんばんは
Dialogue: 0,0:18:26.04,0:18:28.51,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:31.38,0:18:35.81,Default,,0000,0000,0000,,なにしてるの?
Dialogue: 0,0:18:31.38,0:18:35.81,Default,,0000,0000,0000,,ただの散歩
Dialogue: 0,0:18:35.81,0:18:37.78,Default,,0000,0000,0000,,そう
Dialogue: 0,0:18:39.99,0:18:42.15,Default,,0000,0000,0000,,えっと
Dialogue: 0,0:18:42.15,0:18:44.49,Default,,0000,0000,0000,,しろはさんは
Dialogue: 0,0:18:44.49,0:18:47.66,Default,,0000,0000,0000,,えっ!? なんで知ってるの 名前
Dialogue: 0,0:18:47.66,0:18:53.33,Default,,0000,0000,0000,,自己紹介したじゃないか
Dialogue: 0,0:18:47.66,0:18:53.33,Default,,0000,0000,0000,,最初に会ったとき
Dialogue: 0,0:18:53.33,0:18:55.83,Default,,0000,0000,0000,,あっ はいばらさとし
Dialogue: 0,0:18:55.83,0:18:58.84,Default,,0000,0000,0000,,違う 鷹原羽依里
Dialogue: 0,0:18:58.84,0:19:01.17,Default,,0000,0000,0000,,それで しろはさんは
Dialogue: 0,0:19:01.17,0:19:03.84,Default,,0000,0000,0000,,名前
Dialogue: 0,0:19:01.17,0:19:03.84,Default,,0000,0000,0000,,あっ ごめん
Dialogue: 0,0:19:03.84,0:19:07.01,Default,,0000,0000,0000,,逆に変だから 「さん」はいらない
Dialogue: 0,0:19:07.01,0:19:09.35,Default,,0000,0000,0000,,えっ あっ うん
Dialogue: 0,0:19:09.35,0:19:12.68,Default,,0000,0000,0000,,それで なに
Dialogue: 0,0:19:09.35,0:19:12.68,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:19:12.68,0:19:18.36,Default,,0000,0000,0000,,なにか聞こうとしてたから
Dialogue: 0,0:19:12.68,0:19:18.36,Default,,0000,0000,0000,,ああ うん その
Dialogue: 0,0:19:18.36,0:19:22.86,Default,,0000,0000,0000,,ここに来たとき 船の上から港にいる しろはさん
Dialogue: 0,0:19:22.86,0:19:25.20,Default,,0000,0000,0000,,しろはを見たんだ
Dialogue: 0,0:19:22.86,0:19:25.20,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:19:25.20,0:19:28.87,Default,,0000,0000,0000,,いや 別に何か 意図があったわけじゃなくて
Dialogue: 0,0:19:28.87,0:19:32.04,Default,,0000,0000,0000,,ただ船から見えたんだ
Dialogue: 0,0:19:32.04,0:19:35.44,Default,,0000,0000,0000,,しろはは じっと何かを見ていた
Dialogue: 0,0:19:35.44,0:19:38.61,Default,,0000,0000,0000,,鳥
Dialogue: 0,0:19:35.44,0:19:38.61,Default,,0000,0000,0000,,えっ 鳥?
Dialogue: 0,0:19:38.61,0:19:45.62,Default,,0000,0000,0000,,うん あのとき 海の上を
Dialogue: 0,0:19:38.61,0:19:45.62,Default,,0000,0000,0000,,2羽の鳥が飛んでいたの
Dialogue: 0,0:19:51.46,0:19:54.96,Default,,0000,0000,0000,,あなたは何しに来たの?
Dialogue: 0,0:19:51.46,0:19:54.96,Default,,0000,0000,0000,,こんな島に
Dialogue: 0,0:19:57.80,0:20:02.00,Default,,0000,0000,0000,,それは 思い出せないんだ
Dialogue: 0,0:20:03.97,0:20:08.64,Default,,0000,0000,0000,,なにが?
Dialogue: 0,0:20:03.97,0:20:08.64,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:20:08.64,0:20:13.81,Default,,0000,0000,0000,,今なら なんとなく
Dialogue: 0,0:20:08.64,0:20:13.81,Default,,0000,0000,0000,,言葉にできる気がした
Dialogue: 0,0:20:13.81,0:20:16.32,Default,,0000,0000,0000,,俺が この島に来た理由
Dialogue: 0,0:20:18.32,0:20:24.66,Default,,0000,0000,0000,,そうだ 俺は思い出せなくて
Dialogue: 0,0:20:24.66,0:20:32.86,Default,,0000,0000,0000,,あの街で流れていく時間の中で
Dialogue: 0,0:20:24.66,0:20:32.86,Default,,0000,0000,0000,,溺れそうで 窒息しそうで
Dialogue: 0,0:20:36.84,0:20:40.67,Default,,0000,0000,0000,,思い出したくて ここに来た
Dialogue: 0,0:20:40.67,0:20:43.34,Default,,0000,0000,0000,,夏休みの過ごし方
Dialogue: 0,0:20:43.34,0:20:46.51,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:20:43.34,0:20:46.51,Default,,0000,0000,0000,,あの さ
Dialogue: 0,0:20:46.51,0:20:50.62,Default,,0000,0000,0000,,今までで いちばん楽しかった 夏休みって いつ?
Dialogue: 0,0:20:53.52,0:20:57.02,Default,,0000,0000,0000,,小さいとき かな
Dialogue: 0,0:20:57.02,0:21:01.53,Default,,0000,0000,0000,,うん やっぱり
Dialogue: 0,0:20:57.02,0:21:01.53,Default,,0000,0000,0000,,子どもの頃だよな
Dialogue: 0,0:21:01.53,0:21:08.37,Default,,0000,0000,0000,,ずっと昔 小さな頃
Dialogue: 0,0:21:01.53,0:21:08.37,Default,,0000,0000,0000,,永遠みたいな夏を駆け回っていた
Dialogue: 0,0:21:08.37,0:21:14.37,Default,,0000,0000,0000,,家族と 友達と どんなに遊んでも
Dialogue: 0,0:21:08.37,0:21:14.37,Default,,0000,0000,0000,,やることは尽きなくて
Dialogue: 0,0:21:14.37,0:21:18.88,Default,,0000,0000,0000,,太陽は そんな毎日を 眩しく照らし続けていた
Dialogue: 0,0:21:18.88,0:21:22.05,Default,,0000,0000,0000,,いつの間にか 忘れてしまっていた風景
Dialogue: 0,0:21:22.05,0:21:26.22,Default,,0000,0000,0000,,でも 確かに覚えている風景
Dialogue: 0,0:21:26.22,0:21:31.72,Default,,0000,0000,0000,,この島に来てから
Dialogue: 0,0:21:26.22,0:21:31.72,Default,,0000,0000,0000,,小さいときのことを思い出すんだ
Dialogue: 0,0:21:31.72,0:21:36.70,Default,,0000,0000,0000,,なんでかな
Dialogue: 0,0:21:31.72,0:21:36.70,Default,,0000,0000,0000,,ちょっとだけワクワクする
Dialogue: 0,0:21:36.70,0:21:39.53,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:39.53,0:21:42.53,Default,,0000,0000,0000,,そう思えるのは きっと
Dialogue: 0,0:21:42.53,0:21:47.71,Default,,0000,0000,0000,,島が あなたに
Dialogue: 0,0:21:42.53,0:21:47.71,Default,,0000,0000,0000,,合ってるのかもしれない
Dialogue: 0,0:21:47.71,0:21:51.68,Default,,0000,0000,0000,,そうか だったらいいな
Dialogue: 0,0:21:51.68,0:21:54.08,Default,,0000,0000,0000,,うん
Dialogue: 0,0:21:56.05,0:21:59.55,Default,,0000,0000,0000,,あの ひとつ 聞きたいことがある
Dialogue: 0,0:21:59.55,0:22:01.55,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:22:01.55,0:22:05.22,Default,,0000,0000,0000,,あの あのね
Dialogue: 0,0:22:01.55,0:22:05.22,Default,,0000,0000,0000,,うん
Dialogue: 0,0:22:05.22,0:22:09.06,Default,,0000,0000,0000,,翼が 傷ついているって何?
Dialogue: 0,0:22:09.06,0:22:13.23,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:22:09.06,0:22:13.23,Default,,0000,0000,0000,,あなたは 傷ついた翼を癒やしに来たって
Dialogue: 0,0:22:13.23,0:22:16.23,Default,,0000,0000,0000,,木戸のおばあちゃんから 聞いたから
Dialogue: 0,0:22:16.23,0:22:18.20,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:22:21.57,0:22:25.58,Default,,0000,0000,0000,,比喩だよ 比喩
Dialogue: 0,0:22:21.57,0:22:25.58,Default,,0000,0000,0000,,いろいろあったっていう
Dialogue: 0,0:22:25.58,0:22:30.72,Default,,0000,0000,0000,,いろいろあって
Dialogue: 0,0:22:25.58,0:22:30.72,Default,,0000,0000,0000,,翼が傷ついて 舞い上がれない
Dialogue: 0,0:22:30.72,0:22:32.72,Default,,0000,0000,0000,,そんな感じ
Dialogue: 0,0:22:32.72,0:22:36.32,Default,,0000,0000,0000,,そんな感じ
Dialogue: 0,0:22:36.32,0:22:38.32,Default,,0000,0000,0000,,変なの
