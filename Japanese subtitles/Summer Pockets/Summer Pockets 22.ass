Dialogue: 0,0:00:34.67,0:00:38.00,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:38.00,0:00:40.01,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:40.01,0:00:42.18,Default,,0000,0000,0000,,えっ? えっ!?
Dialogue: 0,0:00:42.18,0:00:45.85,Default,,0000,0000,0000,,んっ ふぁ んっ
Dialogue: 0,0:00:45.85,0:00:48.52,Default,,0000,0000,0000,,えっ? えっ!?
Dialogue: 0,0:00:48.52,0:00:51.62,Default,,0000,0000,0000,,おはよ
Dialogue: 0,0:00:48.52,0:00:51.62,Default,,0000,0000,0000,,おはよ
Dialogue: 0,0:00:53.69,0:00:56.19,Default,,0000,0000,0000,,どうして お泊まりしたんだろ
Dialogue: 0,0:00:56.19,0:01:00.03,Default,,0000,0000,0000,,俺も覚えてないけど
Dialogue: 0,0:01:00.03,0:01:03.53,Default,,0000,0000,0000,,してない と思う
Dialogue: 0,0:01:03.53,0:01:05.53,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:02:49.34,0:02:51.54,Default,,0000,0000,0000,,えっと
Dialogue: 0,0:02:53.51,0:02:56.34,Default,,0000,0000,0000,,お お泊まり ですか?
Dialogue: 0,0:02:56.34,0:02:59.01,Default,,0000,0000,0000,,みたい
Dialogue: 0,0:02:56.34,0:02:59.01,Default,,0000,0000,0000,,っぽい
Dialogue: 0,0:02:59.01,0:03:01.01,Default,,0000,0000,0000,,えっ!
Dialogue: 0,0:03:01.01,0:03:06.19,Default,,0000,0000,0000,,ま まぁ こ 恋人同士だから
Dialogue: 0,0:03:01.01,0:03:06.19,Default,,0000,0000,0000,,問題はないっちゃあないんだけど
Dialogue: 0,0:03:06.19,0:03:09.52,Default,,0000,0000,0000,,で どうしたんだ?
Dialogue: 0,0:03:06.19,0:03:09.52,Default,,0000,0000,0000,,こんな朝早くから
Dialogue: 0,0:03:09.52,0:03:11.86,Default,,0000,0000,0000,,あっ そうだった これ
Dialogue: 0,0:03:11.86,0:03:14.86,Default,,0000,0000,0000,,あぁ 連絡くれれば 取りに行ったのに
Dialogue: 0,0:03:14.86,0:03:18.03,Default,,0000,0000,0000,,2人とも すっごい楽しみにしてたからさ
Dialogue: 0,0:03:18.03,0:03:22.84,Default,,0000,0000,0000,,朝イチで届いたの持ってきたの
Dialogue: 0,0:03:18.03,0:03:22.84,Default,,0000,0000,0000,,ありがとう 蒼
Dialogue: 0,0:03:27.54,0:03:30.71,Default,,0000,0000,0000,,へぇ しろはが こんなふうに 笑ってくれるなんて
Dialogue: 0,0:03:30.71,0:03:35.98,Default,,0000,0000,0000,,あんたのおかげね
Dialogue: 0,0:03:30.71,0:03:35.98,Default,,0000,0000,0000,,そう かな?
Dialogue: 0,0:03:35.98,0:03:40.29,Default,,0000,0000,0000,,うわ こゆのを バカップルって言うのよね
Dialogue: 0,0:03:42.99,0:03:46.33,Default,,0000,0000,0000,,足りない
Dialogue: 0,0:03:42.99,0:03:46.33,Default,,0000,0000,0000,,えっ? 枚数間違ってる?
Dialogue: 0,0:03:46.33,0:03:49.33,Default,,0000,0000,0000,,いや そうじゃないけど
Dialogue: 0,0:03:52.67,0:03:55.37,Default,,0000,0000,0000,,しろは できたぞ!
Dialogue: 0,0:03:58.50,0:04:03.68,Default,,0000,0000,0000,,何点だ?
Dialogue: 0,0:03:58.50,0:04:03.68,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:03:58.50,0:04:03.68,Default,,0000,0000,0000,,あっ いや なんとなく
Dialogue: 0,0:04:03.68,0:04:06.68,Default,,0000,0000,0000,,20点 でも おいしい
Dialogue: 0,0:04:06.68,0:04:08.68,Default,,0000,0000,0000,,サンキュー
Dialogue: 0,0:04:15.86,0:04:19.19,Default,,0000,0000,0000,,でも なんで 俺がチャーハン作ったんだ?
Dialogue: 0,0:04:19.19,0:04:21.69,Default,,0000,0000,0000,,しろはのほうが ずっと おいしいのに
Dialogue: 0,0:04:21.69,0:04:25.03,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:04:25.03,0:04:27.03,Default,,0000,0000,0000,,絵本?
Dialogue: 0,0:04:27.03,0:04:29.04,Default,,0000,0000,0000,,なんで こんなとこに
Dialogue: 0,0:04:29.04,0:04:31.54,Default,,0000,0000,0000,,ねぇ これ
Dialogue: 0,0:04:29.04,0:04:31.54,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:04:31.54,0:04:34.14,Default,,0000,0000,0000,,向こうで 見つけたんだけど
Dialogue: 0,0:04:34.14,0:04:36.14,Default,,0000,0000,0000,,それ!
Dialogue: 0,0:04:39.31,0:04:41.81,Default,,0000,0000,0000,,この前も 俺のほうが飛んだんだよな
Dialogue: 0,0:04:41.81,0:04:47.65,Default,,0000,0000,0000,,ううん 私の
Dialogue: 0,0:04:41.81,0:04:47.65,Default,,0000,0000,0000,,スーパーマスタングファイアコズミックモードレベルⅦ
Dialogue: 0,0:04:47.65,0:04:50.56,Default,,0000,0000,0000,,ちゃんと覚えてるんだ 名前
Dialogue: 0,0:04:52.66,0:04:54.66,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:04:52.66,0:04:54.66,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:07.51,0:05:09.84,Default,,0000,0000,0000,,約束
Dialogue: 0,0:05:07.51,0:05:09.84,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:09.84,0:05:15.68,Default,,0000,0000,0000,,今日の花火大会
Dialogue: 0,0:05:09.84,0:05:15.68,Default,,0000,0000,0000,,一緒に見に行くって約束したよな
Dialogue: 0,0:05:15.68,0:05:18.18,Default,,0000,0000,0000,,うん 覚えてる
Dialogue: 0,0:05:21.19,0:05:23.59,Default,,0000,0000,0000,,あん
Dialogue: 0,0:05:26.03,0:05:28.53,Default,,0000,0000,0000,,へぇ ホントに誰もいないんだな
Dialogue: 0,0:05:28.53,0:05:31.03,Default,,0000,0000,0000,,私だけが知ってる 穴場だから
Dialogue: 0,0:05:31.03,0:05:34.63,Default,,0000,0000,0000,,ここなら 2人きりで落ち着いて見られる
Dialogue: 0,0:05:34.63,0:05:38.30,Default,,0000,0000,0000,,2人きり か
Dialogue: 0,0:05:38.30,0:05:40.61,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:47.98,0:05:50.82,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:50.82,0:05:54.62,Default,,0000,0000,0000,,おぉ 思ったより本格的
Dialogue: 0,0:05:50.82,0:05:54.62,Default,,0000,0000,0000,,でしょ?
Dialogue: 0,0:05:58.83,0:06:01.83,Default,,0000,0000,0000,,夏が
Dialogue: 0,0:05:58.83,0:06:01.83,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:06:01.83,0:06:05.03,Default,,0000,0000,0000,,夏が 終わってくんだな
Dialogue: 0,0:06:07.00,0:06:09.00,Default,,0000,0000,0000,,うん
Dialogue: 0,0:06:19.68,0:06:21.68,Default,,0000,0000,0000,,羽依里
Dialogue: 0,0:06:29.52,0:06:33.63,Default,,0000,0000,0000,,約束 守れなかったな
Dialogue: 0,0:06:33.63,0:06:36.63,Default,,0000,0000,0000,,ごめんな
Dialogue: 0,0:06:39.30,0:06:41.30,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:06:41.30,0:06:43.30,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:06:46.47,0:06:48.47,Default,,0000,0000,0000,,うみゅ
Dialogue: 0,0:06:50.98,0:06:52.98,Default,,0000,0000,0000,,うみちゃん!
Dialogue: 0,0:06:54.98,0:06:58.15,Default,,0000,0000,0000,,ごめん ごめんね うみちゃん
Dialogue: 0,0:06:58.15,0:07:00.35,Default,,0000,0000,0000,,おかーさん
Dialogue: 0,0:07:02.32,0:07:04.82,Default,,0000,0000,0000,,もうどこにも行かないよね?
Dialogue: 0,0:07:04.82,0:07:08.16,Default,,0000,0000,0000,,おかーさんたちと一緒にいて
Dialogue: 0,0:07:08.16,0:07:10.50,Default,,0000,0000,0000,,おかーさん 泣かないで
Dialogue: 0,0:07:10.50,0:07:13.83,Default,,0000,0000,0000,,ずっとずっと そばにいてほしいの
Dialogue: 0,0:07:13.83,0:07:17.84,Default,,0000,0000,0000,,私 もっといい おかーさんになるから
Dialogue: 0,0:07:17.84,0:07:21.17,Default,,0000,0000,0000,,また一緒に折り紙をしよう
Dialogue: 0,0:07:21.17,0:07:23.34,Default,,0000,0000,0000,,お歌も一緒に歌おう
Dialogue: 0,0:07:23.34,0:07:25.34,Default,,0000,0000,0000,,かくれんぼしよう
Dialogue: 0,0:07:25.34,0:07:28.35,Default,,0000,0000,0000,,おかーさん うみちゃんがどこにいても
Dialogue: 0,0:07:28.35,0:07:30.35,Default,,0000,0000,0000,,絶対見つけるから
Dialogue: 0,0:07:30.35,0:07:34.12,Default,,0000,0000,0000,,遊んだあとは 一緒におうちに帰って
Dialogue: 0,0:07:34.12,0:07:38.79,Default,,0000,0000,0000,,一緒に お布団に入って 「おやすみなさい」をして
Dialogue: 0,0:07:38.79,0:07:41.63,Default,,0000,0000,0000,,朝は 「おはよう」って
Dialogue: 0,0:07:41.63,0:07:46.63,Default,,0000,0000,0000,,おかーさんにちゃんと 「おはよう」って言わせて
Dialogue: 0,0:07:46.63,0:07:49.64,Default,,0000,0000,0000,,おかーさん
Dialogue: 0,0:07:49.64,0:07:54.14,Default,,0000,0000,0000,,私も おかーさんと もっともっと一緒にいたい
Dialogue: 0,0:07:54.14,0:07:57.31,Default,,0000,0000,0000,,でも もう無理みたい
Dialogue: 0,0:07:57.31,0:08:01.15,Default,,0000,0000,0000,,どうして
Dialogue: 0,0:07:57.31,0:08:01.15,Default,,0000,0000,0000,,おかーさんじゃダメなの?
Dialogue: 0,0:08:01.15,0:08:03.15,Default,,0000,0000,0000,,そんなことない
Dialogue: 0,0:08:03.15,0:08:05.65,Default,,0000,0000,0000,,すごく楽しい夏休みだった
Dialogue: 0,0:08:05.65,0:08:10.32,Default,,0000,0000,0000,,本当に本当に さいこーの夏休みだった
Dialogue: 0,0:08:10.32,0:08:14.49,Default,,0000,0000,0000,,おかーさんと一緒にいられて うれしかった
Dialogue: 0,0:08:14.49,0:08:17.50,Default,,0000,0000,0000,,うっ フフ
Dialogue: 0,0:08:17.50,0:08:20.67,Default,,0000,0000,0000,,おとーさん ありがとう
Dialogue: 0,0:08:20.67,0:08:23.17,Default,,0000,0000,0000,,とても楽しい夏だった
Dialogue: 0,0:08:23.17,0:08:28.17,Default,,0000,0000,0000,,そうか 楽しかったか
Dialogue: 0,0:08:28.17,0:08:31.01,Default,,0000,0000,0000,,でも これから もっと楽しくなる
Dialogue: 0,0:08:31.01,0:08:37.78,Default,,0000,0000,0000,,夏が終わっても 秋も 冬だって
Dialogue: 0,0:08:31.01,0:08:37.78,Default,,0000,0000,0000,,春だって ずっとずっと
Dialogue: 0,0:08:37.78,0:08:41.45,Default,,0000,0000,0000,,俺が
Dialogue: 0,0:08:37.78,0:08:41.45,Default,,0000,0000,0000,,おとーさんが楽しくしてやる
Dialogue: 0,0:08:41.45,0:08:43.76,Default,,0000,0000,0000,,うん
Dialogue: 0,0:08:48.79,0:08:52.13,Default,,0000,0000,0000,,すっごくきれいだね
Dialogue: 0,0:08:52.13,0:08:57.14,Default,,0000,0000,0000,,花火見られて
Dialogue: 0,0:08:52.13,0:08:57.14,Default,,0000,0000,0000,,約束守れて よかった
Dialogue: 0,0:08:57.14,0:09:02.81,Default,,0000,0000,0000,,じゃあ また約束しよう
Dialogue: 0,0:08:57.14,0:09:02.81,Default,,0000,0000,0000,,次は何する?
Dialogue: 0,0:09:02.81,0:09:07.48,Default,,0000,0000,0000,,そうだ また日記を書けばいい
Dialogue: 0,0:09:02.81,0:09:07.48,Default,,0000,0000,0000,,明日からの分をさ
Dialogue: 0,0:09:07.48,0:09:11.98,Default,,0000,0000,0000,,どんなことでも 書いたことが本当になる日記だ
Dialogue: 0,0:09:11.98,0:09:14.99,Default,,0000,0000,0000,,なんでも願い事がかなうんだ!
Dialogue: 0,0:09:14.99,0:09:20.99,Default,,0000,0000,0000,,だから だから
Dialogue: 0,0:09:14.99,0:09:20.99,Default,,0000,0000,0000,,また 続きを
Dialogue: 0,0:09:20.99,0:09:24.33,Default,,0000,0000,0000,,絵日記 書いてくれよ
Dialogue: 0,0:09:24.33,0:09:27.67,Default,,0000,0000,0000,,ありがとう おとーさん
Dialogue: 0,0:09:27.67,0:09:29.84,Default,,0000,0000,0000,,でも もういいの
Dialogue: 0,0:09:29.84,0:09:33.61,Default,,0000,0000,0000,,やりたいこと 全部かなったから
Dialogue: 0,0:09:33.61,0:09:36.78,Default,,0000,0000,0000,,この夏休み 本当に楽しかった
Dialogue: 0,0:09:36.78,0:09:42.78,Default,,0000,0000,0000,,おとーさんと おかーさんと
Dialogue: 0,0:09:36.78,0:09:42.78,Default,,0000,0000,0000,,一緒に過ごせて でも
Dialogue: 0,0:09:42.78,0:09:45.12,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:09:45.12,0:09:48.62,Default,,0000,0000,0000,,私のせいで おとーさんも おかーさんも
Dialogue: 0,0:09:48.62,0:09:51.12,Default,,0000,0000,0000,,悲しい思いをさせてしまって
Dialogue: 0,0:09:51.12,0:09:54.79,Default,,0000,0000,0000,,私だけ 幸せな気持ちになっちゃった!
Dialogue: 0,0:09:54.79,0:09:59.47,Default,,0000,0000,0000,,毎日うれしくて 本当にうれしくて
Dialogue: 0,0:09:59.47,0:10:02.97,Default,,0000,0000,0000,,私ばっかりが こんなに幸せで
Dialogue: 0,0:10:02.97,0:10:04.97,Default,,0000,0000,0000,,初めて
Dialogue: 0,0:10:04.97,0:10:08.07,Default,,0000,0000,0000,,夏が終わってほしくないって 思ったの!
Dialogue: 0,0:10:12.31,0:10:14.81,Default,,0000,0000,0000,,おかーさんも幸せだったよ
Dialogue: 0,0:10:14.81,0:10:19.49,Default,,0000,0000,0000,,うみちゃんと会えて とってもとっても幸せだったよ
Dialogue: 0,0:10:19.49,0:10:21.82,Default,,0000,0000,0000,,おかーさん
Dialogue: 0,0:10:21.82,0:10:24.82,Default,,0000,0000,0000,,おとーさんだって うみと過ごした この夏
Dialogue: 0,0:10:24.82,0:10:27.66,Default,,0000,0000,0000,,すっごく楽しかった!
Dialogue: 0,0:10:27.66,0:10:30.83,Default,,0000,0000,0000,,この夏が 終わらなければいいのにって
Dialogue: 0,0:10:30.83,0:10:32.83,Default,,0000,0000,0000,,今も思ってるんだ
Dialogue: 0,0:10:32.83,0:10:34.83,Default,,0000,0000,0000,,おとーさん
Dialogue: 0,0:10:46.35,0:10:49.02,Default,,0000,0000,0000,,おとーさん おかーさん
Dialogue: 0,0:10:49.02,0:10:52.69,Default,,0000,0000,0000,,ありがとう 私も すごく楽しかった
Dialogue: 0,0:10:52.69,0:10:58.02,Default,,0000,0000,0000,,でも ちょっとだけ ばいばい
Dialogue: 0,0:11:25.72,0:11:28.72,Default,,0000,0000,0000,,しろは? どうして泣いてるんだ?
Dialogue: 0,0:11:28.72,0:11:30.89,Default,,0000,0000,0000,,えっ? 私?
Dialogue: 0,0:11:30.89,0:11:35.33,Default,,0000,0000,0000,,本当だ でも 羽依里だって
Dialogue: 0,0:11:30.89,0:11:35.33,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:11:35.33,0:11:39.33,Default,,0000,0000,0000,,あっ なんでこんな
Dialogue: 0,0:11:39.33,0:11:42.13,Default,,0000,0000,0000,,あっ 花火?
Dialogue: 0,0:11:39.33,0:11:42.13,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:11:45.50,0:11:50.81,Default,,0000,0000,0000,,もう終わってるよ 花火
Dialogue: 0,0:11:45.50,0:11:50.81,Default,,0000,0000,0000,,だよな
Dialogue: 0,0:11:52.85,0:11:55.01,Default,,0000,0000,0000,,永い旅をしてきた
Dialogue: 0,0:11:55.01,0:11:59.85,Default,,0000,0000,0000,,決してかなわないと思っていた 思い出を作ることができた
Dialogue: 0,0:11:59.85,0:12:04.36,Default,,0000,0000,0000,,私にとって大切な宝物になった
Dialogue: 0,0:12:04.36,0:12:10.36,Default,,0000,0000,0000,,何度も繰り返してきた
Dialogue: 0,0:12:04.36,0:12:10.36,Default,,0000,0000,0000,,夏休みが
Dialogue: 0,0:12:10.36,0:12:12.87,Default,,0000,0000,0000,,小さな冒険から始まり
Dialogue: 0,0:12:12.87,0:12:15.70,Default,,0000,0000,0000,,大きな絆をつなぐ夏があった
Dialogue: 0,0:12:15.70,0:12:18.04,Default,,0000,0000,0000,,限られた時間を
Dialogue: 0,0:12:18.04,0:12:21.37,Default,,0000,0000,0000,,まぶしい思い出に変える 夏があった
Dialogue: 0,0:12:21.37,0:12:26.55,Default,,0000,0000,0000,,大切な人との思い出を育み
Dialogue: 0,0:12:21.37,0:12:26.55,Default,,0000,0000,0000,,導く夏があった
Dialogue: 0,0:12:26.55,0:12:28.88,Default,,0000,0000,0000,,諦めないことで
Dialogue: 0,0:12:28.88,0:12:32.99,Default,,0000,0000,0000,,広がる可能性を知った夏があった
Dialogue: 0,0:12:32.99,0:12:35.99,Default,,0000,0000,0000,,そして おかーさんと 過ごすことができた
Dialogue: 0,0:12:35.99,0:12:38.49,Default,,0000,0000,0000,,最後の夏休み
Dialogue: 0,0:12:38.49,0:12:41.66,Default,,0000,0000,0000,,すべてが楽しかった
Dialogue: 0,0:12:41.66,0:12:45.33,Default,,0000,0000,0000,,うれしかった 愛しかった
Dialogue: 0,0:12:45.33,0:12:50.17,Default,,0000,0000,0000,,でも もし
Dialogue: 0,0:12:45.33,0:12:50.17,Default,,0000,0000,0000,,もし許されるのなら
Dialogue: 0,0:12:50.17,0:12:54.84,Default,,0000,0000,0000,,このままずっと おかーさんと一緒にいたい
Dialogue: 0,0:12:54.84,0:12:58.34,Default,,0000,0000,0000,,そう思った
Dialogue: 0,0:12:58.34,0:13:05.02,Default,,0000,0000,0000,,次の夏も
Dialogue: 0,0:12:58.34,0:13:05.02,Default,,0000,0000,0000,,おとーさんは島にやってきた
Dialogue: 0,0:13:05.02,0:13:07.32,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:10.36,0:13:12.86,Default,,0000,0000,0000,,よっ 久しぶり
Dialogue: 0,0:13:12.86,0:13:14.86,Default,,0000,0000,0000,,うん 久しぶり
Dialogue: 0,0:13:32.48,0:13:36.15,Default,,0000,0000,0000,,おめでとう しろは すっごく きれいだぞ
Dialogue: 0,0:13:36.15,0:13:39.15,Default,,0000,0000,0000,,でも しろはに 先越されちゃうなんてねぇ
Dialogue: 0,0:13:39.15,0:13:43.16,Default,,0000,0000,0000,,いや あのラブラブな2人なら これでも遅いくらいだ
Dialogue: 0,0:13:43.16,0:13:45.83,Default,,0000,0000,0000,,まぁ じーさんの お許しをもらうのに
Dialogue: 0,0:13:45.83,0:13:48.66,Default,,0000,0000,0000,,時間かかったからなぁ
Dialogue: 0,0:13:48.66,0:13:53.00,Default,,0000,0000,0000,,うぐっ あの しろはが
Dialogue: 0,0:13:48.66,0:13:53.00,Default,,0000,0000,0000,,しろはがぁ
Dialogue: 0,0:13:53.00,0:13:55.00,Default,,0000,0000,0000,,ぬあ
Dialogue: 0,0:13:55.00,0:13:57.50,Default,,0000,0000,0000,,小鳩さんったら
Dialogue: 0,0:13:57.50,0:13:59.51,Default,,0000,0000,0000,,ほら 見える? 瞳
Dialogue: 0,0:13:59.51,0:14:03.01,Default,,0000,0000,0000,,しろはちゃん お嫁さんだよ
Dialogue: 0,0:14:03.01,0:14:05.68,Default,,0000,0000,0000,,とてもとても 幸せそうだった
Dialogue: 0,0:14:05.68,0:14:10.38,Default,,0000,0000,0000,,こんな時間が ずっと続けばいい そう思っていた
Dialogue: 0,0:14:12.35,0:14:16.02,Default,,0000,0000,0000,,これからは この部屋で しろはと一緒に暮らすんだな
Dialogue: 0,0:14:16.02,0:14:19.02,Default,,0000,0000,0000,,うん 毎日 朝になったら
Dialogue: 0,0:14:19.02,0:14:21.03,Default,,0000,0000,0000,,羽依里に 「おはよう」って言うんだよ
Dialogue: 0,0:14:21.03,0:14:23.03,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:14:23.03,0:14:25.70,Default,,0000,0000,0000,,どうかした?
Dialogue: 0,0:14:23.03,0:14:25.70,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:25.70,0:14:29.10,Default,,0000,0000,0000,,子どもの声が 聞こえたような気がして
Dialogue: 0,0:14:31.37,0:14:33.57,Default,,0000,0000,0000,,これから よろしくね
Dialogue: 0,0:14:35.81,0:14:38.48,Default,,0000,0000,0000,,えっ 今 なんて?
Dialogue: 0,0:14:38.48,0:14:42.15,Default,,0000,0000,0000,,だから 赤ちゃん できた
Dialogue: 0,0:14:42.15,0:14:44.82,Default,,0000,0000,0000,,赤ちゃん?
Dialogue: 0,0:14:44.82,0:14:48.49,Default,,0000,0000,0000,,赤ちゃん 私たちの赤ちゃん
Dialogue: 0,0:14:48.49,0:14:50.49,Default,,0000,0000,0000,,マジで?
Dialogue: 0,0:14:48.49,0:14:50.49,Default,,0000,0000,0000,,マジ
Dialogue: 0,0:14:50.49,0:14:52.49,Default,,0000,0000,0000,,やっ
Dialogue: 0,0:14:52.49,0:14:55.59,Default,,0000,0000,0000,,やった!!
Dialogue: 0,0:14:59.00,0:15:02.50,Default,,0000,0000,0000,,島の人たちが
Dialogue: 0,0:15:02.50,0:15:05.50,Default,,0000,0000,0000,,ひーじーじが
Dialogue: 0,0:15:05.50,0:15:09.34,Default,,0000,0000,0000,,おとーさんが おかーさんに優しくて
Dialogue: 0,0:15:09.34,0:15:11.34,Default,,0000,0000,0000,,それに みんな
Dialogue: 0,0:15:11.34,0:15:14.68,Default,,0000,0000,0000,,私が産まれてくるのを 待ち望んでいてくれてる
Dialogue: 0,0:15:14.68,0:15:18.18,Default,,0000,0000,0000,,それが うれしくて うれしくて
Dialogue: 0,0:15:26.53,0:15:29.86,Default,,0000,0000,0000,,あっ ウフフ とっても元気
Dialogue: 0,0:15:29.86,0:15:33.80,Default,,0000,0000,0000,,聞こえるかな? おかーさんだよ
Dialogue: 0,0:15:33.80,0:15:35.80,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:38.80,0:15:42.31,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:15:42.31,0:15:48.31,Default,,0000,0000,0000,,そんな この子は 私とは
Dialogue: 0,0:15:48.31,0:15:53.65,Default,,0000,0000,0000,,もうずっと見てなかったのに
Dialogue: 0,0:15:48.31,0:15:53.65,Default,,0000,0000,0000,,どうして
Dialogue: 0,0:15:53.65,0:15:55.65,Default,,0000,0000,0000,,どうして
Dialogue: 0,0:15:57.66,0:16:00.49,Default,,0000,0000,0000,,あぁ そういうことなんだ
Dialogue: 0,0:16:00.49,0:16:06.33,Default,,0000,0000,0000,,だから 私に会いに
Dialogue: 0,0:16:00.49,0:16:06.33,Default,,0000,0000,0000,,来てくれたんだね あの夏
Dialogue: 0,0:16:06.33,0:16:08.33,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:16:13.51,0:16:17.11,Default,,0000,0000,0000,,うみちゃん ごめんね
Dialogue: 0,0:16:19.51,0:16:21.81,Default,,0000,0000,0000,,泣かないで おかーさん
Dialogue: 0,0:16:28.35,0:16:31.36,Default,,0000,0000,0000,,ごめんね
Dialogue: 0,0:16:31.36,0:16:37.06,Default,,0000,0000,0000,,謝らないで
Dialogue: 0,0:16:31.36,0:16:37.06,Default,,0000,0000,0000,,おかーさんは悪くないから
Dialogue: 0,0:16:38.96,0:16:41.80,Default,,0000,0000,0000,,それにしても すごい偶然だな
Dialogue: 0,0:16:41.80,0:16:44.30,Default,,0000,0000,0000,,しろはも 同じ名前を思いついたなんて
Dialogue: 0,0:16:44.30,0:16:46.31,Default,,0000,0000,0000,,そうだね
Dialogue: 0,0:16:46.31,0:16:49.14,Default,,0000,0000,0000,,あっ! でも うみって 女の子の名前だよな?
Dialogue: 0,0:16:49.14,0:16:51.31,Default,,0000,0000,0000,,もし 男の子だったら
Dialogue: 0,0:16:51.31,0:16:53.48,Default,,0000,0000,0000,,ううん 大丈夫
Dialogue: 0,0:16:53.48,0:16:58.65,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:16:53.48,0:16:58.65,Default,,0000,0000,0000,,あなたは うみちゃんになったよ
Dialogue: 0,0:16:58.65,0:17:02.99,Default,,0000,0000,0000,,それから おかーさんは 少し変わってしまった
Dialogue: 0,0:17:02.99,0:17:05.82,Default,,0000,0000,0000,,おとーさんが仕事に行ってる間
Dialogue: 0,0:17:05.82,0:17:11.16,Default,,0000,0000,0000,,蔵にこもって 古い書物を
Dialogue: 0,0:17:05.82,0:17:11.16,Default,,0000,0000,0000,,毎日読みふけるようになった
Dialogue: 0,0:17:11.16,0:17:14.00,Default,,0000,0000,0000,,私の過去に戻る力が
Dialogue: 0,0:17:14.00,0:17:17.84,Default,,0000,0000,0000,,発現しない方法を 探しているみたいだった
Dialogue: 0,0:17:17.84,0:17:20.01,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:17:20.01,0:17:22.51,Default,,0000,0000,0000,,おかーさん!
Dialogue: 0,0:17:22.51,0:17:27.01,Default,,0000,0000,0000,,こんな こんな力がなければ
Dialogue: 0,0:17:27.01,0:17:29.35,Default,,0000,0000,0000,,未来は変わるかもしれないのに
Dialogue: 0,0:17:29.35,0:17:34.15,Default,,0000,0000,0000,,うみちゃんを 普通の女の子で いさせてあげられたのに
Dialogue: 0,0:17:38.12,0:17:40.79,Default,,0000,0000,0000,,いつか おとーさんが言ってた
Dialogue: 0,0:17:40.79,0:17:45.30,Default,,0000,0000,0000,,「諦めさえしなければ 未来は変えられる」と
Dialogue: 0,0:17:45.30,0:17:48.80,Default,,0000,0000,0000,,なら あの夏を変えるには?
Dialogue: 0,0:17:52.64,0:17:57.64,Default,,0000,0000,0000,,おかーさんが 未来視の力を 得ることがなければ
Dialogue: 0,0:17:57.64,0:18:00.48,Default,,0000,0000,0000,,しろは 今日も調べものか?
Dialogue: 0,0:18:00.48,0:18:02.48,Default,,0000,0000,0000,,あまり無理しちゃ
Dialogue: 0,0:18:02.48,0:18:04.65,Default,,0000,0000,0000,,あっ! しろは!
Dialogue: 0,0:18:04.65,0:18:06.99,Default,,0000,0000,0000,,しっかりしろ! しろは!
Dialogue: 0,0:18:06.99,0:18:09.66,Default,,0000,0000,0000,,先生!
Dialogue: 0,0:18:06.99,0:18:09.66,Default,,0000,0000,0000,,すぐに来てください!
Dialogue: 0,0:18:09.66,0:18:12.06,Default,,0000,0000,0000,,しろはが しろはが!
Dialogue: 0,0:18:14.99,0:18:20.17,Default,,0000,0000,0000,,しろは
Dialogue: 0,0:18:14.99,0:18:20.17,Default,,0000,0000,0000,,産まれたぞ うみだ
Dialogue: 0,0:18:20.17,0:18:24.17,Default,,0000,0000,0000,,俺たちの娘が 産まれたんだ
Dialogue: 0,0:18:24.17,0:18:27.51,Default,,0000,0000,0000,,だから なぁ
Dialogue: 0,0:18:27.51,0:18:31.51,Default,,0000,0000,0000,,目を開けてくれよ しろは
Dialogue: 0,0:18:34.11,0:18:39.82,Default,,0000,0000,0000,,うっ うぅ あぁ
Dialogue: 0,0:18:42.29,0:18:46.46,Default,,0000,0000,0000,,おかーさんは 私のために
Dialogue: 0,0:18:46.46,0:18:51.13,Default,,0000,0000,0000,,ただただ 私のためだけを思って
Dialogue: 0,0:18:51.13,0:18:57.14,Default,,0000,0000,0000,,こんな悲しみに包まれた光景
Dialogue: 0,0:18:51.13,0:18:57.14,Default,,0000,0000,0000,,見たくない 逃げたい!
Dialogue: 0,0:19:00.47,0:19:02.47,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:19:02.47,0:19:06.81,Default,,0000,0000,0000,,ここは へじゃぷ
Dialogue: 0,0:19:04.48,0:19:06.81,Default,,0000,0000,0000,,へっ?
Dialogue: 0,0:19:06.81,0:19:11.15,Default,,0000,0000,0000,,それって デジャブじゃないですか?
Dialogue: 0,0:19:11.15,0:19:16.05,Default,,0000,0000,0000,,そうそう へじゃぷ
Dialogue: 0,0:19:11.15,0:19:16.05,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:19.66,0:19:24.00,Default,,0000,0000,0000,,おとーさん また心だけ過去に
Dialogue: 0,0:19:24.00,0:19:28.00,Default,,0000,0000,0000,,逃げ出してしまった あの夏休みに
Dialogue: 0,0:19:28.00,0:19:31.67,Default,,0000,0000,0000,,でも この夏に もう私はいない
Dialogue: 0,0:19:31.67,0:19:34.77,Default,,0000,0000,0000,,だったら おとーさんと おかーさんは
Dialogue: 0,0:19:34.77,0:19:39.44,Default,,0000,0000,0000,,仲よくなることはなくて 未来は変わる
Dialogue: 0,0:19:39.44,0:19:45.62,Default,,0000,0000,0000,,よかった これで
Dialogue: 0,0:19:39.44,0:19:45.62,Default,,0000,0000,0000,,おかーさんは死なずに済む
Dialogue: 0,0:19:45.62,0:19:50.62,Default,,0000,0000,0000,,けれど そうじゃなかった こい
Dialogue: 0,0:19:48.62,0:19:50.62,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:19:50.62,0:19:52.79,Default,,0000,0000,0000,,どすこいっ!
Dialogue: 0,0:19:52.79,0:19:56.13,Default,,0000,0000,0000,,おとーさんと おかーさんは出会う
Dialogue: 0,0:19:56.13,0:19:58.13,Default,,0000,0000,0000,,出会って 恋をして
Dialogue: 0,0:19:58.13,0:20:02.30,Default,,0000,0000,0000,,一緒に夏を過ごし始め 恋に落ちて
Dialogue: 0,0:20:02.30,0:20:06.31,Default,,0000,0000,0000,,あの夏をたどっていく
Dialogue: 0,0:20:06.31,0:20:10.31,Default,,0000,0000,0000,,どうして
Dialogue: 0,0:20:06.31,0:20:10.31,Default,,0000,0000,0000,,私はいないはずなのに
Dialogue: 0,0:20:10.31,0:20:12.98,Default,,0000,0000,0000,,未来は変わるんじゃないの?
Dialogue: 0,0:20:12.98,0:20:16.98,Default,,0000,0000,0000,,ダメ ダメだよ おかーさん!
Dialogue: 0,0:20:18.98,0:20:20.99,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:20:22.99,0:20:25.32,Default,,0000,0000,0000,,どうして?
Dialogue: 0,0:20:25.32,0:20:29.16,Default,,0000,0000,0000,,私と出会ってない 夏休みだったはずなのに
Dialogue: 0,0:20:29.16,0:20:33.33,Default,,0000,0000,0000,,おかーさんは 私を知っている
Dialogue: 0,0:20:33.33,0:20:36.00,Default,,0000,0000,0000,,あぁ そうなんだ
Dialogue: 0,0:20:36.00,0:20:38.50,Default,,0000,0000,0000,,おかーさんは 未来を見てるんじゃない
Dialogue: 0,0:20:38.50,0:20:44.34,Default,,0000,0000,0000,,私と同じで 未来から
Dialogue: 0,0:20:38.50,0:20:44.34,Default,,0000,0000,0000,,心だけ戻ってきてたんだ
Dialogue: 0,0:20:44.34,0:20:49.51,Default,,0000,0000,0000,,目を開けてくれよ
Dialogue: 0,0:20:44.34,0:20:49.51,Default,,0000,0000,0000,,しろは
Dialogue: 0,0:20:49.51,0:20:54.02,Default,,0000,0000,0000,,私が産まれて おかーさんが死んでしまった
Dialogue: 0,0:20:54.02,0:20:57.02,Default,,0000,0000,0000,,その現実が受け入れがたくて
Dialogue: 0,0:20:57.02,0:21:01.19,Default,,0000,0000,0000,,そこから目を背けたくて あの夏に戻ってる
Dialogue: 0,0:21:01.19,0:21:07.03,Default,,0000,0000,0000,,もう定められてしまった道を
Dialogue: 0,0:21:01.19,0:21:07.03,Default,,0000,0000,0000,,おかーさんも繰り返している
Dialogue: 0,0:21:07.03,0:21:11.37,Default,,0000,0000,0000,,夏のカゴの中を クルクルと回り続けて
Dialogue: 0,0:21:11.37,0:21:16.07,Default,,0000,0000,0000,,また 私の心も戻っていく
Dialogue: 0,0:21:18.04,0:21:21.38,Default,,0000,0000,0000,,それって デジャブじゃないですか?
Dialogue: 0,0:21:21.38,0:21:24.55,Default,,0000,0000,0000,,そうそう へじゃぷ
Dialogue: 0,0:21:24.55,0:21:26.55,Default,,0000,0000,0000,,また同じ夏
Dialogue: 0,0:21:26.55,0:21:30.72,Default,,0000,0000,0000,,そして どうやっても 避けられない悲劇へ
Dialogue: 0,0:21:30.72,0:21:34.16,Default,,0000,0000,0000,,未来へと歩まされていく
Dialogue: 0,0:21:34.16,0:21:36.66,Default,,0000,0000,0000,,ううん 未来じゃない
Dialogue: 0,0:21:36.66,0:21:38.83,Default,,0000,0000,0000,,これは 私たちにとっては
Dialogue: 0,0:21:38.83,0:21:42.50,Default,,0000,0000,0000,,もう起こってしまった過去だから
Dialogue: 0,0:21:42.50,0:21:45.50,Default,,0000,0000,0000,,でも どうすれば
Dialogue: 0,0:21:45.50,0:21:48.34,Default,,0000,0000,0000,,どうすればいいの?
Dialogue: 0,0:21:45.50,0:21:50.34,Default,,0000,0000,0000,,おかーさん! あっ
Dialogue: 0,0:21:50.34,0:21:54.51,Default,,0000,0000,0000,,こんな力がなければ 未来は変わるかもしれないのに
Dialogue: 0,0:21:54.51,0:21:59.85,Default,,0000,0000,0000,,うみちゃんを 普通の女の子で
Dialogue: 0,0:21:54.51,0:21:59.85,Default,,0000,0000,0000,,いさせてあげられたのに
Dialogue: 0,0:21:59.85,0:22:04.02,Default,,0000,0000,0000,,そうだ 過去に戻る力を 持たないようにできれば
Dialogue: 0,0:22:04.02,0:22:09.36,Default,,0000,0000,0000,,私にはわかる この力が
Dialogue: 0,0:22:04.02,0:22:09.36,Default,,0000,0000,0000,,どうして発現してしまうのか
Dialogue: 0,0:22:09.36,0:22:12.70,Default,,0000,0000,0000,,どうしようもない悲しさから 逃げること
Dialogue: 0,0:22:12.70,0:22:17.87,Default,,0000,0000,0000,,つらい未来よりも
Dialogue: 0,0:22:12.70,0:22:17.87,Default,,0000,0000,0000,,過去にすがりたかったから
Dialogue: 0,0:22:17.87,0:22:21.37,Default,,0000,0000,0000,,なら おかーさんにも そういうときがあったはず
Dialogue: 0,0:22:21.37,0:22:26.04,Default,,0000,0000,0000,,悲しくて つらくて 逃げ出したいときが
Dialogue: 0,0:22:26.04,0:22:30.72,Default,,0000,0000,0000,,ごめんね おとーさん もう私は追いかけない
Dialogue: 0,0:22:30.72,0:22:35.82,Default,,0000,0000,0000,,私は 私が行かなきゃいけない
Dialogue: 0,0:22:30.72,0:22:35.82,Default,,0000,0000,0000,,場所に向かうから
Dialogue: 0,0:22:35.82,0:22:39.16,Default,,0000,0000,0000,,それは きっと あまりに遠くて
Dialogue: 0,0:22:39.16,0:22:43.66,Default,,0000,0000,0000,,帰ることのできないほどの旅に
Dialogue: 0,0:22:43.66,0:22:48.07,Default,,0000,0000,0000,,私が存在しない場所へ 行こう
