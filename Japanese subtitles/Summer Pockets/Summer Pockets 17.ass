Dialogue: 0,0:00:34.80,0:00:36.80,Default,,0000,0000,0000,,ぐはっ!
Dialogue: 0,0:00:36.80,0:00:38.81,Default,,0000,0000,0000,,鷹原!?
Dialogue: 0,0:00:36.80,0:00:38.81,Default,,0000,0000,0000,,羽依里!?
Dialogue: 0,0:00:38.81,0:00:41.14,Default,,0000,0000,0000,,ブハッ! ハァ
Dialogue: 0,0:00:41.14,0:00:45.81,Default,,0000,0000,0000,,水中格闘技は 海神様への奉納の儀
Dialogue: 0,0:00:45.81,0:00:47.81,Default,,0000,0000,0000,,島の男たちは大事なとき
Dialogue: 0,0:00:47.81,0:00:51.48,Default,,0000,0000,0000,,いつも海で 己の覚悟を示してきた
Dialogue: 0,0:00:51.48,0:00:56.49,Default,,0000,0000,0000,,貴様にも覚悟があるのなら
Dialogue: 0,0:00:51.48,0:00:56.49,Default,,0000,0000,0000,,示してみせろ 小僧!
Dialogue: 0,0:02:39.83,0:02:42.50,Default,,0000,0000,0000,,グハッ!
Dialogue: 0,0:02:39.83,0:02:42.50,Default,,0000,0000,0000,,ぬおっ!
Dialogue: 0,0:02:42.50,0:02:44.46,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:02:47.83,0:02:50.40,Default,,0000,0000,0000,,やれるだけのことを やろう
Dialogue: 0,0:02:58.18,0:03:00.15,Default,,0000,0000,0000,,ダメなのか
Dialogue: 0,0:03:03.52,0:03:05.49,Default,,0000,0000,0000,,俺は また
Dialogue: 0,0:03:16.86,0:03:22.20,Default,,0000,0000,0000,,羽依里 頑張れっ!
Dialogue: 0,0:03:22.20,0:03:24.17,Default,,0000,0000,0000,,しろは!
Dialogue: 0,0:03:27.54,0:03:30.21,Default,,0000,0000,0000,,なんとっ!?
Dialogue: 0,0:03:30.21,0:03:34.88,Default,,0000,0000,0000,,ハァ ハァ
Dialogue: 0,0:03:37.82,0:03:40.15,Default,,0000,0000,0000,,場外!?
Dialogue: 0,0:03:37.82,0:03:40.15,Default,,0000,0000,0000,,勝った
Dialogue: 0,0:03:40.15,0:03:43.82,Default,,0000,0000,0000,,羽依里の勝ちだっ!!
Dialogue: 0,0:04:00.84,0:04:07.18,Default,,0000,0000,0000,,10年前の夏
Dialogue: 0,0:04:00.84,0:04:07.18,Default,,0000,0000,0000,,しろはは 父と母を失った
Dialogue: 0,0:04:07.18,0:04:09.52,Default,,0000,0000,0000,,それ以来 引っ込み思案になり
Dialogue: 0,0:04:09.52,0:04:13.52,Default,,0000,0000,0000,,友達もなく よくないうわさをたてられ
Dialogue: 0,0:04:13.52,0:04:17.19,Default,,0000,0000,0000,,1人で夏を過ごしてきたが
Dialogue: 0,0:04:17.19,0:04:19.86,Default,,0000,0000,0000,,しろはを頼む
Dialogue: 0,0:04:19.86,0:04:22.20,Default,,0000,0000,0000,,おじいちゃん
Dialogue: 0,0:04:22.20,0:04:26.87,Default,,0000,0000,0000,,はい 夏鳥の儀の間 ずっと しろはのそばで
Dialogue: 0,0:04:26.87,0:04:28.87,Default,,0000,0000,0000,,しろはを守ります
Dialogue: 0,0:04:28.87,0:04:32.44,Default,,0000,0000,0000,,そうすれば くだらない うわさだってなくなります
Dialogue: 0,0:04:34.44,0:04:38.44,Default,,0000,0000,0000,,羽依里
Dialogue: 0,0:04:38.44,0:04:40.78,Default,,0000,0000,0000,,それだがな
Dialogue: 0,0:04:40.78,0:04:46.39,Default,,0000,0000,0000,,夏鳥の儀の巫女の付き添いは
Dialogue: 0,0:04:40.78,0:04:46.39,Default,,0000,0000,0000,,肉親に限られている
Dialogue: 0,0:04:48.45,0:04:50.46,Default,,0000,0000,0000,,肉親?
Dialogue: 0,0:04:50.46,0:04:52.79,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:04:52.79,0:04:55.80,Default,,0000,0000,0000,,ダ ダ ダ ダメだよ そんなの
Dialogue: 0,0:04:55.80,0:04:59.80,Default,,0000,0000,0000,,羽依里と ふ ふ 夫婦だなんて
Dialogue: 0,0:04:59.80,0:05:03.80,Default,,0000,0000,0000,,無論 儀礼的なかりそめのものだ
Dialogue: 0,0:05:06.81,0:05:10.14,Default,,0000,0000,0000,,俺は しろはに 感謝しているんです
Dialogue: 0,0:05:10.14,0:05:15.48,Default,,0000,0000,0000,,感謝?
Dialogue: 0,0:05:10.14,0:05:15.48,Default,,0000,0000,0000,,だから
Dialogue: 0,0:05:10.14,0:05:15.48,Default,,0000,0000,0000,,しろはに危険が迫ってるなら
Dialogue: 0,0:05:15.48,0:05:18.18,Default,,0000,0000,0000,,いちばん近くで助けたい
Dialogue: 0,0:05:20.15,0:05:23.16,Default,,0000,0000,0000,,もし
Dialogue: 0,0:05:20.15,0:05:23.16,Default,,0000,0000,0000,,うん
Dialogue: 0,0:05:23.16,0:05:27.16,Default,,0000,0000,0000,,迷惑じゃないなら
Dialogue: 0,0:05:23.16,0:05:27.16,Default,,0000,0000,0000,,うん
Dialogue: 0,0:05:27.16,0:05:29.46,Default,,0000,0000,0000,,お願い します
Dialogue: 0,0:05:33.47,0:05:36.44,Default,,0000,0000,0000,,夫婦に なってください
Dialogue: 0,0:05:38.81,0:05:41.14,Default,,0000,0000,0000,,わぁ すごい!
Dialogue: 0,0:05:41.14,0:05:44.14,Default,,0000,0000,0000,,お姉ちゃんとお兄ちゃんが結婚!
Dialogue: 0,0:05:44.14,0:05:47.81,Default,,0000,0000,0000,,まねごとだよ
Dialogue: 0,0:05:44.14,0:05:47.81,Default,,0000,0000,0000,,蝶番の契りとか
Dialogue: 0,0:05:47.81,0:05:50.15,Default,,0000,0000,0000,,いろいろな準備で 忙しくなるから
Dialogue: 0,0:05:50.15,0:05:52.82,Default,,0000,0000,0000,,蔵の整理のことは気にしないで
Dialogue: 0,0:05:52.82,0:05:57.49,Default,,0000,0000,0000,,しっかりね
Dialogue: 0,0:05:52.82,0:05:57.49,Default,,0000,0000,0000,,ありがとうございます
Dialogue: 0,0:05:57.49,0:06:01.49,Default,,0000,0000,0000,,フフッ 夫婦
Dialogue: 0,0:06:11.84,0:06:15.84,Default,,0000,0000,0000,,お祭り当日は これに 明かりをつけて海に流すから
Dialogue: 0,0:06:15.84,0:06:18.51,Default,,0000,0000,0000,,忘れずに持ってくるように
Dialogue: 0,0:06:18.51,0:06:22.52,Default,,0000,0000,0000,,そうか しろはが海で見た赤い光って
Dialogue: 0,0:06:22.52,0:06:26.19,Default,,0000,0000,0000,,灯籠だったのか
Dialogue: 0,0:06:26.19,0:06:28.52,Default,,0000,0000,0000,,なぁ 蒼
Dialogue: 0,0:06:26.19,0:06:28.52,Default,,0000,0000,0000,,何?
Dialogue: 0,0:06:28.52,0:06:30.52,Default,,0000,0000,0000,,あの子
Dialogue: 0,0:06:28.52,0:06:30.52,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:30.52,0:06:33.09,Default,,0000,0000,0000,,あの子 堀田ちゃんっていうの
Dialogue: 0,0:06:33.09,0:06:36.80,Default,,0000,0000,0000,,去年の冬 お母さんが病気で
Dialogue: 0,0:06:41.10,0:06:44.10,Default,,0000,0000,0000,,堀田ちゃん
Dialogue: 0,0:06:44.10,0:06:47.11,Default,,0000,0000,0000,,お盆って何か知ってるかい?
Dialogue: 0,0:06:47.11,0:06:49.44,Default,,0000,0000,0000,,知らない
Dialogue: 0,0:06:49.44,0:06:54.11,Default,,0000,0000,0000,,お盆の間にだけはね 死んだ人が帰ってくるんだ
Dialogue: 0,0:06:54.11,0:06:57.12,Default,,0000,0000,0000,,死んだ人が帰ってくる?
Dialogue: 0,0:06:57.12,0:06:59.45,Default,,0000,0000,0000,,あっ ごめん
Dialogue: 0,0:06:59.45,0:07:03.46,Default,,0000,0000,0000,,姿は見えないんだ
Dialogue: 0,0:07:03.46,0:07:09.46,Default,,0000,0000,0000,,それでさ 夏鳥の儀の夜に
Dialogue: 0,0:07:03.46,0:07:09.46,Default,,0000,0000,0000,,海を渡って帰っていくんだけど
Dialogue: 0,0:07:09.46,0:07:12.80,Default,,0000,0000,0000,,真っ暗だと怖いだろ?
Dialogue: 0,0:07:12.80,0:07:15.13,Default,,0000,0000,0000,,怖い
Dialogue: 0,0:07:15.13,0:07:19.47,Default,,0000,0000,0000,,だから この灯籠で 明るくしてあげないとな
Dialogue: 0,0:07:19.47,0:07:23.14,Default,,0000,0000,0000,,安心して帰れるように
Dialogue: 0,0:07:23.14,0:07:25.14,Default,,0000,0000,0000,,うん
Dialogue: 0,0:07:28.48,0:07:31.15,Default,,0000,0000,0000,,うん
Dialogue: 0,0:07:31.15,0:07:35.12,Default,,0000,0000,0000,,確か 今日は衣装合わせだったよな
Dialogue: 0,0:07:35.12,0:07:37.96,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:07:35.12,0:07:37.96,Default,,0000,0000,0000,,しろはがやってる頃だ
Dialogue: 0,0:07:37.96,0:07:40.46,Default,,0000,0000,0000,,ふむ しろはの予知だと
Dialogue: 0,0:07:40.46,0:07:43.80,Default,,0000,0000,0000,,祭りの日に 鷹原たちは溺れるんだろ
Dialogue: 0,0:07:43.80,0:07:47.13,Default,,0000,0000,0000,,夜の海で着物というのが 原因じゃないのか?
Dialogue: 0,0:07:47.13,0:07:49.10,Default,,0000,0000,0000,,なるほど
Dialogue: 0,0:07:54.47,0:07:56.48,Default,,0000,0000,0000,,えっ 何?
Dialogue: 0,0:07:56.48,0:08:00.48,Default,,0000,0000,0000,,その着物なんだが どうやって脱がせたらいいんだ?
Dialogue: 0,0:08:00.48,0:08:03.48,Default,,0000,0000,0000,,えっ!? なんでそんなこと 聞く?
Dialogue: 0,0:08:03.48,0:08:07.15,Default,,0000,0000,0000,,いざって時 うまく脱がせられるか わからなくて
Dialogue: 0,0:08:07.15,0:08:10.16,Default,,0000,0000,0000,,いざって
Dialogue: 0,0:08:10.16,0:08:12.49,Default,,0000,0000,0000,,バ バカじゃないの!?
Dialogue: 0,0:08:12.49,0:08:16.16,Default,,0000,0000,0000,,ち 契りって そういう意味では!
Dialogue: 0,0:08:16.16,0:08:18.50,Default,,0000,0000,0000,,脱げないと 溺れたときに困るだろ
Dialogue: 0,0:08:18.50,0:08:21.50,Default,,0000,0000,0000,,えっ あぁ
Dialogue: 0,0:08:21.50,0:08:25.17,Default,,0000,0000,0000,,そんなもの着ていたら カッパだって泳げない
Dialogue: 0,0:08:25.17,0:08:27.84,Default,,0000,0000,0000,,なるほど
Dialogue: 0,0:08:27.84,0:08:31.51,Default,,0000,0000,0000,,カバじゃなくて?
Dialogue: 0,0:08:31.51,0:08:35.11,Default,,0000,0000,0000,,ご ごめん
Dialogue: 0,0:08:31.51,0:08:35.11,Default,,0000,0000,0000,,からかうつもりでは
Dialogue: 0,0:08:35.11,0:08:38.12,Default,,0000,0000,0000,,ちょっとしたジョークというか
Dialogue: 0,0:08:38.12,0:08:40.09,Default,,0000,0000,0000,,プッ
Dialogue: 0,0:08:42.46,0:08:46.46,Default,,0000,0000,0000,,でも 確かに 着物着てたら泳げない
Dialogue: 0,0:08:46.46,0:08:51.80,Default,,0000,0000,0000,,だろ? 良一たちに言われてさ
Dialogue: 0,0:08:46.46,0:08:51.80,Default,,0000,0000,0000,,俺も考えなくちゃって
Dialogue: 0,0:08:51.80,0:08:55.47,Default,,0000,0000,0000,,んっ 私も考えておく
Dialogue: 0,0:08:55.47,0:08:57.80,Default,,0000,0000,0000,,羽依里
Dialogue: 0,0:08:55.47,0:08:57.80,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:08:57.80,0:09:02.48,Default,,0000,0000,0000,,ありがとう
Dialogue: 0,0:08:57.80,0:09:02.48,Default,,0000,0000,0000,,考えてくれて いろいろ
Dialogue: 0,0:09:02.48,0:09:05.81,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:09:05.81,0:09:08.08,Default,,0000,0000,0000,,うん
Dialogue: 0,0:09:10.48,0:09:12.82,Default,,0000,0000,0000,,いよいよ明日か
Dialogue: 0,0:09:15.49,0:09:18.16,Default,,0000,0000,0000,,はい 加藤です
Dialogue: 0,0:09:18.16,0:09:21.16,Default,,0000,0000,0000,,あぁ のみき?
Dialogue: 0,0:09:21.16,0:09:23.50,Default,,0000,0000,0000,,えっ? しろはが!?
Dialogue: 0,0:09:23.50,0:09:25.50,Default,,0000,0000,0000,,どういうことだ!?
Dialogue: 0,0:09:25.50,0:09:28.83,Default,,0000,0000,0000,,祭りの前日 巫女は お堂にこもるはずだろ?
Dialogue: 0,0:09:28.83,0:09:31.17,Default,,0000,0000,0000,,わからん
Dialogue: 0,0:09:28.83,0:09:33.07,Default,,0000,0000,0000,,だが とりあえず今は 蒼が しろはになりすまし
Dialogue: 0,0:09:33.07,0:09:36.08,Default,,0000,0000,0000,,良一と天善が しろはを捜している
Dialogue: 0,0:09:36.08,0:09:39.08,Default,,0000,0000,0000,,わかった
Dialogue: 0,0:09:36.08,0:09:39.08,Default,,0000,0000,0000,,なら 俺も捜すよ
Dialogue: 0,0:09:39.08,0:09:43.08,Default,,0000,0000,0000,,なに なんとなく 心当たりがあるんだ
Dialogue: 0,0:09:43.08,0:09:47.79,Default,,0000,0000,0000,,ハァ ハァ
Dialogue: 0,0:09:52.43,0:09:57.43,Default,,0000,0000,0000,,みんな心配してる
Dialogue: 0,0:09:52.43,0:09:57.43,Default,,0000,0000,0000,,せめて誰かに伝えてけよ
Dialogue: 0,0:09:57.43,0:09:59.43,Default,,0000,0000,0000,,ごめん
Dialogue: 0,0:09:59.43,0:10:03.44,Default,,0000,0000,0000,,でも どうしても ここに来たかったから
Dialogue: 0,0:10:03.44,0:10:09.11,Default,,0000,0000,0000,,夏鳥の儀が近づくにつれて
Dialogue: 0,0:10:03.44,0:10:09.11,Default,,0000,0000,0000,,どんどん鮮明になっていくの
Dialogue: 0,0:10:09.11,0:10:13.11,Default,,0000,0000,0000,,今はもう 羽依里の顔も はっきりわかる
Dialogue: 0,0:10:15.45,0:10:18.78,Default,,0000,0000,0000,,なんで声をかけたの?
Dialogue: 0,0:10:18.78,0:10:22.79,Default,,0000,0000,0000,,それで いろんなところに誘ってくれて
Dialogue: 0,0:10:22.79,0:10:25.79,Default,,0000,0000,0000,,1人ならよかった
Dialogue: 0,0:10:25.79,0:10:28.13,Default,,0000,0000,0000,,私がいなくなるのはいいの
Dialogue: 0,0:10:28.13,0:10:30.46,Default,,0000,0000,0000,,でも また誰か
Dialogue: 0,0:10:30.46,0:10:33.87,Default,,0000,0000,0000,,大事な人がいなくなるのは 耐えられない
Dialogue: 0,0:10:38.47,0:10:43.48,Default,,0000,0000,0000,,それでも俺は
Dialogue: 0,0:10:38.47,0:10:43.48,Default,,0000,0000,0000,,しろはに会えてよかった
Dialogue: 0,0:10:43.48,0:10:47.48,Default,,0000,0000,0000,,しろはがいてくれて 俺は救われたんだ
Dialogue: 0,0:10:47.48,0:10:50.82,Default,,0000,0000,0000,,だから そんなこと言うなよ
Dialogue: 0,0:10:50.82,0:10:53.15,Default,,0000,0000,0000,,きっと みんなそうだ
Dialogue: 0,0:10:53.15,0:10:56.46,Default,,0000,0000,0000,,しろはがいなくなるなんて 耐えられない
Dialogue: 0,0:11:01.49,0:11:03.83,Default,,0000,0000,0000,,ごめん
Dialogue: 0,0:11:01.49,0:11:03.83,Default,,0000,0000,0000,,何が?
Dialogue: 0,0:11:03.83,0:11:08.13,Default,,0000,0000,0000,,わからないけど ごめん
Dialogue: 0,0:11:12.51,0:11:14.51,Default,,0000,0000,0000,,そろそろ戻ろう
Dialogue: 0,0:11:14.51,0:11:16.51,Default,,0000,0000,0000,,待って
Dialogue: 0,0:11:14.51,0:11:16.51,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:11:16.51,0:11:21.51,Default,,0000,0000,0000,,もうすぐだから 見てもらいたい
Dialogue: 0,0:11:16.51,0:11:21.51,Default,,0000,0000,0000,,見るって 何を
Dialogue: 0,0:11:30.86,0:11:38.83,Default,,0000,0000,0000,,蛍 ウミホタル
Dialogue: 0,0:11:30.86,0:11:38.83,Default,,0000,0000,0000,,ウミホタル 海の蛍
Dialogue: 0,0:11:38.83,0:11:44.50,Default,,0000,0000,0000,,この場所は昔 お父さんに
Dialogue: 0,0:11:38.83,0:11:44.50,Default,,0000,0000,0000,,教えてもらった秘密の場所
Dialogue: 0,0:11:44.50,0:11:46.84,Default,,0000,0000,0000,,ずっと光らなくなってた
Dialogue: 0,0:11:46.84,0:11:51.18,Default,,0000,0000,0000,,けど 今年の夏 また光ったの
Dialogue: 0,0:11:51.18,0:11:53.85,Default,,0000,0000,0000,,10年ぶりに
Dialogue: 0,0:11:51.18,0:11:53.85,Default,,0000,0000,0000,,10年!?
Dialogue: 0,0:11:53.85,0:11:57.82,Default,,0000,0000,0000,,俺 運がいいんだな
Dialogue: 0,0:11:59.85,0:12:02.86,Default,,0000,0000,0000,,あのね 昔
Dialogue: 0,0:12:02.86,0:12:05.52,Default,,0000,0000,0000,,未来に行きたいって 思ったことがある
Dialogue: 0,0:12:05.52,0:12:07.53,Default,,0000,0000,0000,,未来に?
Dialogue: 0,0:12:07.53,0:12:10.53,Default,,0000,0000,0000,,たぶん 待つのに疲れたから
Dialogue: 0,0:12:10.53,0:12:14.87,Default,,0000,0000,0000,,時間を早送りして 会いに行きたいって思った
Dialogue: 0,0:12:14.87,0:12:20.21,Default,,0000,0000,0000,,だから
Dialogue: 0,0:12:14.87,0:12:20.21,Default,,0000,0000,0000,,見えるようになったのかな
Dialogue: 0,0:12:20.21,0:12:23.88,Default,,0000,0000,0000,,今も行きたい?
Dialogue: 0,0:12:23.88,0:12:26.88,Default,,0000,0000,0000,,いつまで待ったらいいか わからないし
Dialogue: 0,0:12:26.88,0:12:31.45,Default,,0000,0000,0000,,だから もういい
Dialogue: 0,0:12:26.88,0:12:31.45,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:12:46.47,0:12:49.47,Default,,0000,0000,0000,,おかえり
Dialogue: 0,0:12:46.47,0:12:49.47,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:53.81,0:12:55.81,Default,,0000,0000,0000,,ただいま
Dialogue: 0,0:13:11.86,0:13:17.43,Default,,0000,0000,0000,,フフフ 花嫁さんによろしく
Dialogue: 0,0:13:11.86,0:13:17.43,Default,,0000,0000,0000,,はい いってきます
Dialogue: 0,0:13:27.21,0:13:30.48,Default,,0000,0000,0000,,この道も すっかり慣れたな
Dialogue: 0,0:13:33.15,0:13:37.48,Default,,0000,0000,0000,,今のは 虹色の 蝶?
Dialogue: 0,0:13:57.17,0:13:59.84,Default,,0000,0000,0000,,えっ? うみちゃん?
Dialogue: 0,0:13:59.84,0:14:04.18,Default,,0000,0000,0000,,お お兄ちゃん?
Dialogue: 0,0:13:59.84,0:14:04.18,Default,,0000,0000,0000,,どうして ここにいるの?
Dialogue: 0,0:14:04.18,0:14:07.51,Default,,0000,0000,0000,,いや 蝶を追いかけて
Dialogue: 0,0:14:04.18,0:14:07.51,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:14:07.51,0:14:09.85,Default,,0000,0000,0000,,うみちゃんこそ どうしてここに?
Dialogue: 0,0:14:09.85,0:14:13.19,Default,,0000,0000,0000,,ちょっと お散歩
Dialogue: 0,0:14:09.85,0:14:13.19,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:14:13.19,0:14:16.19,Default,,0000,0000,0000,,えっと 一緒に行こうか?
Dialogue: 0,0:14:16.19,0:14:20.16,Default,,0000,0000,0000,,ううん もうちょっと お散歩したいから
Dialogue: 0,0:14:22.53,0:14:24.86,Default,,0000,0000,0000,,ハァ ハァ
Dialogue: 0,0:14:24.86,0:14:27.87,Default,,0000,0000,0000,,何してたの?
Dialogue: 0,0:14:24.86,0:14:27.87,Default,,0000,0000,0000,,もう時間ギリギリよ
Dialogue: 0,0:14:27.87,0:14:31.87,Default,,0000,0000,0000,,悪い 知り合いを見かけてさ
Dialogue: 0,0:14:27.87,0:14:31.87,Default,,0000,0000,0000,,とにかく急げ
Dialogue: 0,0:14:31.87,0:14:36.11,Default,,0000,0000,0000,,蝶番の契りを済まさねば 夏鳥の儀が始められん
Dialogue: 0,0:14:36.11,0:14:38.11,Default,,0000,0000,0000,,わかった
Dialogue: 0,0:14:45.12,0:14:49.12,Default,,0000,0000,0000,,これより 蝶番の契りを執り行う
Dialogue: 0,0:15:27.16,0:15:29.86,Default,,0000,0000,0000,,それ
Dialogue: 0,0:15:33.47,0:15:36.14,Default,,0000,0000,0000,,それ
Dialogue: 0,0:15:36.14,0:15:38.14,Default,,0000,0000,0000,,フゥー
Dialogue: 0,0:15:38.14,0:15:42.81,Default,,0000,0000,0000,,あの舟 去年も担いだけど いっそう重くなってないか?
Dialogue: 0,0:15:42.81,0:15:47.15,Default,,0000,0000,0000,,願いの数だけ重みを増すんだろう
Dialogue: 0,0:15:47.15,0:15:50.48,Default,,0000,0000,0000,,よっ!
Dialogue: 0,0:15:47.15,0:15:50.48,Default,,0000,0000,0000,,何も起きなかったみてえだな
Dialogue: 0,0:15:50.48,0:15:52.45,Default,,0000,0000,0000,,よかったな!
Dialogue: 0,0:15:56.16,0:15:59.83,Default,,0000,0000,0000,,雨?
Dialogue: 0,0:15:56.16,0:15:59.83,Default,,0000,0000,0000,,降り出す前に終わってよかったな
Dialogue: 0,0:15:59.83,0:16:05.16,Default,,0000,0000,0000,,最後まで見送れないのは残念だが
Dialogue: 0,0:15:59.83,0:16:05.16,Default,,0000,0000,0000,,俺たちも戻ろうか
Dialogue: 0,0:16:05.16,0:16:07.83,Default,,0000,0000,0000,,そうだな
Dialogue: 0,0:16:05.16,0:16:07.83,Default,,0000,0000,0000,,羽依里!
Dialogue: 0,0:16:07.83,0:16:10.84,Default,,0000,0000,0000,,堀田ちゃん見なかった?
Dialogue: 0,0:16:10.84,0:16:13.84,Default,,0000,0000,0000,,いや 見てないが
Dialogue: 0,0:16:10.84,0:16:13.84,Default,,0000,0000,0000,,どこにもいないって
Dialogue: 0,0:16:13.84,0:16:16.51,Default,,0000,0000,0000,,のみきも放送で呼びかけるみたい
Dialogue: 0,0:16:16.51,0:16:19.51,Default,,0000,0000,0000,,もし見つけたら捕まえといて!
Dialogue: 0,0:16:16.51,0:16:19.51,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:16:19.51,0:16:21.51,Default,,0000,0000,0000,,羽依里!
Dialogue: 0,0:16:21.51,0:16:23.52,Default,,0000,0000,0000,,私が見た未来のこと
Dialogue: 0,0:16:23.52,0:16:26.52,Default,,0000,0000,0000,,俺と しろはが 海の中ってやつだろ?
Dialogue: 0,0:16:26.52,0:16:30.52,Default,,0000,0000,0000,,でも それはもう
Dialogue: 0,0:16:26.52,0:16:30.52,Default,,0000,0000,0000,,今 はっきり見えたの
Dialogue: 0,0:16:30.52,0:16:34.76,Default,,0000,0000,0000,,羽依里だと思っていたもう1人は 女の子だった
Dialogue: 0,0:16:34.76,0:16:36.76,Default,,0000,0000,0000,,それが堀田ちゃん?
Dialogue: 0,0:16:36.76,0:16:41.43,Default,,0000,0000,0000,,けど なんで海に!?
Dialogue: 0,0:16:41.43,0:16:43.44,Default,,0000,0000,0000,,舟!!
Dialogue: 0,0:16:43.44,0:16:46.44,Default,,0000,0000,0000,,あそこに堀田ちゃんが?
Dialogue: 0,0:16:43.44,0:16:46.44,Default,,0000,0000,0000,,だったら連れ戻さないと!
Dialogue: 0,0:16:46.44,0:16:48.44,Default,,0000,0000,0000,,でも どうやって?
Dialogue: 0,0:16:48.44,0:16:52.11,Default,,0000,0000,0000,,おい! こっちだ!
Dialogue: 0,0:16:52.11,0:16:55.11,Default,,0000,0000,0000,,どこだ? 堀田ちゃん!
Dialogue: 0,0:16:55.11,0:16:58.45,Default,,0000,0000,0000,,勝手に舟を出して あとで おやじに殴られるんだ
Dialogue: 0,0:16:58.45,0:17:01.12,Default,,0000,0000,0000,,どうか無事でいてくれよ
Dialogue: 0,0:17:01.12,0:17:03.79,Default,,0000,0000,0000,,あっ! あそこだ!!
Dialogue: 0,0:17:03.79,0:17:05.79,Default,,0000,0000,0000,,任せろ!!
Dialogue: 0,0:17:05.79,0:17:07.79,Default,,0000,0000,0000,,堀田ちゃん!
Dialogue: 0,0:17:07.79,0:17:11.80,Default,,0000,0000,0000,,お お兄さん?
Dialogue: 0,0:17:07.79,0:17:11.80,Default,,0000,0000,0000,,よかった
Dialogue: 0,0:17:11.80,0:17:15.47,Default,,0000,0000,0000,,私 お母さんに会えると思って
Dialogue: 0,0:17:11.80,0:17:15.47,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:17:15.47,0:17:19.14,Default,,0000,0000,0000,,この舟に乗れば 同じところに行けるかもって
Dialogue: 0,0:17:19.14,0:17:21.14,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:17:21.14,0:17:24.81,Default,,0000,0000,0000,,こっちに手を伸ばして!
Dialogue: 0,0:17:21.14,0:17:24.81,Default,,0000,0000,0000,,うん
Dialogue: 0,0:17:24.81,0:17:27.81,Default,,0000,0000,0000,,さっ こっち
Dialogue: 0,0:17:27.81,0:17:29.82,Default,,0000,0000,0000,,羽依里!
Dialogue: 0,0:17:31.82,0:17:34.12,Default,,0000,0000,0000,,ぐっ!!
Dialogue: 0,0:17:31.82,0:17:34.12,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:17:37.79,0:17:40.36,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:17:37.79,0:17:40.36,Default,,0000,0000,0000,,しろは!
Dialogue: 0,0:17:43.13,0:17:45.13,Default,,0000,0000,0000,,しろは!
Dialogue: 0,0:17:45.13,0:17:47.10,Default,,0000,0000,0000,,良一 この子を頼む!
Dialogue: 0,0:17:51.80,0:17:54.47,Default,,0000,0000,0000,,しろは!
Dialogue: 0,0:17:54.47,0:17:57.81,Default,,0000,0000,0000,,羽依里!
Dialogue: 0,0:17:57.81,0:18:00.78,Default,,0000,0000,0000,,届けっ!!
Dialogue: 0,0:18:11.16,0:18:16.16,Default,,0000,0000,0000,,しろは? いや 違う
Dialogue: 0,0:18:16.16,0:18:19.83,Default,,0000,0000,0000,,私たちは 時の編み人
Dialogue: 0,0:18:19.83,0:18:23.50,Default,,0000,0000,0000,,異邦の少年 いくら求めても無理だよ
Dialogue: 0,0:18:23.50,0:18:27.17,Default,,0000,0000,0000,,たとえ この夏に巡り会えたとしても
Dialogue: 0,0:18:27.17,0:18:32.44,Default,,0000,0000,0000,,それだけのこと
Dialogue: 0,0:18:27.17,0:18:32.44,Default,,0000,0000,0000,,私たちは ただ編み続ける
Dialogue: 0,0:18:37.12,0:18:40.09,Default,,0000,0000,0000,,どっちだ? どっちに行けば?
Dialogue: 0,0:18:42.79,0:18:44.76,Default,,0000,0000,0000,,あれは
Dialogue: 0,0:18:47.63,0:18:49.90,Default,,0000,0000,0000,,こっち
Dialogue: 0,0:18:56.13,0:18:58.10,Default,,0000,0000,0000,,こっち
Dialogue: 0,0:19:31.17,0:19:34.07,Default,,0000,0000,0000,,よっ
Dialogue: 0,0:19:31.17,0:19:34.07,Default,,0000,0000,0000,,うん
Dialogue: 0,0:19:34.07,0:19:36.74,Default,,0000,0000,0000,,お疲れさまでした
Dialogue: 0,0:19:36.74,0:19:40.35,Default,,0000,0000,0000,,いえ お互いにお疲れさまでした
Dialogue: 0,0:20:00.43,0:20:04.44,Default,,0000,0000,0000,,俺 しろはに ずっと 言いたかったことがあるんだ
Dialogue: 0,0:20:04.44,0:20:08.77,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:20:04.44,0:20:08.77,Default,,0000,0000,0000,,実は俺 初めて会ったときから
Dialogue: 0,0:20:08.77,0:20:10.78,Default,,0000,0000,0000,,は 羽依里
Dialogue: 0,0:20:10.78,0:20:14.11,Default,,0000,0000,0000,,プールに下着で入ってたこと 気付いていました
Dialogue: 0,0:20:14.11,0:20:16.45,Default,,0000,0000,0000,,ずっと黙っててごめん
Dialogue: 0,0:20:28.79,0:20:30.80,Default,,0000,0000,0000,,なぜ今になって言う!?
Dialogue: 0,0:20:30.80,0:20:34.47,Default,,0000,0000,0000,,いや なんか いろいろありすぎて いっぱいいっぱいでさぁ
Dialogue: 0,0:20:34.47,0:20:37.80,Default,,0000,0000,0000,,こんなとき何て言えばいいのか わからなくなって
Dialogue: 0,0:20:37.80,0:20:40.14,Default,,0000,0000,0000,,だだだ だからって
Dialogue: 0,0:20:40.14,0:20:43.14,Default,,0000,0000,0000,,それを選ぶことは ないんじゃないかと思う!
Dialogue: 0,0:20:43.14,0:20:48.48,Default,,0000,0000,0000,,そうだよね
Dialogue: 0,0:20:43.14,0:20:48.48,Default,,0000,0000,0000,,ホント どすこいだよ 俺
Dialogue: 0,0:20:48.48,0:20:51.18,Default,,0000,0000,0000,,俺 思ったんだ
Dialogue: 0,0:20:53.49,0:20:57.16,Default,,0000,0000,0000,,未来って あのときの海みたいに真っ暗で
Dialogue: 0,0:20:57.16,0:21:00.46,Default,,0000,0000,0000,,普通 何も見えるはずがないけど
Dialogue: 0,0:21:02.49,0:21:07.17,Default,,0000,0000,0000,,そこに一筋の光を 投げかけるような
Dialogue: 0,0:21:07.17,0:21:10.17,Default,,0000,0000,0000,,それが しろはの力なんだと思う
Dialogue: 0,0:21:12.17,0:21:16.84,Default,,0000,0000,0000,,それって すごいことだよな
Dialogue: 0,0:21:16.84,0:21:20.18,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:16.84,0:21:20.18,Default,,0000,0000,0000,,どうした? しろは
Dialogue: 0,0:21:20.18,0:21:23.52,Default,,0000,0000,0000,,な な なんでもない なんでも
Dialogue: 0,0:21:23.52,0:21:25.85,Default,,0000,0000,0000,,ちらっと見えただけだから
Dialogue: 0,0:21:25.85,0:21:28.85,Default,,0000,0000,0000,,何が? また不吉なものなのか?
Dialogue: 0,0:21:28.85,0:21:34.16,Default,,0000,0000,0000,,なんでもないし
Dialogue: 0,0:21:28.85,0:21:34.16,Default,,0000,0000,0000,,全然不吉じゃなかったけど
Dialogue: 0,0:21:49.84,0:21:53.85,Default,,0000,0000,0000,,どうしたの?
Dialogue: 0,0:21:49.84,0:21:53.85,Default,,0000,0000,0000,,うん 思い出した
Dialogue: 0,0:21:53.85,0:21:59.52,Default,,0000,0000,0000,,何を?
Dialogue: 0,0:21:53.85,0:21:59.52,Default,,0000,0000,0000,,夏休みの過ごし方
Dialogue: 0,0:21:59.52,0:22:02.52,Default,,0000,0000,0000,,いつの間に 忘れていたんだろうな
Dialogue: 0,0:22:02.52,0:22:06.53,Default,,0000,0000,0000,,とても単純で簡単なことなのに
Dialogue: 0,0:22:06.53,0:22:11.53,Default,,0000,0000,0000,,俺は 夏が大好きだったってこと
Dialogue: 0,0:22:11.53,0:22:13.53,Default,,0000,0000,0000,,羽依
Dialogue: 0,0:22:11.53,0:22:13.53,Default,,0000,0000,0000,,まもなく出航します
Dialogue: 0,0:22:13.53,0:22:16.90,Default,,0000,0000,0000,,皆様 乗船を済ませてください
Dialogue: 0,0:22:20.54,0:22:25.21,Default,,0000,0000,0000,,最後にさ 言いたいことが2つあるんだ
Dialogue: 0,0:22:25.21,0:22:27.55,Default,,0000,0000,0000,,今度は何?
Dialogue: 0,0:22:27.55,0:22:30.88,Default,,0000,0000,0000,,あの
Dialogue: 0,0:22:30.88,0:22:33.45,Default,,0000,0000,0000,,一時だけど楽しかった
Dialogue: 0,0:22:33.45,0:22:36.79,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:22:36.79,0:22:39.46,Default,,0000,0000,0000,,私も 楽しかった
Dialogue: 0,0:22:39.46,0:22:42.13,Default,,0000,0000,0000,,うん
Dialogue: 0,0:22:42.13,0:22:44.46,Default,,0000,0000,0000,,それで 俺
Dialogue: 0,0:22:44.46,0:22:46.87,Default,,0000,0000,0000,,君を好きになりました
Dialogue: 0,0:22:53.47,0:22:55.47,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:23:09.82,0:23:12.49,Default,,0000,0000,0000,,しろは?
Dialogue: 0,0:23:16.83,0:23:20.50,Default,,0000,0000,0000,,なに!?
Dialogue: 0,0:23:20.50,0:23:22.50,Default,,0000,0000,0000,,私も!
Dialogue: 0,0:23:22.50,0:23:24.50,Default,,0000,0000,0000,,あなたを!
Dialogue: 0,0:23:24.50,0:23:28.51,Default,,0000,0000,0000,,好きになりました!
Dialogue: 0,0:23:28.51,0:23:30.51,Default,,0000,0000,0000,,俺またこの島に
Dialogue: 0,0:23:30.51,0:23:32.81,Default,,0000,0000,0000,,当船は 機器の不具合のため
Dialogue: 0,0:23:32.81,0:23:35.81,Default,,0000,0000,0000,,引き返します
Dialogue: 0,0:23:32.81,0:23:35.81,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:23:35.81,0:23:39.38,Default,,0000,0000,0000,,えっ なんで戻ってくるの!?
Dialogue: 0,0:23:45.16,0:23:48.83,Default,,0000,0000,0000,,ただいま
Dialogue: 0,0:23:45.16,0:23:48.83,Default,,0000,0000,0000,,おかえり
Dialogue: 0,0:24:07.51,0:24:11.52,Default,,0000,0000,0000,,きっと 次は
Dialogue: 0,0:24:11.52,0:24:15.85,Default,,0000,0000,0000,,次? 次って何?
Dialogue: 0,0:24:15.85,0:24:19.83,Default,,0000,0000,0000,,私って 何?
