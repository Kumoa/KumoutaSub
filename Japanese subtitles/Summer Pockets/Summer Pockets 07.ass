Dialogue: 0,0:00:34.80,0:00:36.80,Default,,0000,0000,0000,,ずっと昔 小さな頃
Dialogue: 0,0:00:36.80,0:00:39.97,Default,,0000,0000,0000,,永遠みたいな夏を駆け回っていた
Dialogue: 0,0:00:39.97,0:00:45.81,Default,,0000,0000,0000,,家族と友達と どんなに遊んでも
Dialogue: 0,0:00:39.97,0:00:45.81,Default,,0000,0000,0000,,やることは尽きなくて
Dialogue: 0,0:00:45.81,0:00:51.32,Default,,0000,0000,0000,,太陽は そんな毎日を
Dialogue: 0,0:00:45.81,0:00:51.32,Default,,0000,0000,0000,,まぶしく照らし続けてくれた
Dialogue: 0,0:00:51.32,0:00:56.16,Default,,0000,0000,0000,,いつの間にか そんな思い出は 記憶のかなたへ
Dialogue: 0,0:00:56.16,0:01:00.83,Default,,0000,0000,0000,,ただ あの日 まぶたに感じた まぶしさは覚えている
Dialogue: 0,0:01:00.83,0:01:05.00,Default,,0000,0000,0000,,あのまぶしさを探して 僕は飛んでいた
Dialogue: 0,0:01:05.00,0:01:09.17,Default,,0000,0000,0000,,もう少し もう少しで たどり着ける
Dialogue: 0,0:01:09.17,0:01:11.67,Default,,0000,0000,0000,,あの夏に
Dialogue: 0,0:01:27.52,0:01:30.22,Default,,0000,0000,0000,,いらっしゃい
Dialogue: 0,0:01:27.52,0:01:30.22,Default,,0000,0000,0000,,話は聞いてるわ
Dialogue: 0,0:01:32.53,0:01:34.53,Default,,0000,0000,0000,,よろしくお願いします
Dialogue: 0,0:01:36.50,0:01:41.33,Default,,0000,0000,0000,,まもなく鳥白島 鳥白島漁港に 到着します
Dialogue: 0,0:01:41.33,0:01:44.84,Default,,0000,0000,0000,,着岸の際は 船に強い衝撃が ある場合もございますので
Dialogue: 0,0:01:44.84,0:01:47.84,Default,,0000,0000,0000,,鳥白島か
Dialogue: 0,0:01:47.84,0:01:50.51,Default,,0000,0000,0000,,そのままで お待ちください
Dialogue: 0,0:01:50.51,0:01:54.51,Default,,0000,0000,0000,,さしずめ俺は 歌を忘れたカナリアか
Dialogue: 0,0:01:54.51,0:01:57.52,Default,,0000,0000,0000,,なんて?
Dialogue: 0,0:01:54.51,0:01:57.52,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:01:57.52,0:02:00.19,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:02:03.86,0:02:06.03,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:04:09.02,0:04:13.69,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:04:09.02,0:04:13.69,Default,,0000,0000,0000,,何をやってるんだ 俺
Dialogue: 0,0:04:13.69,0:04:19.36,Default,,0000,0000,0000,,てか どこだ? ここは
Dialogue: 0,0:04:19.36,0:04:25.20,Default,,0000,0000,0000,,もしもし? もしもし?
Dialogue: 0,0:04:19.36,0:04:25.20,Default,,0000,0000,0000,,もしもし!
Dialogue: 0,0:04:25.20,0:04:30.37,Default,,0000,0000,0000,,起きてください!
Dialogue: 0,0:04:25.20,0:04:30.37,Default,,0000,0000,0000,,羽依里さん!
Dialogue: 0,0:04:33.27,0:04:36.11,Default,,0000,0000,0000,,まったく もう8時ですよ
Dialogue: 0,0:04:36.11,0:04:40.45,Default,,0000,0000,0000,,あぁ おはよう うみちゃん
Dialogue: 0,0:04:40.45,0:04:42.45,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:04:42.45,0:04:46.12,Default,,0000,0000,0000,,どうです?
Dialogue: 0,0:04:42.45,0:04:46.12,Default,,0000,0000,0000,,私が作ったんですよ そのチャーハン!
Dialogue: 0,0:04:46.12,0:04:48.12,Default,,0000,0000,0000,,へぇ そうなんだ
Dialogue: 0,0:04:51.62,0:04:54.29,Default,,0000,0000,0000,,おいしいかな
Dialogue: 0,0:04:54.29,0:04:56.80,Default,,0000,0000,0000,,ぷう
Dialogue: 0,0:04:56.80,0:05:00.60,Default,,0000,0000,0000,,今日も いいわ
Dialogue: 0,0:04:56.80,0:05:00.60,Default,,0000,0000,0000,,おいおい手伝ってもらうから
Dialogue: 0,0:05:02.80,0:05:07.81,Default,,0000,0000,0000,,ふぅ ゆっくりしてて
Dialogue: 0,0:05:02.80,0:05:07.81,Default,,0000,0000,0000,,ねっ 羽依里くん
Dialogue: 0,0:05:07.81,0:05:09.81,Default,,0000,0000,0000,,はぁ
Dialogue: 0,0:05:12.48,0:05:16.32,Default,,0000,0000,0000,,俺が この鳥白島に来て もう数日
Dialogue: 0,0:05:16.32,0:05:20.32,Default,,0000,0000,0000,,祖母の遺品整理の手伝いに来た
Dialogue: 0,0:05:16.32,0:05:20.32,Default,,0000,0000,0000,,はずなのに
Dialogue: 0,0:05:20.32,0:05:24.49,Default,,0000,0000,0000,,いまだ 何もすることがなくて
Dialogue: 0,0:05:24.49,0:05:28.16,Default,,0000,0000,0000,,その間 この島に住んでる 同じ年頃の連中と
Dialogue: 0,0:05:28.16,0:05:30.16,Default,,0000,0000,0000,,知り合いになっていった
Dialogue: 0,0:05:30.16,0:05:32.33,Default,,0000,0000,0000,,みんな悪い人間じゃなさそうだ
Dialogue: 0,0:05:32.33,0:05:36.97,Default,,0000,0000,0000,,もっとも クセの強い連中ばかりだけど
Dialogue: 0,0:05:36.97,0:05:41.14,Default,,0000,0000,0000,,特に彼女 鳴瀬しろはは
Dialogue: 0,0:05:43.14,0:05:47.48,Default,,0000,0000,0000,,ってのは すごくうっとうしいって 意味の方言で
Dialogue: 0,0:05:47.48,0:05:50.65,Default,,0000,0000,0000,,あまり人に 使っちゃいけない言葉らしくて
Dialogue: 0,0:05:50.65,0:05:54.32,Default,,0000,0000,0000,,俺が何したっていうんだ?
Dialogue: 0,0:05:54.32,0:05:57.16,Default,,0000,0000,0000,,なんで ここにいるんだろう 俺
Dialogue: 0,0:05:57.16,0:05:59.33,Default,,0000,0000,0000,,あれよ
Dialogue: 0,0:05:57.16,0:06:02.16,Default,,0000,0000,0000,,木戸のおばあちゃんが言ってた 歌を忘れたカナリアって
Dialogue: 0,0:05:59.33,0:06:02.16,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:06:02.16,0:06:05.83,Default,,0000,0000,0000,,ロックを歌うカナリア
Dialogue: 0,0:06:02.16,0:06:05.83,Default,,0000,0000,0000,,カナリアンロッカーですわ!
Dialogue: 0,0:06:05.83,0:06:08.30,Default,,0000,0000,0000,,なんか ゆがんで伝わってるし!
Dialogue: 0,0:06:21.51,0:06:24.18,Default,,0000,0000,0000,,思ったより遠かったな
Dialogue: 0,0:06:30.19,0:06:32.19,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:06:50.61,0:06:54.95,Default,,0000,0000,0000,,おい!
Dialogue: 0,0:06:50.61,0:06:54.95,Default,,0000,0000,0000,,ん? むぎゅ?
Dialogue: 0,0:06:54.95,0:06:56.95,Default,,0000,0000,0000,,むぎゅ?
Dialogue: 0,0:06:56.95,0:06:59.95,Default,,0000,0000,0000,,そんなところで何してるんだ?
Dialogue: 0,0:06:59.95,0:07:02.29,Default,,0000,0000,0000,,探し物です!
Dialogue: 0,0:07:02.29,0:07:04.62,Default,,0000,0000,0000,,何探してるの?
Dialogue: 0,0:07:04.62,0:07:07.13,Default,,0000,0000,0000,,自分です!
Dialogue: 0,0:07:07.13,0:07:12.93,Default,,0000,0000,0000,,それと
Dialogue: 0,0:07:07.13,0:07:12.93,Default,,0000,0000,0000,,やりたいことを探しています!
Dialogue: 0,0:07:16.64,0:07:20.64,Default,,0000,0000,0000,,そんなところにいたら 危ないと思うぞ!
Dialogue: 0,0:07:20.64,0:07:24.64,Default,,0000,0000,0000,,むぎゅ? 危なくないですよ
Dialogue: 0,0:07:24.64,0:07:28.31,Default,,0000,0000,0000,,落ちたら 死んじゃうかもしれないけど?
Dialogue: 0,0:07:28.31,0:07:30.48,Default,,0000,0000,0000,,死にませんよ
Dialogue: 0,0:07:30.48,0:07:32.95,Default,,0000,0000,0000,,君は 無敵なの?
Dialogue: 0,0:07:32.95,0:07:35.45,Default,,0000,0000,0000,,ムテキです!
Dialogue: 0,0:07:35.45,0:07:37.96,Default,,0000,0000,0000,,おっ
Dialogue: 0,0:07:37.96,0:07:40.43,Default,,0000,0000,0000,,うらやましいな
Dialogue: 0,0:07:49.47,0:07:53.31,Default,,0000,0000,0000,,お風呂が?
Dialogue: 0,0:07:49.47,0:07:53.31,Default,,0000,0000,0000,,そうなのよ
Dialogue: 0,0:07:53.31,0:07:55.48,Default,,0000,0000,0000,,いきなり水が止まっちゃって
Dialogue: 0,0:07:55.48,0:07:57.98,Default,,0000,0000,0000,,じゃあ 今日は入らなくてもいいかな
Dialogue: 0,0:07:57.98,0:08:00.81,Default,,0000,0000,0000,,ダメです!
Dialogue: 0,0:07:57.98,0:08:02.78,Default,,0000,0000,0000,,夏場にお風呂に入らないなんて ありえません!
Dialogue: 0,0:08:12.99,0:08:15.66,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:08:17.83,0:08:20.50,Default,,0000,0000,0000,,あっ 遅かったね うみちゃ ん?
Dialogue: 0,0:08:20.50,0:08:24.17,Default,,0000,0000,0000,,別に普通だし
Dialogue: 0,0:08:20.50,0:08:24.17,Default,,0000,0000,0000,,い いや じゃなくて
Dialogue: 0,0:08:27.51,0:08:29.51,Default,,0000,0000,0000,,お待たせしました!
Dialogue: 0,0:08:29.51,0:08:31.84,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:08:29.51,0:08:31.84,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:08:31.84,0:08:34.95,Default,,0000,0000,0000,,はじめまして
Dialogue: 0,0:08:31.84,0:08:34.95,Default,,0000,0000,0000,,はじめまして
Dialogue: 0,0:08:34.95,0:08:36.92,Default,,0000,0000,0000,,それじゃ
Dialogue: 0,0:08:40.95,0:08:43.29,Default,,0000,0000,0000,,思春期ですか?
Dialogue: 0,0:08:43.29,0:08:45.63,Default,,0000,0000,0000,,えっ!? 何が?
Dialogue: 0,0:08:45.63,0:08:47.63,Default,,0000,0000,0000,,気持ちいい!
Dialogue: 0,0:08:47.63,0:08:50.96,Default,,0000,0000,0000,,私 16になったら 絶対 免許取ります!
Dialogue: 0,0:08:50.96,0:08:52.97,Default,,0000,0000,0000,,あれ?
Dialogue: 0,0:08:50.96,0:08:52.97,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:08:52.97,0:08:55.30,Default,,0000,0000,0000,,夜なのに光が灯ってない
Dialogue: 0,0:08:55.30,0:09:00.14,Default,,0000,0000,0000,,あの灯台ですか? なんでも 管理する人もいなくて
Dialogue: 0,0:09:00.14,0:09:02.48,Default,,0000,0000,0000,,今は使われてないそうですよ
Dialogue: 0,0:09:02.48,0:09:04.84,Default,,0000,0000,0000,,そうなんだ
Dialogue: 0,0:09:15.99,0:09:18.16,Default,,0000,0000,0000,,探し物 か
Dialogue: 0,0:09:21.83,0:09:23.80,Default,,0000,0000,0000,,あららら
Dialogue: 0,0:09:25.83,0:09:28.00,Default,,0000,0000,0000,,はい これ
Dialogue: 0,0:09:28.00,0:09:30.37,Default,,0000,0000,0000,,まあ ありがとう
Dialogue: 0,0:09:32.51,0:09:34.41,Default,,0000,0000,0000,,ハッ うっ
Dialogue: 0,0:09:34.41,0:09:37.74,Default,,0000,0000,0000,,もしかして あなたも探し物を?
Dialogue: 0,0:09:34.41,0:09:37.74,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:09:37.74,0:09:40.75,Default,,0000,0000,0000,,そうなのね
Dialogue: 0,0:09:37.74,0:09:40.75,Default,,0000,0000,0000,,いまだ誰も見たことのない
Dialogue: 0,0:09:40.75,0:09:42.75,Default,,0000,0000,0000,,未知なる おっぱいを
Dialogue: 0,0:09:42.75,0:09:47.75,Default,,0000,0000,0000,,えっ? えっ?
Dialogue: 0,0:09:42.75,0:09:47.75,Default,,0000,0000,0000,,えっ!? 今 おっぱいって
Dialogue: 0,0:09:47.75,0:09:50.92,Default,,0000,0000,0000,,ところで あなた お名前は?
Dialogue: 0,0:09:47.75,0:09:50.92,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:09:50.92,0:09:54.26,Default,,0000,0000,0000,,あぁ 鷹原羽依里です
Dialogue: 0,0:09:54.26,0:09:56.93,Default,,0000,0000,0000,,そう 鷹原パイリくんね
Dialogue: 0,0:09:56.93,0:10:00.60,Default,,0000,0000,0000,,待って 俺の名前 羽依里って
Dialogue: 0,0:10:00.60,0:10:03.94,Default,,0000,0000,0000,,そうよね
Dialogue: 0,0:10:00.60,0:10:03.94,Default,,0000,0000,0000,,パイリくんは パイリくんだもんね
Dialogue: 0,0:10:03.94,0:10:07.44,Default,,0000,0000,0000,,ねっ パイリくん
Dialogue: 0,0:10:07.44,0:10:10.11,Default,,0000,0000,0000,,私は 水織静久
Dialogue: 0,0:10:10.11,0:10:14.95,Default,,0000,0000,0000,,よかったら静久か おっぱいさんって呼んでね
Dialogue: 0,0:10:14.95,0:10:17.62,Default,,0000,0000,0000,,じゃあ 静久で
Dialogue: 0,0:10:17.62,0:10:20.12,Default,,0000,0000,0000,,そう 残念ね
Dialogue: 0,0:10:20.12,0:10:22.12,Default,,0000,0000,0000,,シズク!
Dialogue: 0,0:10:20.12,0:10:22.12,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:10:22.12,0:10:25.96,Default,,0000,0000,0000,,むぎぎぎぎ
Dialogue: 0,0:10:22.12,0:10:25.96,Default,,0000,0000,0000,,手を貸してくださ わわわっ!
Dialogue: 0,0:10:25.96,0:10:27.96,Default,,0000,0000,0000,,むぎゅ
Dialogue: 0,0:10:25.96,0:10:27.96,Default,,0000,0000,0000,,だ 大丈夫?
Dialogue: 0,0:10:27.96,0:10:31.80,Default,,0000,0000,0000,,あ はい すみま
Dialogue: 0,0:10:27.96,0:10:31.80,Default,,0000,0000,0000,,あっ あなたは 昨日の
Dialogue: 0,0:10:31.80,0:10:36.97,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:10:31.80,0:10:36.97,Default,,0000,0000,0000,,えぇと 誰さんでしょうか?
Dialogue: 0,0:10:36.97,0:10:40.64,Default,,0000,0000,0000,,悪いわね 手伝ってもらっちゃって
Dialogue: 0,0:10:40.64,0:10:42.81,Default,,0000,0000,0000,,いや どうせ暇だったから
Dialogue: 0,0:10:42.81,0:10:46.81,Default,,0000,0000,0000,,ホントに ありがとうございます
Dialogue: 0,0:10:42.81,0:10:46.81,Default,,0000,0000,0000,,えっと
Dialogue: 0,0:10:46.81,0:10:51.15,Default,,0000,0000,0000,,「たかはら はいりさん」
Dialogue: 0,0:10:51.15,0:10:53.99,Default,,0000,0000,0000,,もしかして 俺の名前 忘れてた?
Dialogue: 0,0:10:53.99,0:10:57.49,Default,,0000,0000,0000,,はい でも覚えました!
Dialogue: 0,0:10:53.99,0:10:57.49,Default,,0000,0000,0000,,タカハラさん
Dialogue: 0,0:10:57.49,0:11:02.50,Default,,0000,0000,0000,,それにしても 2人だけで
Dialogue: 0,0:10:57.49,0:11:02.50,Default,,0000,0000,0000,,よくこれだけ集めたな
Dialogue: 0,0:11:02.50,0:11:05.00,Default,,0000,0000,0000,,紬ったら おもしろいかもしれないから
Dialogue: 0,0:11:05.00,0:11:07.67,Default,,0000,0000,0000,,海岸のゴミ拾いをしよう とか言い出して
Dialogue: 0,0:11:07.67,0:11:11.84,Default,,0000,0000,0000,,まあ 友達が やりたいことは 断然応援しなくちゃね
Dialogue: 0,0:11:11.84,0:11:15.34,Default,,0000,0000,0000,,友達
Dialogue: 0,0:11:11.84,0:11:15.34,Default,,0000,0000,0000,,で どう? おもしろい?
Dialogue: 0,0:11:15.34,0:11:18.51,Default,,0000,0000,0000,,おもしろくないです
Dialogue: 0,0:11:15.34,0:11:18.51,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:11:18.51,0:11:21.68,Default,,0000,0000,0000,,どうして こんなことを 始めてしまったんだろうと
Dialogue: 0,0:11:21.68,0:11:23.85,Default,,0000,0000,0000,,後悔の連続です
Dialogue: 0,0:11:23.85,0:11:27.69,Default,,0000,0000,0000,,そんなに
Dialogue: 0,0:11:23.85,0:11:27.69,Default,,0000,0000,0000,,でも お友達は増えました
Dialogue: 0,0:11:27.69,0:11:31.19,Default,,0000,0000,0000,,とりあえず ゴミの分別しないとな
Dialogue: 0,0:11:31.19,0:11:33.66,Default,,0000,0000,0000,,あら? これは どっちかしら?
Dialogue: 0,0:11:33.66,0:11:36.50,Default,,0000,0000,0000,,パリングルスの空き容器か
Dialogue: 0,0:11:36.50,0:11:40.83,Default,,0000,0000,0000,,むぎゅぎゅ 本体は紙で できてるから燃えるゴミですけど
Dialogue: 0,0:11:40.83,0:11:46.01,Default,,0000,0000,0000,,底の部分は 金属のようですし
Dialogue: 0,0:11:40.83,0:11:46.01,Default,,0000,0000,0000,,簡単に捨てられないってわけか
Dialogue: 0,0:11:46.01,0:11:49.51,Default,,0000,0000,0000,,そうねぇ リサイクルとかできれば いいんだけど
Dialogue: 0,0:11:49.51,0:11:54.18,Default,,0000,0000,0000,,むぎゅ リサイクル ですか
Dialogue: 0,0:11:54.18,0:11:58.18,Default,,0000,0000,0000,,タカハラさん 今日は 一日 ありがとうございました
Dialogue: 0,0:11:58.18,0:12:02.02,Default,,0000,0000,0000,,それじゃ 手伝ってくれた パイリくんへのお礼に
Dialogue: 0,0:12:02.02,0:12:04.86,Default,,0000,0000,0000,,この島の 観光スポットを案内してあげるわ
Dialogue: 0,0:12:04.86,0:12:10.20,Default,,0000,0000,0000,,ほら あそこ 通称 おっぱい岩よ
Dialogue: 0,0:12:04.86,0:12:10.20,Default,,0000,0000,0000,,私が名付けたの
Dialogue: 0,0:12:10.20,0:12:12.20,Default,,0000,0000,0000,,なんて ひどい名前を
Dialogue: 0,0:12:12.20,0:12:14.20,Default,,0000,0000,0000,,シズク 質問です
Dialogue: 0,0:12:14.20,0:12:18.20,Default,,0000,0000,0000,,岩が3つありますけど おっぱいは 普通 2つじゃないんですか?
Dialogue: 0,0:12:18.20,0:12:21.71,Default,,0000,0000,0000,,紬 3つあって 誰が困るというの?
Dialogue: 0,0:12:21.71,0:12:23.88,Default,,0000,0000,0000,,むしろ お得ということですね!
Dialogue: 0,0:12:25.88,0:12:27.88,Default,,0000,0000,0000,,ここも観光名所なんだ
Dialogue: 0,0:12:27.88,0:12:30.72,Default,,0000,0000,0000,,さあ
Dialogue: 0,0:12:27.88,0:12:30.72,Default,,0000,0000,0000,,権力者さんのお家です
Dialogue: 0,0:12:30.72,0:12:33.12,Default,,0000,0000,0000,,権力者?
Dialogue: 0,0:12:30.72,0:12:33.12,Default,,0000,0000,0000,,はい
Dialogue: 0,0:12:33.12,0:12:36.46,Default,,0000,0000,0000,,でも 大昔に 没落してしまいました
Dialogue: 0,0:12:36.46,0:12:38.96,Default,,0000,0000,0000,,今は 誰も住んでいません
Dialogue: 0,0:12:52.00,0:12:54.84,Default,,0000,0000,0000,,どうかしら?
Dialogue: 0,0:12:52.00,0:12:54.84,Default,,0000,0000,0000,,どうって言われても
Dialogue: 0,0:12:54.84,0:12:58.84,Default,,0000,0000,0000,,すてきです シズク!
Dialogue: 0,0:12:54.84,0:12:58.84,Default,,0000,0000,0000,,まさに おっぱいそのものです!
Dialogue: 0,0:12:58.84,0:13:03.02,Default,,0000,0000,0000,,まあ! 最高の褒め言葉よ 紬!
Dialogue: 0,0:13:03.02,0:13:05.89,Default,,0000,0000,0000,,それじゃ 先に行ってるわね!
Dialogue: 0,0:13:07.85,0:13:11.69,Default,,0000,0000,0000,,やりたいことがあるって ついてきてみれば 海水浴か
Dialogue: 0,0:13:11.69,0:13:15.03,Default,,0000,0000,0000,,シズクが楽しいなら全然オーケーです
Dialogue: 0,0:13:15.03,0:13:17.70,Default,,0000,0000,0000,,紬は その格好で入るのか?
Dialogue: 0,0:13:17.70,0:13:21.03,Default,,0000,0000,0000,,そうですね
Dialogue: 0,0:13:17.70,0:13:21.03,Default,,0000,0000,0000,,水着を持ってきてませんから
Dialogue: 0,0:13:21.03,0:13:26.54,Default,,0000,0000,0000,,足だけ浸けようかと思います
Dialogue: 0,0:13:21.03,0:13:26.54,Default,,0000,0000,0000,,私たちも行きましょう タカハラさん
Dialogue: 0,0:13:26.54,0:13:28.51,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:30.51,0:13:33.15,Default,,0000,0000,0000,,俺は やめとくよ
Dialogue: 0,0:13:33.15,0:13:36.48,Default,,0000,0000,0000,,むぎゅ? 水に入るの苦手ですか?
Dialogue: 0,0:13:36.48,0:13:40.32,Default,,0000,0000,0000,,まあ そんなところだよ
Dialogue: 0,0:13:36.48,0:13:40.32,Default,,0000,0000,0000,,ん
Dialogue: 0,0:13:40.32,0:13:43.32,Default,,0000,0000,0000,,まあ いろいろありますもんね
Dialogue: 0,0:13:43.32,0:13:46.16,Default,,0000,0000,0000,,そうだな いろいろあるな
Dialogue: 0,0:13:46.16,0:13:49.83,Default,,0000,0000,0000,,でも 今日のところは 入ってみませんか?
Dialogue: 0,0:13:49.83,0:13:52.67,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:13:49.83,0:13:54.67,Default,,0000,0000,0000,,一緒に水に入ったら きっと友情が育めます
Dialogue: 0,0:13:54.67,0:13:59.67,Default,,0000,0000,0000,,水かけあいっこしたりして もうずっと育みっぱなしです!
Dialogue: 0,0:13:59.67,0:14:02.44,Default,,0000,0000,0000,,そしたら きっと 楽しいです
Dialogue: 0,0:14:06.51,0:14:11.85,Default,,0000,0000,0000,,こうなったら私の本気を
Dialogue: 0,0:14:06.51,0:14:11.85,Default,,0000,0000,0000,,お見せしましょう せの!
Dialogue: 0,0:14:11.85,0:14:14.19,Default,,0000,0000,0000,,うっ えっ!? ちょ ちょっと!
Dialogue: 0,0:14:14.19,0:14:16.19,Default,,0000,0000,0000,,むぎゅ!
Dialogue: 0,0:14:14.19,0:14:16.19,Default,,0000,0000,0000,,おっ
Dialogue: 0,0:14:16.19,0:14:19.19,Default,,0000,0000,0000,,わ わかったよ 足くらいなら
Dialogue: 0,0:14:16.19,0:14:19.19,Default,,0000,0000,0000,,ぎゅ!
Dialogue: 0,0:14:19.19,0:14:22.03,Default,,0000,0000,0000,,むぎゅ!?
Dialogue: 0,0:14:19.19,0:14:22.03,Default,,0000,0000,0000,,うっ がっ!
Dialogue: 0,0:14:22.03,0:14:24.53,Default,,0000,0000,0000,,紬!
Dialogue: 0,0:14:22.03,0:14:24.53,Default,,0000,0000,0000,,大丈夫か?
Dialogue: 0,0:14:24.53,0:14:26.53,Default,,0000,0000,0000,,プハー!
Dialogue: 0,0:14:24.53,0:14:26.53,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:14:26.53,0:14:28.87,Default,,0000,0000,0000,,あら びしょ濡れね
Dialogue: 0,0:14:28.87,0:14:32.20,Default,,0000,0000,0000,,おぉ これは恥ずかしいですね
Dialogue: 0,0:14:32.20,0:14:35.11,Default,,0000,0000,0000,,あっ! 入りました
Dialogue: 0,0:14:35.11,0:14:39.11,Default,,0000,0000,0000,,えっ? あっ
Dialogue: 0,0:14:39.11,0:14:42.92,Default,,0000,0000,0000,,タカハラさん 水に入りました! ウフフ!
Dialogue: 0,0:14:48.12,0:14:52.29,Default,,0000,0000,0000,,今年の夏 なくちゃってさ やりたいこと
Dialogue: 0,0:14:52.29,0:14:57.46,Default,,0000,0000,0000,,だから思うんだ
Dialogue: 0,0:14:52.29,0:14:57.46,Default,,0000,0000,0000,,ここに来たのは なくした何かを
Dialogue: 0,0:14:57.46,0:14:59.47,Default,,0000,0000,0000,,探すためなのかもって
Dialogue: 0,0:14:59.47,0:15:02.64,Default,,0000,0000,0000,,奇遇ですね
Dialogue: 0,0:14:59.47,0:15:02.64,Default,,0000,0000,0000,,私も ずっと探してます
Dialogue: 0,0:15:02.64,0:15:04.64,Default,,0000,0000,0000,,私のやりたいこと
Dialogue: 0,0:15:04.64,0:15:07.97,Default,,0000,0000,0000,,それに 自分が ここにいる意味も
Dialogue: 0,0:15:07.97,0:15:10.14,Default,,0000,0000,0000,,ここにいる意味
Dialogue: 0,0:15:10.14,0:15:13.65,Default,,0000,0000,0000,,ずっとずっと 難しいと思ってました
Dialogue: 0,0:15:13.65,0:15:19.65,Default,,0000,0000,0000,,でも シズクとタカハラさんが一緒なら
Dialogue: 0,0:15:13.65,0:15:19.65,Default,,0000,0000,0000,,見つかるような気がします!
Dialogue: 0,0:15:19.65,0:15:22.49,Default,,0000,0000,0000,,じゃあ 見つかるかどうか わからないけど
Dialogue: 0,0:15:22.49,0:15:26.66,Default,,0000,0000,0000,,一緒に探してみようか 紬が やりたいこと!
Dialogue: 0,0:15:26.66,0:15:29.16,Default,,0000,0000,0000,,むぎゅ! ありがとうございます!
Dialogue: 0,0:15:29.16,0:15:32.50,Default,,0000,0000,0000,,それで 私のやりたいことは何でしょう?
Dialogue: 0,0:15:32.50,0:15:35.10,Default,,0000,0000,0000,,いきなり直球の質問だな
Dialogue: 0,0:15:35.10,0:15:39.81,Default,,0000,0000,0000,,紬が ちょっとでも やりたいと思ったこと 全部やっちゃいましょうよ
Dialogue: 0,0:15:39.81,0:15:41.81,Default,,0000,0000,0000,,何かない?
Dialogue: 0,0:15:41.81,0:15:45.14,Default,,0000,0000,0000,,そですね あっ 思いつきました
Dialogue: 0,0:15:45.14,0:15:47.81,Default,,0000,0000,0000,,意外と早いな
Dialogue: 0,0:15:47.81,0:15:51.65,Default,,0000,0000,0000,,こんなふうに お二人と ずっと一緒にいたいです!
Dialogue: 0,0:15:51.65,0:15:54.82,Default,,0000,0000,0000,,一緒に ご飯食べたり 夜になったら星を見たり
Dialogue: 0,0:15:54.82,0:15:58.49,Default,,0000,0000,0000,,それで いっぱいいっぱい お話しがしたいです!
Dialogue: 0,0:15:58.49,0:16:01.33,Default,,0000,0000,0000,,それって つまり お泊まり会ね
Dialogue: 0,0:16:01.33,0:16:04.66,Default,,0000,0000,0000,,おぉ さすがシズク そのとおりです!
Dialogue: 0,0:16:04.66,0:16:08.17,Default,,0000,0000,0000,,お泊まり でも いいのか?
Dialogue: 0,0:16:08.17,0:16:10.50,Default,,0000,0000,0000,,知り合って 間もない俺を泊めても
Dialogue: 0,0:16:10.50,0:16:13.67,Default,,0000,0000,0000,,私は大丈夫よ
Dialogue: 0,0:16:10.50,0:16:13.67,Default,,0000,0000,0000,,私もです
Dialogue: 0,0:16:13.67,0:16:16.01,Default,,0000,0000,0000,,タカハラさんのこと好きですし
Dialogue: 0,0:16:16.01,0:16:18.01,Default,,0000,0000,0000,,えっ!? 好き?
Dialogue: 0,0:16:18.01,0:16:21.35,Default,,0000,0000,0000,,はい! らくしょーで大好きです
Dialogue: 0,0:16:21.35,0:16:23.62,Default,,0000,0000,0000,,らくしょう なんだ
Dialogue: 0,0:16:25.68,0:16:28.35,Default,,0000,0000,0000,,いらっしゃいませ タカハラさん!
Dialogue: 0,0:16:28.35,0:16:30.36,Default,,0000,0000,0000,,あっ なんだ それ?
Dialogue: 0,0:16:30.36,0:16:32.93,Default,,0000,0000,0000,,むにゃ ネコです
Dialogue: 0,0:16:32.93,0:16:35.09,Default,,0000,0000,0000,,ネコだね
Dialogue: 0,0:16:35.09,0:16:37.10,Default,,0000,0000,0000,,そして ウシです
Dialogue: 0,0:16:37.10,0:16:39.10,Default,,0000,0000,0000,,ウモー
Dialogue: 0,0:16:41.27,0:16:44.44,Default,,0000,0000,0000,,本当に 灯台に住んでるんだ 紬
Dialogue: 0,0:16:44.44,0:16:47.11,Default,,0000,0000,0000,,それに 結構 かわいい部屋だな
Dialogue: 0,0:16:47.11,0:16:49.44,Default,,0000,0000,0000,,そですか ちょっと照れます
Dialogue: 0,0:16:49.44,0:16:54.28,Default,,0000,0000,0000,,そろそろ晩ご飯作りましょっか
Dialogue: 0,0:16:49.44,0:16:54.28,Default,,0000,0000,0000,,はい! むぎゅ!
Dialogue: 0,0:16:54.28,0:16:56.62,Default,,0000,0000,0000,,いつも私ひとりだから
Dialogue: 0,0:16:56.62,0:16:59.45,Default,,0000,0000,0000,,ご飯一人分しか 用意してませんでした
Dialogue: 0,0:16:59.45,0:17:02.79,Default,,0000,0000,0000,,このままでは全員 餓死です
Dialogue: 0,0:17:02.79,0:17:06.13,Default,,0000,0000,0000,,大げさね
Dialogue: 0,0:17:02.79,0:17:06.13,Default,,0000,0000,0000,,1日くらい食べなくても大丈夫
Dialogue: 0,0:17:08.13,0:17:10.13,Default,,0000,0000,0000,,じゃないかも
Dialogue: 0,0:17:10.13,0:17:12.97,Default,,0000,0000,0000,,あっ オヤツなら用意してきたけど
Dialogue: 0,0:17:12.97,0:17:17.80,Default,,0000,0000,0000,,パリングルスね!
Dialogue: 0,0:17:12.97,0:17:17.80,Default,,0000,0000,0000,,むぎゅ さすがです タカハラさん!
Dialogue: 0,0:17:17.80,0:17:21.64,Default,,0000,0000,0000,,むぎゅ! むぎゅぎゅ
Dialogue: 0,0:17:21.64,0:17:24.48,Default,,0000,0000,0000,,あっ いいこと思いつきました
Dialogue: 0,0:17:24.48,0:17:27.31,Default,,0000,0000,0000,,タカハラさん
Dialogue: 0,0:17:24.48,0:17:27.31,Default,,0000,0000,0000,,はい?
Dialogue: 0,0:17:27.31,0:17:29.98,Default,,0000,0000,0000,,あん
Dialogue: 0,0:17:27.31,0:17:29.98,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:17:29.98,0:17:32.32,Default,,0000,0000,0000,,はへはへえふろはい
Dialogue: 0,0:17:32.32,0:17:35.29,Default,,0000,0000,0000,,私も あん
Dialogue: 0,0:17:35.29,0:17:38.12,Default,,0000,0000,0000,,しょ しようがないな
Dialogue: 0,0:17:38.12,0:17:40.59,Default,,0000,0000,0000,,おいしい!
Dialogue: 0,0:17:40.59,0:17:43.80,Default,,0000,0000,0000,,パリングルスは ムテキです!
Dialogue: 0,0:17:43.80,0:17:46.47,Default,,0000,0000,0000,,あん!
Dialogue: 0,0:17:46.47,0:17:48.43,Default,,0000,0000,0000,,俺も食べたいんだけど
Dialogue: 0,0:17:50.47,0:17:53.64,Default,,0000,0000,0000,,星って こんなにいっぱいあったんだな
Dialogue: 0,0:17:53.64,0:17:56.14,Default,,0000,0000,0000,,これも この島のいいところよ
Dialogue: 0,0:17:56.14,0:17:58.64,Default,,0000,0000,0000,,なんだか つかめそうです
Dialogue: 0,0:17:58.64,0:18:03.15,Default,,0000,0000,0000,,むぎゅ
Dialogue: 0,0:17:58.64,0:18:03.15,Default,,0000,0000,0000,,今日は おあずけですね
Dialogue: 0,0:18:08.49,0:18:12.32,Default,,0000,0000,0000,,その歌 初めて 会ったときも歌ってたけど
Dialogue: 0,0:18:12.32,0:18:14.33,Default,,0000,0000,0000,,紬が うれしいときや楽しいとき
Dialogue: 0,0:18:14.33,0:18:18.00,Default,,0000,0000,0000,,ついつい歌っちゃうのよね
Dialogue: 0,0:18:18.00,0:18:23.50,Default,,0000,0000,0000,,なんて歌なんだ?
Dialogue: 0,0:18:18.00,0:18:23.50,Default,,0000,0000,0000,,むぎゅ? わかりません
Dialogue: 0,0:18:23.50,0:18:26.17,Default,,0000,0000,0000,,知らないで歌ってるの?
Dialogue: 0,0:18:23.50,0:18:26.17,Default,,0000,0000,0000,,はい
Dialogue: 0,0:18:26.17,0:18:28.84,Default,,0000,0000,0000,,題名も歌詞も わからないです
Dialogue: 0,0:18:28.84,0:18:33.78,Default,,0000,0000,0000,,でも ずっとずっと昔から 大好きな歌です
Dialogue: 0,0:18:33.78,0:18:36.95,Default,,0000,0000,0000,,この歌を歌っていると
Dialogue: 0,0:18:36.95,0:18:39.79,Default,,0000,0000,0000,,なんだか 自分を 見つけられるんじゃないか
Dialogue: 0,0:18:39.79,0:18:42.79,Default,,0000,0000,0000,,やりたいことが 見つかるんじゃないかって
Dialogue: 0,0:18:42.79,0:18:45.62,Default,,0000,0000,0000,,そんな気がするんです
Dialogue: 0,0:18:45.62,0:18:49.13,Default,,0000,0000,0000,,それじゃあ とりあえず その歌について調べてみましょう
Dialogue: 0,0:18:49.13,0:18:51.13,Default,,0000,0000,0000,,むぎゅ? 歌を?
Dialogue: 0,0:18:51.13,0:18:55.47,Default,,0000,0000,0000,,いいな それ 島のみんなに 紬の歌を聴いてもらってさ
Dialogue: 0,0:18:55.47,0:18:57.47,Default,,0000,0000,0000,,そしたら 何か わかるんじゃないかな
Dialogue: 0,0:18:57.47,0:19:00.81,Default,,0000,0000,0000,,私の歌を島のみんなに
Dialogue: 0,0:19:00.81,0:19:03.98,Default,,0000,0000,0000,,それって ステージを用意してくれるんですか?
Dialogue: 0,0:19:03.98,0:19:06.48,Default,,0000,0000,0000,,それは無理だけど
Dialogue: 0,0:19:06.48,0:19:09.98,Default,,0000,0000,0000,,やっぱり お二人と 一緒にいられてよかったです
Dialogue: 0,0:19:09.98,0:19:14.32,Default,,0000,0000,0000,,ワクワクして なんだか このまま 寝るのが もったいないです
Dialogue: 0,0:19:14.32,0:19:17.49,Default,,0000,0000,0000,,フフッ じゃあ このお泊まりって
Dialogue: 0,0:19:17.49,0:19:20.16,Default,,0000,0000,0000,,紬が探してる やりたいこと だったのかしら?
Dialogue: 0,0:19:20.16,0:19:22.13,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:19:25.50,0:19:29.00,Default,,0000,0000,0000,,ちょっと 違うような気がしますが
Dialogue: 0,0:19:29.00,0:19:31.17,Default,,0000,0000,0000,,でも またやりたいです
Dialogue: 0,0:19:31.17,0:19:34.74,Default,,0000,0000,0000,,あっ! そのときは もう一人 呼んでもいいですか?
Dialogue: 0,0:19:34.74,0:19:37.08,Default,,0000,0000,0000,,大切なお友達なんです
Dialogue: 0,0:19:37.08,0:19:40.41,Default,,0000,0000,0000,,もちろんよ
Dialogue: 0,0:19:37.08,0:19:40.41,Default,,0000,0000,0000,,どんな子なんだ?
Dialogue: 0,0:19:40.41,0:19:44.75,Default,,0000,0000,0000,,その子は お友達を作るのが苦手で
Dialogue: 0,0:19:44.75,0:19:48.75,Default,,0000,0000,0000,,でも とても優しい子です
Dialogue: 0,0:19:48.75,0:19:52.09,Default,,0000,0000,0000,,あらら 寝ちゃったわ
Dialogue: 0,0:19:52.09,0:19:54.93,Default,,0000,0000,0000,,寝るの もったいないって言ってたのに
Dialogue: 0,0:19:54.93,0:19:57.43,Default,,0000,0000,0000,,まぁ いいか
Dialogue: 0,0:19:57.43,0:20:01.63,Default,,0000,0000,0000,,夏休みは まだまだいっぱいあるんだから
Dialogue: 0,0:20:03.77,0:20:06.27,Default,,0000,0000,0000,,帰っちゃうんですか?
Dialogue: 0,0:20:06.27,0:20:08.44,Default,,0000,0000,0000,,さすがに一度は家に戻らないと
Dialogue: 0,0:20:08.44,0:20:11.61,Default,,0000,0000,0000,,じゃないと 家の人も心配するし
Dialogue: 0,0:20:11.61,0:20:14.95,Default,,0000,0000,0000,,でも
Dialogue: 0,0:20:11.61,0:20:14.95,Default,,0000,0000,0000,,そんな顔しないの
Dialogue: 0,0:20:14.95,0:20:18.95,Default,,0000,0000,0000,,明日から 目いっぱい遊ぶために 今日は ゆっくり休みましょ
Dialogue: 0,0:20:18.95,0:20:23.16,Default,,0000,0000,0000,,そですね また明日 ですね
Dialogue: 0,0:20:26.46,0:20:28.79,Default,,0000,0000,0000,,また明日
Dialogue: 0,0:20:28.79,0:20:32.13,Default,,0000,0000,0000,,この夏は 紬と静久と
Dialogue: 0,0:20:32.13,0:20:35.33,Default,,0000,0000,0000,,こんな日が ずっと続くのかな
Dialogue: 0,0:20:39.64,0:20:42.14,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:20:42.14,0:20:45.98,Default,,0000,0000,0000,,あ やっと起きた!
Dialogue: 0,0:20:42.14,0:20:45.98,Default,,0000,0000,0000,,もう夕方ですよ!
Dialogue: 0,0:20:45.98,0:20:48.15,Default,,0000,0000,0000,,えっ? マジ?
Dialogue: 0,0:20:48.15,0:20:50.65,Default,,0000,0000,0000,,洗濯物 出してくださいね
Dialogue: 0,0:20:52.99,0:20:55.49,Default,,0000,0000,0000,,あ あれ?
Dialogue: 0,0:20:55.49,0:20:59.49,Default,,0000,0000,0000,,ごめん 紬 忘れ物しちゃって
Dialogue: 0,0:21:01.99,0:21:04.16,Default,,0000,0000,0000,,紬?
Dialogue: 0,0:21:01.99,0:21:04.16,Default,,0000,0000,0000,,むぎゅ?
Dialogue: 0,0:21:04.16,0:21:07.17,Default,,0000,0000,0000,,タカハラさん どうして?
Dialogue: 0,0:21:07.17,0:21:09.33,Default,,0000,0000,0000,,いや 何かあった?
Dialogue: 0,0:21:09.33,0:21:14.34,Default,,0000,0000,0000,,い いえ なんでもないです
Dialogue: 0,0:21:09.33,0:21:14.34,Default,,0000,0000,0000,,でも
Dialogue: 0,0:21:14.34,0:21:18.68,Default,,0000,0000,0000,,あの タカハラさん 今日も泊まっていきませんか?
Dialogue: 0,0:21:18.68,0:21:21.35,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:21:21.35,0:21:24.68,Default,,0000,0000,0000,,い いや
Dialogue: 0,0:21:21.35,0:21:24.68,Default,,0000,0000,0000,,静久が いるならまだしも
Dialogue: 0,0:21:24.68,0:21:26.69,Default,,0000,0000,0000,,2人っきりは まずいだろ
Dialogue: 0,0:21:26.69,0:21:30.36,Default,,0000,0000,0000,,ダメですか
Dialogue: 0,0:21:26.69,0:21:30.36,Default,,0000,0000,0000,,ほら 夏休みは まだ長いし
Dialogue: 0,0:21:30.36,0:21:33.16,Default,,0000,0000,0000,,また次の機会にさ
Dialogue: 0,0:21:33.16,0:21:35.16,Default,,0000,0000,0000,,ありません
Dialogue: 0,0:21:33.16,0:21:35.16,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:21:35.16,0:21:38.66,Default,,0000,0000,0000,,時間 あんまりないんです
Dialogue: 0,0:21:38.66,0:21:44.34,Default,,0000,0000,0000,,あの 私 もうすぐ
Dialogue: 0,0:21:38.66,0:21:44.34,Default,,0000,0000,0000,,帰らなくちゃならないんです
Dialogue: 0,0:21:44.34,0:21:48.01,Default,,0000,0000,0000,,えっ 今 なんて?
Dialogue: 0,0:21:48.01,0:21:51.34,Default,,0000,0000,0000,,で でも別に また会えるだろうし
Dialogue: 0,0:21:51.34,0:21:53.85,Default,,0000,0000,0000,,電話とか手紙とか連絡だって
Dialogue: 0,0:21:53.85,0:21:56.85,Default,,0000,0000,0000,,できません
Dialogue: 0,0:21:56.85,0:21:59.85,Default,,0000,0000,0000,,すごく遠いところなんです
Dialogue: 0,0:21:59.85,0:22:03.52,Default,,0000,0000,0000,,帰ったら きっと もう会えません
Dialogue: 0,0:22:03.52,0:22:08.19,Default,,0000,0000,0000,,じゃあ 夏が終わったら もう会えないのか?
Dialogue: 0,0:22:08.19,0:22:10.86,Default,,0000,0000,0000,,ずっと言おうと 思ってたんですけど
Dialogue: 0,0:22:10.86,0:22:16.54,Default,,0000,0000,0000,,言ったら お二人とも もう
Dialogue: 0,0:22:10.86,0:22:16.54,Default,,0000,0000,0000,,遊んでくれなくなるかもって
Dialogue: 0,0:22:16.54,0:22:19.37,Default,,0000,0000,0000,,でも 帰る前に
Dialogue: 0,0:22:19.37,0:22:25.54,Default,,0000,0000,0000,,もっと タカハラさんとシズクと
Dialogue: 0,0:22:19.37,0:22:25.54,Default,,0000,0000,0000,,もっと一緒に遊びたいです
Dialogue: 0,0:22:25.54,0:22:28.41,Default,,0000,0000,0000,,だから だから
Dialogue: 0,0:22:30.38,0:22:33.95,Default,,0000,0000,0000,,ごめん やっぱり今日は 泊まれないよ
Dialogue: 0,0:22:33.95,0:22:36.62,Default,,0000,0000,0000,,でも
Dialogue: 0,0:22:33.95,0:22:36.62,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:22:36.62,0:22:41.96,Default,,0000,0000,0000,,その代わりにさ 残った時間
Dialogue: 0,0:22:36.62,0:22:41.96,Default,,0000,0000,0000,,全部 紬のために使う
Dialogue: 0,0:22:41.96,0:22:43.96,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:22:43.96,0:22:49.13,Default,,0000,0000,0000,,俺の残りの夏休みを
Dialogue: 0,0:22:43.96,0:22:49.13,Default,,0000,0000,0000,,全部 紬にあげるよ
Dialogue: 0,0:22:49.13,0:22:51.34,Default,,0000,0000,0000,,ハイリさん
