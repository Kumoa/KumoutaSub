Dialogue: 0,0:00:34.77,0:00:41.27,Default,,0000,0000,0000,,「君と一緒なら
Dialogue: 0,0:00:34.77,0:00:41.27,Default,,0000,0000,0000,,どこでも行ける」
Dialogue: 0,0:00:41.27,0:00:43.44,Default,,0000,0000,0000,,何を歌ってるの?
Dialogue: 0,0:00:43.44,0:00:46.28,Default,,0000,0000,0000,,「ウィズ」
Dialogue: 0,0:00:43.44,0:00:46.28,Default,,0000,0000,0000,,「ウィズ」って何?
Dialogue: 0,0:00:46.28,0:00:51.12,Default,,0000,0000,0000,,英語で一緒という意味なり
Dialogue: 0,0:00:46.28,0:00:51.12,Default,,0000,0000,0000,,一緒って意味なの?
Dialogue: 0,0:00:51.12,0:00:53.95,Default,,0000,0000,0000,,知らずに歌ってたのかよ
Dialogue: 0,0:00:51.12,0:00:53.95,Default,,0000,0000,0000,,エヘッ
Dialogue: 0,0:00:53.95,0:00:57.46,Default,,0000,0000,0000,,一緒っていうタイトル? 変なの
Dialogue: 0,0:00:57.46,0:01:01.46,Default,,0000,0000,0000,,タイトルといえば 僕たちのチーム名を決めませんか?
Dialogue: 0,0:01:01.46,0:01:04.63,Default,,0000,0000,0000,,チーム名?
Dialogue: 0,0:01:01.46,0:01:04.63,Default,,0000,0000,0000,,あっ! それならもう
Dialogue: 0,0:01:04.63,0:01:08.13,Default,,0000,0000,0000,,考えてるんだ! ジャーン!
Dialogue: 0,0:01:08.13,0:01:11.81,Default,,0000,0000,0000,,なんだよ それ
Dialogue: 0,0:01:08.13,0:01:11.81,Default,,0000,0000,0000,,ひげ猫だよ
Dialogue: 0,0:01:11.81,0:01:14.64,Default,,0000,0000,0000,,ということで決定しました!
Dialogue: 0,0:01:14.64,0:01:18.48,Default,,0000,0000,0000,,私たちのチーム名は ひげ猫かもめ団!
Dialogue: 0,0:01:18.48,0:01:20.65,Default,,0000,0000,0000,,かもめは入れるな!
Dialogue: 0,0:01:20.65,0:01:24.15,Default,,0000,0000,0000,,それじゃあ ひげ猫団! おっ!
Dialogue: 0,0:01:24.15,0:01:26.32,Default,,0000,0000,0000,,お!
Dialogue: 0,0:01:26.32,0:01:28.66,Default,,0000,0000,0000,,お おぉ
Dialogue: 0,0:01:26.32,0:01:28.66,Default,,0000,0000,0000,,おぉ
Dialogue: 0,0:01:28.66,0:01:31.49,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:01:28.66,0:01:31.49,Default,,0000,0000,0000,,かもめ!
Dialogue: 0,0:01:31.49,0:01:34.13,Default,,0000,0000,0000,,う あっ!
Dialogue: 0,0:01:34.13,0:01:36.96,Default,,0000,0000,0000,,うっ 重い
Dialogue: 0,0:01:36.96,0:01:39.33,Default,,0000,0000,0000,,へっ?
Dialogue: 0,0:01:41.30,0:01:45.14,Default,,0000,0000,0000,,うっ おい 起きろ 鴎
Dialogue: 0,0:01:45.14,0:01:49.98,Default,,0000,0000,0000,,んっ ん ふぇ? あっ!
Dialogue: 0,0:01:49.98,0:01:52.85,Default,,0000,0000,0000,,エロいことされる!
Dialogue: 0,0:01:49.98,0:01:52.85,Default,,0000,0000,0000,,しないから!
Dialogue: 0,0:03:35.28,0:03:37.62,Default,,0000,0000,0000,,食糧よし
Dialogue: 0,0:03:37.62,0:03:41.45,Default,,0000,0000,0000,,良一くんから借りたキャンプ道具 よし!
Dialogue: 0,0:03:41.45,0:03:43.46,Default,,0000,0000,0000,,号令! 鷹原羽依里!
Dialogue: 0,0:03:43.46,0:03:45.79,Default,,0000,0000,0000,,おぉ!
Dialogue: 0,0:03:45.79,0:03:48.29,Default,,0000,0000,0000,,腕は もう大丈夫なの?
Dialogue: 0,0:03:48.29,0:03:50.80,Default,,0000,0000,0000,,ああ このとおりだ
Dialogue: 0,0:03:50.80,0:03:55.30,Default,,0000,0000,0000,,うん それじゃ 海賊船を探す冒険に出発!
Dialogue: 0,0:03:55.30,0:03:57.37,Default,,0000,0000,0000,,おぉ!
Dialogue: 0,0:04:00.64,0:04:03.28,Default,,0000,0000,0000,,で? ここから どうやって進むんだ?
Dialogue: 0,0:04:03.28,0:04:08.82,Default,,0000,0000,0000,,えっとね あっちだよ!
Dialogue: 0,0:04:08.82,0:04:10.78,Default,,0000,0000,0000,,うん
Dialogue: 0,0:04:18.32,0:04:21.09,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:04:18.32,0:04:21.09,Default,,0000,0000,0000,,あれは
Dialogue: 0,0:04:28.17,0:04:31.84,Default,,0000,0000,0000,,ここが スタート地点なんだね!
Dialogue: 0,0:04:31.84,0:04:35.24,Default,,0000,0000,0000,,みたいだな
Dialogue: 0,0:04:39.25,0:04:41.58,Default,,0000,0000,0000,,「ウィズ」だったか?
Dialogue: 0,0:04:41.58,0:04:45.29,Default,,0000,0000,0000,,それ 昔に聴いたことある曲だな
Dialogue: 0,0:04:41.58,0:04:45.29,Default,,0000,0000,0000,,でしょ
Dialogue: 0,0:04:52.76,0:04:54.76,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:04:56.93,0:05:00.27,Default,,0000,0000,0000,,ごめんね 歩くの遅くて
Dialogue: 0,0:05:00.27,0:05:03.44,Default,,0000,0000,0000,,線路の上だと スーツケースは引きづらいだろ?
Dialogue: 0,0:05:03.44,0:05:06.11,Default,,0000,0000,0000,,そうでもないよ
Dialogue: 0,0:05:03.44,0:05:06.11,Default,,0000,0000,0000,,ちゃんと出かける前に
Dialogue: 0,0:05:06.11,0:05:08.78,Default,,0000,0000,0000,,マウンテン仕様にしておいたから
Dialogue: 0,0:05:08.78,0:05:10.78,Default,,0000,0000,0000,,そ そうか
Dialogue: 0,0:05:10.78,0:05:14.45,Default,,0000,0000,0000,,俺が持とうか?
Dialogue: 0,0:05:10.78,0:05:14.45,Default,,0000,0000,0000,,ううん 大丈夫
Dialogue: 0,0:05:14.45,0:05:17.45,Default,,0000,0000,0000,,そっか 行こっか
Dialogue: 0,0:05:20.95,0:05:23.79,Default,,0000,0000,0000,,昔も
Dialogue: 0,0:05:20.95,0:05:23.79,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:05:23.79,0:05:27.13,Default,,0000,0000,0000,,昔も みんなに 迷惑かけたの覚えてる
Dialogue: 0,0:05:27.13,0:05:29.80,Default,,0000,0000,0000,,私だけ歩くの遅くて
Dialogue: 0,0:05:29.80,0:05:32.93,Default,,0000,0000,0000,,そうか でも気にすんなよ
Dialogue: 0,0:05:29.80,0:05:32.93,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:05:32.93,0:05:37.44,Default,,0000,0000,0000,,ゆっくり いろいろ思い出しながら行けばいいんじゃないか?
Dialogue: 0,0:05:37.44,0:05:39.44,Default,,0000,0000,0000,,羽依里
Dialogue: 0,0:05:39.44,0:05:41.61,Default,,0000,0000,0000,,羽依里 イズ いいやつ
Dialogue: 0,0:05:41.61,0:05:43.88,Default,,0000,0000,0000,,やめろって それ
Dialogue: 0,0:05:53.79,0:05:56.12,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:56.12,0:05:58.89,Default,,0000,0000,0000,,ホントに あった
Dialogue: 0,0:06:03.30,0:06:06.97,Default,,0000,0000,0000,,メモにあった おやつ時間に進むべし っていうのは
Dialogue: 0,0:06:06.97,0:06:10.14,Default,,0000,0000,0000,,15時の方角に進めって ことだったんだな
Dialogue: 0,0:06:10.14,0:06:12.81,Default,,0000,0000,0000,,羽依里 冴えてる
Dialogue: 0,0:06:12.81,0:06:16.14,Default,,0000,0000,0000,,この線路の先に 洞窟があるのかな?
Dialogue: 0,0:06:16.14,0:06:18.61,Default,,0000,0000,0000,,そう願いたいけどな
Dialogue: 0,0:06:20.65,0:06:25.32,Default,,0000,0000,0000,,ハァ ハァ
Dialogue: 0,0:06:25.32,0:06:28.99,Default,,0000,0000,0000,,ハァ 暑い
Dialogue: 0,0:06:28.99,0:06:31.16,Default,,0000,0000,0000,,大丈夫か?
Dialogue: 0,0:06:31.16,0:06:34.06,Default,,0000,0000,0000,,ハァ 日陰で少し休んで
Dialogue: 0,0:06:34.06,0:06:36.06,Default,,0000,0000,0000,,あっ!?
Dialogue: 0,0:06:38.06,0:06:40.87,Default,,0000,0000,0000,,鴎? 鴎!?
Dialogue: 0,0:06:43.74,0:06:47.04,Default,,0000,0000,0000,,おい! 鴎!
Dialogue: 0,0:06:55.75,0:06:57.75,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:57.75,0:07:00.25,Default,,0000,0000,0000,,ハァ 暑いなり
Dialogue: 0,0:07:00.25,0:07:02.26,Default,,0000,0000,0000,,ハァ ハァ
Dialogue: 0,0:07:02.26,0:07:05.43,Default,,0000,0000,0000,,ねぇ いつまで歩くのかな
Dialogue: 0,0:07:05.43,0:07:08.93,Default,,0000,0000,0000,,カモメくん 早くしてください!
Dialogue: 0,0:07:13.10,0:07:18.10,Default,,0000,0000,0000,,あぁ ごめん 私は景色楽しみながら行くから
Dialogue: 0,0:07:18.10,0:07:21.11,Default,,0000,0000,0000,,先に行ってて ハ ハハ
Dialogue: 0,0:07:21.11,0:07:24.11,Default,,0000,0000,0000,,それが 重いんじゃないのか? 持つぞ
Dialogue: 0,0:07:24.11,0:07:26.45,Default,,0000,0000,0000,,いい! 自分で持つ!
Dialogue: 0,0:07:26.45,0:07:29.45,Default,,0000,0000,0000,,ごちゃごちゃ言ってないで よこせよ!
Dialogue: 0,0:07:26.45,0:07:29.45,Default,,0000,0000,0000,,イヤだ!
Dialogue: 0,0:07:29.45,0:07:31.65,Default,,0000,0000,0000,,ほら いいから
Dialogue: 0,0:07:29.45,0:07:31.65,Default,,0000,0000,0000,,やめてよ!
Dialogue: 0,0:07:34.75,0:07:36.92,Default,,0000,0000,0000,,お前
Dialogue: 0,0:07:36.92,0:07:41.26,Default,,0000,0000,0000,,先に行ってて
Dialogue: 0,0:07:36.92,0:07:41.26,Default,,0000,0000,0000,,迷惑は かけたくないから
Dialogue: 0,0:07:41.26,0:07:43.93,Default,,0000,0000,0000,,先に行ってて
Dialogue: 0,0:07:43.93,0:07:47.43,Default,,0000,0000,0000,,羽依里? ねぇ 羽依里
Dialogue: 0,0:07:47.43,0:07:51.27,Default,,0000,0000,0000,,おい? 鷹原羽依里くん
Dialogue: 0,0:07:51.27,0:07:53.27,Default,,0000,0000,0000,,あっ! えっ?
Dialogue: 0,0:07:53.27,0:07:57.11,Default,,0000,0000,0000,,大丈夫? なんか ボーッとしてたけど
Dialogue: 0,0:07:57.11,0:08:00.45,Default,,0000,0000,0000,,い いや お前 どこ行ってたんだ?
Dialogue: 0,0:08:00.45,0:08:04.12,Default,,0000,0000,0000,,えっ ずっと 羽依里の後ろをついてきたよ
Dialogue: 0,0:08:06.62,0:08:08.79,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:08:13.96,0:08:15.96,Default,,0000,0000,0000,,ずいぶん歩いてきたけど
Dialogue: 0,0:08:15.96,0:08:20.13,Default,,0000,0000,0000,,ハァ ハァ まだ着かないのかな
Dialogue: 0,0:08:20.13,0:08:22.80,Default,,0000,0000,0000,,これだけ歩いて 見つからないなら
Dialogue: 0,0:08:22.80,0:08:24.80,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:08:24.80,0:08:27.97,Default,,0000,0000,0000,,洞窟!
Dialogue: 0,0:08:27.97,0:08:32.45,Default,,0000,0000,0000,,洞窟 あったね!
Dialogue: 0,0:08:27.97,0:08:32.45,Default,,0000,0000,0000,,ああ!
Dialogue: 0,0:08:44.76,0:08:48.26,Default,,0000,0000,0000,,うるさい
Dialogue: 0,0:08:50.60,0:08:54.43,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:08:50.60,0:08:54.43,Default,,0000,0000,0000,,イタタタ アッ!
Dialogue: 0,0:08:54.43,0:08:58.60,Default,,0000,0000,0000,,おい 大丈夫か!? 脚が痛いのか?
Dialogue: 0,0:08:58.60,0:09:03.11,Default,,0000,0000,0000,,うん でも大丈夫 すぐ治るから
Dialogue: 0,0:09:03.11,0:09:09.12,Default,,0000,0000,0000,,ウソだろ お前 今日の昼から
Dialogue: 0,0:09:03.11,0:09:09.12,Default,,0000,0000,0000,,痛かったんじゃないのか?
Dialogue: 0,0:09:09.12,0:09:12.45,Default,,0000,0000,0000,,俺にスーツケースを よこさなかったのも
Dialogue: 0,0:09:12.45,0:09:15.79,Default,,0000,0000,0000,,あれを杖がわりに 使ってたからなんだろ?
Dialogue: 0,0:09:15.79,0:09:17.96,Default,,0000,0000,0000,,うん
Dialogue: 0,0:09:17.96,0:09:20.96,Default,,0000,0000,0000,,なんで黙ってたんだよ
Dialogue: 0,0:09:20.96,0:09:24.83,Default,,0000,0000,0000,,おはよう
Dialogue: 0,0:09:20.96,0:09:24.83,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:09:28.63,0:09:30.97,Default,,0000,0000,0000,,ヒッ!? エロいことされる!
Dialogue: 0,0:09:30.97,0:09:33.04,Default,,0000,0000,0000,,ん しないよ
Dialogue: 0,0:09:33.04,0:09:35.21,Default,,0000,0000,0000,,それより 羽依里は眠れた?
Dialogue: 0,0:09:35.21,0:09:38.71,Default,,0000,0000,0000,,ふわぁ おかげさまで
Dialogue: 0,0:09:38.71,0:09:41.55,Default,,0000,0000,0000,,あのね ひとついいかな?
Dialogue: 0,0:09:41.55,0:09:44.05,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:09:41.55,0:09:44.05,Default,,0000,0000,0000,,私も眠れたけど
Dialogue: 0,0:09:44.05,0:09:47.89,Default,,0000,0000,0000,,すごい汗かいた
Dialogue: 0,0:09:44.05,0:09:47.89,Default,,0000,0000,0000,,そうだな 俺もだ
Dialogue: 0,0:09:47.89,0:09:53.23,Default,,0000,0000,0000,,でね すぐそこに小さな泉みたいな
Dialogue: 0,0:09:47.89,0:09:53.23,Default,,0000,0000,0000,,ところがあったんだよ
Dialogue: 0,0:09:53.23,0:09:56.90,Default,,0000,0000,0000,,そうか
Dialogue: 0,0:09:53.23,0:09:56.90,Default,,0000,0000,0000,,それで その ちょっくら
Dialogue: 0,0:09:56.90,0:09:59.90,Default,,0000,0000,0000,,水浴びしてこようと 思うんだけど
Dialogue: 0,0:10:13.25,0:10:17.42,Default,,0000,0000,0000,,あらぁ 水音? なんだろう
Dialogue: 0,0:10:17.42,0:10:19.75,Default,,0000,0000,0000,,なんてな
Dialogue: 0,0:10:17.42,0:10:19.75,Default,,0000,0000,0000,,キャー!
Dialogue: 0,0:10:19.75,0:10:22.09,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:10:22.09,0:10:24.09,Default,,0000,0000,0000,,大丈夫か!?
Dialogue: 0,0:10:24.09,0:10:28.09,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:10:24.09,0:10:28.09,Default,,0000,0000,0000,,なんかいたの! でっかいのが!
Dialogue: 0,0:10:28.09,0:10:30.60,Default,,0000,0000,0000,,あっ あぁ
Dialogue: 0,0:10:30.60,0:10:33.93,Default,,0000,0000,0000,,確かにいた でっかいのが
Dialogue: 0,0:10:33.93,0:10:40.11,Default,,0000,0000,0000,,あっ どこに何がいるって?
Dialogue: 0,0:10:33.93,0:10:40.11,Default,,0000,0000,0000,,そ そこの岩場
Dialogue: 0,0:10:40.11,0:10:42.11,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:10:42.11,0:10:45.95,Default,,0000,0000,0000,,もしかして ここが あいつの 水飲み場なんじゃないか?
Dialogue: 0,0:10:45.95,0:10:49.12,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:10:45.95,0:10:49.12,Default,,0000,0000,0000,,いつもの水飲み場に お前がいたから
Dialogue: 0,0:10:49.12,0:10:54.29,Default,,0000,0000,0000,,興奮したんだろ
Dialogue: 0,0:10:49.12,0:10:54.29,Default,,0000,0000,0000,,そっか 私がいるから興奮して
Dialogue: 0,0:10:54.29,0:10:56.79,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:10:54.29,0:10:56.79,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:10:56.79,0:10:59.29,Default,,0000,0000,0000,,あぁ いや 俺のことじゃないからな!
Dialogue: 0,0:11:01.79,0:11:04.60,Default,,0000,0000,0000,,イヤーッ!
Dialogue: 0,0:11:07.63,0:11:10.80,Default,,0000,0000,0000,,見なかったよね?
Dialogue: 0,0:11:10.80,0:11:15.14,Default,,0000,0000,0000,,な なにを?
Dialogue: 0,0:11:10.80,0:11:15.14,Default,,0000,0000,0000,,その いろいろ
Dialogue: 0,0:11:15.14,0:11:18.98,Default,,0000,0000,0000,,あ ああ 見なかったぜ
Dialogue: 0,0:11:18.98,0:11:21.98,Default,,0000,0000,0000,,ウソだね
Dialogue: 0,0:11:21.98,0:11:25.32,Default,,0000,0000,0000,,見たよ! 見ざるを得なかったよ!
Dialogue: 0,0:11:25.32,0:11:28.99,Default,,0000,0000,0000,,うぅ 何を見た?
Dialogue: 0,0:11:28.99,0:11:32.49,Default,,0000,0000,0000,,何って むっ ゴホ! ゴホッ ゴホッ!
Dialogue: 0,0:11:32.49,0:11:35.90,Default,,0000,0000,0000,,出た! 謎の発作 むごっほ!
Dialogue: 0,0:11:40.47,0:11:42.97,Default,,0000,0000,0000,,今更言うのも なんだが
Dialogue: 0,0:11:42.97,0:11:45.64,Default,,0000,0000,0000,,立ち入り禁止の洞窟なんて 危なくないか?
Dialogue: 0,0:11:45.64,0:11:49.48,Default,,0000,0000,0000,,うん でも ここに来て そんな心配しても
Dialogue: 0,0:11:49.48,0:11:52.65,Default,,0000,0000,0000,,しようがないじゃない
Dialogue: 0,0:11:49.48,0:11:52.65,Default,,0000,0000,0000,,いや 心配だろ 普通は
Dialogue: 0,0:11:52.65,0:11:54.81,Default,,0000,0000,0000,,私は 1人でも行くよ
Dialogue: 0,0:11:54.81,0:11:57.48,Default,,0000,0000,0000,,まったく 言うと思ったよ
Dialogue: 0,0:11:57.48,0:11:59.49,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:11:59.49,0:12:01.65,Default,,0000,0000,0000,,同じだな 昔と
Dialogue: 0,0:12:01.65,0:12:04.49,Default,,0000,0000,0000,,えっ? 昔と同じって?
Dialogue: 0,0:12:04.49,0:12:06.46,Default,,0000,0000,0000,,いや なんでもない
Dialogue: 0,0:12:09.66,0:12:11.66,Default,,0000,0000,0000,,このまま進めばいいんだよな?
Dialogue: 0,0:12:11.66,0:12:16.17,Default,,0000,0000,0000,,確かね 入り口から 300mくらい行ったところで
Dialogue: 0,0:12:16.17,0:12:18.64,Default,,0000,0000,0000,,急に狭くなってるところが あるんだよ
Dialogue: 0,0:12:22.01,0:12:24.98,Default,,0000,0000,0000,,ここか?
Dialogue: 0,0:12:22.01,0:12:24.98,Default,,0000,0000,0000,,うん ここ
Dialogue: 0,0:12:27.01,0:12:29.85,Default,,0000,0000,0000,,ここを抜けると 少し広いところに出るの
Dialogue: 0,0:12:29.85,0:12:32.02,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:12:36.59,0:12:39.76,Default,,0000,0000,0000,,私が先に行くね
Dialogue: 0,0:12:39.76,0:12:41.76,Default,,0000,0000,0000,,あ ああ
Dialogue: 0,0:12:47.10,0:12:50.80,Default,,0000,0000,0000,,もしかして俺は
Dialogue: 0,0:12:47.10,0:12:50.80,Default,,0000,0000,0000,,ここに来たことがある?
Dialogue: 0,0:12:54.61,0:12:56.94,Default,,0000,0000,0000,,うっ うぅ
Dialogue: 0,0:12:56.94,0:13:00.95,Default,,0000,0000,0000,,あっ ああ おぉ!
Dialogue: 0,0:13:00.95,0:13:03.62,Default,,0000,0000,0000,,これ どっちに進むんだ?
Dialogue: 0,0:13:00.95,0:13:03.62,Default,,0000,0000,0000,,あっち
Dialogue: 0,0:13:03.62,0:13:06.62,Default,,0000,0000,0000,,もう少し行ったところに 小川が流れてるの
Dialogue: 0,0:13:06.62,0:13:08.82,Default,,0000,0000,0000,,わかった
Dialogue: 0,0:13:13.13,0:13:17.13,Default,,0000,0000,0000,,脚 大丈夫か?
Dialogue: 0,0:13:13.13,0:13:17.13,Default,,0000,0000,0000,,えっ なんで?
Dialogue: 0,0:13:17.13,0:13:19.63,Default,,0000,0000,0000,,いや ふと そう思ったんだ
Dialogue: 0,0:13:19.63,0:13:22.80,Default,,0000,0000,0000,,そもそも そのスーツケースって
Dialogue: 0,0:13:22.80,0:13:25.14,Default,,0000,0000,0000,,脚が悪いから 引いてるんじゃないのか?
Dialogue: 0,0:13:25.14,0:13:27.47,Default,,0000,0000,0000,,あっ な なんで?
Dialogue: 0,0:13:27.47,0:13:31.81,Default,,0000,0000,0000,,大丈夫なんだから
Dialogue: 0,0:13:27.47,0:13:31.81,Default,,0000,0000,0000,,脚が悪いなら
Dialogue: 0,0:13:31.81,0:13:34.45,Default,,0000,0000,0000,,こんなところに 来るわけないんだから
Dialogue: 0,0:13:34.45,0:13:38.62,Default,,0000,0000,0000,,そうだな じゃあ なんで そんなもの引いてるんだ?
Dialogue: 0,0:13:38.62,0:13:40.79,Default,,0000,0000,0000,,これは
Dialogue: 0,0:13:40.79,0:13:43.62,Default,,0000,0000,0000,,教えてあげない よ
Dialogue: 0,0:13:43.62,0:13:45.96,Default,,0000,0000,0000,,いや 聞いておきたい
Dialogue: 0,0:13:43.62,0:13:45.96,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:13:45.96,0:13:50.30,Default,,0000,0000,0000,,一緒に冒険している仲間だろ?
Dialogue: 0,0:13:45.96,0:13:50.30,Default,,0000,0000,0000,,冒険には危険がつきものだ
Dialogue: 0,0:13:50.30,0:13:54.13,Default,,0000,0000,0000,,隠しごとをされたら みんなに迷惑がかかる
Dialogue: 0,0:13:54.13,0:13:57.30,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:54.13,0:13:57.30,Default,,0000,0000,0000,,まあ みんなと言っても
Dialogue: 0,0:13:57.30,0:13:59.81,Default,,0000,0000,0000,,俺と お前だけなんだけどさ
Dialogue: 0,0:13:59.81,0:14:01.97,Default,,0000,0000,0000,,あ あの
Dialogue: 0,0:14:01.97,0:14:06.15,Default,,0000,0000,0000,,本当は 昔から脚が痛むことがあるの
Dialogue: 0,0:14:06.15,0:14:11.15,Default,,0000,0000,0000,,特に寒い日の朝とか夜に
Dialogue: 0,0:14:06.15,0:14:11.15,Default,,0000,0000,0000,,そうか
Dialogue: 0,0:14:11.15,0:14:13.82,Default,,0000,0000,0000,,ごめんなさい 黙ってて
Dialogue: 0,0:14:15.99,0:14:18.32,Default,,0000,0000,0000,,ごめんなさい 黙ってて
Dialogue: 0,0:14:18.32,0:14:22.49,Default,,0000,0000,0000,,入院してたって 病気なのか?
Dialogue: 0,0:14:18.32,0:14:22.49,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:22.49,0:14:26.17,Default,,0000,0000,0000,,ふだんは ちょっと歩きづらい くらいなんだけど
Dialogue: 0,0:14:26.17,0:14:29.17,Default,,0000,0000,0000,,ときどき息ができないくらい 苦しくなったり
Dialogue: 0,0:14:29.17,0:14:32.34,Default,,0000,0000,0000,,まったく体に 力が入らなくなったりするの
Dialogue: 0,0:14:32.34,0:14:38.28,Default,,0000,0000,0000,,ふざけるなよ!
Dialogue: 0,0:14:32.34,0:14:38.28,Default,,0000,0000,0000,,なんで そんなんで こんな
Dialogue: 0,0:14:38.28,0:14:42.62,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:14:38.28,0:14:42.62,Default,,0000,0000,0000,,私 調子がよかったから
Dialogue: 0,0:14:42.62,0:14:46.45,Default,,0000,0000,0000,,大丈夫かなって
Dialogue: 0,0:14:42.62,0:14:46.45,Default,,0000,0000,0000,,朝になったら帰るぞ
Dialogue: 0,0:14:46.45,0:14:48.95,Default,,0000,0000,0000,,イ イヤだ!
Dialogue: 0,0:14:46.45,0:14:48.95,Default,,0000,0000,0000,,バカ言うなよ!
Dialogue: 0,0:14:48.95,0:14:51.62,Default,,0000,0000,0000,,そんなんで 洞窟に入っていくつもりかよ!?
Dialogue: 0,0:14:51.62,0:14:58.30,Default,,0000,0000,0000,,お願いだから 引き返すのはイヤ
Dialogue: 0,0:14:58.30,0:15:01.30,Default,,0000,0000,0000,,フッ 言うと思ったよ
Dialogue: 0,0:15:01.30,0:15:04.80,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:15:01.30,0:15:04.80,Default,,0000,0000,0000,,まっ ここまで来たら
Dialogue: 0,0:15:04.80,0:15:08.47,Default,,0000,0000,0000,,行くも戻るも同じだろう
Dialogue: 0,0:15:08.47,0:15:10.81,Default,,0000,0000,0000,,ありがとう
Dialogue: 0,0:15:10.81,0:15:13.98,Default,,0000,0000,0000,,少し休んでくか
Dialogue: 0,0:15:10.81,0:15:13.98,Default,,0000,0000,0000,,うん
Dialogue: 0,0:15:13.98,0:15:15.98,Default,,0000,0000,0000,,ねぇ
Dialogue: 0,0:15:13.98,0:15:15.98,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:15:15.98,0:15:19.32,Default,,0000,0000,0000,,羽依里は どうして この島に来てるの?
Dialogue: 0,0:15:19.32,0:15:21.49,Default,,0000,0000,0000,,なんだ 唐突に
Dialogue: 0,0:15:21.49,0:15:25.99,Default,,0000,0000,0000,,だって 私のことばかり 詮索されてる気がして悔しいから
Dialogue: 0,0:15:25.99,0:15:29.66,Default,,0000,0000,0000,,ったく 癒やされに来たって 言っただろ?
Dialogue: 0,0:15:29.66,0:15:33.07,Default,,0000,0000,0000,,つまり 傷ついてるの?
Dialogue: 0,0:15:29.66,0:15:33.07,Default,,0000,0000,0000,,まあ
Dialogue: 0,0:15:33.07,0:15:35.07,Default,,0000,0000,0000,,なんで?
Dialogue: 0,0:15:33.07,0:15:35.07,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:15:35.07,0:15:38.40,Default,,0000,0000,0000,,なんで そんな個人的なことを 話さないといけないんだ?
Dialogue: 0,0:15:38.40,0:15:41.07,Default,,0000,0000,0000,,だって 知りたいよ
Dialogue: 0,0:15:38.40,0:15:41.07,Default,,0000,0000,0000,,隠しごとはなし
Dialogue: 0,0:15:41.07,0:15:43.38,Default,,0000,0000,0000,,ったく
Dialogue: 0,0:15:45.41,0:15:47.75,Default,,0000,0000,0000,,部活で しくじった
Dialogue: 0,0:16:01.93,0:16:07.60,Default,,0000,0000,0000,,ふむ しくじったって?
Dialogue: 0,0:16:01.93,0:16:07.60,Default,,0000,0000,0000,,総じて人の期待を裏切った
Dialogue: 0,0:16:07.60,0:16:12.27,Default,,0000,0000,0000,,それで逃げてきた?
Dialogue: 0,0:16:07.60,0:16:12.27,Default,,0000,0000,0000,,逃げた か
Dialogue: 0,0:16:12.27,0:16:16.44,Default,,0000,0000,0000,,まあ そんなところかな
Dialogue: 0,0:16:12.27,0:16:16.44,Default,,0000,0000,0000,,なるほど
Dialogue: 0,0:16:16.44,0:16:19.45,Default,,0000,0000,0000,,期待に応えられなかったと
Dialogue: 0,0:16:19.45,0:16:23.12,Default,,0000,0000,0000,,でもさ そもそも 期待してもらえるのは すごいね
Dialogue: 0,0:16:23.12,0:16:25.95,Default,,0000,0000,0000,,そうだな
Dialogue: 0,0:16:25.95,0:16:31.46,Default,,0000,0000,0000,,それだけに裏切るのは つらいね
Dialogue: 0,0:16:25.95,0:16:31.46,Default,,0000,0000,0000,,そうだな
Dialogue: 0,0:16:31.46,0:16:35.09,Default,,0000,0000,0000,,期待を裏切られるのは やっぱり つらいよね
Dialogue: 0,0:16:35.09,0:16:38.76,Default,,0000,0000,0000,,お前なぁ もっと 気の利いたこと言えないのか?
Dialogue: 0,0:16:38.76,0:16:41.27,Default,,0000,0000,0000,,ああ ごめん! 違うの
Dialogue: 0,0:16:41.27,0:16:45.44,Default,,0000,0000,0000,,今のは 私のこと
Dialogue: 0,0:16:41.27,0:16:45.44,Default,,0000,0000,0000,,羽依里のことじゃなくて
Dialogue: 0,0:16:45.44,0:16:48.94,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:16:45.44,0:16:48.94,Default,,0000,0000,0000,,私は やっぱり期待してるんだ
Dialogue: 0,0:16:48.94,0:16:53.45,Default,,0000,0000,0000,,そんなつもりはなかったけど ゴールが近くなるにつれて
Dialogue: 0,0:16:53.45,0:16:57.45,Default,,0000,0000,0000,,自分が すごく 期待してたんだって自覚してる
Dialogue: 0,0:16:57.45,0:17:01.29,Default,,0000,0000,0000,,何を?
Dialogue: 0,0:16:57.45,0:17:01.29,Default,,0000,0000,0000,,みんなに会えるのを
Dialogue: 0,0:17:01.29,0:17:04.96,Default,,0000,0000,0000,,この洞窟の先に まだ海賊船があって
Dialogue: 0,0:17:04.96,0:17:08.63,Default,,0000,0000,0000,,そこに みんなのうち 誰か1人でも来ていて
Dialogue: 0,0:17:08.63,0:17:12.80,Default,,0000,0000,0000,,私を待ってるかもしれないって 期待してるの
Dialogue: 0,0:17:12.80,0:17:14.97,Default,,0000,0000,0000,,けど ホント言うとね
Dialogue: 0,0:17:14.97,0:17:17.97,Default,,0000,0000,0000,,たぶん 誰もいないと思うんだ
Dialogue: 0,0:17:14.97,0:17:17.97,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:17:17.97,0:17:23.81,Default,,0000,0000,0000,,私 小さいときから体が悪くて
Dialogue: 0,0:17:17.97,0:17:23.81,Default,,0000,0000,0000,,ずっと病院で過ごしてたから
Dialogue: 0,0:17:23.81,0:17:26.98,Default,,0000,0000,0000,,夏休みに遊んだ記憶って ほとんどなくて
Dialogue: 0,0:17:26.98,0:17:33.05,Default,,0000,0000,0000,,だから私には この思い出だけが
Dialogue: 0,0:17:26.98,0:17:33.05,Default,,0000,0000,0000,,大事だけど でも みんなは
Dialogue: 0,0:17:33.05,0:17:36.06,Default,,0000,0000,0000,,そうじゃ ないんだろうなって わかる
Dialogue: 0,0:17:36.06,0:17:40.56,Default,,0000,0000,0000,,あの夏も いくつもある 思い出の中の1つになって
Dialogue: 0,0:17:40.56,0:17:48.07,Default,,0000,0000,0000,,埋もれて 忘れられて だけど
Dialogue: 0,0:17:40.56,0:17:48.07,Default,,0000,0000,0000,,私には たった1つの宝物だから
Dialogue: 0,0:17:48.07,0:17:51.40,Default,,0000,0000,0000,,だから こだわるんだ
Dialogue: 0,0:17:51.40,0:17:54.57,Default,,0000,0000,0000,,さてと
Dialogue: 0,0:17:54.57,0:17:56.78,Default,,0000,0000,0000,,そろそろ行こっか
Dialogue: 0,0:18:03.08,0:18:05.58,Default,,0000,0000,0000,,あっ ちょっと待て!
Dialogue: 0,0:18:03.08,0:18:05.58,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:18:05.58,0:18:07.59,Default,,0000,0000,0000,,懐中電灯 あっ!
Dialogue: 0,0:18:07.59,0:18:12.59,Default,,0000,0000,0000,,だ 大丈夫 電池交換するから
Dialogue: 0,0:18:12.59,0:18:14.79,Default,,0000,0000,0000,,あっ あっ!
Dialogue: 0,0:18:12.59,0:18:14.79,Default,,0000,0000,0000,,鴎!
Dialogue: 0,0:18:16.93,0:18:19.13,Default,,0000,0000,0000,,鴎!
Dialogue: 0,0:18:21.77,0:18:24.27,Default,,0000,0000,0000,,プハッ プハッ!
Dialogue: 0,0:18:26.77,0:18:29.11,Default,,0000,0000,0000,,ハァ ハァ ハァ
Dialogue: 0,0:18:29.11,0:18:31.61,Default,,0000,0000,0000,,羽依里!
Dialogue: 0,0:18:33.58,0:18:35.58,Default,,0000,0000,0000,,羽依里!
Dialogue: 0,0:18:35.58,0:18:38.58,Default,,0000,0000,0000,,ハァ ハァ
Dialogue: 0,0:18:38.58,0:18:42.25,Default,,0000,0000,0000,,羽依里! ねぇ 羽依里!!
Dialogue: 0,0:18:42.25,0:18:46.33,Default,,0000,0000,0000,,大丈夫!
Dialogue: 0,0:18:42.25,0:18:46.33,Default,,0000,0000,0000,,目的地は もう少しのはずだから
Dialogue: 0,0:18:56.10,0:19:04.44,Default,,0000,0000,0000,,「君と一緒なら どこでもいける」
Dialogue: 0,0:19:04.44,0:19:10.78,Default,,0000,0000,0000,,「どこにも
Dialogue: 0,0:19:04.44,0:19:10.78,Default,,0000,0000,0000,,いかなくてもいい」
Dialogue: 0,0:19:10.78,0:19:15.62,Default,,0000,0000,0000,,「君と一緒なら」
Dialogue: 0,0:19:15.62,0:19:20.29,Default,,0000,0000,0000,,「世界のどこにでも」
Dialogue: 0,0:19:20.29,0:19:22.29,Default,,0000,0000,0000,,「行ける」
Dialogue: 0,0:19:22.29,0:19:26.80,Default,,0000,0000,0000,,「行けなくてもいい」
Dialogue: 0,0:19:26.80,0:19:31.30,Default,,0000,0000,0000,,「どこでもいける」
Dialogue: 0,0:19:31.30,0:19:33.91,Default,,0000,0000,0000,,光だ!
Dialogue: 0,0:19:31.30,0:19:33.91,Default,,0000,0000,0000,,出口だよ!
Dialogue: 0,0:19:33.91,0:19:36.74,Default,,0000,0000,0000,,外だ!
Dialogue: 0,0:19:33.91,0:19:36.74,Default,,0000,0000,0000,,海のにおいがする!
Dialogue: 0,0:19:36.74,0:19:39.21,Default,,0000,0000,0000,,行こう!
Dialogue: 0,0:19:36.74,0:19:39.21,Default,,0000,0000,0000,,うん!
Dialogue: 0,0:19:48.42,0:19:53.09,Default,,0000,0000,0000,,あっ あっ 羽依里 大丈夫?
Dialogue: 0,0:19:53.09,0:19:55.59,Default,,0000,0000,0000,,ああ 大丈夫だ
Dialogue: 0,0:19:55.59,0:19:57.60,Default,,0000,0000,0000,,よかった
Dialogue: 0,0:19:57.60,0:19:59.77,Default,,0000,0000,0000,,溺れ死んでたまるか
Dialogue: 0,0:19:59.77,0:20:02.60,Default,,0000,0000,0000,,俺は 水泳部だぞ
Dialogue: 0,0:20:02.60,0:20:05.60,Default,,0000,0000,0000,,あっ 初耳
Dialogue: 0,0:20:02.60,0:20:05.60,Default,,0000,0000,0000,,そうだったな
Dialogue: 0,0:20:05.60,0:20:10.78,Default,,0000,0000,0000,,つまり 水泳部で
Dialogue: 0,0:20:05.60,0:20:10.78,Default,,0000,0000,0000,,期待に応えられなかったんだね?
Dialogue: 0,0:20:10.78,0:20:12.78,Default,,0000,0000,0000,,今 それを持ち出すな
Dialogue: 0,0:20:12.78,0:20:16.78,Default,,0000,0000,0000,,ごめん
Dialogue: 0,0:20:12.78,0:20:16.78,Default,,0000,0000,0000,,あと 間違ってたら すまん
Dialogue: 0,0:20:16.78,0:20:19.28,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:20:16.78,0:20:19.28,Default,,0000,0000,0000,,目覚める前に なんか
Dialogue: 0,0:20:19.28,0:20:22.29,Default,,0000,0000,0000,,キスされてたような気がして
Dialogue: 0,0:20:22.29,0:20:24.46,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:20:24.46,0:20:27.79,Default,,0000,0000,0000,,つまり 人工呼吸してくれたのかな?
Dialogue: 0,0:20:27.79,0:20:31.30,Default,,0000,0000,0000,,あっ あぁ
Dialogue: 0,0:20:27.79,0:20:31.30,Default,,0000,0000,0000,,じ 人命救助だからな
Dialogue: 0,0:20:31.30,0:20:33.47,Default,,0000,0000,0000,,そんなに照れなくていいんだぞ
Dialogue: 0,0:20:33.47,0:20:36.30,Default,,0000,0000,0000,,そう! 人 命 救 助!
Dialogue: 0,0:20:36.30,0:20:38.80,Default,,0000,0000,0000,,あ あっ!
Dialogue: 0,0:20:38.80,0:20:42.64,Default,,0000,0000,0000,,羽依里 見て!
Dialogue: 0,0:20:38.80,0:20:42.64,Default,,0000,0000,0000,,向こうに光が見えるよ!
Dialogue: 0,0:20:42.64,0:20:45.31,Default,,0000,0000,0000,,ああ!
Dialogue: 0,0:20:42.64,0:20:45.31,Default,,0000,0000,0000,,ああっ イッ!
Dialogue: 0,0:20:45.31,0:20:47.81,Default,,0000,0000,0000,,痛むのか? 脚
Dialogue: 0,0:20:45.31,0:20:47.81,Default,,0000,0000,0000,,ごめん
Dialogue: 0,0:20:47.81,0:20:49.82,Default,,0000,0000,0000,,スーツケースは?
Dialogue: 0,0:20:49.82,0:20:53.32,Default,,0000,0000,0000,,水の中に落ちたとき そのまま
Dialogue: 0,0:20:53.32,0:20:55.99,Default,,0000,0000,0000,,そうか
Dialogue: 0,0:20:55.99,0:20:59.66,Default,,0000,0000,0000,,肩 貸すか?
Dialogue: 0,0:20:55.99,0:20:59.66,Default,,0000,0000,0000,,大丈夫
Dialogue: 0,0:20:59.66,0:21:03.16,Default,,0000,0000,0000,,もう少しだから 自分で行かせて
Dialogue: 0,0:21:03.16,0:21:07.17,Default,,0000,0000,0000,,わかった
Dialogue: 0,0:21:03.16,0:21:07.17,Default,,0000,0000,0000,,でも ゆっくりでいいぞ
Dialogue: 0,0:21:07.17,0:21:10.34,Default,,0000,0000,0000,,うん
Dialogue: 0,0:21:10.34,0:21:13.67,Default,,0000,0000,0000,,さっきの話だけどさ
Dialogue: 0,0:21:10.34,0:21:13.67,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:21:13.67,0:21:16.51,Default,,0000,0000,0000,,みんなが思い出を忘れるって話
Dialogue: 0,0:21:16.51,0:21:19.85,Default,,0000,0000,0000,,お前は 夏休みを 過大評価しているのかもな
Dialogue: 0,0:21:19.85,0:21:23.18,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:21:19.85,0:21:23.18,Default,,0000,0000,0000,,お前が思ってるほど
Dialogue: 0,0:21:23.18,0:21:25.52,Default,,0000,0000,0000,,そうそう すごい思い出なんて作れないよ
Dialogue: 0,0:21:25.52,0:21:30.36,Default,,0000,0000,0000,,例えば 海賊船を見つけるために 島を冒険するなんて
Dialogue: 0,0:21:30.36,0:21:33.76,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:30.36,0:21:33.76,Default,,0000,0000,0000,,俺は もう子どもじゃないけど
Dialogue: 0,0:21:33.76,0:21:36.76,Default,,0000,0000,0000,,それでも 今 ワクワクしてる
Dialogue: 0,0:21:36.76,0:21:38.76,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:21:38.76,0:21:42.27,Default,,0000,0000,0000,,羽依里は 今日のこと忘れない?
Dialogue: 0,0:21:42.27,0:21:47.11,Default,,0000,0000,0000,,忘れないだろうな
Dialogue: 0,0:21:42.27,0:21:47.11,Default,,0000,0000,0000,,ずっと覚えてると思う
Dialogue: 0,0:22:12.30,0:22:14.30,Default,,0000,0000,0000,,うん
Dialogue: 0,0:22:16.30,0:22:18.30,Default,,0000,0000,0000,,うん
Dialogue: 0,0:22:39.62,0:22:41.79,Default,,0000,0000,0000,,ああっ
