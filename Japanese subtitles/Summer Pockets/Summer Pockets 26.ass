Dialogue: 0,0:00:47.01,0:00:49.52,Default,,0000,0000,0000,,うみ ちゃん
Dialogue: 0,0:00:53.02,0:00:55.36,Default,,0000,0000,0000,,時間だね
Dialogue: 0,0:00:55.36,0:00:59.36,Default,,0000,0000,0000,,きっと 私のやらなきゃいけないことが
Dialogue: 0,0:00:59.36,0:01:01.86,Default,,0000,0000,0000,,終わっちゃった
Dialogue: 0,0:01:01.86,0:01:06.20,Default,,0000,0000,0000,,おかーさんを助けることができた
Dialogue: 0,0:01:06.20,0:01:11.37,Default,,0000,0000,0000,,おかーさんに また会えて
Dialogue: 0,0:01:06.20,0:01:11.37,Default,,0000,0000,0000,,言いたかったことを言えて
Dialogue: 0,0:01:11.37,0:01:17.54,Default,,0000,0000,0000,,おかーさんに
Dialogue: 0,0:01:11.37,0:01:17.54,Default,,0000,0000,0000,,また名前を呼んでもらえた
Dialogue: 0,0:01:17.54,0:01:23.35,Default,,0000,0000,0000,,すごく 本当に
Dialogue: 0,0:01:17.54,0:01:23.35,Default,,0000,0000,0000,,すごく うれしい
Dialogue: 0,0:01:27.05,0:01:29.06,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:01:29.06,0:01:33.49,Default,,0000,0000,0000,,あれ? ちょっと
Dialogue: 0,0:01:29.06,0:01:33.49,Default,,0000,0000,0000,,疲れちゃったみたい
Dialogue: 0,0:01:33.49,0:01:35.50,Default,,0000,0000,0000,,うみちゃん!
Dialogue: 0,0:01:40.00,0:01:44.17,Default,,0000,0000,0000,,あっ おかーさんのお膝だ
Dialogue: 0,0:01:44.17,0:01:46.67,Default,,0000,0000,0000,,懐かしいな
Dialogue: 0,0:01:46.67,0:01:50.01,Default,,0000,0000,0000,,うみちゃん 私はただ
Dialogue: 0,0:01:50.01,0:01:53.51,Default,,0000,0000,0000,,あなたに幸せになってほしかった だけなのに
Dialogue: 0,0:01:53.51,0:01:56.85,Default,,0000,0000,0000,,ただ それだけなのに
Dialogue: 0,0:01:56.85,0:02:01.52,Default,,0000,0000,0000,,うみちゃんの
Dialogue: 0,0:01:56.85,0:02:01.52,Default,,0000,0000,0000,,おかーさんなのに
Dialogue: 0,0:02:01.52,0:02:08.70,Default,,0000,0000,0000,,うん おかーさんだから
Dialogue: 0,0:02:01.52,0:02:08.70,Default,,0000,0000,0000,,私は おかーさんの子だから
Dialogue: 0,0:02:08.70,0:02:13.70,Default,,0000,0000,0000,,だから こんなにも 頑張れたんだよ
Dialogue: 0,0:02:13.70,0:02:15.70,Default,,0000,0000,0000,,そうだね
Dialogue: 0,0:02:15.70,0:02:21.21,Default,,0000,0000,0000,,うみちゃんは すごく頑張ったよ
Dialogue: 0,0:02:21.21,0:02:25.21,Default,,0000,0000,0000,,なのに 頑張ったのに
Dialogue: 0,0:02:25.21,0:02:31.05,Default,,0000,0000,0000,,頑張ってくれたのに
Dialogue: 0,0:02:25.21,0:02:31.05,Default,,0000,0000,0000,,褒めてあげられないの
Dialogue: 0,0:02:31.05,0:02:33.49,Default,,0000,0000,0000,,うみちゃんのおかーさんで いたいのに
Dialogue: 0,0:02:33.49,0:02:38.32,Default,,0000,0000,0000,,私のうみちゃんで いてほしいのに
Dialogue: 0,0:02:38.32,0:02:40.33,Default,,0000,0000,0000,,おかーさん
Dialogue: 0,0:02:40.33,0:02:42.33,Default,,0000,0000,0000,,嫌だよ!
Dialogue: 0,0:02:42.33,0:02:45.83,Default,,0000,0000,0000,,どこにも行かないで ずっと一緒にいたいよ!
Dialogue: 0,0:02:45.83,0:02:49.84,Default,,0000,0000,0000,,だって 私は うみちゃんとやりたいこと
Dialogue: 0,0:02:49.84,0:02:51.84,Default,,0000,0000,0000,,たくさんあるよ!
Dialogue: 0,0:02:51.84,0:02:55.34,Default,,0000,0000,0000,,一緒に料理をしたり 買い物に出かけたり
Dialogue: 0,0:02:55.34,0:02:58.85,Default,,0000,0000,0000,,いろいろな場所に行って 写真撮って
Dialogue: 0,0:02:58.85,0:03:04.18,Default,,0000,0000,0000,,たくさんの思い出を作って
Dialogue: 0,0:02:58.85,0:03:04.18,Default,,0000,0000,0000,,それを見て昔話をして
Dialogue: 0,0:03:04.18,0:03:10.52,Default,,0000,0000,0000,,何度も夏を 一緒に過ごして
Dialogue: 0,0:03:04.18,0:03:10.52,Default,,0000,0000,0000,,私は
Dialogue: 0,0:03:10.52,0:03:13.69,Default,,0000,0000,0000,,うみちゃんがいない夏なんて嫌!
Dialogue: 0,0:03:13.69,0:03:18.03,Default,,0000,0000,0000,,夏だけじゃない 一年中ずっと!
Dialogue: 0,0:03:18.03,0:03:20.37,Default,,0000,0000,0000,,ずっと一緒にいたいよ!
Dialogue: 0,0:03:20.37,0:03:26.71,Default,,0000,0000,0000,,もう おかーさんのほうが
Dialogue: 0,0:03:20.37,0:03:26.71,Default,,0000,0000,0000,,子どもみたいだね
Dialogue: 0,0:03:26.71,0:03:29.38,Default,,0000,0000,0000,,ずるいよ
Dialogue: 0,0:03:29.38,0:03:32.81,Default,,0000,0000,0000,,我慢 したかったのに
Dialogue: 0,0:03:32.81,0:03:37.82,Default,,0000,0000,0000,,私も おかーさんと一緒にいたい!
Dialogue: 0,0:03:37.82,0:03:40.65,Default,,0000,0000,0000,,もっと おかーさんって呼びたい!
Dialogue: 0,0:03:40.65,0:03:45.33,Default,,0000,0000,0000,,もっと おかーさんに 料理を教えてほしい!
Dialogue: 0,0:03:45.33,0:03:48.16,Default,,0000,0000,0000,,一緒に遊びたい!
Dialogue: 0,0:03:48.16,0:03:54.83,Default,,0000,0000,0000,,まだ 私も
Dialogue: 0,0:03:48.16,0:03:54.83,Default,,0000,0000,0000,,ずっと一緒にいたい
Dialogue: 0,0:03:54.83,0:03:57.34,Default,,0000,0000,0000,,おかーさん おかーさん
Dialogue: 0,0:03:57.34,0:04:02.01,Default,,0000,0000,0000,,おかーさん大好きだよ
Dialogue: 0,0:04:02.01,0:04:04.51,Default,,0000,0000,0000,,うぅ うみちゃん
Dialogue: 0,0:04:04.51,0:04:07.01,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:04:10.02,0:04:15.02,Default,,0000,0000,0000,,おかーさん
Dialogue: 0,0:04:10.02,0:04:15.02,Default,,0000,0000,0000,,一つだけお願いがあるの
Dialogue: 0,0:04:15.02,0:04:18.02,Default,,0000,0000,0000,,なに? 何でも聞くよ
Dialogue: 0,0:04:18.02,0:04:22.70,Default,,0000,0000,0000,,お歌 歌ってほしいの
Dialogue: 0,0:04:22.70,0:04:27.20,Default,,0000,0000,0000,,おかーさんの歌声 覚えてるから
Dialogue: 0,0:04:27.20,0:04:31.04,Default,,0000,0000,0000,,あの夏よりも もっと昔に聴いてたよ
Dialogue: 0,0:04:31.04,0:04:34.97,Default,,0000,0000,0000,,ずっと 聴いていたもん
Dialogue: 0,0:04:34.97,0:04:38.48,Default,,0000,0000,0000,,私は すごく愛されていた
Dialogue: 0,0:04:38.48,0:04:43.98,Default,,0000,0000,0000,,とても温かくて 幸せで
Dialogue: 0,0:04:43.98,0:04:47.49,Default,,0000,0000,0000,,もう一度だけ あのころに戻りたい
Dialogue: 0,0:04:47.49,0:04:52.79,Default,,0000,0000,0000,,おかーさんに包まれて
Dialogue: 0,0:04:47.49,0:04:52.79,Default,,0000,0000,0000,,眠りたいよ
Dialogue: 0,0:04:56.83,0:04:58.83,Default,,0000,0000,0000,,あっ そんな
Dialogue: 0,0:04:58.83,0:05:02.17,Default,,0000,0000,0000,,嫌だよ
Dialogue: 0,0:05:02.17,0:05:04.17,Default,,0000,0000,0000,,そんなこと言わないで
Dialogue: 0,0:05:04.17,0:05:08.34,Default,,0000,0000,0000,,眠っちゃったら うみちゃん いなくなっちゃう!
Dialogue: 0,0:05:08.34,0:05:15.01,Default,,0000,0000,0000,,ううん もう無理 みたい
Dialogue: 0,0:05:15.01,0:05:17.52,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:05:17.52,0:05:23.62,Default,,0000,0000,0000,,おかーさん おかーさん
Dialogue: 0,0:05:26.53,0:05:32.47,Default,,0000,0000,0000,,大丈夫だよ ここに いるよ
Dialogue: 0,0:05:32.47,0:05:34.47,Default,,0000,0000,0000,,うん
Dialogue: 0,0:05:41.97,0:05:54.99,Default,,0000,0000,0000,,「ゆりかごの歌を
Dialogue: 0,0:05:41.97,0:05:54.99,Default,,0000,0000,0000,,カナリヤが歌うよ」
Dialogue: 0,0:06:04.00,0:06:10.50,Default,,0000,0000,0000,,こんなふうに抱かれながら
Dialogue: 0,0:06:04.00,0:06:10.50,Default,,0000,0000,0000,,眠りたかった
Dialogue: 0,0:06:10.50,0:06:17.34,Default,,0000,0000,0000,,おかーさんを知らない頃
Dialogue: 0,0:06:10.50,0:06:17.34,Default,,0000,0000,0000,,おとーさんも仕事でいない夜
Dialogue: 0,0:06:17.34,0:06:23.02,Default,,0000,0000,0000,,一人で眠りながら
Dialogue: 0,0:06:17.34,0:06:23.02,Default,,0000,0000,0000,,ぼんやりと思い出していた
Dialogue: 0,0:06:23.02,0:06:27.69,Default,,0000,0000,0000,,それは 物心が付く前に
Dialogue: 0,0:06:27.69,0:06:34.29,Default,,0000,0000,0000,,誰かの腕の中で
Dialogue: 0,0:06:27.69,0:06:34.29,Default,,0000,0000,0000,,優しく抱かれていた
Dialogue: 0,0:06:34.29,0:06:37.96,Default,,0000,0000,0000,,まだ開ききらない目で
Dialogue: 0,0:06:37.96,0:06:42.47,Default,,0000,0000,0000,,うっすらと 影のように見えるその人を
Dialogue: 0,0:06:42.47,0:06:45.81,Default,,0000,0000,0000,,私は見つめていた
Dialogue: 0,0:06:45.81,0:06:52.48,Default,,0000,0000,0000,,その感触を そのぬくもりを
Dialogue: 0,0:06:45.81,0:06:52.48,Default,,0000,0000,0000,,私は覚えている
Dialogue: 0,0:06:52.48,0:06:56.82,Default,,0000,0000,0000,,まぶしい空の下で 気持ちよく眠っていた
Dialogue: 0,0:06:56.82,0:06:59.49,Default,,0000,0000,0000,,あのころみたいに
Dialogue: 0,0:06:59.49,0:07:04.49,Default,,0000,0000,0000,,かすかに覚えている まぶしさの中で
Dialogue: 0,0:07:04.49,0:07:09.16,Default,,0000,0000,0000,,その人は笑いながら 私を抱いていた
Dialogue: 0,0:07:09.16,0:07:15.00,Default,,0000,0000,0000,,それで 歌ってくれていた
Dialogue: 0,0:07:15.00,0:07:19.34,Default,,0000,0000,0000,,私は いくつもの夏を旅した
Dialogue: 0,0:07:19.34,0:07:23.04,Default,,0000,0000,0000,,そうして 見つけた
Dialogue: 0,0:07:29.68,0:07:34.29,Default,,0000,0000,0000,,あぁ やっとわかった
Dialogue: 0,0:07:34.29,0:07:37.79,Default,,0000,0000,0000,,これは 失うってことなんだ
Dialogue: 0,0:07:37.79,0:07:41.46,Default,,0000,0000,0000,,過去を失うんだ
Dialogue: 0,0:07:41.46,0:07:45.46,Default,,0000,0000,0000,,存在を失うってことなんだ
Dialogue: 0,0:07:45.46,0:07:52.47,Default,,0000,0000,0000,,全部なかったことになって
Dialogue: 0,0:07:45.46,0:07:52.47,Default,,0000,0000,0000,,私は生まれなくて
Dialogue: 0,0:07:52.47,0:08:01.65,Default,,0000,0000,0000,,二度と会えないんだ
Dialogue: 0,0:07:52.47,0:08:01.65,Default,,0000,0000,0000,,おとーさんにも おかーさんにも
Dialogue: 0,0:08:01.65,0:08:04.48,Default,,0000,0000,0000,,でも いいんだ
Dialogue: 0,0:08:04.48,0:08:09.99,Default,,0000,0000,0000,,それでも私は
Dialogue: 0,0:08:04.48,0:08:09.99,Default,,0000,0000,0000,,私がしたかったことをした
Dialogue: 0,0:08:09.99,0:08:12.33,Default,,0000,0000,0000,,おかーさんに会って
Dialogue: 0,0:08:12.33,0:08:16.50,Default,,0000,0000,0000,,おかーさんと いっぱい 楽しい夏を過ごして
Dialogue: 0,0:08:16.50,0:08:22.00,Default,,0000,0000,0000,,それで 最後に会えた
Dialogue: 0,0:08:24.84,0:08:28.84,Default,,0000,0000,0000,,おかーさん ばいばい
Dialogue: 0,0:08:28.84,0:08:31.01,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:08:31.01,0:08:34.61,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:34.61,0:08:37.12,Default,,0000,0000,0000,,うみ ちゃん
Dialogue: 0,0:08:50.96,0:08:56.64,Default,,0000,0000,0000,,いっぱい いっぱい
Dialogue: 0,0:08:50.96,0:08:56.64,Default,,0000,0000,0000,,夏を楽しめたんだね
Dialogue: 0,0:08:56.64,0:09:05.48,Default,,0000,0000,0000,,一生分の夏休みを楽しんで
Dialogue: 0,0:08:56.64,0:09:05.48,Default,,0000,0000,0000,,それを 全部私に 教えてくれた
Dialogue: 0,0:09:05.48,0:09:11.32,Default,,0000,0000,0000,,夏の思い出が
Dialogue: 0,0:09:05.48,0:09:11.32,Default,,0000,0000,0000,,あんなにもまぶしいものだって
Dialogue: 0,0:09:11.32,0:09:13.82,Default,,0000,0000,0000,,教えてくれた
Dialogue: 0,0:09:13.82,0:09:20.16,Default,,0000,0000,0000,,もう あの夏休みは
Dialogue: 0,0:09:13.82,0:09:20.16,Default,,0000,0000,0000,,取り戻せないんだね
Dialogue: 0,0:09:20.16,0:09:24.83,Default,,0000,0000,0000,,取り戻そうと
Dialogue: 0,0:09:20.16,0:09:24.83,Default,,0000,0000,0000,,思っちゃだめなんだよね
Dialogue: 0,0:09:24.83,0:09:28.17,Default,,0000,0000,0000,,わかってる
Dialogue: 0,0:09:28.17,0:09:35.27,Default,,0000,0000,0000,,過去に縛られちゃだめ
Dialogue: 0,0:09:28.17,0:09:35.27,Default,,0000,0000,0000,,なんだよね
Dialogue: 0,0:09:35.27,0:09:42.78,Default,,0000,0000,0000,,でも それでも
Dialogue: 0,0:09:35.27,0:09:42.78,Default,,0000,0000,0000,,私は覚えているよ
Dialogue: 0,0:09:42.78,0:09:47.62,Default,,0000,0000,0000,,あの夏休みは 私にとって
Dialogue: 0,0:09:47.62,0:09:52.46,Default,,0000,0000,0000,,いちばん楽しい 夏休みだったんだよ
Dialogue: 0,0:09:52.46,0:09:58.26,Default,,0000,0000,0000,,うみちゃんが 私を
Dialogue: 0,0:09:52.46,0:09:58.26,Default,,0000,0000,0000,,おかーさんにしてくれたんだよ
Dialogue: 0,0:10:03.64,0:10:07.31,Default,,0000,0000,0000,,全部 覚えてる
Dialogue: 0,0:10:07.31,0:10:12.98,Default,,0000,0000,0000,,忘れたくない!
Dialogue: 0,0:10:12.98,0:10:16.48,Default,,0000,0000,0000,,うみちゃん!
Dialogue: 0,0:10:22.82,0:10:28.33,Default,,0000,0000,0000,,昔々 世界には
Dialogue: 0,0:10:22.82,0:10:28.33,Default,,0000,0000,0000,,色がありませんでした
Dialogue: 0,0:10:28.33,0:10:30.50,Default,,0000,0000,0000,,そんな世界に
Dialogue: 0,0:10:30.50,0:10:33.67,Default,,0000,0000,0000,,きれいな羽の ちょうちょがいました
Dialogue: 0,0:10:33.67,0:10:37.34,Default,,0000,0000,0000,,羽には たくさんの色がついています
Dialogue: 0,0:10:37.34,0:10:41.01,Default,,0000,0000,0000,,ちょうちょは いろいろな場所を旅しています
Dialogue: 0,0:10:41.01,0:10:45.85,Default,,0000,0000,0000,,旅先で ちょうちょは その きれいな羽の色を
Dialogue: 0,0:10:45.85,0:10:49.02,Default,,0000,0000,0000,,出会う人々にあげていきました
Dialogue: 0,0:10:49.02,0:10:52.52,Default,,0000,0000,0000,,気がつけば きれいだった ちょうちょは
Dialogue: 0,0:10:52.52,0:10:55.19,Default,,0000,0000,0000,,真っ白になっていました
Dialogue: 0,0:10:55.19,0:10:59.69,Default,,0000,0000,0000,,それでも ちょうちょは旅を続けます
Dialogue: 0,0:10:59.69,0:11:04.20,Default,,0000,0000,0000,,羽がボロボロになっても 飛び続けました
Dialogue: 0,0:11:04.20,0:11:09.20,Default,,0000,0000,0000,,もう誰も きれいだった ちょうちょだと 気付きません
Dialogue: 0,0:11:09.20,0:11:12.71,Default,,0000,0000,0000,,でも 世界には色があふれ
Dialogue: 0,0:11:12.71,0:11:16.38,Default,,0000,0000,0000,,世界は とてもきれいになりました
Dialogue: 0,0:11:16.38,0:11:18.71,Default,,0000,0000,0000,,やがて 故郷に戻ったちょうちょは
Dialogue: 0,0:11:18.71,0:11:21.88,Default,,0000,0000,0000,,静かに花の上に横たわります
Dialogue: 0,0:11:21.88,0:11:25.89,Default,,0000,0000,0000,,ちょうちょは たくさんの人と出会えたことに
Dialogue: 0,0:11:25.89,0:11:28.39,Default,,0000,0000,0000,,満足していました
Dialogue: 0,0:11:28.39,0:11:32.16,Default,,0000,0000,0000,,ちょうちょは 静かに眠りにつきました
Dialogue: 0,0:11:32.16,0:11:37.06,Default,,0000,0000,0000,,みんな悲しみ 涙が雨になりました
Dialogue: 0,0:11:41.33,0:11:43.67,Default,,0000,0000,0000,,あれ? 続きがある
Dialogue: 0,0:11:43.67,0:11:46.01,Default,,0000,0000,0000,,うみが教えてくれた キーワードだけだと
Dialogue: 0,0:11:46.01,0:11:49.01,Default,,0000,0000,0000,,さっきのところで終わりなんだ
Dialogue: 0,0:11:49.01,0:11:52.01,Default,,0000,0000,0000,,でも なんか さみしい結末だったから
Dialogue: 0,0:11:52.01,0:11:56.02,Default,,0000,0000,0000,,ちょっと付け足してみた
Dialogue: 0,0:11:52.01,0:11:56.02,Default,,0000,0000,0000,,そうなんだ
Dialogue: 0,0:11:56.02,0:11:58.82,Default,,0000,0000,0000,,うん いいと思うよ
Dialogue: 0,0:12:04.52,0:12:09.03,Default,,0000,0000,0000,,雨がやむと ちょうちょは 大きな虹になっていました
Dialogue: 0,0:12:09.03,0:12:14.37,Default,,0000,0000,0000,,世界を包むような
Dialogue: 0,0:12:09.03,0:12:14.37,Default,,0000,0000,0000,,とてもきれいな懸け橋です
Dialogue: 0,0:12:14.37,0:12:19.37,Default,,0000,0000,0000,,みんなが見上げて 「ありがとう」と言いました
Dialogue: 0,0:12:33.99,0:12:37.99,Default,,0000,0000,0000,,間もなく 鳥白島 鳥白島漁港に到着します
Dialogue: 0,0:12:37.99,0:12:43.33,Default,,0000,0000,0000,,着岸の際は 船に強い衝撃が
Dialogue: 0,0:12:37.99,0:12:43.33,Default,,0000,0000,0000,,ある場合もございますので
Dialogue: 0,0:12:43.33,0:12:46.67,Default,,0000,0000,0000,,「鳥白島に来ませんか」
Dialogue: 0,0:12:46.67,0:12:50.17,Default,,0000,0000,0000,,夏休みに入る少し前 手紙が届いた
Dialogue: 0,0:12:50.17,0:12:55.67,Default,,0000,0000,0000,,会ったことのない 母の妹
Dialogue: 0,0:12:50.17,0:12:55.67,Default,,0000,0000,0000,,叔母からのものだった
Dialogue: 0,0:12:55.67,0:12:59.18,Default,,0000,0000,0000,,手紙に同封されていた写真を 見たとき
Dialogue: 0,0:12:59.18,0:13:02.01,Default,,0000,0000,0000,,不思議と懐かしかった
Dialogue: 0,0:13:02.01,0:13:06.69,Default,,0000,0000,0000,,だから こんなところにやってきた
Dialogue: 0,0:13:06.69,0:13:10.36,Default,,0000,0000,0000,,祖母の遺品整理ですか?
Dialogue: 0,0:13:06.69,0:13:10.36,Default,,0000,0000,0000,,そうなの
Dialogue: 0,0:13:10.36,0:13:14.19,Default,,0000,0000,0000,,これは おばあちゃんが いろんな人から預かったものなの
Dialogue: 0,0:13:14.19,0:13:18.36,Default,,0000,0000,0000,,預かったもの?
Dialogue: 0,0:13:14.19,0:13:18.36,Default,,0000,0000,0000,,返さなくていいんですか?
Dialogue: 0,0:13:18.36,0:13:22.37,Default,,0000,0000,0000,,ほとんどの人が亡くなったか 音信不通だからね
Dialogue: 0,0:13:22.37,0:13:26.37,Default,,0000,0000,0000,,その人たちはまた どうして預けていったんでしょう
Dialogue: 0,0:13:26.37,0:13:30.88,Default,,0000,0000,0000,,うん 羽依里くんは こういうことってなかった?
Dialogue: 0,0:13:30.88,0:13:34.65,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:13:30.88,0:13:34.65,Default,,0000,0000,0000,,子どもの頃 外で遊んでるときに
Dialogue: 0,0:13:34.65,0:13:36.82,Default,,0000,0000,0000,,何か見つけるじゃない
Dialogue: 0,0:13:36.82,0:13:41.32,Default,,0000,0000,0000,,それを 大事に ポケットに入れたりしたことない?
Dialogue: 0,0:13:41.32,0:13:45.66,Default,,0000,0000,0000,,あぁ ありますね 昔は
Dialogue: 0,0:13:45.66,0:13:49.33,Default,,0000,0000,0000,,でしょ
Dialogue: 0,0:13:49.33,0:13:53.17,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:13:49.33,0:13:53.17,Default,,0000,0000,0000,,チャックをして こぼれないようにして
Dialogue: 0,0:13:53.17,0:13:55.67,Default,,0000,0000,0000,,とても大事に しまったはずなのに
Dialogue: 0,0:13:55.67,0:13:59.17,Default,,0000,0000,0000,,いつの間にかなくなってるの
Dialogue: 0,0:14:01.17,0:14:04.01,Default,,0000,0000,0000,,でもね ふと思い出して
Dialogue: 0,0:14:04.01,0:14:08.68,Default,,0000,0000,0000,,ポケットを探ると そのかけらが残ってたりするの
Dialogue: 0,0:14:08.68,0:14:13.85,Default,,0000,0000,0000,,かけら?
Dialogue: 0,0:14:08.68,0:14:13.85,Default,,0000,0000,0000,,うん 本当に小さなかけら
Dialogue: 0,0:14:13.85,0:14:18.02,Default,,0000,0000,0000,,でも それが何なのか 思い出せないの
Dialogue: 0,0:14:18.02,0:14:22.36,Default,,0000,0000,0000,,この蔵は そういう場所なのかもしれない
Dialogue: 0,0:14:22.36,0:14:26.37,Default,,0000,0000,0000,,誰かの大事な何かを そっとしまう場所
Dialogue: 0,0:14:26.37,0:14:30.04,Default,,0000,0000,0000,,そうして忘れられた場所
Dialogue: 0,0:14:30.04,0:14:32.97,Default,,0000,0000,0000,,ポケットみたいな場所 ですか
Dialogue: 0,0:14:32.97,0:14:36.31,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:36.31,0:14:40.98,Default,,0000,0000,0000,,ここから 10分ほど 港のほうに戻ったところに 食堂があるから
Dialogue: 0,0:14:40.98,0:14:43.48,Default,,0000,0000,0000,,夜やってる お店といえば そこぐらいよ
Dialogue: 0,0:14:47.99,0:14:49.99,Default,,0000,0000,0000,,え
Dialogue: 0,0:14:52.83,0:14:58.53,Default,,0000,0000,0000,,ハァ しようがない
Dialogue: 0,0:14:52.83,0:14:58.53,Default,,0000,0000,0000,,島をぐるっと回って帰るか
Dialogue: 0,0:15:02.00,0:15:04.34,Default,,0000,0000,0000,,あれ?
Dialogue: 0,0:15:04.34,0:15:06.54,Default,,0000,0000,0000,,ウソだろ
Dialogue: 0,0:15:08.51,0:15:13.51,Default,,0000,0000,0000,,あぁ あっつい
Dialogue: 0,0:15:39.47,0:15:41.97,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:15:39.47,0:15:41.97,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:15:45.64,0:15:47.65,Default,,0000,0000,0000,,どうしたの?
Dialogue: 0,0:15:47.65,0:15:52.15,Default,,0000,0000,0000,,えっ? ううん さっきの
Dialogue: 0,0:15:52.15,0:15:55.32,Default,,0000,0000,0000,,あぁ 見ない男の子ね
Dialogue: 0,0:15:55.32,0:15:58.82,Default,,0000,0000,0000,,観光客じゃない?
Dialogue: 0,0:15:55.32,0:15:58.82,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:16:00.83,0:16:02.83,Default,,0000,0000,0000,,どうしたの? 知り合い?
Dialogue: 0,0:16:02.83,0:16:06.83,Default,,0000,0000,0000,,ううん 知らない
Dialogue: 0,0:16:06.83,0:16:11.50,Default,,0000,0000,0000,,それより 藍との約束の時間
Dialogue: 0,0:16:06.83,0:16:11.50,Default,,0000,0000,0000,,急がないとすねるよ
Dialogue: 0,0:16:11.50,0:16:15.01,Default,,0000,0000,0000,,あぁ そうね 行きましょ
Dialogue: 0,0:16:27.19,0:16:29.36,Default,,0000,0000,0000,,今日からお手伝いします
Dialogue: 0,0:16:29.36,0:16:31.69,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:16:29.36,0:16:31.69,Default,,0000,0000,0000,,そのために来たんですし
Dialogue: 0,0:16:31.69,0:16:35.46,Default,,0000,0000,0000,,べつにやることもないので こき使ってください
Dialogue: 0,0:16:35.46,0:16:39.63,Default,,0000,0000,0000,,うん お願いします
Dialogue: 0,0:16:39.63,0:16:42.30,Default,,0000,0000,0000,,それで どうすればいいんでしょう?
Dialogue: 0,0:16:42.30,0:16:47.81,Default,,0000,0000,0000,,適当にラベルを貼って
Dialogue: 0,0:16:42.30,0:16:47.81,Default,,0000,0000,0000,,あるべき場所に並べていくの
Dialogue: 0,0:16:47.81,0:16:49.81,Default,,0000,0000,0000,,あるべき場所?
Dialogue: 0,0:16:49.81,0:16:51.98,Default,,0000,0000,0000,,羽依里くんの直感でいいから
Dialogue: 0,0:16:51.98,0:16:55.15,Default,,0000,0000,0000,,あっ うん
Dialogue: 0,0:16:55.15,0:16:58.32,Default,,0000,0000,0000,,とりあえず やってみます
Dialogue: 0,0:16:58.32,0:17:00.65,Default,,0000,0000,0000,,蔵に積み上げられた ガラクタを
Dialogue: 0,0:17:00.65,0:17:04.49,Default,,0000,0000,0000,,どこの誰が どんな思いで ここに託していったのか
Dialogue: 0,0:17:04.49,0:17:07.49,Default,,0000,0000,0000,,俺が知るはずもない
Dialogue: 0,0:17:07.49,0:17:11.00,Default,,0000,0000,0000,,それでも 俺なりに整頓していく
Dialogue: 0,0:17:11.00,0:17:14.67,Default,,0000,0000,0000,,そうしているうちに ガラクタの一つ一つの由来が
Dialogue: 0,0:17:14.67,0:17:17.00,Default,,0000,0000,0000,,ぼんやりと見えてくるようで
Dialogue: 0,0:17:17.00,0:17:21.11,Default,,0000,0000,0000,,言ってみれば それは 時の地図とも言えるものだ
Dialogue: 0,0:17:24.01,0:17:26.18,Default,,0000,0000,0000,,フゥ
Dialogue: 0,0:17:26.18,0:17:29.88,Default,,0000,0000,0000,,時の地図 か
Dialogue: 0,0:17:33.45,0:17:35.75,Default,,0000,0000,0000,,タイムマップ
Dialogue: 0,0:17:38.46,0:17:41.46,Default,,0000,0000,0000,,今日は これくらいにしておくか
Dialogue: 0,0:17:47.97,0:17:49.97,Default,,0000,0000,0000,,あの
Dialogue: 0,0:17:47.97,0:17:49.97,Default,,0000,0000,0000,,はい
Dialogue: 0,0:17:51.97,0:17:53.97,Default,,0000,0000,0000,,何にしますか?
Dialogue: 0,0:17:53.97,0:17:55.97,Default,,0000,0000,0000,,オススメとか ありますか?
Dialogue: 0,0:17:55.97,0:17:59.31,Default,,0000,0000,0000,,うん
Dialogue: 0,0:17:59.31,0:18:02.82,Default,,0000,0000,0000,,チャーハン とか
Dialogue: 0,0:17:59.31,0:18:02.82,Default,,0000,0000,0000,,チャーハン?
Dialogue: 0,0:18:02.82,0:18:05.15,Default,,0000,0000,0000,,書いてない
Dialogue: 0,0:18:05.15,0:18:08.82,Default,,0000,0000,0000,,あっ ごめん お店のオススメじゃなかった
Dialogue: 0,0:18:08.82,0:18:11.49,Default,,0000,0000,0000,,んっ? 何のオススメ?
Dialogue: 0,0:18:11.49,0:18:15.99,Default,,0000,0000,0000,,私の オススメ
Dialogue: 0,0:18:20.00,0:18:22.33,Default,,0000,0000,0000,,お待たせしました
Dialogue: 0,0:18:22.33,0:18:25.34,Default,,0000,0000,0000,,どうぞ ごゆっくり
Dialogue: 0,0:18:22.33,0:18:25.34,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:18:30.01,0:18:32.01,Default,,0000,0000,0000,,おいしい!
Dialogue: 0,0:18:35.95,0:18:37.95,Default,,0000,0000,0000,,うん おいしい!
Dialogue: 0,0:18:37.95,0:18:41.45,Default,,0000,0000,0000,,あの これ 味付けとか どうやって作ってるの?
Dialogue: 0,0:18:41.45,0:18:43.46,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:18:45.46,0:18:47.79,Default,,0000,0000,0000,,秘密
Dialogue: 0,0:18:47.79,0:18:50.80,Default,,0000,0000,0000,,ごちそうさまでした
Dialogue: 0,0:18:47.79,0:18:50.80,Default,,0000,0000,0000,,ありがとう
Dialogue: 0,0:18:58.80,0:19:00.81,Default,,0000,0000,0000,,不思議な子だったな
Dialogue: 0,0:19:04.48,0:19:07.31,Default,,0000,0000,0000,,あぁ すごい きれいになったね
Dialogue: 0,0:19:07.31,0:19:09.65,Default,,0000,0000,0000,,どうも
Dialogue: 0,0:19:09.65,0:19:11.98,Default,,0000,0000,0000,,そもそも どうして俺は
Dialogue: 0,0:19:11.98,0:19:14.82,Default,,0000,0000,0000,,蔵の整理をすることが できたんでしょう?
Dialogue: 0,0:19:14.82,0:19:16.82,Default,,0000,0000,0000,,自分でも不思議で
Dialogue: 0,0:19:16.82,0:19:18.99,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:19:18.99,0:19:21.49,Default,,0000,0000,0000,,えっ! 鏡子さん!?
Dialogue: 0,0:19:26.33,0:19:28.33,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:34.61,0:19:36.61,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:19:43.28,0:19:45.28,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:19:49.62,0:19:52.62,Default,,0000,0000,0000,,俺は あの子を知っている
Dialogue: 0,0:19:52.62,0:19:55.96,Default,,0000,0000,0000,,あの子を覚えている
Dialogue: 0,0:19:55.96,0:19:59.30,Default,,0000,0000,0000,,あの子を俺は忘れない
Dialogue: 0,0:19:59.30,0:20:03.64,Default,,0000,0000,0000,,だから だから
Dialogue: 0,0:20:03.64,0:20:06.64,Default,,0000,0000,0000,,うみ!!
Dialogue: 0,0:20:11.31,0:20:13.65,Default,,0000,0000,0000,,いつか遠い夏
Dialogue: 0,0:20:13.65,0:20:17.48,Default,,0000,0000,0000,,ポケットの中に 大事にしまっていた思い出
Dialogue: 0,0:20:17.48,0:20:20.99,Default,,0000,0000,0000,,いつの間にか なくしてしまったとしても
Dialogue: 0,0:20:20.99,0:20:26.66,Default,,0000,0000,0000,,長い君の冒険を
Dialogue: 0,0:20:20.99,0:20:26.66,Default,,0000,0000,0000,,決して忘れはしない
Dialogue: 0,0:20:48.51,0:20:50.52,Default,,0000,0000,0000,,羽依里くん?
Dialogue: 0,0:20:50.52,0:20:52.85,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:20:52.85,0:20:56.19,Default,,0000,0000,0000,,大丈夫? ボーッとしてたけど
Dialogue: 0,0:20:56.19,0:20:59.69,Default,,0000,0000,0000,,あっ いえ 何でも
Dialogue: 0,0:20:59.69,0:21:01.69,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:21:22.05,0:21:26.22,Default,,0000,0000,0000,,ありがとうね 羽依里くん おかげで助かっちゃった
Dialogue: 0,0:21:26.22,0:21:30.06,Default,,0000,0000,0000,,フッ やっと お力になれて よかったです
Dialogue: 0,0:21:30.06,0:21:32.82,Default,,0000,0000,0000,,んっ? やっとって?
Dialogue: 0,0:21:30.06,0:21:32.82,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:21:32.82,0:21:35.49,Default,,0000,0000,0000,,そんなに昔から お手伝いしたかったの?
Dialogue: 0,0:21:35.49,0:21:39.16,Default,,0000,0000,0000,,あっ アハハハハ なんででしょう
Dialogue: 0,0:21:39.16,0:21:42.83,Default,,0000,0000,0000,,なんか やっと手伝えたなっていう 感慨が
Dialogue: 0,0:21:42.83,0:21:46.84,Default,,0000,0000,0000,,フフッ 変なの
Dialogue: 0,0:21:42.83,0:21:46.84,Default,,0000,0000,0000,,変ですね
Dialogue: 0,0:21:49.01,0:21:53.18,Default,,0000,0000,0000,,それじゃあ 行きますね
Dialogue: 0,0:21:53.18,0:21:55.35,Default,,0000,0000,0000,,うん またいらっしゃい
Dialogue: 0,0:21:55.35,0:21:57.35,Default,,0000,0000,0000,,はい
Dialogue: 0,0:22:03.02,0:22:05.19,Default,,0000,0000,0000,,羽依里くん
Dialogue: 0,0:22:05.19,0:22:07.19,Default,,0000,0000,0000,,頑張って
Dialogue: 0,0:22:07.19,0:22:12.53,Default,,0000,0000,0000,,えっ はい 頑張ります
Dialogue: 0,0:22:12.53,0:22:14.53,Default,,0000,0000,0000,,うん
Dialogue: 0,0:22:20.71,0:22:24.88,Default,,0000,0000,0000,,これでよかったんだよね
Dialogue: 0,0:22:24.88,0:22:27.58,Default,,0000,0000,0000,,瞳
Dialogue: 0,0:22:36.32,0:22:38.32,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:22:38.32,0:22:41.33,Default,,0000,0000,0000,,あっ お前は
Dialogue: 0,0:22:41.33,0:22:43.83,Default,,0000,0000,0000,,たしか 加藤さんのところに来ている
Dialogue: 0,0:22:43.83,0:22:47.83,Default,,0000,0000,0000,,あぁ ばあさんの 遺品整理で来てたんだ
Dialogue: 0,0:22:47.83,0:22:50.84,Default,,0000,0000,0000,,あら あんた
Dialogue: 0,0:22:47.83,0:22:50.84,Default,,0000,0000,0000,,なんだ 知り合いか?
Dialogue: 0,0:22:50.84,0:22:53.67,Default,,0000,0000,0000,,ううん ちょっと見かけたくらい
Dialogue: 0,0:22:53.67,0:22:59.68,Default,,0000,0000,0000,,夏休みの始めくらいかな
Dialogue: 0,0:22:53.67,0:22:59.68,Default,,0000,0000,0000,,ふん そうだ
Dialogue: 0,0:22:59.68,0:23:04.68,Default,,0000,0000,0000,,俺らは これから 山に行くんだが 来るか?
Dialogue: 0,0:23:02.68,0:23:04.68,Default,,0000,0000,0000,,山で何を?
Dialogue: 0,0:23:04.68,0:23:07.19,Default,,0000,0000,0000,,麻雀だ
Dialogue: 0,0:23:04.68,0:23:07.19,Default,,0000,0000,0000,,特訓だ!
Dialogue: 0,0:23:07.19,0:23:09.35,Default,,0000,0000,0000,,おぉ
Dialogue: 0,0:23:09.35,0:23:13.36,Default,,0000,0000,0000,,いや 俺 もう帰るんだ
Dialogue: 0,0:23:13.36,0:23:17.53,Default,,0000,0000,0000,,そうか
Dialogue: 0,0:23:13.36,0:23:17.53,Default,,0000,0000,0000,,まぁ 夏休みも終わりだしな
Dialogue: 0,0:23:17.53,0:23:19.70,Default,,0000,0000,0000,,誘ってくれて ありがとう
Dialogue: 0,0:23:19.70,0:23:21.70,Default,,0000,0000,0000,,じゃあ
Dialogue: 0,0:23:24.70,0:23:28.11,Default,,0000,0000,0000,,またな!
Dialogue: 0,0:23:24.70,0:23:28.11,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:23:33.81,0:23:35.81,Default,,0000,0000,0000,,あぁ! また!
Dialogue: 0,0:23:44.16,0:23:46.32,Default,,0000,0000,0000,,また 来年があるわよ
Dialogue: 0,0:23:46.32,0:23:48.49,Default,,0000,0000,0000,,うん わかってる
Dialogue: 0,0:23:48.49,0:23:51.00,Default,,0000,0000,0000,,よし!
Dialogue: 0,0:23:51.00,0:23:53.33,Default,,0000,0000,0000,,来年は もっと クオリティーを上げるの!
Dialogue: 0,0:23:53.33,0:23:55.67,Default,,0000,0000,0000,,すっごい 驚かせてみせるんだから
Dialogue: 0,0:23:55.67,0:23:57.84,Default,,0000,0000,0000,,はいはい
Dialogue: 0,0:23:55.67,0:23:57.84,Default,,0000,0000,0000,,ヘヘッ
Dialogue: 0,0:23:57.84,0:24:00.84,Default,,0000,0000,0000,,たくさん わがまま聞いてくれて ありがとう
Dialogue: 0,0:24:00.84,0:24:03.34,Default,,0000,0000,0000,,そうだ!
Dialogue: 0,0:24:00.84,0:24:05.34,Default,,0000,0000,0000,,洞窟の明かりのスイッチ チェックしておいてね
Dialogue: 0,0:24:05.34,0:24:07.55,Default,,0000,0000,0000,,あれ しょっちゅう つかなく なってるから
Dialogue: 0,0:24:12.68,0:24:15.02,Default,,0000,0000,0000,,ねぇ それ暑くないの?
Dialogue: 0,0:24:15.02,0:24:17.02,Default,,0000,0000,0000,,むぎゅ?
Dialogue: 0,0:24:17.02,0:24:19.69,Default,,0000,0000,0000,,そのぬいぐるみ 暑そうよ
Dialogue: 0,0:24:19.69,0:24:23.36,Default,,0000,0000,0000,,大丈夫ですよ お友達ですから
Dialogue: 0,0:24:23.36,0:24:26.20,Default,,0000,0000,0000,,そう お友達なのね
Dialogue: 0,0:24:26.20,0:24:28.37,Default,,0000,0000,0000,,そういえば
Dialogue: 0,0:24:28.37,0:24:31.54,Default,,0000,0000,0000,,あの灯台 あなた何があるか知ってる?
Dialogue: 0,0:24:31.54,0:24:35.47,Default,,0000,0000,0000,,灯台ですか むぎ
Dialogue: 0,0:24:35.47,0:24:40.15,Default,,0000,0000,0000,,私はよく遊びに行きますが 特に何も
Dialogue: 0,0:24:40.15,0:24:43.98,Default,,0000,0000,0000,,遊びに行くの?
Dialogue: 0,0:24:40.15,0:24:43.98,Default,,0000,0000,0000,,鍵持ってますから
Dialogue: 0,0:24:43.98,0:24:46.15,Default,,0000,0000,0000,,一緒に行きますか?
Dialogue: 0,0:24:46.15,0:24:50.49,Default,,0000,0000,0000,,いいの? ありがとう!
Dialogue: 0,0:24:46.15,0:24:50.49,Default,,0000,0000,0000,,いえ こちらこそ
Dialogue: 0,0:24:50.49,0:24:54.16,Default,,0000,0000,0000,,声をかけてくれて ありがとうございます
Dialogue: 0,0:25:04.84,0:25:06.84,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:25:10.84,0:25:12.84,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:25:20.19,0:25:23.19,Default,,0000,0000,0000,,その行き先を知っている
Dialogue: 0,0:25:23.19,0:25:26.02,Default,,0000,0000,0000,,どうしてか そんなことを思った
Dialogue: 0,0:25:26.02,0:25:29.19,Default,,0000,0000,0000,,それは 言葉にできないけれど
Dialogue: 0,0:25:29.19,0:25:33.60,Default,,0000,0000,0000,,胸を締めつける 不思議な気持ちで
Dialogue: 0,0:25:35.80,0:25:37.80,Default,,0000,0000,0000,,すみません!
Dialogue: 0,0:25:35.80,0:25:37.80,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:25:37.80,0:25:40.31,Default,,0000,0000,0000,,あの すみません!
Dialogue: 0,0:25:37.80,0:25:40.31,Default,,0000,0000,0000,,えっ 何ですか!?
Dialogue: 0,0:25:37.80,0:25:40.31,Default,,0000,0000,0000,,降ります!
Dialogue: 0,0:25:40.31,0:25:43.14,Default,,0000,0000,0000,,あっ ちょ ちょっとお客さん!
Dialogue: 0,0:25:43.14,0:25:45.14,Default,,0000,0000,0000,,過去を懐かしむように
Dialogue: 0,0:25:45.14,0:25:49.15,Default,,0000,0000,0000,,まだ見ぬ未来を懐かしんでいた
Dialogue: 0,0:25:49.15,0:25:52.82,Default,,0000,0000,0000,,何かを思い出せなくて この島に来た
Dialogue: 0,0:25:52.82,0:25:56.82,Default,,0000,0000,0000,,それが何なのか 自分でもわからなかった
Dialogue: 0,0:25:56.82,0:26:01.49,Default,,0000,0000,0000,,だけど 俺は 誰かに それを話したことがある
Dialogue: 0,0:26:01.49,0:26:03.83,Default,,0000,0000,0000,,どこかで
Dialogue: 0,0:26:03.83,0:26:07.67,Default,,0000,0000,0000,,今 それを 思い出そうとしていた
Dialogue: 0,0:26:07.67,0:26:12.67,Default,,0000,0000,0000,,ここで 立ち止まったままじゃいけない
Dialogue: 0,0:26:12.67,0:26:14.84,Default,,0000,0000,0000,,あの子に
Dialogue: 0,0:26:14.84,0:26:17.34,Default,,0000,0000,0000,,あの子と 話をしないといけないんだ!
Dialogue: 0,0:26:23.85,0:26:27.35,Default,,0000,0000,0000,,えっと
Dialogue: 0,0:26:27.35,0:26:31.86,Default,,0000,0000,0000,,ハァハァハァ
Dialogue: 0,0:26:31.86,0:26:38.46,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:26:38.46,0:26:40.47,Default,,0000,0000,0000,,俺!
Dialogue: 0,0:26:45.14,0:26:47.14,Default,,0000,0000,0000,,チャーハン おいしかった
Dialogue: 0,0:26:47.14,0:26:50.98,Default,,0000,0000,0000,,あっ う うん
Dialogue: 0,0:26:50.98,0:26:52.98,Default,,0000,0000,0000,,だから
Dialogue: 0,0:26:57.48,0:26:59.99,Default,,0000,0000,0000,,やっぱり 作り方教えて
Dialogue: 0,0:27:03.66,0:27:05.66,Default,,0000,0000,0000,,へっ?
Dialogue: 0,0:27:09.33,0:27:11.33,Default,,0000,0000,0000,,プッ
Dialogue: 0,0:27:11.33,0:27:13.33,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:27:16.00,0:27:19.67,Default,,0000,0000,0000,,あの
Dialogue: 0,0:27:19.67,0:27:22.07,Default,,0000,0000,0000,,いいよ
