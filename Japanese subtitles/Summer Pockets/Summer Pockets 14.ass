Dialogue: 0,0:00:34.93,0:00:39.11,Default,,0000,0000,0000,,ん くすぐったい
Dialogue: 0,0:00:39.11,0:00:41.78,Default,,0000,0000,0000,,蒼ちゃん
Dialogue: 0,0:00:41.78,0:00:44.28,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:46.78,0:00:48.78,Default,,0000,0000,0000,,えっ! 藍!?
Dialogue: 0,0:00:48.78,0:00:50.78,Default,,0000,0000,0000,,みぎゃ!?
Dialogue: 0,0:00:48.78,0:00:50.78,Default,,0000,0000,0000,,ふぎゃ!
Dialogue: 0,0:00:50.78,0:00:52.99,Default,,0000,0000,0000,,うわぁ
Dialogue: 0,0:02:37.12,0:02:40.63,Default,,0000,0000,0000,,蒼ちゃん すごく痛い
Dialogue: 0,0:02:40.63,0:02:44.96,Default,,0000,0000,0000,,藍
Dialogue: 0,0:02:40.63,0:02:44.96,Default,,0000,0000,0000,,んっ 苦しいよ 蒼ちゃん
Dialogue: 0,0:02:44.96,0:02:47.13,Default,,0000,0000,0000,,藍 藍
Dialogue: 0,0:02:47.13,0:02:49.97,Default,,0000,0000,0000,,たくさん言いたいことがあったの
Dialogue: 0,0:02:49.97,0:02:52.47,Default,,0000,0000,0000,,ずっとずっと謝りたかった
Dialogue: 0,0:02:52.47,0:02:57.31,Default,,0000,0000,0000,,でも ありがとう 私を信じてくれて
Dialogue: 0,0:02:57.31,0:03:02.15,Default,,0000,0000,0000,,私のために ずっとずっと ありがとう
Dialogue: 0,0:03:02.15,0:03:08.15,Default,,0000,0000,0000,,ううん 蒼ちゃん 私のために
Dialogue: 0,0:03:02.15,0:03:08.15,Default,,0000,0000,0000,,とても頑張ってくれた
Dialogue: 0,0:03:08.15,0:03:10.82,Default,,0000,0000,0000,,ずっと声が聞こえていた
Dialogue: 0,0:03:10.82,0:03:13.83,Default,,0000,0000,0000,,蒼ちゃんが 私をつなぎ止めてくれていた
Dialogue: 0,0:03:13.83,0:03:18.00,Default,,0000,0000,0000,,蒼ちゃんのおかげで 私は 戻ってこられた
Dialogue: 0,0:03:18.00,0:03:21.27,Default,,0000,0000,0000,,ありがとう 蒼ちゃん
Dialogue: 0,0:03:24.17,0:03:27.84,Default,,0000,0000,0000,,鷹原 羽依里さんで 合っている?
Dialogue: 0,0:03:27.84,0:03:29.84,Default,,0000,0000,0000,,わかるのか?
Dialogue: 0,0:03:29.84,0:03:32.45,Default,,0000,0000,0000,,ずっと蒼ちゃんが 話してくれていましたから
Dialogue: 0,0:03:32.45,0:03:35.45,Default,,0000,0000,0000,,蒼ちゃんを支えてくれて ありがとうございます
Dialogue: 0,0:03:35.45,0:03:37.45,Default,,0000,0000,0000,,俺は 当然のことをした
Dialogue: 0,0:03:37.45,0:03:39.95,Default,,0000,0000,0000,,でも おつきあいは認めない
Dialogue: 0,0:03:37.45,0:03:39.95,Default,,0000,0000,0000,,え?
Dialogue: 0,0:03:39.95,0:03:43.29,Default,,0000,0000,0000,,蒼ちゃんは私の 大切な大切な妹だから
Dialogue: 0,0:03:43.29,0:03:46.13,Default,,0000,0000,0000,,蒼ちゃんに ふさわしい人じゃないとダメ
Dialogue: 0,0:03:46.13,0:03:49.13,Default,,0000,0000,0000,,藍が そう言うなら 仕方ないわね
Dialogue: 0,0:03:49.13,0:03:52.13,Default,,0000,0000,0000,,え
Dialogue: 0,0:03:49.13,0:03:52.13,Default,,0000,0000,0000,,でもね 藍
Dialogue: 0,0:03:52.13,0:03:54.30,Default,,0000,0000,0000,,羽依里は とてもいいやつよ
Dialogue: 0,0:03:54.30,0:03:56.80,Default,,0000,0000,0000,,私が好きになるくらいなんだから
Dialogue: 0,0:03:56.80,0:04:00.64,Default,,0000,0000,0000,,うん 知ってる だから仕方ない
Dialogue: 0,0:04:00.64,0:04:04.98,Default,,0000,0000,0000,,ふわぁ 安心したら 眠くなってきちゃった
Dialogue: 0,0:04:04.98,0:04:10.15,Default,,0000,0000,0000,,羽依里 ごめん もうちょっと寝る
Dialogue: 0,0:04:10.15,0:04:12.49,Default,,0000,0000,0000,,ああ わかった
Dialogue: 0,0:04:12.49,0:04:16.16,Default,,0000,0000,0000,,私も まだ ふわぁ
Dialogue: 0,0:04:16.16,0:04:21.33,Default,,0000,0000,0000,,藍 起きたら
Dialogue: 0,0:04:16.16,0:04:21.33,Default,,0000,0000,0000,,たくさん おしゃべりしよう
Dialogue: 0,0:04:21.33,0:04:24.50,Default,,0000,0000,0000,,うん たくさんしよう
Dialogue: 0,0:04:24.50,0:04:27.33,Default,,0000,0000,0000,,おやすみ 藍
Dialogue: 0,0:04:27.33,0:04:30.50,Default,,0000,0000,0000,,おやすみ 蒼ちゃん
Dialogue: 0,0:04:30.50,0:04:35.24,Default,,0000,0000,0000,,羽依里 また 起こして
Dialogue: 0,0:04:35.24,0:04:40.25,Default,,0000,0000,0000,,藍が目覚めたことは
Dialogue: 0,0:04:35.24,0:04:40.25,Default,,0000,0000,0000,,島の中でも大きなニュースになった
Dialogue: 0,0:04:40.25,0:04:42.58,Default,,0000,0000,0000,,医者は奇跡だと驚いていたが
Dialogue: 0,0:04:42.58,0:04:46.09,Default,,0000,0000,0000,,これが奇跡じゃないことを 俺は知っている
Dialogue: 0,0:04:48.09,0:04:51.59,Default,,0000,0000,0000,,藍 本当に 目を覚ましたんだな
Dialogue: 0,0:04:51.59,0:04:54.59,Default,,0000,0000,0000,,私が わかるか?
Dialogue: 0,0:04:51.59,0:04:54.59,Default,,0000,0000,0000,,うん
Dialogue: 0,0:04:54.59,0:04:56.60,Default,,0000,0000,0000,,美希ちゃん ね?
Dialogue: 0,0:04:56.60,0:04:59.43,Default,,0000,0000,0000,,藍 俺は わかるか?
Dialogue: 0,0:04:59.43,0:05:01.60,Default,,0000,0000,0000,,うん 天善ちゃん ひさしぶり
Dialogue: 0,0:05:01.60,0:05:04.27,Default,,0000,0000,0000,,ためらいなく間違えてるし!
Dialogue: 0,0:05:04.27,0:05:07.27,Default,,0000,0000,0000,,フッ 俺のほうが 印象に残っていただけのことだ
Dialogue: 0,0:05:07.27,0:05:11.44,Default,,0000,0000,0000,,正直 男の子が2人いる というだけの認識だったから
Dialogue: 0,0:05:11.44,0:05:14.61,Default,,0000,0000,0000,,どっちが どっちでもよかった
Dialogue: 0,0:05:11.44,0:05:14.61,Default,,0000,0000,0000,,ぬぐはあぁっ!
Dialogue: 0,0:05:14.61,0:05:18.79,Default,,0000,0000,0000,,俺たち 幼なじみだったよな?
Dialogue: 0,0:05:14.61,0:05:18.79,Default,,0000,0000,0000,,なあ?
Dialogue: 0,0:05:18.79,0:05:20.95,Default,,0000,0000,0000,,蒼ちゃんの愉快な下僕たち
Dialogue: 0,0:05:20.95,0:05:23.12,Default,,0000,0000,0000,,仲間でもない!!
Dialogue: 0,0:05:23.12,0:05:25.29,Default,,0000,0000,0000,,あっ ホントに起きてる
Dialogue: 0,0:05:25.29,0:05:28.63,Default,,0000,0000,0000,,しろはちゃん
Dialogue: 0,0:05:25.29,0:05:28.63,Default,,0000,0000,0000,,すごく ひさしぶり
Dialogue: 0,0:05:28.63,0:05:32.93,Default,,0000,0000,0000,,ひさしぶり それじゃ
Dialogue: 0,0:05:28.63,0:05:32.93,Default,,0000,0000,0000,,って それだけ?
Dialogue: 0,0:05:32.93,0:05:36.27,Default,,0000,0000,0000,,だって ここ 人が多いし
Dialogue: 0,0:05:36.27,0:05:39.77,Default,,0000,0000,0000,,男どもは カエルの浮き球だと思えば 大丈夫だろう
Dialogue: 0,0:05:39.77,0:05:42.11,Default,,0000,0000,0000,,ひどい!
Dialogue: 0,0:05:42.11,0:05:44.61,Default,,0000,0000,0000,,蒼は 寝てるんだね
Dialogue: 0,0:05:44.61,0:05:48.28,Default,,0000,0000,0000,,ああ こんなときくらい 早く起きろよ 蒼
Dialogue: 0,0:05:48.28,0:05:51.62,Default,,0000,0000,0000,,うん 早く目覚めてほしい
Dialogue: 0,0:05:51.62,0:05:55.79,Default,,0000,0000,0000,,そのあとも 俺たちは藍と蒼の病室で
Dialogue: 0,0:05:55.79,0:05:58.29,Default,,0000,0000,0000,,他愛のないことを話した
Dialogue: 0,0:05:58.29,0:06:01.79,Default,,0000,0000,0000,,蒼が起きるのを待ちながら
Dialogue: 0,0:06:01.79,0:06:07.67,Default,,0000,0000,0000,,でも この日
Dialogue: 0,0:06:01.79,0:06:07.67,Default,,0000,0000,0000,,蒼が目を覚ますことはなかった
Dialogue: 0,0:06:12.64,0:06:16.31,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:06:16.31,0:06:19.78,Default,,0000,0000,0000,,こんなところに 珍しいな
Dialogue: 0,0:06:35.56,0:06:39.40,Default,,0000,0000,0000,,ノックから開けるまでが早い
Dialogue: 0,0:06:35.56,0:06:39.40,Default,,0000,0000,0000,,失礼です
Dialogue: 0,0:06:39.40,0:06:43.24,Default,,0000,0000,0000,,あ ごめん
Dialogue: 0,0:06:39.40,0:06:43.24,Default,,0000,0000,0000,,ラッキースケベでも期待しましたか?
Dialogue: 0,0:06:43.24,0:06:45.24,Default,,0000,0000,0000,,あ
Dialogue: 0,0:06:47.41,0:06:51.91,Default,,0000,0000,0000,,なぜでしょうか 無性に あなたが憎く感じるのですが
Dialogue: 0,0:06:51.91,0:06:54.58,Default,,0000,0000,0000,,気のせいだよ それより 蒼は?
Dialogue: 0,0:06:54.58,0:06:56.58,Default,,0000,0000,0000,,今日も かわいいです
Dialogue: 0,0:06:56.58,0:06:59.59,Default,,0000,0000,0000,,それは わかってる
Dialogue: 0,0:06:56.58,0:06:59.59,Default,,0000,0000,0000,,そうじゃなくて
Dialogue: 0,0:07:01.92,0:07:04.76,Default,,0000,0000,0000,,そうか
Dialogue: 0,0:07:01.92,0:07:04.76,Default,,0000,0000,0000,,今日で丸2日
Dialogue: 0,0:07:04.76,0:07:07.43,Default,,0000,0000,0000,,蒼ちゃんが こんなに眠り続けることは
Dialogue: 0,0:07:07.43,0:07:10.93,Default,,0000,0000,0000,,少なくとも 俺が蒼に会ってからはない
Dialogue: 0,0:07:10.93,0:07:15.77,Default,,0000,0000,0000,,先生は 私のときと同じで原因不明と
Dialogue: 0,0:07:15.77,0:07:19.61,Default,,0000,0000,0000,,でも 原因は 七影蝶 ですよね
Dialogue: 0,0:07:19.61,0:07:21.61,Default,,0000,0000,0000,,蒼から聞いていた?
Dialogue: 0,0:07:21.61,0:07:24.61,Default,,0000,0000,0000,,はい 眠っているときに
Dialogue: 0,0:07:24.61,0:07:27.45,Default,,0000,0000,0000,,記憶の整理には 眠りが必要らしい
Dialogue: 0,0:07:27.45,0:07:30.45,Default,,0000,0000,0000,,たぶん 今は その記憶の整理ってのが
Dialogue: 0,0:07:30.45,0:07:33.59,Default,,0000,0000,0000,,追いついていないんじゃないかな
Dialogue: 0,0:07:33.59,0:07:36.26,Default,,0000,0000,0000,,私のせい
Dialogue: 0,0:07:36.26,0:07:40.09,Default,,0000,0000,0000,,そう言うなよ
Dialogue: 0,0:07:36.26,0:07:40.09,Default,,0000,0000,0000,,蒼の頑張りを否定することになる
Dialogue: 0,0:07:40.09,0:07:42.09,Default,,0000,0000,0000,,すみません
Dialogue: 0,0:07:42.09,0:07:45.10,Default,,0000,0000,0000,,ちゃんと蒼は 起きるからさ そんときに
Dialogue: 0,0:07:45.10,0:07:49.44,Default,,0000,0000,0000,,もう一回ありがとうって言えば それだけで蒼は報われるよ
Dialogue: 0,0:07:49.44,0:07:51.44,Default,,0000,0000,0000,,羽依里さん
Dialogue: 0,0:07:51.44,0:07:54.77,Default,,0000,0000,0000,,早く起きてくれよ
Dialogue: 0,0:07:51.44,0:07:54.77,Default,,0000,0000,0000,,藍の記憶を見つけたら
Dialogue: 0,0:07:54.77,0:07:57.44,Default,,0000,0000,0000,,ちゃんと恋人になるって 約束したろ
Dialogue: 0,0:07:57.44,0:07:59.45,Default,,0000,0000,0000,,は?
Dialogue: 0,0:07:57.44,0:08:01.78,Default,,0000,0000,0000,,ここは いいところだから 黙ってて
Dialogue: 0,0:07:59.45,0:08:01.78,Default,,0000,0000,0000,,すみません
Dialogue: 0,0:08:01.78,0:08:04.78,Default,,0000,0000,0000,,容認しがたい言葉が聞こえたので
Dialogue: 0,0:08:04.78,0:08:07.45,Default,,0000,0000,0000,,もしや 蒼ちゃんが好みということは
Dialogue: 0,0:08:07.45,0:08:10.62,Default,,0000,0000,0000,,双子である私にも 惚れていますか?
Dialogue: 0,0:08:10.62,0:08:12.96,Default,,0000,0000,0000,,なんでそうなる?
Dialogue: 0,0:08:10.62,0:08:12.96,Default,,0000,0000,0000,,そうですね
Dialogue: 0,0:08:12.96,0:08:15.96,Default,,0000,0000,0000,,蒼ちゃんと一緒なら やぶさかではありません
Dialogue: 0,0:08:15.96,0:08:18.97,Default,,0000,0000,0000,,両手に花ですね
Dialogue: 0,0:08:15.96,0:08:18.97,Default,,0000,0000,0000,,そういう冗談は
Dialogue: 0,0:08:18.97,0:08:21.47,Default,,0000,0000,0000,,本気ですが?
Dialogue: 0,0:08:18.97,0:08:21.47,Default,,0000,0000,0000,,なっ!?
Dialogue: 0,0:08:21.47,0:08:25.81,Default,,0000,0000,0000,,うぅ ひとまずは 蒼一筋で お願いします!
Dialogue: 0,0:08:25.81,0:08:29.64,Default,,0000,0000,0000,,では 私も ひとまずは蒼ちゃん一筋で
Dialogue: 0,0:08:29.64,0:08:33.75,Default,,0000,0000,0000,,蒼が起きてくれないと いろいろと始まらないな
Dialogue: 0,0:08:33.75,0:08:35.75,Default,,0000,0000,0000,,そうですね
Dialogue: 0,0:08:39.75,0:08:42.59,Default,,0000,0000,0000,,ポン!
Dialogue: 0,0:08:39.75,0:08:42.59,Default,,0000,0000,0000,,タヌキ?
Dialogue: 0,0:08:42.59,0:08:45.26,Default,,0000,0000,0000,,いや キツネ ずっと蒼と一緒に
Dialogue: 0,0:08:45.26,0:08:48.26,Default,,0000,0000,0000,,七影蝶探しをしてくれていた イナリだ
Dialogue: 0,0:08:48.26,0:08:50.76,Default,,0000,0000,0000,,名前は聞いていましたけど
Dialogue: 0,0:08:50.76,0:08:54.93,Default,,0000,0000,0000,,こいつも蒼に会いたいと思ってさ
Dialogue: 0,0:08:50.76,0:08:54.93,Default,,0000,0000,0000,,先生たちには内緒にな
Dialogue: 0,0:08:54.93,0:08:57.77,Default,,0000,0000,0000,,ポン?
Dialogue: 0,0:08:57.77,0:09:01.44,Default,,0000,0000,0000,,お前でもダメか
Dialogue: 0,0:08:57.77,0:09:01.44,Default,,0000,0000,0000,,ポーン
Dialogue: 0,0:09:03.78,0:09:07.28,Default,,0000,0000,0000,,でも 寝ている蒼ちゃん 寝言が増えてきています
Dialogue: 0,0:09:07.28,0:09:09.28,Default,,0000,0000,0000,,そうなのか?
Dialogue: 0,0:09:09.28,0:09:13.12,Default,,0000,0000,0000,,羽依里さんの名前を 口にしていました
Dialogue: 0,0:09:09.28,0:09:13.12,Default,,0000,0000,0000,,え? 俺の?
Dialogue: 0,0:09:13.12,0:09:17.62,Default,,0000,0000,0000,,いや 夢の中でも俺と会ってるのか
Dialogue: 0,0:09:17.62,0:09:21.46,Default,,0000,0000,0000,,外じゃ恥ずかしいって何です?
Dialogue: 0,0:09:21.46,0:09:25.13,Default,,0000,0000,0000,,寝言だろ
Dialogue: 0,0:09:21.46,0:09:25.13,Default,,0000,0000,0000,,すっごく幸せって何です?
Dialogue: 0,0:09:25.13,0:09:28.63,Default,,0000,0000,0000,,寝言です
Dialogue: 0,0:09:25.13,0:09:28.63,Default,,0000,0000,0000,,もう一回って何です!?
Dialogue: 0,0:09:28.63,0:09:30.80,Default,,0000,0000,0000,,寝言です!
Dialogue: 0,0:09:30.80,0:09:33.54,Default,,0000,0000,0000,,ああ 蒼ちゃんが汚された
Dialogue: 0,0:09:33.54,0:09:37.04,Default,,0000,0000,0000,,いや どちらかと言えば 蒼のほうが
Dialogue: 0,0:09:37.04,0:09:39.38,Default,,0000,0000,0000,,スン
Dialogue: 0,0:09:39.38,0:09:41.71,Default,,0000,0000,0000,,フゥ
Dialogue: 0,0:09:41.71,0:09:44.38,Default,,0000,0000,0000,,羽依里さん もしよかったら
Dialogue: 0,0:09:44.38,0:09:47.05,Default,,0000,0000,0000,,蒼ちゃんに何か 話をしてあげてくれませんか?
Dialogue: 0,0:09:47.05,0:09:50.39,Default,,0000,0000,0000,,話って言われても 何を?
Dialogue: 0,0:09:50.39,0:09:53.89,Default,,0000,0000,0000,,夢の中より こっちのほうが 楽しいと思えるような
Dialogue: 0,0:09:53.89,0:09:56.73,Default,,0000,0000,0000,,そんな話です
Dialogue: 0,0:09:53.89,0:09:56.73,Default,,0000,0000,0000,,なるほど
Dialogue: 0,0:09:56.73,0:10:00.23,Default,,0000,0000,0000,,じゃあ 楽しいかどうかは わからないけど
Dialogue: 0,0:10:00.23,0:10:03.40,Default,,0000,0000,0000,,俺さ 水泳やってたんだ
Dialogue: 0,0:10:03.40,0:10:08.57,Default,,0000,0000,0000,,それでさ 高校に入ってすぐに
Dialogue: 0,0:10:03.40,0:10:08.57,Default,,0000,0000,0000,,リレーのレギュラーに抜擢されたんだ
Dialogue: 0,0:10:08.57,0:10:10.91,Default,,0000,0000,0000,,フッ すごいだろ
Dialogue: 0,0:10:10.91,0:10:15.08,Default,,0000,0000,0000,,でもさ 俺 その夏の大会で
Dialogue: 0,0:10:15.08,0:10:19.92,Default,,0000,0000,0000,,蒼ちゃんに たくさん話をしてくれてありがとうございます
Dialogue: 0,0:10:19.92,0:10:22.59,Default,,0000,0000,0000,,いや こっちこそ いい機会をもらったよ
Dialogue: 0,0:10:22.59,0:10:25.09,Default,,0000,0000,0000,,でも あんな話でよかったのかな?
Dialogue: 0,0:10:25.09,0:10:29.93,Default,,0000,0000,0000,,羽依里さんのことを知れて 蒼ちゃんは うれしいと思いますよ
Dialogue: 0,0:10:29.93,0:10:34.77,Default,,0000,0000,0000,,蒼の絶対に諦めないって まっすぐなとこが まぶしかった
Dialogue: 0,0:10:34.77,0:10:37.44,Default,,0000,0000,0000,,俺にない強さを持ってて
Dialogue: 0,0:10:37.44,0:10:40.11,Default,,0000,0000,0000,,そんなところに 惹かれたんだと思う
Dialogue: 0,0:10:40.11,0:10:44.61,Default,,0000,0000,0000,,はい 自慢の蒼ちゃんです
Dialogue: 0,0:10:44.61,0:10:49.28,Default,,0000,0000,0000,,ん 羽依 里
Dialogue: 0,0:10:49.28,0:10:53.95,Default,,0000,0000,0000,,蒼?
Dialogue: 0,0:10:49.28,0:10:53.95,Default,,0000,0000,0000,,ずっと んへ いっしょ
Dialogue: 0,0:10:53.95,0:10:56.29,Default,,0000,0000,0000,,寝言 ですね
Dialogue: 0,0:10:56.29,0:11:00.46,Default,,0000,0000,0000,,むにゃ 夜明けのコーヒー
Dialogue: 0,0:11:00.46,0:11:04.30,Default,,0000,0000,0000,,ハハハ うん 飲もうな
Dialogue: 0,0:11:00.46,0:11:04.30,Default,,0000,0000,0000,,は?
Dialogue: 0,0:11:04.30,0:11:08.13,Default,,0000,0000,0000,,だから いいところは スルーして
Dialogue: 0,0:11:08.13,0:11:13.31,Default,,0000,0000,0000,,試しにやってみたけど
Dialogue: 0,0:11:08.13,0:11:13.31,Default,,0000,0000,0000,,俺でもできるんだな お役目って
Dialogue: 0,0:11:13.31,0:11:15.47,Default,,0000,0000,0000,,ポン
Dialogue: 0,0:11:15.47,0:11:19.81,Default,,0000,0000,0000,,おっ もう一匹 追加っと
Dialogue: 0,0:11:19.81,0:11:23.32,Default,,0000,0000,0000,,蒼みたいに もう触れる必要はないしな
Dialogue: 0,0:11:23.32,0:11:26.15,Default,,0000,0000,0000,,ポーン
Dialogue: 0,0:11:26.15,0:11:28.45,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:11:34.13,0:11:38.30,Default,,0000,0000,0000,,花が ほとんど散っている
Dialogue: 0,0:11:38.30,0:11:42.47,Default,,0000,0000,0000,,山の祭事の期間も もうすぐ終わりってことか
Dialogue: 0,0:11:42.47,0:11:45.64,Default,,0000,0000,0000,,いや 終わるのは祭事だけじゃない
Dialogue: 0,0:11:45.64,0:11:49.81,Default,,0000,0000,0000,,夏休みも もう終わりに近づいている
Dialogue: 0,0:11:49.81,0:11:55.65,Default,,0000,0000,0000,,夏休みが終われば
Dialogue: 0,0:11:49.81,0:11:55.65,Default,,0000,0000,0000,,俺は家に戻らなきゃいけない
Dialogue: 0,0:11:55.65,0:11:58.62,Default,,0000,0000,0000,,それまでに起きるよな 蒼
Dialogue: 0,0:12:09.96,0:12:12.30,Default,,0000,0000,0000,,はい
Dialogue: 0,0:12:09.96,0:12:12.30,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:12:12.30,0:12:14.63,Default,,0000,0000,0000,,蒼!
Dialogue: 0,0:12:14.63,0:12:17.80,Default,,0000,0000,0000,,エヘヘ ちょっと寝すぎた?
Dialogue: 0,0:12:17.80,0:12:20.31,Default,,0000,0000,0000,,ん 蒼ちゃん?
Dialogue: 0,0:12:20.31,0:12:22.31,Default,,0000,0000,0000,,藍 ごめんね
Dialogue: 0,0:12:22.31,0:12:26.98,Default,,0000,0000,0000,,せっかく あんたが 起きてくれたのに 私が寝てばっかで
Dialogue: 0,0:12:26.98,0:12:31.98,Default,,0000,0000,0000,,ううん ちゃんと蒼ちゃんの 声を聞くことができたから
Dialogue: 0,0:12:31.98,0:12:34.45,Default,,0000,0000,0000,,もう大丈夫
Dialogue: 0,0:12:34.45,0:12:36.46,Default,,0000,0000,0000,,あ 先生を呼んでくるよ
Dialogue: 0,0:12:36.46,0:12:38.46,Default,,0000,0000,0000,,待って
Dialogue: 0,0:12:36.46,0:12:38.46,Default,,0000,0000,0000,,あっ! ん?
Dialogue: 0,0:12:38.46,0:12:41.96,Default,,0000,0000,0000,,それより 外の空気 吸いたい
Dialogue: 0,0:12:41.96,0:12:44.80,Default,,0000,0000,0000,,ああ 窓開ければいいか?
Dialogue: 0,0:12:44.80,0:12:48.30,Default,,0000,0000,0000,,そうじゃなくて 外 歩きたい
Dialogue: 0,0:12:48.30,0:12:51.80,Default,,0000,0000,0000,,うん?
Dialogue: 0,0:12:48.30,0:12:51.80,Default,,0000,0000,0000,,だから
Dialogue: 0,0:12:51.80,0:12:53.97,Default,,0000,0000,0000,,おんぶして?
Dialogue: 0,0:12:56.64,0:13:00.48,Default,,0000,0000,0000,,蒼ちゃんが これまで してくれたこと全部覚えてるよ
Dialogue: 0,0:13:00.48,0:13:02.65,Default,,0000,0000,0000,,どうしたの 急に
Dialogue: 0,0:13:02.65,0:13:05.92,Default,,0000,0000,0000,,まだ うまく体が動かないけど 頑張るから
Dialogue: 0,0:13:07.99,0:13:10.99,Default,,0000,0000,0000,,蒼ちゃんと同じことをするから
Dialogue: 0,0:13:10.99,0:13:16.50,Default,,0000,0000,0000,,そっか うん それは楽しみね
Dialogue: 0,0:13:16.50,0:13:19.83,Default,,0000,0000,0000,,外行くのはいいけど少しだけだぞ
Dialogue: 0,0:13:19.83,0:13:22.84,Default,,0000,0000,0000,,ずっと眠ってたんだから 無理しないほうが
Dialogue: 0,0:13:22.84,0:13:26.01,Default,,0000,0000,0000,,少しだけでも かなえてあげてください
Dialogue: 0,0:13:26.01,0:13:29.18,Default,,0000,0000,0000,,蒼ちゃんが 起きていられるうちに
Dialogue: 0,0:13:29.18,0:13:32.44,Default,,0000,0000,0000,,え? 何言ってるんだ?
Dialogue: 0,0:13:32.44,0:13:36.62,Default,,0000,0000,0000,,あっ! なんで ここに って!?
Dialogue: 0,0:13:36.62,0:13:39.29,Default,,0000,0000,0000,,蒼 それは?
Dialogue: 0,0:13:39.29,0:13:42.29,Default,,0000,0000,0000,,たくさんの記憶に 触れちゃったからさ
Dialogue: 0,0:13:42.29,0:13:44.62,Default,,0000,0000,0000,,頭の中 結構めちゃくちゃで
Dialogue: 0,0:13:44.62,0:13:47.63,Default,,0000,0000,0000,,ずっと いろんな人の声が聞こえてて
Dialogue: 0,0:13:47.63,0:13:50.63,Default,,0000,0000,0000,,自分を保つのが しんどいの
Dialogue: 0,0:13:50.63,0:13:52.80,Default,,0000,0000,0000,,蒼 そんな
Dialogue: 0,0:13:52.80,0:13:55.30,Default,,0000,0000,0000,,私が起きてられるうちにさ
Dialogue: 0,0:13:55.30,0:13:58.80,Default,,0000,0000,0000,,この子たちを ちゃんと還してあげないと
Dialogue: 0,0:13:58.80,0:14:00.81,Default,,0000,0000,0000,,羽依里にしか頼めないの
Dialogue: 0,0:14:00.81,0:14:05.81,Default,,0000,0000,0000,,そんな そんなことよりも どうにかできる方法を!
Dialogue: 0,0:14:05.81,0:14:07.81,Default,,0000,0000,0000,,羽依里さん!
Dialogue: 0,0:14:05.81,0:14:07.81,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:14:07.81,0:14:12.48,Default,,0000,0000,0000,,お願いします 蒼ちゃんの お願いをかなえてください
Dialogue: 0,0:14:14.99,0:14:17.32,Default,,0000,0000,0000,,迷い橘まで行けばいいんだよな?
Dialogue: 0,0:14:17.32,0:14:21.49,Default,,0000,0000,0000,,ん ちょっと寄り道しながらが いいかな
Dialogue: 0,0:14:21.49,0:14:24.33,Default,,0000,0000,0000,,寄り道?
Dialogue: 0,0:15:14.95,0:15:17.75,Default,,0000,0000,0000,,それでさ 蒼?
Dialogue: 0,0:15:19.79,0:15:24.12,Default,,0000,0000,0000,,ん あ うん へい き
Dialogue: 0,0:15:24.12,0:15:29.80,Default,,0000,0000,0000,,でも ちょっと急いで
Dialogue: 0,0:15:24.12,0:15:29.80,Default,,0000,0000,0000,,ほしい かも
Dialogue: 0,0:15:29.80,0:15:31.80,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:34.77,0:15:37.77,Default,,0000,0000,0000,,ポン!
Dialogue: 0,0:15:34.77,0:15:37.77,Default,,0000,0000,0000,,蒼 イナリだぞ!
Dialogue: 0,0:15:37.77,0:15:39.94,Default,,0000,0000,0000,,んえ?
Dialogue: 0,0:15:37.77,0:15:39.94,Default,,0000,0000,0000,,ポーン!
Dialogue: 0,0:15:39.94,0:15:43.28,Default,,0000,0000,0000,,あ イナリ
Dialogue: 0,0:15:39.94,0:15:43.28,Default,,0000,0000,0000,,ポンポン
Dialogue: 0,0:15:43.28,0:15:47.78,Default,,0000,0000,0000,,ん あんたにも 心配 かけちゃったわね
Dialogue: 0,0:15:47.78,0:15:49.78,Default,,0000,0000,0000,,ポンポン
Dialogue: 0,0:15:49.78,0:15:53.29,Default,,0000,0000,0000,,たくさん手伝ってくれて ありがとう
Dialogue: 0,0:15:53.29,0:15:55.29,Default,,0000,0000,0000,,ポン?
Dialogue: 0,0:15:55.29,0:15:59.16,Default,,0000,0000,0000,,イナリ 迷い橘まで頼めるか?
Dialogue: 0,0:15:55.29,0:15:59.16,Default,,0000,0000,0000,,ポン!
Dialogue: 0,0:16:04.80,0:16:07.27,Default,,0000,0000,0000,,ふわぁ ん ふぅ
Dialogue: 0,0:16:11.97,0:16:14.14,Default,,0000,0000,0000,,このあたりだっけかな
Dialogue: 0,0:16:14.14,0:16:17.64,Default,,0000,0000,0000,,蒼が お役目をしているのを 初めて見たのは
Dialogue: 0,0:16:17.64,0:16:22.98,Default,,0000,0000,0000,,夜の山に入っちゃダメって
Dialogue: 0,0:16:17.64,0:16:22.98,Default,,0000,0000,0000,,言ったのに あんた
Dialogue: 0,0:16:22.98,0:16:28.32,Default,,0000,0000,0000,,ふわぁ
Dialogue: 0,0:16:22.98,0:16:28.32,Default,,0000,0000,0000,,全然 守ってくれないんだもの
Dialogue: 0,0:16:28.32,0:16:31.66,Default,,0000,0000,0000,,でも この夏 楽しかった
Dialogue: 0,0:16:31.66,0:16:38.40,Default,,0000,0000,0000,,毎日 一緒にいて バカなことして
Dialogue: 0,0:16:31.66,0:16:38.40,Default,,0000,0000,0000,,無茶なことして
Dialogue: 0,0:16:38.40,0:16:44.90,Default,,0000,0000,0000,,私が眠っている間も ずっと
Dialogue: 0,0:16:38.40,0:16:44.90,Default,,0000,0000,0000,,一緒にいてくれて ありがとう
Dialogue: 0,0:16:44.90,0:16:48.74,Default,,0000,0000,0000,,俺さ 夏休みが終わったら 帰らなきゃいけない
Dialogue: 0,0:16:48.74,0:16:50.74,Default,,0000,0000,0000,,うん
Dialogue: 0,0:16:50.74,0:16:55.58,Default,,0000,0000,0000,,でも バイトして週末は ここに来る
Dialogue: 0,0:16:50.74,0:16:55.58,Default,,0000,0000,0000,,え?
Dialogue: 0,0:16:55.58,0:17:00.59,Default,,0000,0000,0000,,秋も 冬も 春も
Dialogue: 0,0:16:55.58,0:17:00.59,Default,,0000,0000,0000,,この島で蒼と一緒に過ごす
Dialogue: 0,0:17:00.59,0:17:04.59,Default,,0000,0000,0000,,そして 次の夏は またずっと一緒にいよう
Dialogue: 0,0:17:04.59,0:17:07.59,Default,,0000,0000,0000,,エヘヘ それ すっごくうれしい
Dialogue: 0,0:17:07.59,0:17:09.76,Default,,0000,0000,0000,,でも 私は
Dialogue: 0,0:17:09.76,0:17:15.60,Default,,0000,0000,0000,,もし蒼が 眠り続けていたとしても
Dialogue: 0,0:17:09.76,0:17:15.60,Default,,0000,0000,0000,,俺は この島に来るから
Dialogue: 0,0:17:15.60,0:17:17.60,Default,,0000,0000,0000,,羽依里
Dialogue: 0,0:17:17.60,0:17:20.77,Default,,0000,0000,0000,,蒼を起こすのは 俺の役目だから
Dialogue: 0,0:17:20.77,0:17:24.11,Default,,0000,0000,0000,,最初は 優しくね
Dialogue: 0,0:17:24.11,0:17:26.11,Default,,0000,0000,0000,,ずっと優しくする
Dialogue: 0,0:17:26.11,0:17:30.62,Default,,0000,0000,0000,,それは ちょっと 物足りなくなるかも エヘヘ
Dialogue: 0,0:17:41.26,0:17:44.60,Default,,0000,0000,0000,,ハァ ハァ
Dialogue: 0,0:17:44.60,0:17:50.27,Default,,0000,0000,0000,,着いたぞ 蒼 迷い橘だ
Dialogue: 0,0:17:53.77,0:17:56.94,Default,,0000,0000,0000,,蒼?
Dialogue: 0,0:17:53.77,0:17:56.94,Default,,0000,0000,0000,,ポン! フーッ!
Dialogue: 0,0:17:56.94,0:18:00.11,Default,,0000,0000,0000,,こんなに いつの間に?
Dialogue: 0,0:18:00.11,0:18:02.11,Default,,0000,0000,0000,,ポン ポン!
Dialogue: 0,0:18:02.11,0:18:05.78,Default,,0000,0000,0000,,お おい 何を! あっ!
Dialogue: 0,0:18:05.78,0:18:08.45,Default,,0000,0000,0000,,え
Dialogue: 0,0:18:08.45,0:18:11.62,Default,,0000,0000,0000,,これって
Dialogue: 0,0:18:11.62,0:18:14.96,Default,,0000,0000,0000,,もしかして 眠りじゃ整理しきれない記憶が
Dialogue: 0,0:18:14.96,0:18:16.96,Default,,0000,0000,0000,,あふれだしてるのか?
Dialogue: 0,0:18:16.96,0:18:19.97,Default,,0000,0000,0000,,だったら この調子で 七影蝶が出続ければ
Dialogue: 0,0:18:19.97,0:18:24.80,Default,,0000,0000,0000,,蒼は目覚めて ポ ポーン!
Dialogue: 0,0:18:24.80,0:18:27.27,Default,,0000,0000,0000,,あっ イナリ!?
Dialogue: 0,0:18:29.64,0:18:34.25,Default,,0000,0000,0000,,蒼! 起きろ! お前の記憶は お前の中に残ってるよな?
Dialogue: 0,0:18:34.25,0:18:36.25,Default,,0000,0000,0000,,蒼!
Dialogue: 0,0:18:36.25,0:18:38.75,Default,,0000,0000,0000,,ポーン! ポーン!
Dialogue: 0,0:18:38.75,0:18:43.59,Default,,0000,0000,0000,,まさか あれなのか? 嘘だろ
Dialogue: 0,0:18:43.59,0:18:48.26,Default,,0000,0000,0000,,待ってくれ 蒼! 蒼!!
Dialogue: 0,0:18:48.26,0:18:50.26,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:18:50.26,0:18:52.60,Default,,0000,0000,0000,,いきなり人の寝込みを 襲うとか
Dialogue: 0,0:18:52.60,0:18:55.93,Default,,0000,0000,0000,,っていうか 心配って 私のことが?
Dialogue: 0,0:18:55.93,0:18:58.10,Default,,0000,0000,0000,,変なやつ
Dialogue: 0,0:18:58.10,0:19:00.11,Default,,0000,0000,0000,,あぁ もう!
Dialogue: 0,0:18:58.10,0:19:00.11,Default,,0000,0000,0000,,着替えも見られて
Dialogue: 0,0:19:00.11,0:19:03.44,Default,,0000,0000,0000,,かき氷ぶっかけられるって なに!?
Dialogue: 0,0:19:03.44,0:19:06.11,Default,,0000,0000,0000,,ちょっとだけ 楽しかったけど
Dialogue: 0,0:19:06.11,0:19:08.95,Default,,0000,0000,0000,,子ども相手にムキになってガキねぇ
Dialogue: 0,0:19:08.95,0:19:12.62,Default,,0000,0000,0000,,でも 本当は 負けてあげる気だったのよね?
Dialogue: 0,0:19:12.62,0:19:15.79,Default,,0000,0000,0000,,とりあえず悪いやつじゃないのは 確かね うん
Dialogue: 0,0:19:15.79,0:19:17.96,Default,,0000,0000,0000,,き きれいって言われた!
Dialogue: 0,0:19:17.96,0:19:22.13,Default,,0000,0000,0000,,触ってもいいかって トンボ玉か!
Dialogue: 0,0:19:22.13,0:19:24.13,Default,,0000,0000,0000,,ドキドキしたのに!
Dialogue: 0,0:19:24.13,0:19:26.30,Default,,0000,0000,0000,,大胆なことを聞いちゃった!
Dialogue: 0,0:19:26.30,0:19:29.97,Default,,0000,0000,0000,,どうしよ これ 惚れたって言われたら!?
Dialogue: 0,0:19:29.97,0:19:35.71,Default,,0000,0000,0000,,私の気持ちは
Dialogue: 0,0:19:29.97,0:19:35.71,Default,,0000,0000,0000,,えっと まだよくわからない
Dialogue: 0,0:19:35.71,0:19:39.04,Default,,0000,0000,0000,,抱き締めちゃってる!
Dialogue: 0,0:19:35.71,0:19:39.04,Default,,0000,0000,0000,,あたたかい たくましい!
Dialogue: 0,0:19:39.04,0:19:41.38,Default,,0000,0000,0000,,ドキドキする
Dialogue: 0,0:19:41.38,0:19:46.22,Default,,0000,0000,0000,,よかった 羽依里が無事で 本当に よかった
Dialogue: 0,0:19:46.22,0:19:50.56,Default,,0000,0000,0000,,ずるい そんな言い方されたら 断れないじゃない
Dialogue: 0,0:19:50.56,0:19:55.89,Default,,0000,0000,0000,,っていうか やばい
Dialogue: 0,0:19:50.56,0:19:55.89,Default,,0000,0000,0000,,私 今 うれしくなってる
Dialogue: 0,0:19:55.89,0:19:58.40,Default,,0000,0000,0000,,すごくうれしい
Dialogue: 0,0:19:58.40,0:20:03.90,Default,,0000,0000,0000,,幸せ 羽依里が
Dialogue: 0,0:19:58.40,0:20:03.90,Default,,0000,0000,0000,,そばにいてくれるから安心
Dialogue: 0,0:20:03.90,0:20:08.07,Default,,0000,0000,0000,,好き キス しちゃった
Dialogue: 0,0:20:08.07,0:20:11.24,Default,,0000,0000,0000,,羽依里と ずっと一緒にいたい
Dialogue: 0,0:20:11.24,0:20:14.58,Default,,0000,0000,0000,,夏が終わっても ずっと一緒に
Dialogue: 0,0:20:14.58,0:20:23.39,Default,,0000,0000,0000,,羽依里 はいり
Dialogue: 0,0:20:14.58,0:20:23.39,Default,,0000,0000,0000,,ごめんね ずっと 大好き
Dialogue: 0,0:20:28.93,0:20:33.27,Default,,0000,0000,0000,,蒼 今のが お前の記憶なのか
Dialogue: 0,0:20:33.27,0:20:35.97,Default,,0000,0000,0000,,こんなにも俺のことを
Dialogue: 0,0:20:39.94,0:20:44.44,Default,,0000,0000,0000,,お別れってわけじゃないんだから 謝るなよ
Dialogue: 0,0:20:44.44,0:20:47.61,Default,,0000,0000,0000,,お前は ただ眠るだけだろ
Dialogue: 0,0:20:47.61,0:20:51.12,Default,,0000,0000,0000,,帰ろう 蒼
Dialogue: 0,0:20:57.29,0:20:59.29,Default,,0000,0000,0000,,蒼ちゃん
Dialogue: 0,0:20:59.29,0:21:03.63,Default,,0000,0000,0000,,1年待ってくれ
Dialogue: 0,0:20:59.29,0:21:03.63,Default,,0000,0000,0000,,また迷い橘の花が咲くから
Dialogue: 0,0:21:03.63,0:21:06.97,Default,,0000,0000,0000,,そしたら山の祭事で 必ず蒼を見つける
Dialogue: 0,0:21:06.97,0:21:08.97,Default,,0000,0000,0000,,え?
Dialogue: 0,0:21:08.97,0:21:11.14,Default,,0000,0000,0000,,藍も同じことをしようと していたんじゃないのか?
Dialogue: 0,0:21:11.14,0:21:13.64,Default,,0000,0000,0000,,蒼ちゃんと同じことをする
Dialogue: 0,0:21:13.64,0:21:16.14,Default,,0000,0000,0000,,してもらったことを返すだけです
Dialogue: 0,0:21:16.14,0:21:18.94,Default,,0000,0000,0000,,じゃあ リハビリ頑張らないとな
Dialogue: 0,0:21:22.15,0:21:24.82,Default,,0000,0000,0000,,羽依里さん ひとつ お願いがあります
Dialogue: 0,0:21:24.82,0:21:27.32,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:21:24.82,0:21:27.32,Default,,0000,0000,0000,,これからも
Dialogue: 0,0:21:27.32,0:21:29.99,Default,,0000,0000,0000,,蒼ちゃんに 会いに来てほしいんです
Dialogue: 0,0:21:29.99,0:21:34.29,Default,,0000,0000,0000,,あなたが見たこと 聞いたこと 体験したこと
Dialogue: 0,0:21:34.29,0:21:38.80,Default,,0000,0000,0000,,蒼ちゃんの眠る時間を
Dialogue: 0,0:21:34.29,0:21:38.80,Default,,0000,0000,0000,,空白を埋めてあげてほしいんです
Dialogue: 0,0:21:38.80,0:21:42.97,Default,,0000,0000,0000,,本当は 蒼ちゃんに 分けてもらった時間を
Dialogue: 0,0:21:42.97,0:21:45.30,Default,,0000,0000,0000,,私が返してあげたいけれど
Dialogue: 0,0:21:45.30,0:21:48.81,Default,,0000,0000,0000,,まだ自由に 歩くことができないから
Dialogue: 0,0:21:48.81,0:21:52.14,Default,,0000,0000,0000,,大丈夫 蒼にも話してたんだ
Dialogue: 0,0:21:52.14,0:21:55.48,Default,,0000,0000,0000,,夏休みが終わって 一度は帰るけど
Dialogue: 0,0:21:55.48,0:21:59.65,Default,,0000,0000,0000,,バイトして金貯めて 週末は ここに来る
Dialogue: 0,0:21:59.65,0:22:03.82,Default,,0000,0000,0000,,秋も冬も春も この島で蒼と一緒に過ごして
Dialogue: 0,0:22:03.82,0:22:07.33,Default,,0000,0000,0000,,次の夏は またずっと一緒にいようってさ
Dialogue: 0,0:22:07.33,0:22:09.66,Default,,0000,0000,0000,,羽依里さん
Dialogue: 0,0:22:09.66,0:22:13.83,Default,,0000,0000,0000,,それに もっと前から 約束していたことがあるんだ
Dialogue: 0,0:22:13.83,0:22:17.50,Default,,0000,0000,0000,,寝てる蒼を起こすのは 俺の役目だから
Dialogue: 0,0:22:23.18,0:22:27.15,Default,,0000,0000,0000,,大丈夫
Dialogue: 0,0:22:23.18,0:22:27.15,Default,,0000,0000,0000,,きっと見つけてもらえるから
Dialogue: 0,0:22:30.52,0:22:35.29,Default,,0000,0000,0000,,私は うん まだ大丈夫
Dialogue: 0,0:23:35.28,0:23:37.78,Default,,0000,0000,0000,,さて 始めようか
Dialogue: 0,0:23:37.78,0:23:39.75,Default,,0000,0000,0000,,ポン!
Dialogue: 0,0:23:46.96,0:23:50.13,Default,,0000,0000,0000,,ずっと声が聞こえていた
Dialogue: 0,0:23:50.13,0:23:55.30,Default,,0000,0000,0000,,それは とても安心できる声
Dialogue: 0,0:23:50.13,0:23:55.30,Default,,0000,0000,0000,,とても大好きな声
Dialogue: 0,0:23:55.30,0:23:58.14,Default,,0000,0000,0000,,思わず ほほ笑んでしまう声
Dialogue: 0,0:23:58.14,0:24:02.14,Default,,0000,0000,0000,,優しいまぶしさに心を揺らされる
Dialogue: 0,0:24:02.14,0:24:05.48,Default,,0000,0000,0000,,少しだけ息苦しくなった
Dialogue: 0,0:24:05.48,0:24:09.82,Default,,0000,0000,0000,,体の中をぬくもりが巡る
Dialogue: 0,0:24:09.82,0:24:13.15,Default,,0000,0000,0000,,最初に なんて言えばいいのか 知っている
Dialogue: 0,0:24:13.15,0:24:18.16,Default,,0000,0000,0000,,ずっと 言っていた言葉
Dialogue: 0,0:24:13.15,0:24:18.16,Default,,0000,0000,0000,,ずっと 言いたかった言葉
Dialogue: 0,0:24:18.16,0:24:20.13,Default,,0000,0000,0000,,おはよう
