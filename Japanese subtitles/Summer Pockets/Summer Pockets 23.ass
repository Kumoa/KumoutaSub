Dialogue: 0,0:00:34.90,0:00:37.57,Default,,0000,0000,0000,,私は 飛び続ける
Dialogue: 0,0:00:37.57,0:00:43.58,Default,,0000,0000,0000,,羽ばたくほど 飛び続けるほど
Dialogue: 0,0:00:37.57,0:00:43.58,Default,,0000,0000,0000,,どんどんとこぼれていく
Dialogue: 0,0:00:43.58,0:00:47.25,Default,,0000,0000,0000,,あんなにも たくさんの夏を繰り返してきて
Dialogue: 0,0:00:47.25,0:00:52.25,Default,,0000,0000,0000,,たくさんの思い出と 大切な気持ちをもらったのに
Dialogue: 0,0:00:52.25,0:00:55.92,Default,,0000,0000,0000,,すべてが
Dialogue: 0,0:00:52.25,0:00:55.92,Default,,0000,0000,0000,,おぼろげになっていく
Dialogue: 0,0:00:55.92,0:00:59.93,Default,,0000,0000,0000,,だけど 誰かが背中を支えてくれた
Dialogue: 0,0:00:59.93,0:01:02.26,Default,,0000,0000,0000,,手を引いてくれた
Dialogue: 0,0:01:02.26,0:01:04.60,Default,,0000,0000,0000,,失ったはずの体が
Dialogue: 0,0:01:04.60,0:01:08.60,Default,,0000,0000,0000,,さまざまな記憶で 補われていくようだった
Dialogue: 0,0:01:08.60,0:01:14.61,Default,,0000,0000,0000,,そして どの記憶も
Dialogue: 0,0:01:08.60,0:01:14.61,Default,,0000,0000,0000,,まるで祈りかのようで
Dialogue: 0,0:01:19.95,0:01:23.28,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:01:19.95,0:01:23.28,Default,,0000,0000,0000,,ちょ くすぐったい
Dialogue: 0,0:01:23.28,0:01:26.59,Default,,0000,0000,0000,,いや 痛い 痛いから
Dialogue: 0,0:01:31.62,0:01:34.56,Default,,0000,0000,0000,,鶏小屋?
Dialogue: 0,0:01:34.56,0:01:36.56,Default,,0000,0000,0000,,起こしてくれたの?
Dialogue: 0,0:01:36.56,0:01:40.57,Default,,0000,0000,0000,,ええと ありがとう キャサリン
Dialogue: 0,0:01:40.57,0:01:44.27,Default,,0000,0000,0000,,あぁ 僕は
Dialogue: 0,0:01:52.25,0:01:59.55,Default,,0000,0000,0000,,あの ここはどこで
Dialogue: 0,0:01:52.25,0:01:59.55,Default,,0000,0000,0000,,僕は誰でしょうか?
Dialogue: 0,0:02:11.93,0:02:14.93,Default,,0000,0000,0000,,自分が誰で どこから来たか
Dialogue: 0,0:02:14.93,0:02:17.60,Default,,0000,0000,0000,,まったく覚えていないだと
Dialogue: 0,0:02:17.60,0:02:20.31,Default,,0000,0000,0000,,はい ん?
Dialogue: 0,0:02:22.28,0:02:26.28,Default,,0000,0000,0000,,挨拶をしなさい
Dialogue: 0,0:02:26.28,0:02:29.62,Default,,0000,0000,0000,,こ こんにちは?
Dialogue: 0,0:02:29.62,0:02:31.95,Default,,0000,0000,0000,,これ しろは!
Dialogue: 0,0:02:31.95,0:02:35.22,Default,,0000,0000,0000,,しろはちゃん ですか
Dialogue: 0,0:02:31.95,0:02:35.22,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:02:35.22,0:02:39.23,Default,,0000,0000,0000,,そして わしは 鳴瀬 小鳩だ
Dialogue: 0,0:02:39.23,0:02:41.23,Default,,0000,0000,0000,,小鳩 さん
Dialogue: 0,0:02:41.23,0:02:43.23,Default,,0000,0000,0000,,記憶喪失というのなら
Dialogue: 0,0:02:43.23,0:02:46.90,Default,,0000,0000,0000,,本土の専門的な病院で しっかり診てもらえ
Dialogue: 0,0:02:46.90,0:02:50.24,Default,,0000,0000,0000,,飯を食べたら 行けるよう手配してやろう
Dialogue: 0,0:02:50.24,0:02:52.24,Default,,0000,0000,0000,,すみません
Dialogue: 0,0:03:06.92,0:03:08.92,Default,,0000,0000,0000,,フゥー
Dialogue: 0,0:03:08.92,0:03:12.59,Default,,0000,0000,0000,,ありがとう
Dialogue: 0,0:03:08.92,0:03:12.59,Default,,0000,0000,0000,,しろは ちゃん?
Dialogue: 0,0:03:12.59,0:03:15.93,Default,,0000,0000,0000,,な な な なんで
Dialogue: 0,0:03:12.59,0:03:15.93,Default,,0000,0000,0000,,名前知ってるの
Dialogue: 0,0:03:15.93,0:03:20.27,Default,,0000,0000,0000,,いや さっき お父さんが
Dialogue: 0,0:03:20.27,0:03:25.61,Default,,0000,0000,0000,,お父さんは いない
Dialogue: 0,0:03:20.27,0:03:25.61,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:03:25.61,0:03:28.01,Default,,0000,0000,0000,,死んだから!
Dialogue: 0,0:03:30.94,0:03:35.22,Default,,0000,0000,0000,,こら 何を泣かせていた
Dialogue: 0,0:03:30.94,0:03:35.22,Default,,0000,0000,0000,,すみません
Dialogue: 0,0:03:35.22,0:03:39.22,Default,,0000,0000,0000,,って お父さん!?
Dialogue: 0,0:03:35.22,0:03:39.22,Default,,0000,0000,0000,,あなたは死んでるはずじゃあ!
Dialogue: 0,0:03:39.22,0:03:43.89,Default,,0000,0000,0000,,わしは あの子の祖父だ
Dialogue: 0,0:03:39.22,0:03:43.89,Default,,0000,0000,0000,,見たらわかるだろうが
Dialogue: 0,0:03:43.89,0:03:47.23,Default,,0000,0000,0000,,ほれ あったかいうちに 食べてしまえ
Dialogue: 0,0:03:47.23,0:03:50.90,Default,,0000,0000,0000,,はい
Dialogue: 0,0:03:50.90,0:03:52.90,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:03:57.24,0:04:00.57,Default,,0000,0000,0000,,おいしいですね このから揚げ
Dialogue: 0,0:04:00.57,0:04:05.58,Default,,0000,0000,0000,,あぁ 今朝
Dialogue: 0,0:04:00.57,0:04:05.58,Default,,0000,0000,0000,,しめたばかりのやつだからな
Dialogue: 0,0:04:05.58,0:04:07.98,Default,,0000,0000,0000,,それは新鮮です
Dialogue: 0,0:04:10.58,0:04:13.59,Default,,0000,0000,0000,,キャサリーン!?
Dialogue: 0,0:04:17.26,0:04:24.26,Default,,0000,0000,0000,,忘れ物はないか?
Dialogue: 0,0:04:17.26,0:04:24.26,Default,,0000,0000,0000,,ええと あっ
Dialogue: 0,0:04:24.26,0:04:26.27,Default,,0000,0000,0000,,しろはちゃん!
Dialogue: 0,0:04:28.27,0:04:31.94,Default,,0000,0000,0000,,さっきは ごめん
Dialogue: 0,0:04:28.27,0:04:31.94,Default,,0000,0000,0000,,えっ なんで
Dialogue: 0,0:04:31.94,0:04:35.54,Default,,0000,0000,0000,,その
Dialogue: 0,0:04:31.94,0:04:35.54,Default,,0000,0000,0000,,デリカシーがなかったから
Dialogue: 0,0:04:35.54,0:04:37.54,Default,,0000,0000,0000,,デリカシー?
Dialogue: 0,0:04:37.54,0:04:41.88,Default,,0000,0000,0000,,なんて言うか
Dialogue: 0,0:04:37.54,0:04:41.88,Default,,0000,0000,0000,,そう 無神経だった
Dialogue: 0,0:04:41.88,0:04:43.88,Default,,0000,0000,0000,,無神経?
Dialogue: 0,0:04:43.88,0:04:46.89,Default,,0000,0000,0000,,うかつだった
Dialogue: 0,0:04:43.88,0:04:46.89,Default,,0000,0000,0000,,うかつ?
Dialogue: 0,0:04:46.89,0:04:49.56,Default,,0000,0000,0000,,いや あの つまり
Dialogue: 0,0:04:49.56,0:04:53.56,Default,,0000,0000,0000,,国語の授業は もうええかの
Dialogue: 0,0:04:49.56,0:04:53.56,Default,,0000,0000,0000,,は はい
Dialogue: 0,0:04:53.56,0:04:55.56,Default,,0000,0000,0000,,じゃあね
Dialogue: 0,0:04:57.56,0:05:00.57,Default,,0000,0000,0000,,じゃあ ね
Dialogue: 0,0:05:07.24,0:05:09.24,Default,,0000,0000,0000,,アハハハ
Dialogue: 0,0:05:09.24,0:05:13.58,Default,,0000,0000,0000,,なにゆえ
Dialogue: 0,0:05:09.24,0:05:13.58,Default,,0000,0000,0000,,なにゆえと言われましても
Dialogue: 0,0:05:13.58,0:05:15.58,Default,,0000,0000,0000,,船が怖いそうだ
Dialogue: 0,0:05:15.58,0:05:18.58,Default,,0000,0000,0000,,船に乗ろうとして 海を見たら
Dialogue: 0,0:05:18.58,0:05:21.59,Default,,0000,0000,0000,,なぜか その場から動けなくなって
Dialogue: 0,0:05:21.59,0:05:25.59,Default,,0000,0000,0000,,いやぁ お恥ずかしい
Dialogue: 0,0:05:21.59,0:05:25.59,Default,,0000,0000,0000,,まったくだ
Dialogue: 0,0:05:25.59,0:05:29.60,Default,,0000,0000,0000,,うかつだった?
Dialogue: 0,0:05:25.59,0:05:29.60,Default,,0000,0000,0000,,それは ちょっと違う?
Dialogue: 0,0:05:29.60,0:05:33.20,Default,,0000,0000,0000,,違うの? うかつは難しい
Dialogue: 0,0:05:33.20,0:05:37.20,Default,,0000,0000,0000,,プッ あっ ごめん つい
Dialogue: 0,0:05:37.20,0:05:42.21,Default,,0000,0000,0000,,そういうの 無神経
Dialogue: 0,0:05:37.20,0:05:42.21,Default,,0000,0000,0000,,だよね
Dialogue: 0,0:05:42.21,0:05:46.88,Default,,0000,0000,0000,,そういうわけで しばらく こいつを うちで預かることにした
Dialogue: 0,0:05:46.88,0:05:48.88,Default,,0000,0000,0000,,ふえ?
Dialogue: 0,0:05:48.88,0:05:52.22,Default,,0000,0000,0000,,あの
Dialogue: 0,0:05:48.88,0:05:52.22,Default,,0000,0000,0000,,本当にいいんですか?
Dialogue: 0,0:05:52.22,0:05:55.22,Default,,0000,0000,0000,,この家は わしとあの子の2人だけ
Dialogue: 0,0:05:55.22,0:05:58.56,Default,,0000,0000,0000,,わしは 仕事で家を空けることが多い
Dialogue: 0,0:05:58.56,0:06:02.23,Default,,0000,0000,0000,,あんたがいてくれるのは そう悪いことじゃない
Dialogue: 0,0:06:02.23,0:06:04.23,Default,,0000,0000,0000,,だが 1つだけ
Dialogue: 0,0:06:04.23,0:06:07.57,Default,,0000,0000,0000,,あの子の前で親の話
Dialogue: 0,0:06:07.57,0:06:12.91,Default,,0000,0000,0000,,特に 母親の話を持ち出すのだけは
Dialogue: 0,0:06:07.57,0:06:12.91,Default,,0000,0000,0000,,やめてもらいたい
Dialogue: 0,0:06:12.91,0:06:15.58,Default,,0000,0000,0000,,もしかして お母さんも?
Dialogue: 0,0:06:15.58,0:06:20.58,Default,,0000,0000,0000,,1か月前 あの子の父親が 事故で亡くなった
Dialogue: 0,0:06:20.58,0:06:23.58,Default,,0000,0000,0000,,それから ほどなく しろはの母親
Dialogue: 0,0:06:23.58,0:06:28.25,Default,,0000,0000,0000,,わしの娘が姿を消した
Dialogue: 0,0:06:28.25,0:06:32.26,Default,,0000,0000,0000,,両親が一度にいなくなり まだ1か月
Dialogue: 0,0:06:32.26,0:06:35.86,Default,,0000,0000,0000,,お前には難しい子に 見えるかもしれないが
Dialogue: 0,0:06:35.86,0:06:38.20,Default,,0000,0000,0000,,立派な子だ
Dialogue: 0,0:06:38.20,0:06:41.53,Default,,0000,0000,0000,,わしの前でも ほとんど泣いたりしない
Dialogue: 0,0:06:41.53,0:06:45.87,Default,,0000,0000,0000,,いや あるいは 度が過ぎた悲しみの前には
Dialogue: 0,0:06:45.87,0:06:51.21,Default,,0000,0000,0000,,人は泣くことも
Dialogue: 0,0:06:45.87,0:06:51.21,Default,,0000,0000,0000,,できないのかもしれないな
Dialogue: 0,0:06:51.21,0:06:55.21,Default,,0000,0000,0000,,それはそれとして お前の名前だ
Dialogue: 0,0:06:51.21,0:06:55.21,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:06:55.21,0:06:58.55,Default,,0000,0000,0000,,一緒に住む以上 ないと困るだろう
Dialogue: 0,0:06:58.55,0:07:03.56,Default,,0000,0000,0000,,何か思い出したりしないのか?
Dialogue: 0,0:06:58.55,0:07:03.56,Default,,0000,0000,0000,,うん
Dialogue: 0,0:07:03.56,0:07:08.90,Default,,0000,0000,0000,,海 七つの海
Dialogue: 0,0:07:08.90,0:07:10.90,Default,,0000,0000,0000,,どうした?
Dialogue: 0,0:07:10.90,0:07:14.90,Default,,0000,0000,0000,,頭に浮かんだんです
Dialogue: 0,0:07:10.90,0:07:14.90,Default,,0000,0000,0000,,七つの海って
Dialogue: 0,0:07:14.90,0:07:17.57,Default,,0000,0000,0000,,海にも 出られないやつがか?
Dialogue: 0,0:07:17.57,0:07:21.91,Default,,0000,0000,0000,,ふむ 七つの海 七海か
Dialogue: 0,0:07:21.91,0:07:24.91,Default,,0000,0000,0000,,ななみ 七海
Dialogue: 0,0:07:24.91,0:07:28.92,Default,,0000,0000,0000,,とりあえず そうしておくか
Dialogue: 0,0:07:24.91,0:07:28.92,Default,,0000,0000,0000,,はい
Dialogue: 0,0:07:34.85,0:07:39.16,Default,,0000,0000,0000,,ななみ それが僕の名前?
Dialogue: 0,0:07:43.20,0:07:47.20,Default,,0000,0000,0000,,これは 羽 かな?
Dialogue: 0,0:07:47.20,0:07:49.20,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:07:53.54,0:07:56.21,Default,,0000,0000,0000,,チョウ?
Dialogue: 0,0:07:56.21,0:07:58.21,Default,,0000,0000,0000,,七海
Dialogue: 0,0:07:58.21,0:08:00.55,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:07:58.21,0:08:00.55,Default,,0000,0000,0000,,ごめん
Dialogue: 0,0:08:00.55,0:08:03.88,Default,,0000,0000,0000,,そういう名前だって聞いたから
Dialogue: 0,0:08:03.88,0:08:06.89,Default,,0000,0000,0000,,ごはんができたって
Dialogue: 0,0:08:14.89,0:08:18.23,Default,,0000,0000,0000,,鳴瀬家のお世話になり 早数日
Dialogue: 0,0:08:18.23,0:08:21.90,Default,,0000,0000,0000,,僕は 記憶を求めて 島内を散策したが
Dialogue: 0,0:08:21.90,0:08:25.57,Default,,0000,0000,0000,,あいにくと 記憶が戻る気配はなかった
Dialogue: 0,0:08:25.57,0:08:28.24,Default,,0000,0000,0000,,小鳩さんは 漁師の仕事
Dialogue: 0,0:08:28.24,0:08:31.24,Default,,0000,0000,0000,,しろはちゃんは 朝から1人で出かけて
Dialogue: 0,0:08:31.24,0:08:36.18,Default,,0000,0000,0000,,お昼ごはんを食べたら夕方まで また1人で どこかに行く
Dialogue: 0,0:08:36.18,0:08:39.19,Default,,0000,0000,0000,,そして そんな日々が続くなか
Dialogue: 0,0:08:39.19,0:08:41.52,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:08:41.52,0:08:45.52,Default,,0000,0000,0000,,わ 小鳩さん 今日も大漁だ
Dialogue: 0,0:08:45.52,0:08:50.53,Default,,0000,0000,0000,,毎日 豪華海鮮なんて
Dialogue: 0,0:08:45.52,0:08:50.53,Default,,0000,0000,0000,,うれしいね しろはちゃん
Dialogue: 0,0:08:53.87,0:08:58.87,Default,,0000,0000,0000,,いくら新鮮で豪華でも 毎日お刺身っていうのは
Dialogue: 0,0:08:58.87,0:09:01.54,Default,,0000,0000,0000,,子どもには やっぱり ちょっとつらいよ
Dialogue: 0,0:09:01.54,0:09:06.21,Default,,0000,0000,0000,,あの無表情な食事
Dialogue: 0,0:09:01.54,0:09:06.21,Default,,0000,0000,0000,,あれはよくない
Dialogue: 0,0:09:06.21,0:09:10.22,Default,,0000,0000,0000,,ちょっとは 食事を 楽しんでくれるといいんだけど
Dialogue: 0,0:09:10.22,0:09:12.89,Default,,0000,0000,0000,,よし 完成!
Dialogue: 0,0:09:12.89,0:09:16.89,Default,,0000,0000,0000,,お あり合わせにしては いい感じ
Dialogue: 0,0:09:16.89,0:09:19.56,Default,,0000,0000,0000,,というか 記憶がないのに
Dialogue: 0,0:09:19.56,0:09:22.23,Default,,0000,0000,0000,,なんで作れるなんて 思ったんだろう
Dialogue: 0,0:09:22.23,0:09:24.23,Default,,0000,0000,0000,,チャーハン?
Dialogue: 0,0:09:24.23,0:09:27.90,Default,,0000,0000,0000,,なに作ったの?
Dialogue: 0,0:09:24.23,0:09:27.90,Default,,0000,0000,0000,,しろはちゃん
Dialogue: 0,0:09:27.90,0:09:30.90,Default,,0000,0000,0000,,チャーハンだよ
Dialogue: 0,0:09:27.90,0:09:30.90,Default,,0000,0000,0000,,焼き飯のこと?
Dialogue: 0,0:09:30.90,0:09:35.17,Default,,0000,0000,0000,,違うよ チャーハン
Dialogue: 0,0:09:30.90,0:09:35.17,Default,,0000,0000,0000,,焼き飯?
Dialogue: 0,0:09:35.17,0:09:39.51,Default,,0000,0000,0000,,ふむ
Dialogue: 0,0:09:35.17,0:09:39.51,Default,,0000,0000,0000,,じゃあ 間を取って やーはん
Dialogue: 0,0:09:39.51,0:09:42.52,Default,,0000,0000,0000,,やーはん!
Dialogue: 0,0:09:39.51,0:09:42.52,Default,,0000,0000,0000,,そう やーはん
Dialogue: 0,0:09:42.52,0:09:44.52,Default,,0000,0000,0000,,やーはん!
Dialogue: 0,0:09:44.52,0:09:48.52,Default,,0000,0000,0000,,やーはん! やーはん!
Dialogue: 0,0:09:44.52,0:09:48.52,Default,,0000,0000,0000,,やーはん! やーはん!
Dialogue: 0,0:09:48.52,0:09:50.52,Default,,0000,0000,0000,,やーはん!
Dialogue: 0,0:10:00.53,0:10:04.20,Default,,0000,0000,0000,,おいしい
Dialogue: 0,0:10:00.53,0:10:04.20,Default,,0000,0000,0000,,よかった
Dialogue: 0,0:10:04.20,0:10:08.87,Default,,0000,0000,0000,,いくら豪華で新鮮でも お刺身ばかりだと飽きるよね
Dialogue: 0,0:10:08.87,0:10:13.55,Default,,0000,0000,0000,,それは悪かったな
Dialogue: 0,0:10:08.87,0:10:13.55,Default,,0000,0000,0000,,うわぁ!
Dialogue: 0,0:10:13.55,0:10:16.88,Default,,0000,0000,0000,,七海が作ったのか
Dialogue: 0,0:10:13.55,0:10:16.88,Default,,0000,0000,0000,,は はい
Dialogue: 0,0:10:16.88,0:10:20.19,Default,,0000,0000,0000,,あっ 小鳩さんの分もありますよ
Dialogue: 0,0:10:23.89,0:10:27.23,Default,,0000,0000,0000,,うむ うまい
Dialogue: 0,0:10:27.23,0:10:29.56,Default,,0000,0000,0000,,しかし これは
Dialogue: 0,0:10:29.56,0:10:33.23,Default,,0000,0000,0000,,ど どうかしましたか?
Dialogue: 0,0:10:29.56,0:10:33.23,Default,,0000,0000,0000,,いや
Dialogue: 0,0:10:33.23,0:10:39.24,Default,,0000,0000,0000,,それよりも 世話をかけた
Dialogue: 0,0:10:33.23,0:10:39.24,Default,,0000,0000,0000,,そうか 七海は料理ができるのか
Dialogue: 0,0:10:39.24,0:10:42.24,Default,,0000,0000,0000,,よかったら しろはのために
Dialogue: 0,0:10:42.24,0:10:46.91,Default,,0000,0000,0000,,いや 七海は 客人だ
Dialogue: 0,0:10:42.24,0:10:46.91,Default,,0000,0000,0000,,今後 料理などする必要はない
Dialogue: 0,0:10:46.91,0:10:50.92,Default,,0000,0000,0000,,はっ? 別に料理くらい
Dialogue: 0,0:10:50.92,0:10:54.59,Default,,0000,0000,0000,,ごちそうになった
Dialogue: 0,0:10:50.92,0:10:54.59,Default,,0000,0000,0000,,わしは 少し寝る
Dialogue: 0,0:10:54.59,0:10:59.59,Default,,0000,0000,0000,,ごちそうさま
Dialogue: 0,0:10:54.59,0:10:59.59,Default,,0000,0000,0000,,あ うん お粗末さま
Dialogue: 0,0:10:59.59,0:11:02.93,Default,,0000,0000,0000,,これ お父さんの味に似てる
Dialogue: 0,0:11:02.93,0:11:05.60,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:11:02.93,0:11:05.60,Default,,0000,0000,0000,,あの
Dialogue: 0,0:11:05.60,0:11:08.93,Default,,0000,0000,0000,,作り方 教えてほしい!
Dialogue: 0,0:11:08.93,0:11:14.27,Default,,0000,0000,0000,,い いいけど でも
Dialogue: 0,0:11:08.93,0:11:14.27,Default,,0000,0000,0000,,僕も感覚で作っただけだし
Dialogue: 0,0:11:14.27,0:11:16.28,Default,,0000,0000,0000,,それに おじいさん
Dialogue: 0,0:11:16.28,0:11:20.28,Default,,0000,0000,0000,,僕が料理するの よく思ってないみたいだし
Dialogue: 0,0:11:20.28,0:11:26.62,Default,,0000,0000,0000,,じゃあ あのね
Dialogue: 0,0:11:20.28,0:11:26.62,Default,,0000,0000,0000,,私の秘密の場所も教えてあげる
Dialogue: 0,0:11:26.62,0:11:29.02,Default,,0000,0000,0000,,秘密の場所?
Dialogue: 0,0:11:32.29,0:11:35.23,Default,,0000,0000,0000,,今はやってないの?
Dialogue: 0,0:11:32.29,0:11:35.23,Default,,0000,0000,0000,,うん
Dialogue: 0,0:11:35.23,0:11:38.23,Default,,0000,0000,0000,,ここでお父さんが作ってたの
Dialogue: 0,0:11:38.23,0:11:41.23,Default,,0000,0000,0000,,お母さんは あんまり料理できなくて
Dialogue: 0,0:11:41.23,0:11:44.24,Default,,0000,0000,0000,,それ以外のこと手伝っていたの
Dialogue: 0,0:11:44.24,0:11:47.91,Default,,0000,0000,0000,,けど お父さんは 事故で死んじゃった
Dialogue: 0,0:11:47.91,0:11:50.24,Default,,0000,0000,0000,,お母さんも どこかに行った
Dialogue: 0,0:11:50.24,0:11:54.58,Default,,0000,0000,0000,,どこかって
Dialogue: 0,0:11:50.24,0:11:54.58,Default,,0000,0000,0000,,わからない
Dialogue: 0,0:11:54.58,0:11:58.25,Default,,0000,0000,0000,,でも たぶん お父さんを探しにいったの
Dialogue: 0,0:11:58.25,0:12:03.26,Default,,0000,0000,0000,,とても仲よしだったから
Dialogue: 0,0:11:58.25,0:12:03.26,Default,,0000,0000,0000,,しろはちゃん
Dialogue: 0,0:12:07.26,0:12:11.93,Default,,0000,0000,0000,,そうか しろはちゃん 毎日 掃除しにきてたんだ
Dialogue: 0,0:12:11.93,0:12:14.93,Default,,0000,0000,0000,,お母さんがやってたから
Dialogue: 0,0:12:17.94,0:12:22.94,Default,,0000,0000,0000,,僕も手伝うよ
Dialogue: 0,0:12:17.94,0:12:22.94,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:12:22.94,0:12:24.94,Default,,0000,0000,0000,,うん
Dialogue: 0,0:12:31.95,0:12:34.55,Default,,0000,0000,0000,,どうかな しろはちゃん
Dialogue: 0,0:12:34.55,0:12:38.56,Default,,0000,0000,0000,,んっ おいしい
Dialogue: 0,0:12:34.55,0:12:38.56,Default,,0000,0000,0000,,味付けもそっくり
Dialogue: 0,0:12:38.56,0:12:42.56,Default,,0000,0000,0000,,でも お父さんが作ったのは もっとおいしかった
Dialogue: 0,0:12:42.56,0:12:44.56,Default,,0000,0000,0000,,うん やっぱり
Dialogue: 0,0:12:44.56,0:12:48.23,Default,,0000,0000,0000,,完全に再現するには レシピが必要かぁ
Dialogue: 0,0:12:48.23,0:12:50.57,Default,,0000,0000,0000,,あったはず
Dialogue: 0,0:12:48.23,0:12:50.57,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:12:50.57,0:12:53.57,Default,,0000,0000,0000,,お母さんが書いた秘伝のレシピ
Dialogue: 0,0:12:55.91,0:12:57.91,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:12:57.91,0:12:59.91,Default,,0000,0000,0000,,これは しろはちゃんの
Dialogue: 0,0:12:59.91,0:13:02.58,Default,,0000,0000,0000,,七海 あったよ
Dialogue: 0,0:13:02.58,0:13:05.58,Default,,0000,0000,0000,,ホント? 見せて見せて
Dialogue: 0,0:13:05.58,0:13:10.92,Default,,0000,0000,0000,,なになに?
Dialogue: 0,0:13:05.58,0:13:10.92,Default,,0000,0000,0000,,「胡椒 人参 レタス 河の主」?
Dialogue: 0,0:13:10.92,0:13:17.26,Default,,0000,0000,0000,,ん? 「君は見たことがあるか
Dialogue: 0,0:13:10.92,0:13:17.26,Default,,0000,0000,0000,,日没の頃だけに現れる幻の山菜」
Dialogue: 0,0:13:17.26,0:13:21.27,Default,,0000,0000,0000,,「山の頂にわき出る 渡り鳥が愛した天然水」
Dialogue: 0,0:13:21.27,0:13:24.94,Default,,0000,0000,0000,,「渡り鳥が愛した 猛々しき獣の死肉」
Dialogue: 0,0:13:24.94,0:13:26.94,Default,,0000,0000,0000,,ちょっと待って
Dialogue: 0,0:13:26.94,0:13:29.28,Default,,0000,0000,0000,,なんか謎の材料が 混じってるけど
Dialogue: 0,0:13:29.28,0:13:31.94,Default,,0000,0000,0000,,全部 この島にある食材
Dialogue: 0,0:13:31.94,0:13:34.88,Default,,0000,0000,0000,,お母さんが集めて お父さんが作るの
Dialogue: 0,0:13:34.88,0:13:39.55,Default,,0000,0000,0000,,で 私も一緒に お母さん手伝った
Dialogue: 0,0:13:34.88,0:13:39.55,Default,,0000,0000,0000,,偉いね
Dialogue: 0,0:13:39.55,0:13:43.96,Default,,0000,0000,0000,,じゃあ 今から探しに行くから 手伝ってくれる?
Dialogue: 0,0:13:39.55,0:13:43.96,Default,,0000,0000,0000,,うん!
Dialogue: 0,0:14:32.27,0:14:34.87,Default,,0000,0000,0000,,材料 そろったね
Dialogue: 0,0:14:34.87,0:14:38.21,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:14:38.21,0:14:41.55,Default,,0000,0000,0000,,フフッ やーはんの試作は 明日かな
Dialogue: 0,0:14:41.55,0:14:44.22,Default,,0000,0000,0000,,今日は お疲れさま しろはちゃん
Dialogue: 0,0:14:44.22,0:14:46.89,Default,,0000,0000,0000,,ただいま戻りました
Dialogue: 0,0:14:46.89,0:14:49.56,Default,,0000,0000,0000,,よほど 楽しかったのだろうな
Dialogue: 0,0:14:49.56,0:14:52.22,Default,,0000,0000,0000,,うれしそうな顔をしていた
Dialogue: 0,0:14:52.22,0:14:55.23,Default,,0000,0000,0000,,いったい 島を回って 何していたんだ?
Dialogue: 0,0:14:55.23,0:14:58.56,Default,,0000,0000,0000,,あぁ まぁ いろいろと
Dialogue: 0,0:14:58.56,0:15:02.23,Default,,0000,0000,0000,,そうだ 小鳩さんのお友達にも 会いましたよ
Dialogue: 0,0:15:02.23,0:15:07.24,Default,,0000,0000,0000,,たしか 青龍 朱雀 白虎 玄武さん
Dialogue: 0,0:15:07.24,0:15:11.08,Default,,0000,0000,0000,,待て 玄武は わしの称号だぞ!
Dialogue: 0,0:15:11.08,0:15:14.25,Default,,0000,0000,0000,,えぇ
Dialogue: 0,0:15:11.08,0:15:14.25,Default,,0000,0000,0000,,おのれ あの青二才
Dialogue: 0,0:15:14.25,0:15:16.58,Default,,0000,0000,0000,,また勝手に名乗りおって!
Dialogue: 0,0:15:18.58,0:15:21.25,Default,,0000,0000,0000,,七海よ しろはと よく遊んでくれて
Dialogue: 0,0:15:21.25,0:15:23.92,Default,,0000,0000,0000,,なんというか 助かる
Dialogue: 0,0:15:23.92,0:15:26.59,Default,,0000,0000,0000,,いえいえ これくらいなんてこと
Dialogue: 0,0:15:26.59,0:15:30.26,Default,,0000,0000,0000,,だが お前のことは いろいろ調べているが
Dialogue: 0,0:15:30.26,0:15:33.87,Default,,0000,0000,0000,,何も手がかりはないというのに
Dialogue: 0,0:15:33.87,0:15:38.54,Default,,0000,0000,0000,,あぁ 僕の記憶!
Dialogue: 0,0:15:33.87,0:15:38.54,Default,,0000,0000,0000,,アハハ 気にしないでください
Dialogue: 0,0:15:38.54,0:15:40.54,Default,,0000,0000,0000,,お前は気にしろ
Dialogue: 0,0:15:40.54,0:15:42.54,Default,,0000,0000,0000,,それよりも この島だが
Dialogue: 0,0:15:42.54,0:15:47.21,Default,,0000,0000,0000,,港近くの坂道の手前に 食堂があってな
Dialogue: 0,0:15:47.21,0:15:50.22,Default,,0000,0000,0000,,島のどこに行くのも自由だが
Dialogue: 0,0:15:50.22,0:15:53.55,Default,,0000,0000,0000,,そこだけは しろはが 行きたがっても断ってくれ
Dialogue: 0,0:15:53.55,0:15:55.89,Default,,0000,0000,0000,,悲しい思いをするからな
Dialogue: 0,0:15:55.89,0:15:57.89,Default,,0000,0000,0000,,小鳩さん
Dialogue: 0,0:15:57.89,0:16:02.90,Default,,0000,0000,0000,,あの しろはちゃんのお母さんは
Dialogue: 0,0:15:57.89,0:16:02.90,Default,,0000,0000,0000,,友達とかいなかったんですか?
Dialogue: 0,0:16:02.90,0:16:08.90,Default,,0000,0000,0000,,そうだな 友達は たくさんいたが
Dialogue: 0,0:16:02.90,0:16:08.90,Default,,0000,0000,0000,,特に仲がよかったのは
Dialogue: 0,0:16:08.90,0:16:11.24,Default,,0000,0000,0000,,はい
Dialogue: 0,0:16:11.24,0:16:14.91,Default,,0000,0000,0000,,加藤 鏡子さんでしょうか?
Dialogue: 0,0:16:14.91,0:16:17.24,Default,,0000,0000,0000,,鏡子は私だけど
Dialogue: 0,0:16:17.24,0:16:21.25,Default,,0000,0000,0000,,あなたはたしか 鳴瀬さんのところの
Dialogue: 0,0:16:17.24,0:16:21.25,Default,,0000,0000,0000,,七海です
Dialogue: 0,0:16:21.25,0:16:25.58,Default,,0000,0000,0000,,その しろはちゃんの お母さんのことでお話が
Dialogue: 0,0:16:25.58,0:16:29.92,Default,,0000,0000,0000,,私も不思議なの
Dialogue: 0,0:16:25.58,0:16:29.92,Default,,0000,0000,0000,,あの子 瞳が
Dialogue: 0,0:16:29.92,0:16:32.26,Default,,0000,0000,0000,,しろはちゃんを置いて いなくなるなんて
Dialogue: 0,0:16:32.26,0:16:36.86,Default,,0000,0000,0000,,何も相談とかなかったんですか?
Dialogue: 0,0:16:32.26,0:16:36.86,Default,,0000,0000,0000,,うん
Dialogue: 0,0:16:36.86,0:16:39.20,Default,,0000,0000,0000,,あっ そういえば
Dialogue: 0,0:16:39.20,0:16:43.87,Default,,0000,0000,0000,,瞳がいなくなる少し前 話を聞きにきたわ
Dialogue: 0,0:16:43.87,0:16:46.54,Default,,0000,0000,0000,,あの 話とは!?
Dialogue: 0,0:16:46.54,0:16:48.54,Default,,0000,0000,0000,,白羽の伝承
Dialogue: 0,0:16:48.54,0:16:50.54,Default,,0000,0000,0000,,しろはね?
Dialogue: 0,0:16:50.54,0:16:52.54,Default,,0000,0000,0000,,鳥白島の伝承よ
Dialogue: 0,0:16:52.54,0:16:55.88,Default,,0000,0000,0000,,私は そういうのが好きで 調べているの
Dialogue: 0,0:16:55.88,0:16:57.88,Default,,0000,0000,0000,,どういった話なんですか?
Dialogue: 0,0:16:57.88,0:17:02.89,Default,,0000,0000,0000,,女の人が蝶になって
Dialogue: 0,0:16:57.88,0:17:02.89,Default,,0000,0000,0000,,愛する人に会いにいくお話ね
Dialogue: 0,0:17:02.89,0:17:05.22,Default,,0000,0000,0000,,彼女は 海に身を投げ
Dialogue: 0,0:17:05.22,0:17:09.23,Default,,0000,0000,0000,,海の神様に命を捧げることで 力を得て
Dialogue: 0,0:17:09.23,0:17:13.90,Default,,0000,0000,0000,,白い羽の蝶になり 愛する人のもとへ飛んでいく
Dialogue: 0,0:17:13.90,0:17:17.90,Default,,0000,0000,0000,,けれど 代わりに 他のすべてを失ってしまう
Dialogue: 0,0:17:17.90,0:17:20.57,Default,,0000,0000,0000,,愛する人のもと
Dialogue: 0,0:17:20.57,0:17:23.58,Default,,0000,0000,0000,,その話を瞳さんに?
Dialogue: 0,0:17:20.57,0:17:23.58,Default,,0000,0000,0000,,えぇ
Dialogue: 0,0:17:23.58,0:17:27.91,Default,,0000,0000,0000,,今思えば 伝承にでも すがりたかったのかもしれない
Dialogue: 0,0:17:27.91,0:17:30.25,Default,,0000,0000,0000,,瞳さんは どんな人だったんですか?
Dialogue: 0,0:17:30.25,0:17:32.85,Default,,0000,0000,0000,,瞳? パワフルだったよ
Dialogue: 0,0:17:32.85,0:17:35.85,Default,,0000,0000,0000,,彼女がいると どんな小さなことも
Dialogue: 0,0:17:35.85,0:17:38.52,Default,,0000,0000,0000,,すっごく楽しいことに思えたわ
Dialogue: 0,0:17:38.52,0:17:41.53,Default,,0000,0000,0000,,そうそう 口癖みたいに言ってたっけ
Dialogue: 0,0:17:41.53,0:17:44.86,Default,,0000,0000,0000,,私はね 過去を懐かしむ暇もないくらい
Dialogue: 0,0:17:44.86,0:17:48.87,Default,,0000,0000,0000,,今を楽しむんだ! って
Dialogue: 0,0:17:51.20,0:17:56.54,Default,,0000,0000,0000,,結局 何もわからずじまいかぁ
Dialogue: 0,0:17:56.54,0:17:59.95,Default,,0000,0000,0000,,白羽の伝承 か
Dialogue: 0,0:18:02.88,0:18:07.19,Default,,0000,0000,0000,,今のは いったい あっ
Dialogue: 0,0:18:13.23,0:18:15.23,Default,,0000,0000,0000,,チョウ
Dialogue: 0,0:18:15.23,0:18:18.93,Default,,0000,0000,0000,,君なら 僕に何か教えてくれるの?
Dialogue: 0,0:18:22.23,0:18:24.94,Default,,0000,0000,0000,,さぁ 食べてみて
Dialogue: 0,0:18:29.24,0:18:32.85,Default,,0000,0000,0000,,おいしい
Dialogue: 0,0:18:29.24,0:18:32.85,Default,,0000,0000,0000,,お父さんの味とそっくり
Dialogue: 0,0:18:32.85,0:18:36.18,Default,,0000,0000,0000,,じゃあ
Dialogue: 0,0:18:36.18,0:18:38.52,Default,,0000,0000,0000,,しろはちゃん?
Dialogue: 0,0:18:38.52,0:18:44.52,Default,,0000,0000,0000,,ごめん でも違うの
Dialogue: 0,0:18:38.52,0:18:44.52,Default,,0000,0000,0000,,すごくすごく近いんだけど
Dialogue: 0,0:18:44.52,0:18:48.19,Default,,0000,0000,0000,,うん レシピどおりなんだけど
Dialogue: 0,0:18:48.19,0:18:50.86,Default,,0000,0000,0000,,具体的には 何が足りないかわかる?
Dialogue: 0,0:18:50.86,0:18:55.87,Default,,0000,0000,0000,,えっと もう少し甘かった
Dialogue: 0,0:18:50.86,0:18:55.87,Default,,0000,0000,0000,,甘いかぁ
Dialogue: 0,0:18:55.87,0:19:00.54,Default,,0000,0000,0000,,しろはちゃん お父さんが作ったとき 何か入れてなかった?
Dialogue: 0,0:19:00.54,0:19:05.21,Default,,0000,0000,0000,,ええと そうだ!
Dialogue: 0,0:19:00.54,0:19:05.21,Default,,0000,0000,0000,,黒くて細かいの 最後に入れてた
Dialogue: 0,0:19:05.21,0:19:08.55,Default,,0000,0000,0000,,黒くて細かい ごま?
Dialogue: 0,0:19:08.55,0:19:11.88,Default,,0000,0000,0000,,ごまじゃなかった
Dialogue: 0,0:19:08.55,0:19:11.88,Default,,0000,0000,0000,,そっかぁ
Dialogue: 0,0:19:11.88,0:19:16.56,Default,,0000,0000,0000,,でも レシピには これ以上何も書いて ん?
Dialogue: 0,0:19:16.56,0:19:18.56,Default,,0000,0000,0000,,なんだこれ?
Dialogue: 0,0:19:18.56,0:19:21.23,Default,,0000,0000,0000,,発電所?
Dialogue: 0,0:19:18.56,0:19:21.23,Default,,0000,0000,0000,,よく知ってるね
Dialogue: 0,0:19:21.23,0:19:24.23,Default,,0000,0000,0000,,でも これ どっちかっていうと
Dialogue: 0,0:19:24.23,0:19:26.57,Default,,0000,0000,0000,,太陽なんじゃないかな
Dialogue: 0,0:19:26.57,0:19:29.23,Default,,0000,0000,0000,,太陽なんか どうやって入れるの?
Dialogue: 0,0:19:29.23,0:19:31.90,Default,,0000,0000,0000,,わからない
Dialogue: 0,0:19:29.23,0:19:31.90,Default,,0000,0000,0000,,でも きっと これは
Dialogue: 0,0:19:31.90,0:19:35.51,Default,,0000,0000,0000,,材料の手がかりなんだよ
Dialogue: 0,0:19:31.90,0:19:35.51,Default,,0000,0000,0000,,ってなわけで
Dialogue: 0,0:19:35.51,0:19:40.51,Default,,0000,0000,0000,,太陽を探しに出発!
Dialogue: 0,0:19:35.51,0:19:40.51,Default,,0000,0000,0000,,おっ!
Dialogue: 0,0:20:06.20,0:20:09.88,Default,,0000,0000,0000,,太陽に近い感じの場所とか 行ってみたけど
Dialogue: 0,0:20:09.88,0:20:13.55,Default,,0000,0000,0000,,材料っぽいものはなかったね
Dialogue: 0,0:20:09.88,0:20:13.55,Default,,0000,0000,0000,,うん
Dialogue: 0,0:20:13.55,0:20:16.25,Default,,0000,0000,0000,,あっ しろは!
Dialogue: 0,0:20:19.89,0:20:22.22,Default,,0000,0000,0000,,久しぶり! 元気?
Dialogue: 0,0:20:22.22,0:20:24.89,Default,,0000,0000,0000,,夏休みに入って 一度も会えてなかったから
Dialogue: 0,0:20:24.89,0:20:27.23,Default,,0000,0000,0000,,寂しかった
Dialogue: 0,0:20:27.23,0:20:31.56,Default,,0000,0000,0000,,そうだ 君たちに ちょっと聞きたいんだけど
Dialogue: 0,0:20:31.56,0:20:35.57,Default,,0000,0000,0000,,この島で 太陽と関係ありそうな場所?
Dialogue: 0,0:20:35.57,0:20:38.57,Default,,0000,0000,0000,,うん 藍 知ってる?
Dialogue: 0,0:20:38.57,0:20:41.57,Default,,0000,0000,0000,,蒼ちゃんが私の太陽
Dialogue: 0,0:20:38.57,0:20:41.57,Default,,0000,0000,0000,,はえ?
Dialogue: 0,0:20:41.57,0:20:44.24,Default,,0000,0000,0000,,太陽 太陽
Dialogue: 0,0:20:44.24,0:20:46.91,Default,,0000,0000,0000,,そういえば 前に しろはさん
Dialogue: 0,0:20:46.91,0:20:49.25,Default,,0000,0000,0000,,それっぽいこと 言ってませんでしたか?
Dialogue: 0,0:20:49.25,0:20:51.92,Default,,0000,0000,0000,,たしか おひさまがどうとか
Dialogue: 0,0:20:51.92,0:20:56.26,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:20:51.92,0:20:56.26,Default,,0000,0000,0000,,どうしたの? 何か思い出した?
Dialogue: 0,0:20:56.26,0:21:00.26,Default,,0000,0000,0000,,行ったこと あるかもしれない
Dialogue: 0,0:20:56.26,0:21:00.26,Default,,0000,0000,0000,,ホント?
Dialogue: 0,0:21:03.93,0:21:06.93,Default,,0000,0000,0000,,うわぁ!
Dialogue: 0,0:21:06.93,0:21:10.94,Default,,0000,0000,0000,,太陽って そういうことか
Dialogue: 0,0:21:10.94,0:21:14.94,Default,,0000,0000,0000,,これを潰して 細かくして
Dialogue: 0,0:21:14.94,0:21:17.61,Default,,0000,0000,0000,,うん ほのかに甘い
Dialogue: 0,0:21:17.61,0:21:22.28,Default,,0000,0000,0000,,見つけたよ しろはちゃん!
Dialogue: 0,0:21:17.61,0:21:22.28,Default,,0000,0000,0000,,思い出のやーはんの最後の材料
Dialogue: 0,0:21:22.28,0:21:27.29,Default,,0000,0000,0000,,初めて来た
Dialogue: 0,0:21:22.28,0:21:27.29,Default,,0000,0000,0000,,えっ? 前に来たって
Dialogue: 0,0:21:27.29,0:21:32.89,Default,,0000,0000,0000,,お母さんがいなくなってから
Dialogue: 0,0:21:27.29,0:21:32.89,Default,,0000,0000,0000,,初めて 来たの
Dialogue: 0,0:21:32.89,0:21:35.89,Default,,0000,0000,0000,,しろは ちゃん
Dialogue: 0,0:21:35.89,0:21:41.57,Default,,0000,0000,0000,,戻りたい
Dialogue: 0,0:21:35.89,0:21:41.57,Default,,0000,0000,0000,,1年前に 戻りたいよ
Dialogue: 0,0:21:41.57,0:21:44.24,Default,,0000,0000,0000,,だって いないんだよ
Dialogue: 0,0:21:44.24,0:21:49.24,Default,,0000,0000,0000,,ここで お母さんと
Dialogue: 0,0:21:44.24,0:21:49.24,Default,,0000,0000,0000,,肩車してくれて
Dialogue: 0,0:21:49.24,0:21:53.91,Default,,0000,0000,0000,,お店に戻ったら お父さんが料理してて
Dialogue: 0,0:21:53.91,0:21:57.92,Default,,0000,0000,0000,,3人で食べて
Dialogue: 0,0:21:53.91,0:21:57.92,Default,,0000,0000,0000,,あったかかった
Dialogue: 0,0:21:57.92,0:22:02.59,Default,,0000,0000,0000,,でも いない 今年はいないの
Dialogue: 0,0:22:02.59,0:22:10.60,Default,,0000,0000,0000,,う う うわぁ
Dialogue: 0,0:22:10.60,0:22:14.60,Default,,0000,0000,0000,,しろはちゃんが望むものを 取り戻したかった
Dialogue: 0,0:22:14.60,0:22:18.60,Default,,0000,0000,0000,,でも 本当にしろはちゃんが 望むものはもう
Dialogue: 0,0:22:21.27,0:22:24.94,Default,,0000,0000,0000,,覚えている
Dialogue: 0,0:22:21.27,0:22:24.94,Default,,0000,0000,0000,,僕も いつか誰かと
Dialogue: 0,0:22:24.94,0:22:27.95,Default,,0000,0000,0000,,こうして 大きな花を見上げていた
Dialogue: 0,0:22:29.95,0:22:33.55,Default,,0000,0000,0000,,なのに 思い出せない
Dialogue: 0,0:22:33.55,0:22:36.89,Default,,0000,0000,0000,,ごめん ごめんね
Dialogue: 0,0:22:36.89,0:22:41.23,Default,,0000,0000,0000,,こんな気持ちを しろはちゃんにもさせてしまったこと
Dialogue: 0,0:22:41.23,0:22:44.90,Default,,0000,0000,0000,,だから せめて
Dialogue: 0,0:22:44.90,0:22:50.50,Default,,0000,0000,0000,,僕がいる間は しろはちゃんが
Dialogue: 0,0:22:44.90,0:22:50.50,Default,,0000,0000,0000,,笑えるようにしてあげたい!
