Dialogue: 0,0:00:34.60,0:00:38.10,Default,,0000,0000,0000,,う うん
Dialogue: 0,0:00:41.94,0:00:43.94,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:00:50.45,0:00:52.45,Default,,0000,0000,0000,,むぎゅぎゅ
Dialogue: 0,0:00:54.45,0:00:56.46,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:01:01.46,0:01:03.46,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:01:05.63,0:01:09.14,Default,,0000,0000,0000,,また 2人とも いなくなったのかと
Dialogue: 0,0:01:12.31,0:01:15.64,Default,,0000,0000,0000,,私ね あれから読み返したの
Dialogue: 0,0:01:15.64,0:01:18.48,Default,,0000,0000,0000,,ツムギさんの日記
Dialogue: 0,0:01:15.64,0:01:18.48,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:01:18.48,0:01:20.98,Default,,0000,0000,0000,,なんとなくわかっちゃった
Dialogue: 0,0:01:20.98,0:01:25.15,Default,,0000,0000,0000,,紬の役目とか この子が帰る って言ってるのが
Dialogue: 0,0:01:25.15,0:01:28.49,Default,,0000,0000,0000,,何なのかとか
Dialogue: 0,0:01:25.15,0:01:28.49,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:01:28.49,0:01:32.49,Default,,0000,0000,0000,,でも 俺たちにとって 紬は紬だ
Dialogue: 0,0:01:32.49,0:01:36.63,Default,,0000,0000,0000,,何があろうと 最後の最後まで一緒にいる
Dialogue: 0,0:01:36.63,0:01:40.30,Default,,0000,0000,0000,,それだけだ
Dialogue: 0,0:01:40.30,0:01:42.30,Default,,0000,0000,0000,,そうね
Dialogue: 0,0:01:42.30,0:01:48.48,Default,,0000,0000,0000,,あっ 静久
Dialogue: 0,0:01:42.30,0:01:48.48,Default,,0000,0000,0000,,バカなことを思いついたんだけど
Dialogue: 0,0:01:48.48,0:01:51.48,Default,,0000,0000,0000,,ふわぁ
Dialogue: 0,0:01:51.48,0:01:55.98,Default,,0000,0000,0000,,おはようございます ハイリさん
Dialogue: 0,0:01:55.98,0:01:58.15,Default,,0000,0000,0000,,むぎゅ?
Dialogue: 0,0:01:58.15,0:02:00.99,Default,,0000,0000,0000,,シズクもいます?
Dialogue: 0,0:02:00.99,0:02:04.26,Default,,0000,0000,0000,,おはよう 紬
Dialogue: 0,0:02:08.16,0:02:10.83,Default,,0000,0000,0000,,おはようございます!
Dialogue: 0,0:03:52.10,0:03:54.93,Default,,0000,0000,0000,,あけましておめでとう 紬
Dialogue: 0,0:03:54.93,0:03:57.94,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:03:57.94,0:04:01.27,Default,,0000,0000,0000,,実は 今日って 1月1日なんだ
Dialogue: 0,0:04:01.27,0:04:03.28,Default,,0000,0000,0000,,むぎゅ?
Dialogue: 0,0:04:03.28,0:04:05.28,Default,,0000,0000,0000,,さっき思いついたんだけどさ
Dialogue: 0,0:04:05.28,0:04:08.62,Default,,0000,0000,0000,,これから 8月31日までの一週間で
Dialogue: 0,0:04:08.62,0:04:12.45,Default,,0000,0000,0000,,正月とか花見とか 1年分のイベントを
Dialogue: 0,0:04:12.45,0:04:14.62,Default,,0000,0000,0000,,ギュッと凝縮させるのはどうだろう?
Dialogue: 0,0:04:14.62,0:04:17.62,Default,,0000,0000,0000,,1年分?
Dialogue: 0,0:04:14.62,0:04:17.62,Default,,0000,0000,0000,,いや 思い切って
Dialogue: 0,0:04:17.62,0:04:19.63,Default,,0000,0000,0000,,一生分のイベント やっちゃおうか!
Dialogue: 0,0:04:19.63,0:04:23.46,Default,,0000,0000,0000,,すてきじゃない!
Dialogue: 0,0:04:19.63,0:04:23.46,Default,,0000,0000,0000,,ハロウィンとか クリスマスとか
Dialogue: 0,0:04:23.46,0:04:25.47,Default,,0000,0000,0000,,まとめて楽しめるし
Dialogue: 0,0:04:25.47,0:04:27.47,Default,,0000,0000,0000,,適当すぎます!
Dialogue: 0,0:04:27.47,0:04:31.47,Default,,0000,0000,0000,,イベントには その季節や 暦に合った 文化というものがあって
Dialogue: 0,0:04:31.47,0:04:34.74,Default,,0000,0000,0000,,あら だいたいのことは 遅れると失礼だけど
Dialogue: 0,0:04:34.74,0:04:36.91,Default,,0000,0000,0000,,早くやる分には問題ないわ
Dialogue: 0,0:04:36.91,0:04:39.41,Default,,0000,0000,0000,,う
Dialogue: 0,0:04:39.41,0:04:41.91,Default,,0000,0000,0000,,でも いいのでしょうか?
Dialogue: 0,0:04:41.91,0:04:44.58,Default,,0000,0000,0000,,紬
Dialogue: 0,0:04:44.58,0:04:48.76,Default,,0000,0000,0000,,別にこれは 紬のためだけに やろうって 言ってるんじゃないんだ
Dialogue: 0,0:04:48.76,0:04:50.92,Default,,0000,0000,0000,,むぎゅ?
Dialogue: 0,0:04:48.76,0:04:50.92,Default,,0000,0000,0000,,そうね
Dialogue: 0,0:04:50.92,0:04:55.09,Default,,0000,0000,0000,,うん 私が遊びたいの 紬と
Dialogue: 0,0:04:55.09,0:04:57.43,Default,,0000,0000,0000,,何十年分も まとめて
Dialogue: 0,0:04:57.43,0:05:00.60,Default,,0000,0000,0000,,シズク
Dialogue: 0,0:04:57.43,0:05:00.60,Default,,0000,0000,0000,,紬は どうなんだ?
Dialogue: 0,0:05:00.60,0:05:03.30,Default,,0000,0000,0000,,紬のやりたいことを 聞かせてくれよ
Dialogue: 0,0:05:07.11,0:05:10.28,Default,,0000,0000,0000,,私は んぎゅ
Dialogue: 0,0:05:10.28,0:05:15.95,Default,,0000,0000,0000,,ハイリさんと シズクと
Dialogue: 0,0:05:10.28,0:05:15.95,Default,,0000,0000,0000,,いっぱい いっぱい遊びたいです
Dialogue: 0,0:05:15.95,0:05:17.95,Default,,0000,0000,0000,,ずっと ずっと
Dialogue: 0,0:05:17.95,0:05:20.45,Default,,0000,0000,0000,,うっ うっ
Dialogue: 0,0:05:23.12,0:05:25.12,Default,,0000,0000,0000,,一緒にいたいです!
Dialogue: 0,0:05:28.29,0:05:30.30,Default,,0000,0000,0000,,一生分の イベント?
Dialogue: 0,0:05:30.30,0:05:33.90,Default,,0000,0000,0000,,頼みって 無理だし
Dialogue: 0,0:05:33.90,0:05:37.57,Default,,0000,0000,0000,,俺たちに任せろ!
Dialogue: 0,0:05:33.90,0:05:37.57,Default,,0000,0000,0000,,おお お任せください!
Dialogue: 0,0:05:37.57,0:05:40.74,Default,,0000,0000,0000,,そういう事情なら 喜んで協力しよう
Dialogue: 0,0:05:40.74,0:05:43.24,Default,,0000,0000,0000,,ありがとう 恩に着るよ
Dialogue: 0,0:05:43.24,0:05:47.08,Default,,0000,0000,0000,,フフ なんだか面白くなりそう
Dialogue: 0,0:05:47.08,0:05:51.58,Default,,0000,0000,0000,,ああ それでさ 最後の8月31日だけど
Dialogue: 0,0:05:51.58,0:05:54.42,Default,,0000,0000,0000,,誕生日のお祝いを しようと思うんだ
Dialogue: 0,0:05:54.42,0:05:57.76,Default,,0000,0000,0000,,いいわね 盛大にお祝いしましょ!
Dialogue: 0,0:05:57.76,0:06:01.59,Default,,0000,0000,0000,,で どうせなら 何か サプライズとかできないかな?
Dialogue: 0,0:06:01.59,0:06:05.26,Default,,0000,0000,0000,,サプライズか あっ!
Dialogue: 0,0:06:05.26,0:06:07.27,Default,,0000,0000,0000,,今度は 私が思いついちゃった
Dialogue: 0,0:06:07.27,0:06:09.94,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:06:07.27,0:06:09.94,Default,,0000,0000,0000,,フフ
Dialogue: 0,0:06:09.94,0:06:11.97,Default,,0000,0000,0000,,そして 俺たちの
Dialogue: 0,0:06:11.97,0:06:15.14,Default,,0000,0000,0000,,夏休み 最後の一週間が始まった
Dialogue: 0,0:07:02.59,0:07:05.76,Default,,0000,0000,0000,,俺たちは なんて密度の濃い
Dialogue: 0,0:07:05.76,0:07:08.09,Default,,0000,0000,0000,,夏を過ごしているんだろう
Dialogue: 0,0:07:08.09,0:07:11.10,Default,,0000,0000,0000,,呼吸する暇さえ もったいないくらいに
Dialogue: 0,0:07:13.77,0:07:18.57,Default,,0000,0000,0000,,この夏休みを 最高の思い出にするために
Dialogue: 0,0:07:21.77,0:07:25.44,Default,,0000,0000,0000,,メリークリスマス!
Dialogue: 0,0:07:25.44,0:07:31.78,Default,,0000,0000,0000,,えっと 私から お二人に
Dialogue: 0,0:07:25.44,0:07:31.78,Default,,0000,0000,0000,,クリスマスプレゼントがあります
Dialogue: 0,0:07:31.78,0:07:33.92,Default,,0000,0000,0000,,ここの合鍵です
Dialogue: 0,0:07:33.92,0:07:37.59,Default,,0000,0000,0000,,ハイリさんと シズクが遊びにきたとき
Dialogue: 0,0:07:37.59,0:07:41.43,Default,,0000,0000,0000,,私が出かけてても これで大丈夫です!
Dialogue: 0,0:07:41.43,0:07:45.93,Default,,0000,0000,0000,,ありがとう
Dialogue: 0,0:07:41.43,0:07:45.93,Default,,0000,0000,0000,,でも 意外と積極的だな 紬も
Dialogue: 0,0:07:45.93,0:07:48.94,Default,,0000,0000,0000,,恋人に合鍵を渡すなんてさ
Dialogue: 0,0:07:48.94,0:07:53.61,Default,,0000,0000,0000,,むぎゅ そ そういう意味は
Dialogue: 0,0:07:53.61,0:07:55.61,Default,,0000,0000,0000,,あるんですけどね!
Dialogue: 0,0:07:55.61,0:07:58.95,Default,,0000,0000,0000,,私からも 紬に プレゼントがあるの
Dialogue: 0,0:07:58.95,0:08:02.11,Default,,0000,0000,0000,,はい!
Dialogue: 0,0:07:58.95,0:08:02.11,Default,,0000,0000,0000,,わぁ!
Dialogue: 0,0:08:02.11,0:08:04.28,Default,,0000,0000,0000,,ありがとうございます!
Dialogue: 0,0:08:07.62,0:08:10.62,Default,,0000,0000,0000,,おお!
Dialogue: 0,0:08:07.62,0:08:10.62,Default,,0000,0000,0000,,フフフ 水着よ
Dialogue: 0,0:08:10.62,0:08:14.29,Default,,0000,0000,0000,,いや これはないだろ
Dialogue: 0,0:08:10.62,0:08:14.29,Default,,0000,0000,0000,,そ そんな!
Dialogue: 0,0:08:14.29,0:08:16.80,Default,,0000,0000,0000,,紬が パイリくんと つきあい始めて
Dialogue: 0,0:08:16.80,0:08:20.63,Default,,0000,0000,0000,,おっぱいに 何らかの科学反応が 起こると思ったのに
Dialogue: 0,0:08:20.63,0:08:24.64,Default,,0000,0000,0000,,フ フフフ アハハハハッ!
Dialogue: 0,0:08:24.64,0:08:28.47,Default,,0000,0000,0000,,シズクのおっぱいより 大きいなんて不可能です
Dialogue: 0,0:08:28.47,0:08:30.48,Default,,0000,0000,0000,,アハッ アハハハハッ
Dialogue: 0,0:08:30.48,0:08:34.91,Default,,0000,0000,0000,,プッ そうだな それは 俺も断言するぞ
Dialogue: 0,0:08:34.91,0:08:38.08,Default,,0000,0000,0000,,ハハハハ ハハハハ
Dialogue: 0,0:08:34.91,0:08:38.08,Default,,0000,0000,0000,,アハハハッ
Dialogue: 0,0:08:38.08,0:08:42.26,Default,,0000,0000,0000,,なによ 成長してほしいって 願いを込めたのに
Dialogue: 0,0:08:55.43,0:08:57.44,Default,,0000,0000,0000,,紬?
Dialogue: 0,0:08:57.44,0:08:59.61,Default,,0000,0000,0000,,うわぁん!
Dialogue: 0,0:08:59.61,0:09:03.28,Default,,0000,0000,0000,,やだよ!
Dialogue: 0,0:08:59.61,0:09:03.28,Default,,0000,0000,0000,,帰りたくないよ!
Dialogue: 0,0:09:03.28,0:09:06.11,Default,,0000,0000,0000,,もっと もっと
Dialogue: 0,0:09:06.11,0:09:08.95,Default,,0000,0000,0000,,海にも また行きたかったです
Dialogue: 0,0:09:08.95,0:09:12.12,Default,,0000,0000,0000,,浴衣を着て お祭りにも
Dialogue: 0,0:09:12.12,0:09:17.62,Default,,0000,0000,0000,,雪合戦だって
Dialogue: 0,0:09:12.12,0:09:17.62,Default,,0000,0000,0000,,やりたいことだらけなのに
Dialogue: 0,0:09:17.62,0:09:22.30,Default,,0000,0000,0000,,2人と ずっと ずっと
Dialogue: 0,0:09:22.30,0:09:25.06,Default,,0000,0000,0000,,一緒にいたいのに!
Dialogue: 0,0:09:28.63,0:09:33.37,Default,,0000,0000,0000,,大丈夫よ 紬 大丈夫だから
Dialogue: 0,0:09:33.37,0:09:35.88,Default,,0000,0000,0000,,で でも
Dialogue: 0,0:09:35.88,0:09:39.21,Default,,0000,0000,0000,,明日になったら 私
Dialogue: 0,0:09:39.21,0:09:42.21,Default,,0000,0000,0000,,最後まで3人で 楽しく遊ぶんでしょう?
Dialogue: 0,0:09:42.21,0:09:45.22,Default,,0000,0000,0000,,だったら 笑顔でいなくちゃ
Dialogue: 0,0:09:45.22,0:09:48.39,Default,,0000,0000,0000,,ねっ パイリくん
Dialogue: 0,0:09:45.22,0:09:48.39,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:09:48.39,0:09:50.39,Default,,0000,0000,0000,,ああ もちろんだ
Dialogue: 0,0:09:50.39,0:09:55.73,Default,,0000,0000,0000,,俺たちは ずっと
Dialogue: 0,0:09:50.39,0:09:55.73,Default,,0000,0000,0000,,紬のそばにいるから
Dialogue: 0,0:09:55.73,0:09:58.06,Default,,0000,0000,0000,,ハイリさん
Dialogue: 0,0:09:58.06,0:10:01.40,Default,,0000,0000,0000,,だから ほら もう泣かないの
Dialogue: 0,0:10:01.40,0:10:05.57,Default,,0000,0000,0000,,どうしてですか?
Dialogue: 0,0:10:01.40,0:10:05.57,Default,,0000,0000,0000,,どうして2人とも
Dialogue: 0,0:10:05.57,0:10:08.41,Default,,0000,0000,0000,,そんなに優しいんですか?
Dialogue: 0,0:10:08.41,0:10:13.08,Default,,0000,0000,0000,,そんなの決まってるでしょ
Dialogue: 0,0:10:08.41,0:10:13.08,Default,,0000,0000,0000,,紬のことが大好きだからよ
Dialogue: 0,0:10:13.08,0:10:16.42,Default,,0000,0000,0000,,俺も 紬が大好きだ
Dialogue: 0,0:10:16.42,0:10:21.09,Default,,0000,0000,0000,,わ 私もです
Dialogue: 0,0:10:21.09,0:10:25.93,Default,,0000,0000,0000,,私も ハイリさんと シズクのこと 大好きです!
Dialogue: 0,0:10:25.93,0:10:30.60,Default,,0000,0000,0000,,こうして俺たちは 8月31日
Dialogue: 0,0:10:30.60,0:10:34.30,Default,,0000,0000,0000,,夏休み最後の日を迎えた
Dialogue: 0,0:10:42.27,0:10:44.28,Default,,0000,0000,0000,,じゃあ 行くわね
Dialogue: 0,0:10:44.28,0:10:46.28,Default,,0000,0000,0000,,いろいろ 準備があるから
Dialogue: 0,0:10:46.28,0:10:48.28,Default,,0000,0000,0000,,あとは パイリくんと ゆっくり過ごしてね
Dialogue: 0,0:10:48.28,0:10:53.29,Default,,0000,0000,0000,,むぎゅ シズクと もっと
Dialogue: 0,0:10:48.28,0:10:53.29,Default,,0000,0000,0000,,一緒にいたいのに
Dialogue: 0,0:10:53.29,0:10:56.79,Default,,0000,0000,0000,,そんな顔しないの
Dialogue: 0,0:10:53.29,0:10:56.79,Default,,0000,0000,0000,,いっぱい遊んだでしょ?
Dialogue: 0,0:10:56.79,0:11:00.29,Default,,0000,0000,0000,,本当に楽しかったわ 羽依里くん
Dialogue: 0,0:11:00.29,0:11:02.63,Default,,0000,0000,0000,,静久 ありがと
Dialogue: 0,0:11:02.63,0:11:05.63,Default,,0000,0000,0000,,大好きよ 紬
Dialogue: 0,0:11:05.63,0:11:08.47,Default,,0000,0000,0000,,私もです シズク!
Dialogue: 0,0:11:08.47,0:11:13.31,Default,,0000,0000,0000,,泣いちゃだめ 約束よ
Dialogue: 0,0:11:13.31,0:11:15.31,Default,,0000,0000,0000,,はい!
Dialogue: 0,0:11:31.86,0:11:35.26,Default,,0000,0000,0000,,えっ 紬?
Dialogue: 0,0:11:35.26,0:11:38.10,Default,,0000,0000,0000,,紬!
Dialogue: 0,0:11:38.10,0:11:41.60,Default,,0000,0000,0000,,ハイリさん?
Dialogue: 0,0:11:38.10,0:11:41.60,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:41.60,0:11:44.00,Default,,0000,0000,0000,,どうかしたんですか?
Dialogue: 0,0:11:47.27,0:11:51.11,Default,,0000,0000,0000,,紬 好きって言ってくれないか
Dialogue: 0,0:11:51.11,0:11:55.28,Default,,0000,0000,0000,,むぎゅ
Dialogue: 0,0:11:51.11,0:11:55.28,Default,,0000,0000,0000,,紬の声 覚えていたいから
Dialogue: 0,0:11:55.28,0:11:59.29,Default,,0000,0000,0000,,私も 覚えてたいです
Dialogue: 0,0:11:59.29,0:12:03.29,Default,,0000,0000,0000,,うん 好きだよ 紬
Dialogue: 0,0:12:03.29,0:12:05.99,Default,,0000,0000,0000,,大好きです ハイリさん!
Dialogue: 0,0:12:22.98,0:12:26.48,Default,,0000,0000,0000,,そろそろ時間だな
Dialogue: 0,0:12:22.98,0:12:26.48,Default,,0000,0000,0000,,何か始まるんですか?
Dialogue: 0,0:12:26.48,0:12:29.65,Default,,0000,0000,0000,,さぁ 何だろ? 楽しみだな
Dialogue: 0,0:12:29.65,0:12:33.85,Default,,0000,0000,0000,,むぎゅ ハイリさん 意地悪です
Dialogue: 0,0:12:47.97,0:12:50.30,Default,,0000,0000,0000,,わぁ!
Dialogue: 0,0:12:59.65,0:13:01.81,Default,,0000,0000,0000,,すごいです
Dialogue: 0,0:13:01.81,0:13:04.15,Default,,0000,0000,0000,,今日は 紬の誕生日だ
Dialogue: 0,0:13:04.15,0:13:06.99,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:13:04.15,0:13:06.99,Default,,0000,0000,0000,,だから お祝いしなくちゃ
Dialogue: 0,0:13:06.99,0:13:10.82,Default,,0000,0000,0000,,一生分の バースデーケーキの ロウソクをともしてさ
Dialogue: 0,0:13:10.82,0:13:14.16,Default,,0000,0000,0000,,私の 誕生日
Dialogue: 0,0:13:14.16,0:13:18.66,Default,,0000,0000,0000,,でも こんなにいっぱいの ロウソク どうやって?
Dialogue: 0,0:13:18.66,0:13:20.67,Default,,0000,0000,0000,,少年団のみんなだよ
Dialogue: 0,0:13:20.67,0:13:23.50,Default,,0000,0000,0000,,皆さんが?
Dialogue: 0,0:13:20.67,0:13:23.50,Default,,0000,0000,0000,,紬を喜ばそうって
Dialogue: 0,0:13:23.50,0:13:26.67,Default,,0000,0000,0000,,静久のアイデアに みんなが協力してくれてさ
Dialogue: 0,0:13:26.67,0:13:29.84,Default,,0000,0000,0000,,パリングルスの空き容器を使って 作ったんだ
Dialogue: 0,0:13:29.84,0:13:34.45,Default,,0000,0000,0000,,フフ やっぱり パリングルスは ムテキです!
Dialogue: 0,0:13:57.97,0:14:02.64,Default,,0000,0000,0000,,皆さん すごくいい人です
Dialogue: 0,0:14:02.64,0:14:05.51,Default,,0000,0000,0000,,うん 最高の仲間たちだ
Dialogue: 0,0:14:08.15,0:14:12.99,Default,,0000,0000,0000,,ハイリさん ちょっと 昔の話 してもいいですか?
Dialogue: 0,0:14:12.99,0:14:17.32,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:14:12.99,0:14:17.32,Default,,0000,0000,0000,,ツムギちゃんは 私のお友達です
Dialogue: 0,0:14:17.32,0:14:19.79,Default,,0000,0000,0000,,あの鼻歌も
Dialogue: 0,0:14:19.79,0:14:23.13,Default,,0000,0000,0000,,ツムギちゃんが 海の向こうの お家にいるとき
Dialogue: 0,0:14:23.13,0:14:25.80,Default,,0000,0000,0000,,よく歌っていました
Dialogue: 0,0:14:25.80,0:14:29.30,Default,,0000,0000,0000,,こっちに来てからは お友達もできなくて
Dialogue: 0,0:14:29.30,0:14:31.64,Default,,0000,0000,0000,,あまり歌っていませんでした
Dialogue: 0,0:14:31.64,0:14:35.74,Default,,0000,0000,0000,,お友達は ぬいぐるみだけだったんです
Dialogue: 0,0:14:35.74,0:14:38.91,Default,,0000,0000,0000,,でも ある日 加藤さんという人と
Dialogue: 0,0:14:38.91,0:14:42.92,Default,,0000,0000,0000,,お友達になったと うれしそうに お話ししてくれました
Dialogue: 0,0:14:42.92,0:14:49.09,Default,,0000,0000,0000,,好きな人もできて その人と一緒に
Dialogue: 0,0:14:42.92,0:14:49.09,Default,,0000,0000,0000,,島を出ていくことにしました
Dialogue: 0,0:14:49.09,0:14:55.79,Default,,0000,0000,0000,,でも ツムギちゃんは
Dialogue: 0,0:14:49.09,0:14:55.79,Default,,0000,0000,0000,,いなくなってしまいました
Dialogue: 0,0:15:02.60,0:15:06.11,Default,,0000,0000,0000,,でも ツムギちゃんは きっと帰ってきます
Dialogue: 0,0:15:06.11,0:15:09.28,Default,,0000,0000,0000,,それまで 私が
Dialogue: 0,0:15:09.28,0:15:12.95,Default,,0000,0000,0000,,ツムギちゃんの代わりを しようと思いました
Dialogue: 0,0:15:12.95,0:15:17.05,Default,,0000,0000,0000,,ツムギちゃんを 忘れないでくださいって
Dialogue: 0,0:15:24.29,0:15:26.79,Default,,0000,0000,0000,,いなくなった ツムギちゃんを探しながら
Dialogue: 0,0:15:26.79,0:15:29.96,Default,,0000,0000,0000,,「私を知りませんか」って
Dialogue: 0,0:15:29.96,0:15:34.93,Default,,0000,0000,0000,,でも ツムギちゃんを 覚えている人は
Dialogue: 0,0:15:34.93,0:15:38.44,Default,,0000,0000,0000,,どんどん いなくなっていきました
Dialogue: 0,0:15:38.44,0:15:42.27,Default,,0000,0000,0000,,そんなある日 加藤さんがやってきました
Dialogue: 0,0:15:49.58,0:15:52.45,Default,,0000,0000,0000,,これからは 自分の やりたいことをやりなさいって
Dialogue: 0,0:15:52.45,0:15:55.25,Default,,0000,0000,0000,,言ってくれました
Dialogue: 0,0:15:55.25,0:15:58.09,Default,,0000,0000,0000,,やりたいこと
Dialogue: 0,0:15:58.09,0:16:03.26,Default,,0000,0000,0000,,でも 自分が何をやりたいか
Dialogue: 0,0:15:58.09,0:16:03.26,Default,,0000,0000,0000,,わかりませんでした
Dialogue: 0,0:16:03.26,0:16:07.93,Default,,0000,0000,0000,,だから とりあえず 迷子になった ツムギちゃんが
Dialogue: 0,0:16:07.93,0:16:09.94,Default,,0000,0000,0000,,いつ戻ってきてもいいように
Dialogue: 0,0:16:09.94,0:16:13.27,Default,,0000,0000,0000,,お友達を作ろうと思いました
Dialogue: 0,0:16:13.27,0:16:16.78,Default,,0000,0000,0000,,私が ここからいなくなるまでに
Dialogue: 0,0:16:16.78,0:16:19.45,Default,,0000,0000,0000,,すると 出会いがありました
Dialogue: 0,0:16:19.45,0:16:22.95,Default,,0000,0000,0000,,その人は ぬいぐるみを褒めてくれました
Dialogue: 0,0:16:22.95,0:16:26.29,Default,,0000,0000,0000,,そんな小さなきっかけから
Dialogue: 0,0:16:26.29,0:16:30.29,Default,,0000,0000,0000,,シズクというお友達ができました
Dialogue: 0,0:16:30.29,0:16:34.73,Default,,0000,0000,0000,,そして ハイリさんに出会いました
Dialogue: 0,0:16:34.73,0:16:38.40,Default,,0000,0000,0000,,好きになりました
Dialogue: 0,0:16:34.73,0:16:38.40,Default,,0000,0000,0000,,ツムギちゃんのためじゃありません
Dialogue: 0,0:16:38.40,0:16:43.07,Default,,0000,0000,0000,,私の 私だけの恋です
Dialogue: 0,0:16:43.07,0:16:46.74,Default,,0000,0000,0000,,お友達も いっぱいできました
Dialogue: 0,0:16:46.74,0:16:49.41,Default,,0000,0000,0000,,幸せな気持ちになれました
Dialogue: 0,0:16:49.41,0:16:52.91,Default,,0000,0000,0000,,今は もう やりたいことだらけです
Dialogue: 0,0:16:52.91,0:16:55.08,Default,,0000,0000,0000,,うん
Dialogue: 0,0:16:55.08,0:16:58.58,Default,,0000,0000,0000,,この先も すごく楽しみです
Dialogue: 0,0:16:58.58,0:17:02.42,Default,,0000,0000,0000,,きっと 冬になったら雪が降ります
Dialogue: 0,0:17:02.42,0:17:04.76,Default,,0000,0000,0000,,そしたら 大ピンチです
Dialogue: 0,0:17:04.76,0:17:07.26,Default,,0000,0000,0000,,雪のせいで ドアが開かなくて
Dialogue: 0,0:17:07.26,0:17:11.60,Default,,0000,0000,0000,,ハイリさんと シズクのおかげで 九死に一生です
Dialogue: 0,0:17:11.60,0:17:15.10,Default,,0000,0000,0000,,命の恩人です
Dialogue: 0,0:17:11.60,0:17:15.10,Default,,0000,0000,0000,,大げさだな
Dialogue: 0,0:17:15.10,0:17:17.94,Default,,0000,0000,0000,,夏になったら海で泳いで
Dialogue: 0,0:17:17.94,0:17:20.94,Default,,0000,0000,0000,,浴衣を着て お祭りにも行きます
Dialogue: 0,0:17:20.94,0:17:25.94,Default,,0000,0000,0000,,時々 ケンカもして
Dialogue: 0,0:17:20.94,0:17:25.94,Default,,0000,0000,0000,,でも すぐに仲直りして
Dialogue: 0,0:17:25.94,0:17:30.28,Default,,0000,0000,0000,,やっぱり 3人がいいなぁ なんて 言ったりします
Dialogue: 0,0:17:30.28,0:17:33.42,Default,,0000,0000,0000,,うん
Dialogue: 0,0:17:30.28,0:17:33.42,Default,,0000,0000,0000,,楽しみですね
Dialogue: 0,0:17:33.42,0:17:35.42,Default,,0000,0000,0000,,うん
Dialogue: 0,0:17:35.42,0:17:39.43,Default,,0000,0000,0000,,今日も楽しいです
Dialogue: 0,0:17:35.42,0:17:39.43,Default,,0000,0000,0000,,うん
Dialogue: 0,0:17:39.43,0:17:44.26,Default,,0000,0000,0000,,明日もあさっても ずっと ずっと楽しいです
Dialogue: 0,0:17:44.26,0:17:46.27,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:17:46.27,0:17:51.07,Default,,0000,0000,0000,,シズクがいますし シロハさんもいます
Dialogue: 0,0:17:51.07,0:17:54.41,Default,,0000,0000,0000,,アオさんがいて ノムラさんも ミタニさんも
Dialogue: 0,0:17:54.41,0:17:58.51,Default,,0000,0000,0000,,カノーさんもいます
Dialogue: 0,0:17:54.41,0:17:58.51,Default,,0000,0000,0000,,毎日 絶対 楽しいです
Dialogue: 0,0:18:01.25,0:18:04.75,Default,,0000,0000,0000,,だから
Dialogue: 0,0:18:04.75,0:18:06.75,Default,,0000,0000,0000,,泣かないで
Dialogue: 0,0:18:06.75,0:18:11.46,Default,,0000,0000,0000,,ごめん
Dialogue: 0,0:18:06.75,0:18:11.46,Default,,0000,0000,0000,,でも そこに キミがいない
Dialogue: 0,0:18:17.76,0:18:21.60,Default,,0000,0000,0000,,ハイリさん 私 幸せです
Dialogue: 0,0:18:21.60,0:18:25.44,Default,,0000,0000,0000,,皆さんと出会えて シズクと出会えて
Dialogue: 0,0:18:25.44,0:18:29.27,Default,,0000,0000,0000,,ハイリさんと出会えて
Dialogue: 0,0:18:29.27,0:18:33.38,Default,,0000,0000,0000,,うん 俺も幸せだ
Dialogue: 0,0:18:33.38,0:18:36.98,Default,,0000,0000,0000,,だから 楽しく ねっ!
Dialogue: 0,0:18:39.38,0:18:41.39,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:18:43.39,0:18:45.39,Default,,0000,0000,0000,,むぎぃ!
Dialogue: 0,0:18:47.73,0:18:53.07,Default,,0000,0000,0000,,本当に すてきな夏休みでした
Dialogue: 0,0:18:53.07,0:18:59.24,Default,,0000,0000,0000,,「私は歌います 私を探して」
Dialogue: 0,0:18:59.24,0:19:02.74,Default,,0000,0000,0000,,「むむぎゅぎゅぎゅぎゅぎゅ むむぎゅぎゅぎゅぎゅぎゅ」
Dialogue: 0,0:19:02.74,0:19:05.78,Default,,0000,0000,0000,,「むむぎゅぎゅむぎゅぎゅぎゅ」
Dialogue: 0,0:19:05.78,0:19:12.45,Default,,0000,0000,0000,,「灯台で歌います
Dialogue: 0,0:19:05.78,0:19:12.45,Default,,0000,0000,0000,,見つけてもらうため」
Dialogue: 0,0:19:12.45,0:19:15.62,Default,,0000,0000,0000,,「むむぎゅぎゅぎゅぎゅぎゅ むむぎゅぎゅぎゅぎゅぎゅ」
Dialogue: 0,0:19:15.62,0:19:18.46,Default,,0000,0000,0000,,「むむぎゅぎゅむぎゅぎゅぎゅ」
Dialogue: 0,0:19:18.46,0:19:24.80,Default,,0000,0000,0000,,「素材を集めます
Dialogue: 0,0:19:18.46,0:19:24.80,Default,,0000,0000,0000,,頼もしい鳥さん」
Dialogue: 0,0:19:24.80,0:19:28.13,Default,,0000,0000,0000,,「むむぎゅぎゅぎゅぎゅぎゅ むむぎゅぎゅぎゅぎゅぎゅ」
Dialogue: 0,0:19:28.13,0:19:30.97,Default,,0000,0000,0000,,「むむぎゅぎゅむぎゅぎゅぎゅ」
Dialogue: 0,0:19:30.97,0:19:37.88,Default,,0000,0000,0000,,「私と鳥さんと牛さんで水遊び」
Dialogue: 0,0:19:37.88,0:19:41.21,Default,,0000,0000,0000,,「むむぎゅぎゅぎゅぎゅぎゅ むむぎゅぎゅぎゅぎゅぎゅ」
Dialogue: 0,0:19:41.21,0:19:43.88,Default,,0000,0000,0000,,「むむぎゅぎゅむぎゅぎゅぎゅ」
Dialogue: 0,0:19:43.88,0:19:50.72,Default,,0000,0000,0000,,「鳥さんと牛さんと
Dialogue: 0,0:19:43.88,0:19:50.72,Default,,0000,0000,0000,,この夏は一緒です」
Dialogue: 0,0:19:50.72,0:19:53.89,Default,,0000,0000,0000,,「むむぎゅぎゅぎゅぎゅぎゅ むむぎゅぎゅぎゅぎゅぎゅ」
Dialogue: 0,0:19:53.89,0:19:57.06,Default,,0000,0000,0000,,「むむぎゅぎゅむぎゅぎゅぎゅ」
Dialogue: 0,0:19:57.06,0:20:03.40,Default,,0000,0000,0000,,鳥さんと手を繋ぎ
Dialogue: 0,0:19:57.06,0:20:03.40,Default,,0000,0000,0000,,私たち恋人です」
Dialogue: 0,0:20:03.40,0:20:06.57,Default,,0000,0000,0000,,「むむぎゅぎゅぎゅぎゅぎゅ むむぎゅぎゅぎゅぎゅぎゅ」
Dialogue: 0,0:20:06.57,0:20:10.08,Default,,0000,0000,0000,,「むむぎゅぎゅむぎゅぎゅぎゅ」
Dialogue: 0,0:20:15.91,0:20:22.59,Default,,0000,0000,0000,,「大好きな鳥さん
Dialogue: 0,0:20:15.91,0:20:22.59,Default,,0000,0000,0000,,大好きな牛さん」
Dialogue: 0,0:20:22.59,0:20:25.76,Default,,0000,0000,0000,,「むむぎゅぎゅぎゅぎゅぎゅ むむぎゅぎゅぎゅぎゅぎゅ」
Dialogue: 0,0:20:25.76,0:20:28.93,Default,,0000,0000,0000,,「むむぎゅぎゅむぎゅぎゅぎゅ」
Dialogue: 0,0:20:28.93,0:20:35.60,Default,,0000,0000,0000,,「そらいろのリボン わたしの宝物」
Dialogue: 0,0:20:35.60,0:20:38.44,Default,,0000,0000,0000,,「むむぎゅぎゅぎゅぎゅぎゅ むむぎゅぎゅぎゅぎゅぎゅ」
Dialogue: 0,0:20:38.44,0:20:42.11,Default,,0000,0000,0000,,「むむぎゅぎゅむぎゅぎゅぎゅ」
Dialogue: 0,0:20:42.11,0:20:48.11,Default,,0000,0000,0000,,「この夏と灯台と
Dialogue: 0,0:20:42.11,0:20:48.11,Default,,0000,0000,0000,,この島を忘れない」
Dialogue: 0,0:20:48.11,0:20:51.45,Default,,0000,0000,0000,,「むむぎゅぎゅぎゅぎゅぎゅ むむぎゅぎゅぎゅぎゅぎゅ」
Dialogue: 0,0:20:51.45,0:20:54.62,Default,,0000,0000,0000,,「むむぎゅぎゅむぎゅぎゅぎゅ」
Dialogue: 0,0:21:26.15,0:21:28.15,Default,,0000,0000,0000,,紬
Dialogue: 0,0:21:34.96,0:21:37.93,Default,,0000,0000,0000,,誕生日 おめでとう
Dialogue: 0,0:21:46.64,0:21:48.61,Default,,0000,0000,0000,,いい夏休みだったな
Dialogue: 0,0:21:52.48,0:21:57.65,Default,,0000,0000,0000,,私 思うの 紬って
Dialogue: 0,0:21:52.48,0:21:57.65,Default,,0000,0000,0000,,夏休みそのものだったなって
Dialogue: 0,0:21:57.65,0:21:59.65,Default,,0000,0000,0000,,うん
Dialogue: 0,0:21:59.65,0:22:03.16,Default,,0000,0000,0000,,知らない場所で 初めての人に出会って
Dialogue: 0,0:22:03.16,0:22:08.16,Default,,0000,0000,0000,,仲よくなって いつまでも 時間があるような感じがしてて
Dialogue: 0,0:22:08.16,0:22:11.50,Default,,0000,0000,0000,,最後には 時間がないことを嘆いて
Dialogue: 0,0:22:11.50,0:22:14.50,Default,,0000,0000,0000,,友達とのお別れを惜しんで
Dialogue: 0,0:22:14.50,0:22:17.34,Default,,0000,0000,0000,,あの子は 夏休みだったの
Dialogue: 0,0:22:17.34,0:22:20.34,Default,,0000,0000,0000,,ああ 俺もそうだった
Dialogue: 0,0:22:20.34,0:22:23.84,Default,,0000,0000,0000,,だからね
Dialogue: 0,0:22:20.34,0:22:23.84,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:22:23.84,0:22:27.68,Default,,0000,0000,0000,,この歌
Dialogue: 0,0:22:27.68,0:22:30.02,Default,,0000,0000,0000,,なぁに? その歌
Dialogue: 0,0:22:30.02,0:22:34.75,Default,,0000,0000,0000,,時々 ラジオ体操に来てた ネコのお姉さんが歌ってたの
Dialogue: 0,0:22:34.75,0:22:38.59,Default,,0000,0000,0000,,私 お友達になったんだよ
Dialogue: 0,0:22:34.75,0:22:38.59,Default,,0000,0000,0000,,へぇ
Dialogue: 0,0:22:38.59,0:22:41.59,Default,,0000,0000,0000,,じゃあ 来年も会えるといいわね
Dialogue: 0,0:22:38.59,0:22:41.59,Default,,0000,0000,0000,,うん!
Dialogue: 0,0:22:41.59,0:22:46.26,Default,,0000,0000,0000,,来年 か
Dialogue: 0,0:22:46.26,0:22:51.27,Default,,0000,0000,0000,,そっか そうだよな
Dialogue: 0,0:22:46.26,0:22:51.27,Default,,0000,0000,0000,,ええ
Dialogue: 0,0:22:51.27,0:22:55.61,Default,,0000,0000,0000,,また 夏休みは やってくるもの
Dialogue: 0,0:23:07.79,0:23:09.79,Default,,0000,0000,0000,,わたあめさん
Dialogue: 0,0:23:09.79,0:23:13.63,Default,,0000,0000,0000,,またな 紬
Dialogue: 0,0:23:38.95,0:23:42.62,Default,,0000,0000,0000,,さよなら また ねっ
Dialogue: 0,0:24:11.32,0:24:13.29,Default,,0000,0000,0000,,ただいま
Dialogue: 0,0:24:15.65,0:24:19.83,Default,,0000,0000,0000,,おかえりなさい!
