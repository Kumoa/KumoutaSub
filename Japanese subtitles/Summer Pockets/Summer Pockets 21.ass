Dialogue: 0,0:00:35.10,0:00:38.44,Default,,0000,0000,0000,,うみ!
Dialogue: 0,0:00:35.10,0:00:38.44,Default,,0000,0000,0000,,うみちゃん!
Dialogue: 0,0:00:38.44,0:00:44.44,Default,,0000,0000,0000,,あっ お父さん!
Dialogue: 0,0:00:38.44,0:00:44.44,Default,,0000,0000,0000,,お母さん!
Dialogue: 0,0:00:44.44,0:00:48.45,Default,,0000,0000,0000,,うみ! うみ!!
Dialogue: 0,0:00:44.44,0:00:48.45,Default,,0000,0000,0000,,うみちゃん!
Dialogue: 0,0:00:48.45,0:00:52.12,Default,,0000,0000,0000,,大丈夫か うみ!
Dialogue: 0,0:00:52.12,0:00:54.12,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:00:54.12,0:00:57.12,Default,,0000,0000,0000,,どうしても お母さんを見たくて
Dialogue: 0,0:00:57.12,0:01:00.83,Default,,0000,0000,0000,,いいんだ 謝らなくていい
Dialogue: 0,0:00:57.12,0:01:00.83,Default,,0000,0000,0000,,こっち!
Dialogue: 0,0:01:05.80,0:01:08.40,Default,,0000,0000,0000,,もう少し!
Dialogue: 0,0:01:05.80,0:01:08.40,Default,,0000,0000,0000,,頑張れ!
Dialogue: 0,0:01:10.47,0:01:13.14,Default,,0000,0000,0000,,あっ キャッ!
Dialogue: 0,0:01:13.14,0:01:15.14,Default,,0000,0000,0000,,うみちゃん!?
Dialogue: 0,0:01:13.14,0:01:15.14,Default,,0000,0000,0000,,うみ!?
Dialogue: 0,0:03:01.11,0:03:04.45,Default,,0000,0000,0000,,どこだ うみ!?
Dialogue: 0,0:03:30.81,0:03:32.75,Default,,0000,0000,0000,,しろは!
Dialogue: 0,0:03:52.10,0:03:56.77,Default,,0000,0000,0000,,うみ 寝た?
Dialogue: 0,0:03:52.10,0:03:56.77,Default,,0000,0000,0000,,うん もうぐっすり
Dialogue: 0,0:03:56.77,0:04:00.11,Default,,0000,0000,0000,,しばらく 鏡子さんが見ててくれるって
Dialogue: 0,0:04:00.11,0:04:02.11,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:04:02.11,0:04:06.11,Default,,0000,0000,0000,,ホントによかった
Dialogue: 0,0:04:02.11,0:04:06.11,Default,,0000,0000,0000,,うん そうだな
Dialogue: 0,0:04:06.11,0:04:09.78,Default,,0000,0000,0000,,しろはも無事だった
Dialogue: 0,0:04:06.11,0:04:09.78,Default,,0000,0000,0000,,えっ? 私?
Dialogue: 0,0:04:09.78,0:04:13.12,Default,,0000,0000,0000,,もともと しろはが溺れる って未来を変えるのが
Dialogue: 0,0:04:13.12,0:04:16.46,Default,,0000,0000,0000,,目的だったじゃないか
Dialogue: 0,0:04:13.12,0:04:16.46,Default,,0000,0000,0000,,そうだった
Dialogue: 0,0:04:16.46,0:04:20.46,Default,,0000,0000,0000,,うみちゃんが 大変なことになったから
Dialogue: 0,0:04:20.46,0:04:24.80,Default,,0000,0000,0000,,やっぱり 私と一緒にいたから 2人とも危ない目に
Dialogue: 0,0:04:24.80,0:04:27.13,Default,,0000,0000,0000,,違うよ
Dialogue: 0,0:04:27.13,0:04:31.14,Default,,0000,0000,0000,,俺と うみは しろはを助けたかったんだ
Dialogue: 0,0:04:31.14,0:04:34.07,Default,,0000,0000,0000,,だから 気に病むことじゃない
Dialogue: 0,0:04:31.14,0:04:34.07,Default,,0000,0000,0000,,でも
Dialogue: 0,0:04:34.07,0:04:38.75,Default,,0000,0000,0000,,しろはのさ 未来を見てしまう力は本当なんだ
Dialogue: 0,0:04:38.75,0:04:40.75,Default,,0000,0000,0000,,俺も見たんだから
Dialogue: 0,0:04:40.75,0:04:45.08,Default,,0000,0000,0000,,海の中から見上げた 海面に浮かんでる赤い光
Dialogue: 0,0:04:45.08,0:04:49.42,Default,,0000,0000,0000,,あらかじめ しろはから 聞いていたから 落ち着けた
Dialogue: 0,0:04:49.42,0:04:54.09,Default,,0000,0000,0000,,そうだけど 未来が 変えられたわけじゃないし
Dialogue: 0,0:04:54.09,0:04:56.43,Default,,0000,0000,0000,,変える必要は ないんじゃないかな
Dialogue: 0,0:04:56.43,0:04:59.10,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:04:56.43,0:04:59.10,Default,,0000,0000,0000,,見てしまった未来を
Dialogue: 0,0:04:59.10,0:05:02.10,Default,,0000,0000,0000,,結果として受け取らなければ いいと思うんだ
Dialogue: 0,0:05:02.10,0:05:06.11,Default,,0000,0000,0000,,しろはが見た未来は 単なるきっかけなんだよ
Dialogue: 0,0:05:06.11,0:05:08.11,Default,,0000,0000,0000,,その更に先がある
Dialogue: 0,0:05:08.11,0:05:11.44,Default,,0000,0000,0000,,きっとそれは とてもいい未来になるんだ
Dialogue: 0,0:05:11.44,0:05:16.45,Default,,0000,0000,0000,,そのために 少しつらかったり
Dialogue: 0,0:05:11.44,0:05:16.45,Default,,0000,0000,0000,,苦しい思いをしてしまう
Dialogue: 0,0:05:16.45,0:05:19.12,Default,,0000,0000,0000,,っていうのは どうだろう
Dialogue: 0,0:05:19.12,0:05:23.79,Default,,0000,0000,0000,,そんな考え方
Dialogue: 0,0:05:19.12,0:05:23.79,Default,,0000,0000,0000,,したことなかった
Dialogue: 0,0:05:23.79,0:05:26.13,Default,,0000,0000,0000,,しろはは優しすぎるから
Dialogue: 0,0:05:26.13,0:05:30.13,Default,,0000,0000,0000,,人に迷惑をかけないように ってことばかり考えてるから
Dialogue: 0,0:05:30.13,0:05:34.07,Default,,0000,0000,0000,,だから ぼっちになってたんだよ
Dialogue: 0,0:05:34.07,0:05:38.07,Default,,0000,0000,0000,,うぅ ぼっちって言うな
Dialogue: 0,0:05:38.07,0:05:40.07,Default,,0000,0000,0000,,もう ぼっちじゃないけどさ
Dialogue: 0,0:05:40.07,0:05:45.08,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:05:40.07,0:05:45.08,Default,,0000,0000,0000,,俺がもう ぼっちにさせないから
Dialogue: 0,0:05:45.08,0:05:48.08,Default,,0000,0000,0000,,羽依里は すごいね
Dialogue: 0,0:05:48.08,0:05:53.42,Default,,0000,0000,0000,,未来は結果じゃなくて
Dialogue: 0,0:05:48.08,0:05:53.42,Default,,0000,0000,0000,,更に先の未来の過程
Dialogue: 0,0:05:53.42,0:05:58.42,Default,,0000,0000,0000,,うん そう考えると 気持ちが楽になる
Dialogue: 0,0:05:58.42,0:06:00.43,Default,,0000,0000,0000,,ありがとう
Dialogue: 0,0:06:02.76,0:06:06.43,Default,,0000,0000,0000,,いや 少しは役に立ててよかった
Dialogue: 0,0:06:06.43,0:06:12.11,Default,,0000,0000,0000,,海で溺れて苦しかったのも
Dialogue: 0,0:06:06.43,0:06:12.11,Default,,0000,0000,0000,,その先のいいことへの過程
Dialogue: 0,0:06:12.11,0:06:15.78,Default,,0000,0000,0000,,その先の いい こと
Dialogue: 0,0:06:15.78,0:06:21.45,Default,,0000,0000,0000,,ん? どうした しろは?
Dialogue: 0,0:06:15.78,0:06:21.45,Default,,0000,0000,0000,,あ あの 海の中で
Dialogue: 0,0:06:21.45,0:06:27.45,Default,,0000,0000,0000,,どさくさ紛れに キ キ キ
Dialogue: 0,0:06:21.45,0:06:27.45,Default,,0000,0000,0000,,き?
Dialogue: 0,0:06:27.45,0:06:30.86,Default,,0000,0000,0000,,キス したよね
Dialogue: 0,0:06:33.39,0:06:39.40,Default,,0000,0000,0000,,あっ あれは!
Dialogue: 0,0:06:33.39,0:06:39.40,Default,,0000,0000,0000,,キ キキ キス じゃなくて
Dialogue: 0,0:06:39.40,0:06:43.74,Default,,0000,0000,0000,,人工呼吸っていうか
Dialogue: 0,0:06:39.40,0:06:43.74,Default,,0000,0000,0000,,緊急処置というか
Dialogue: 0,0:06:43.74,0:06:47.41,Default,,0000,0000,0000,,じゃ じゃあ 数に数えなくて大丈夫?
Dialogue: 0,0:06:47.41,0:06:49.41,Default,,0000,0000,0000,,も もちろん
Dialogue: 0,0:06:49.41,0:06:53.08,Default,,0000,0000,0000,,じゃあ 私のファーストキスは まだということで
Dialogue: 0,0:06:53.08,0:06:55.42,Default,,0000,0000,0000,,俺もまだということで
Dialogue: 0,0:06:55.42,0:06:58.42,Default,,0000,0000,0000,,う うん
Dialogue: 0,0:07:00.75,0:07:04.09,Default,,0000,0000,0000,,今 していい?
Dialogue: 0,0:07:04.09,0:07:06.43,Default,,0000,0000,0000,,何を?
Dialogue: 0,0:07:06.43,0:07:08.76,Default,,0000,0000,0000,,ファーストキス
Dialogue: 0,0:07:08.76,0:07:12.77,Default,,0000,0000,0000,,ヒエッ!!
Dialogue: 0,0:07:08.76,0:07:12.77,Default,,0000,0000,0000,,ダ ダメか?
Dialogue: 0,0:07:12.77,0:07:15.77,Default,,0000,0000,0000,,い いいけど
Dialogue: 0,0:07:15.77,0:07:20.37,Default,,0000,0000,0000,,うん いいけど
Dialogue: 0,0:07:15.77,0:07:20.37,Default,,0000,0000,0000,,けど?
Dialogue: 0,0:07:25.78,0:07:29.45,Default,,0000,0000,0000,,いい よ
Dialogue: 0,0:07:29.45,0:07:34.39,Default,,0000,0000,0000,,じゃ じゃあ 失礼します
Dialogue: 0,0:08:09.42,0:08:11.42,Default,,0000,0000,0000,,ただいま
Dialogue: 0,0:08:11.42,0:08:14.43,Default,,0000,0000,0000,,おかえり
Dialogue: 0,0:08:11.42,0:08:14.43,Default,,0000,0000,0000,,お母さん!
Dialogue: 0,0:08:14.43,0:08:17.43,Default,,0000,0000,0000,,来てたのか
Dialogue: 0,0:08:17.43,0:08:19.43,Default,,0000,0000,0000,,うん
Dialogue: 0,0:08:19.43,0:08:23.10,Default,,0000,0000,0000,,うみちゃんは 大丈夫?
Dialogue: 0,0:08:19.43,0:08:23.10,Default,,0000,0000,0000,,元気だ
Dialogue: 0,0:08:23.10,0:08:25.77,Default,,0000,0000,0000,,今もラジオ体操に 行ってきたところだ
Dialogue: 0,0:08:25.77,0:08:28.37,Default,,0000,0000,0000,,そう よかった
Dialogue: 0,0:08:33.05,0:08:35.05,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:08:35.05,0:08:37.72,Default,,0000,0000,0000,,わぁ しろはちゃん すごいわねぇ
Dialogue: 0,0:08:37.72,0:08:39.72,Default,,0000,0000,0000,,いえ
Dialogue: 0,0:08:37.72,0:08:39.72,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:08:42.39,0:08:45.73,Default,,0000,0000,0000,,うみ 握り箸は お行儀が悪いぞ
Dialogue: 0,0:08:45.73,0:08:48.06,Default,,0000,0000,0000,,うみゅ?
Dialogue: 0,0:08:45.73,0:08:48.06,Default,,0000,0000,0000,,あら?
Dialogue: 0,0:08:48.06,0:08:50.40,Default,,0000,0000,0000,,ちゃんとお箸を使えていたのに
Dialogue: 0,0:08:50.40,0:08:54.80,Default,,0000,0000,0000,,どうしたのかしら?
Dialogue: 0,0:08:50.40,0:08:54.80,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:08:59.41,0:09:01.41,Default,,0000,0000,0000,,う
Dialogue: 0,0:09:01.41,0:09:04.74,Default,,0000,0000,0000,,スプーン持ってくるわね
Dialogue: 0,0:09:01.41,0:09:04.74,Default,,0000,0000,0000,,おかしいな
Dialogue: 0,0:09:04.74,0:09:07.75,Default,,0000,0000,0000,,もしかして 昨日の後遺症?
Dialogue: 0,0:09:07.75,0:09:10.75,Default,,0000,0000,0000,,お医者さんは 大丈夫 って言っていたんだけど
Dialogue: 0,0:09:10.75,0:09:13.42,Default,,0000,0000,0000,,うみ どこか痛いところとか ないか?
Dialogue: 0,0:09:13.42,0:09:15.42,Default,,0000,0000,0000,,痛くない
Dialogue: 0,0:09:15.42,0:09:17.82,Default,,0000,0000,0000,,ケガじゃないみたい
Dialogue: 0,0:09:26.43,0:09:28.43,Default,,0000,0000,0000,,ん
Dialogue: 0,0:09:28.43,0:09:32.37,Default,,0000,0000,0000,,もっと ちゃんと角を折らないと まっすぐ飛ばないぞ?
Dialogue: 0,0:09:32.37,0:09:34.37,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:09:42.72,0:09:44.72,Default,,0000,0000,0000,,うみゅ
Dialogue: 0,0:09:44.72,0:09:50.06,Default,,0000,0000,0000,,一緒に作ろう
Dialogue: 0,0:09:44.72,0:09:50.06,Default,,0000,0000,0000,,きれいな折り紙
Dialogue: 0,0:09:50.06,0:09:52.06,Default,,0000,0000,0000,,いけ!
Dialogue: 0,0:09:52.06,0:09:55.06,Default,,0000,0000,0000,,うるとらぐれーとすーぱー おかーさんのいかり
Dialogue: 0,0:09:55.06,0:09:58.40,Default,,0000,0000,0000,,れべるまっくす!
Dialogue: 0,0:09:58.40,0:10:03.37,Default,,0000,0000,0000,,あんなに元気に 走り回ってるんだ 大丈夫だよな
Dialogue: 0,0:10:08.74,0:10:11.74,Default,,0000,0000,0000,,おかーさんに いたずらをして おこられた
Dialogue: 0,0:10:11.74,0:10:14.75,Default,,0000,0000,0000,,おとーさんは もっとたくさん おこられた
Dialogue: 0,0:10:14.75,0:10:17.42,Default,,0000,0000,0000,,でも とってもたのしかった
Dialogue: 0,0:10:17.42,0:10:21.75,Default,,0000,0000,0000,,いたずらといえば
Dialogue: 0,0:10:17.42,0:10:21.75,Default,,0000,0000,0000,,スカートめくりとか?
Dialogue: 0,0:10:21.75,0:10:23.76,Default,,0000,0000,0000,,な 何よ その目!?
Dialogue: 0,0:10:23.76,0:10:26.43,Default,,0000,0000,0000,,せっかくアイデアを 出してあげたのに!!
Dialogue: 0,0:10:26.43,0:10:30.76,Default,,0000,0000,0000,,いや 前から思ってはいたんだけどさ
Dialogue: 0,0:10:30.76,0:10:33.43,Default,,0000,0000,0000,,蒼って エロいよな
Dialogue: 0,0:10:33.43,0:10:36.10,Default,,0000,0000,0000,,エ エ エ エロちゃうわ!!
Dialogue: 0,0:10:36.10,0:10:38.10,Default,,0000,0000,0000,,スカートめくりか
Dialogue: 0,0:10:38.10,0:10:40.44,Default,,0000,0000,0000,,一理あるな
Dialogue: 0,0:10:38.10,0:10:40.44,Default,,0000,0000,0000,,なに!?
Dialogue: 0,0:10:40.44,0:10:43.44,Default,,0000,0000,0000,,ほら!!
Dialogue: 0,0:10:40.44,0:10:43.44,Default,,0000,0000,0000,,私がエロいわけじゃないじゃない!
Dialogue: 0,0:10:43.44,0:10:45.78,Default,,0000,0000,0000,,いや 蒼は エロい
Dialogue: 0,0:10:45.78,0:10:49.12,Default,,0000,0000,0000,,おそらく この島で いちばんの 耳年増だ
Dialogue: 0,0:10:49.12,0:10:51.12,Default,,0000,0000,0000,,うあ
Dialogue: 0,0:10:51.12,0:10:55.79,Default,,0000,0000,0000,,スカートめくりは単純明快で 何の前準備もなくできる いたずらだ
Dialogue: 0,0:10:55.79,0:10:58.46,Default,,0000,0000,0000,,俺の心の準備がいるんだが
Dialogue: 0,0:10:58.46,0:11:01.13,Default,,0000,0000,0000,,お父さん ふぁいお!
Dialogue: 0,0:11:01.13,0:11:05.46,Default,,0000,0000,0000,,電話で しろはに ここに来るよう連絡したわよ
Dialogue: 0,0:11:05.46,0:11:10.14,Default,,0000,0000,0000,,うみ 行くぞ
Dialogue: 0,0:11:05.46,0:11:10.14,Default,,0000,0000,0000,,あい
Dialogue: 0,0:11:10.14,0:11:13.47,Default,,0000,0000,0000,,あっ 蒼に呼ばれたんだけど
Dialogue: 0,0:11:13.47,0:11:15.81,Default,,0000,0000,0000,,お母さん
Dialogue: 0,0:11:15.81,0:11:17.81,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:11:17.81,0:11:19.81,Default,,0000,0000,0000,,たっ!!
Dialogue: 0,0:11:17.81,0:11:19.81,Default,,0000,0000,0000,,キャッ!
Dialogue: 0,0:11:19.81,0:11:22.42,Default,,0000,0000,0000,,夏の風がささやくがごとく
Dialogue: 0,0:11:28.82,0:11:32.83,Default,,0000,0000,0000,,おぉ!
Dialogue: 0,0:11:28.82,0:11:32.83,Default,,0000,0000,0000,,お
Dialogue: 0,0:11:34.76,0:11:38.10,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:38.10,0:11:43.44,Default,,0000,0000,0000,,えっと 怒ってる?
Dialogue: 0,0:11:38.10,0:11:43.44,Default,,0000,0000,0000,,怒ってないと思う?
Dialogue: 0,0:11:43.44,0:11:45.44,Default,,0000,0000,0000,,ううん
Dialogue: 0,0:11:45.44,0:11:47.44,Default,,0000,0000,0000,,記憶って
Dialogue: 0,0:11:45.44,0:11:47.44,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:11:47.44,0:11:49.44,Default,,0000,0000,0000,,殴ったら消えるんだっけ?
Dialogue: 0,0:11:49.44,0:11:52.45,Default,,0000,0000,0000,,あ あのですね
Dialogue: 0,0:11:49.44,0:11:52.45,Default,,0000,0000,0000,,こ こ これには理由
Dialogue: 0,0:11:52.45,0:11:54.45,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:11:57.45,0:12:01.85,Default,,0000,0000,0000,,この人に言われて やなことやらされちゃったね
Dialogue: 0,0:12:04.12,0:12:08.79,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:12:04.12,0:12:08.79,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:12:08.79,0:12:13.13,Default,,0000,0000,0000,,めっ だよ
Dialogue: 0,0:12:13.13,0:12:17.14,Default,,0000,0000,0000,,お母さんに 怒られた
Dialogue: 0,0:12:17.14,0:12:20.44,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:12:17.14,0:12:20.44,Default,,0000,0000,0000,,うん
Dialogue: 0,0:12:23.81,0:12:26.81,Default,,0000,0000,0000,,変態
Dialogue: 0,0:12:23.81,0:12:26.81,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:12:26.81,0:12:29.12,Default,,0000,0000,0000,,うえっ!!
Dialogue: 0,0:12:31.15,0:12:33.09,Default,,0000,0000,0000,,ブッハー!!
Dialogue: 0,0:12:33.09,0:12:36.09,Default,,0000,0000,0000,,パンツ嫌いな男なんて いねえんだよ!
Dialogue: 0,0:12:36.09,0:12:40.09,Default,,0000,0000,0000,,そうだそうだ!
Dialogue: 0,0:12:36.09,0:12:40.09,Default,,0000,0000,0000,,パンツなんてただの布だ!
Dialogue: 0,0:12:40.09,0:12:43.76,Default,,0000,0000,0000,,だよな!
Dialogue: 0,0:12:40.09,0:12:43.76,Default,,0000,0000,0000,,隠すこと自体おこがましいぜ!
Dialogue: 0,0:12:43.76,0:12:47.43,Default,,0000,0000,0000,,なんであの2人は ラムネでテンションを上げているんだ?
Dialogue: 0,0:12:47.43,0:12:51.44,Default,,0000,0000,0000,,普通に自業自得じゃない
Dialogue: 0,0:12:47.43,0:12:51.44,Default,,0000,0000,0000,,それはそうだけど
Dialogue: 0,0:12:51.44,0:12:54.11,Default,,0000,0000,0000,,スカートめくりの発案は お前じゃないか
Dialogue: 0,0:12:54.11,0:12:58.78,Default,,0000,0000,0000,,まったく だいたい どうして急に しろはに いたずらをしようと思った
Dialogue: 0,0:12:58.78,0:13:01.45,Default,,0000,0000,0000,,だから言ったじゃないか
Dialogue: 0,0:13:01.45,0:13:04.45,Default,,0000,0000,0000,,うみが描いた絵日記を かなえるためだって
Dialogue: 0,0:13:04.45,0:13:06.45,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:13:06.45,0:13:09.16,Default,,0000,0000,0000,,うみ?
Dialogue: 0,0:13:06.45,0:13:09.16,Default,,0000,0000,0000,,誰のことだ?
Dialogue: 0,0:13:13.79,0:13:17.46,Default,,0000,0000,0000,,おい
Dialogue: 0,0:13:17.46,0:13:21.47,Default,,0000,0000,0000,,あぁ そうだったわね!
Dialogue: 0,0:13:17.46,0:13:21.47,Default,,0000,0000,0000,,うみちゃんのためだったっけ
Dialogue: 0,0:13:21.47,0:13:25.47,Default,,0000,0000,0000,,でなければ あんなバカげたことに 協力するはずがない
Dialogue: 0,0:13:25.47,0:13:28.47,Default,,0000,0000,0000,,うみちゃん そうそう
Dialogue: 0,0:13:38.75,0:13:43.42,Default,,0000,0000,0000,,はい! 次の人
Dialogue: 0,0:13:38.75,0:13:43.42,Default,,0000,0000,0000,,わい!
Dialogue: 0,0:13:43.42,0:13:46.76,Default,,0000,0000,0000,,ん? 2枚あるぞ?
Dialogue: 0,0:13:43.42,0:13:46.76,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:13:46.76,0:13:49.36,Default,,0000,0000,0000,,かとう うみ
Dialogue: 0,0:13:51.43,0:13:53.43,Default,,0000,0000,0000,,あっ!!
Dialogue: 0,0:13:59.77,0:14:02.78,Default,,0000,0000,0000,,ハァ ハァ
Dialogue: 0,0:14:02.78,0:14:05.11,Default,,0000,0000,0000,,何やってんだ 俺は!
Dialogue: 0,0:14:05.11,0:14:08.11,Default,,0000,0000,0000,,うみ?
Dialogue: 0,0:14:05.11,0:14:08.11,Default,,0000,0000,0000,,誰のことだ?
Dialogue: 0,0:14:10.45,0:14:13.12,Default,,0000,0000,0000,,違う 違う違う!
Dialogue: 0,0:14:13.12,0:14:15.79,Default,,0000,0000,0000,,うみのことを 忘れてなんていない!
Dialogue: 0,0:14:15.79,0:14:20.46,Default,,0000,0000,0000,,うみ 朝だぞ?
Dialogue: 0,0:14:15.79,0:14:20.46,Default,,0000,0000,0000,,ラジオ体操 終わっちまったぞ
Dialogue: 0,0:14:20.46,0:14:27.13,Default,,0000,0000,0000,,んっ うぅ うみゅ
Dialogue: 0,0:14:27.13,0:14:30.80,Default,,0000,0000,0000,,お母さん どこ
Dialogue: 0,0:14:27.13,0:14:30.80,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:14:30.80,0:14:33.11,Default,,0000,0000,0000,,お母さん
Dialogue: 0,0:14:35.07,0:14:37.41,Default,,0000,0000,0000,,お母さん!
Dialogue: 0,0:14:37.41,0:14:42.08,Default,,0000,0000,0000,,うみ どうしたんだよ?
Dialogue: 0,0:14:37.41,0:14:42.08,Default,,0000,0000,0000,,お母さん! お母さん!
Dialogue: 0,0:14:45.08,0:14:48.75,Default,,0000,0000,0000,,フフ お母さん
Dialogue: 0,0:14:48.75,0:14:53.09,Default,,0000,0000,0000,,うん ここにいるよ
Dialogue: 0,0:14:48.75,0:14:53.09,Default,,0000,0000,0000,,んっ ぎゅ
Dialogue: 0,0:14:53.09,0:14:56.43,Default,,0000,0000,0000,,赤ちゃん返り かな
Dialogue: 0,0:14:56.43,0:14:59.77,Default,,0000,0000,0000,,やっぱり病院に 連れていったほうがいいのかな
Dialogue: 0,0:14:59.77,0:15:02.77,Default,,0000,0000,0000,,病院? やあ
Dialogue: 0,0:15:05.44,0:15:10.78,Default,,0000,0000,0000,,お父さんが
Dialogue: 0,0:15:05.44,0:15:10.78,Default,,0000,0000,0000,,うみのお父さんでよかった
Dialogue: 0,0:15:10.78,0:15:13.38,Default,,0000,0000,0000,,どうしたの?
Dialogue: 0,0:15:15.45,0:15:19.45,Default,,0000,0000,0000,,いや 何か大事なことを 忘れてる気がして
Dialogue: 0,0:15:19.45,0:15:21.45,Default,,0000,0000,0000,,大事なことって?
Dialogue: 0,0:15:21.45,0:15:25.79,Default,,0000,0000,0000,,それが わからないんだ
Dialogue: 0,0:15:25.79,0:15:29.13,Default,,0000,0000,0000,,8月24日 はれのちあめ
Dialogue: 0,0:15:29.13,0:15:31.13,Default,,0000,0000,0000,,きゅうに あめがふってきた
Dialogue: 0,0:15:31.13,0:15:33.07,Default,,0000,0000,0000,,おかーさんもびしょぬれ
Dialogue: 0,0:15:33.07,0:15:36.07,Default,,0000,0000,0000,,おかーさんといっしょに おふろに入った
Dialogue: 0,0:15:36.07,0:15:40.74,Default,,0000,0000,0000,,たのしかった うみちゃん かゆいところはない?
Dialogue: 0,0:15:40.74,0:15:42.74,Default,,0000,0000,0000,,もっとみぎ
Dialogue: 0,0:15:42.74,0:15:45.08,Default,,0000,0000,0000,,ここ?
Dialogue: 0,0:15:42.74,0:15:45.08,Default,,0000,0000,0000,,そこ
Dialogue: 0,0:15:47.41,0:15:50.42,Default,,0000,0000,0000,,ひゃ
Dialogue: 0,0:15:47.41,0:15:50.42,Default,,0000,0000,0000,,着替え 置いとくぞ
Dialogue: 0,0:15:50.42,0:15:53.42,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:15:50.42,0:15:53.42,Default,,0000,0000,0000,,う うん ありがとう
Dialogue: 0,0:15:53.42,0:15:57.09,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:15:53.42,0:15:57.09,Default,,0000,0000,0000,,お父さんも一緒に入ろ!
Dialogue: 0,0:15:57.09,0:16:00.43,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:15:57.09,0:16:00.43,Default,,0000,0000,0000,,いかだらん
Dialogue: 0,0:16:00.43,0:16:02.83,Default,,0000,0000,0000,,ダメだ! まだ早い!
Dialogue: 0,0:16:06.10,0:16:09.10,Default,,0000,0000,0000,,絵日記の天気 当たったな
Dialogue: 0,0:16:09.10,0:16:11.77,Default,,0000,0000,0000,,ホント 不思議ね
Dialogue: 0,0:16:09.10,0:16:11.77,Default,,0000,0000,0000,,うん
Dialogue: 0,0:16:11.77,0:16:15.77,Default,,0000,0000,0000,,なんだか この夏は ズルをした気がする
Dialogue: 0,0:16:15.77,0:16:17.78,Default,,0000,0000,0000,,ズルって?
Dialogue: 0,0:16:17.78,0:16:20.78,Default,,0000,0000,0000,,羽依里に言われて始めた お母さん役
Dialogue: 0,0:16:20.78,0:16:24.45,Default,,0000,0000,0000,,最初は それっぽく 振る舞ってればいいと思ってた
Dialogue: 0,0:16:24.45,0:16:27.45,Default,,0000,0000,0000,,そうすれば アイスが食べられるし
Dialogue: 0,0:16:27.45,0:16:30.46,Default,,0000,0000,0000,,冷凍庫に まだたっぷり確保しています
Dialogue: 0,0:16:30.46,0:16:32.39,Default,,0000,0000,0000,,うん 知ってる
Dialogue: 0,0:16:32.39,0:16:35.73,Default,,0000,0000,0000,,でも 途中から 全然減らなくなったんだけど?
Dialogue: 0,0:16:35.73,0:16:39.73,Default,,0000,0000,0000,,アイスを食べちゃったら 偽物になっちゃう気がして
Dialogue: 0,0:16:39.73,0:16:43.07,Default,,0000,0000,0000,,うみちゃんが 楽しい夏休みを過ごせるように
Dialogue: 0,0:16:43.07,0:16:48.74,Default,,0000,0000,0000,,子どものために
Dialogue: 0,0:16:43.07,0:16:48.74,Default,,0000,0000,0000,,普通なら体験できない夏だと思う
Dialogue: 0,0:16:48.74,0:16:51.41,Default,,0000,0000,0000,,お母さんになれる夏なんて
Dialogue: 0,0:16:51.41,0:16:55.75,Default,,0000,0000,0000,,いつか そういう夏が 来るんだろうけど
Dialogue: 0,0:16:55.75,0:16:58.75,Default,,0000,0000,0000,,ズルして 先にお母さんになっちゃった
Dialogue: 0,0:16:58.75,0:17:02.42,Default,,0000,0000,0000,,つまり しろはは 早く子どもが欲しい と?
Dialogue: 0,0:17:02.42,0:17:04.42,Default,,0000,0000,0000,,うん そうかも
Dialogue: 0,0:17:04.42,0:17:08.13,Default,,0000,0000,0000,,それが うみちゃんみたいな子だと うれしい
Dialogue: 0,0:17:12.10,0:17:14.10,Default,,0000,0000,0000,,羽依里?
Dialogue: 0,0:17:14.10,0:17:17.77,Default,,0000,0000,0000,,夏休みが終わったら 俺は もとの街に帰るけど
Dialogue: 0,0:17:17.77,0:17:21.77,Default,,0000,0000,0000,,でも 遠距離恋愛とか無理
Dialogue: 0,0:17:17.77,0:17:21.77,Default,,0000,0000,0000,,寂しくて死ぬ
Dialogue: 0,0:17:21.77,0:17:23.78,Default,,0000,0000,0000,,重い
Dialogue: 0,0:17:23.78,0:17:27.08,Default,,0000,0000,0000,,じゃあ しろはは 遠距離恋愛 平気か?
Dialogue: 0,0:17:29.45,0:17:31.45,Default,,0000,0000,0000,,心細くて死ぬ
Dialogue: 0,0:17:31.45,0:17:33.72,Default,,0000,0000,0000,,重っ
Dialogue: 0,0:17:31.45,0:17:33.72,Default,,0000,0000,0000,,呪うかも
Dialogue: 0,0:17:33.72,0:17:36.39,Default,,0000,0000,0000,,怖っ!!
Dialogue: 0,0:17:33.72,0:17:36.39,Default,,0000,0000,0000,,ことばのあやだし
Dialogue: 0,0:17:36.39,0:17:40.06,Default,,0000,0000,0000,,じゃあ 呪われないためにも 俺 頑張るよ
Dialogue: 0,0:17:40.06,0:17:44.73,Default,,0000,0000,0000,,頑張る?
Dialogue: 0,0:17:40.06,0:17:44.73,Default,,0000,0000,0000,,バイトして 金貯めて 毎週末ここに来る
Dialogue: 0,0:17:44.73,0:17:48.40,Default,,0000,0000,0000,,えっ!? そ そんなこと できるわけないし
Dialogue: 0,0:17:48.40,0:17:52.40,Default,,0000,0000,0000,,できるよ
Dialogue: 0,0:17:48.40,0:17:52.40,Default,,0000,0000,0000,,っていうか そうしたいんだ
Dialogue: 0,0:17:52.40,0:17:57.41,Default,,0000,0000,0000,,どうしよう むちゃくちゃなこと
Dialogue: 0,0:17:52.40,0:17:57.41,Default,,0000,0000,0000,,言ってるってわかってるのに
Dialogue: 0,0:17:57.41,0:18:00.41,Default,,0000,0000,0000,,すごく うれしい
Dialogue: 0,0:18:03.75,0:18:07.42,Default,,0000,0000,0000,,これってデート?
Dialogue: 0,0:18:03.75,0:18:07.42,Default,,0000,0000,0000,,そうなんじゃないの?
Dialogue: 0,0:18:07.42,0:18:10.42,Default,,0000,0000,0000,,そうか これがデートか
Dialogue: 0,0:18:10.42,0:18:14.76,Default,,0000,0000,0000,,初めてなの?
Dialogue: 0,0:18:10.42,0:18:14.76,Default,,0000,0000,0000,,男子高だからな
Dialogue: 0,0:18:14.76,0:18:17.43,Default,,0000,0000,0000,,私も デートって初めて
Dialogue: 0,0:18:17.43,0:18:21.13,Default,,0000,0000,0000,,ぼっちだったもんな
Dialogue: 0,0:18:17.43,0:18:21.13,Default,,0000,0000,0000,,ぼっちって言わないで
Dialogue: 0,0:18:26.77,0:18:28.77,Default,,0000,0000,0000,,なんで今まで しなかったんだろうな
Dialogue: 0,0:18:28.77,0:18:31.44,Default,,0000,0000,0000,,何を?
Dialogue: 0,0:18:28.77,0:18:31.44,Default,,0000,0000,0000,,デート
Dialogue: 0,0:18:31.44,0:18:36.05,Default,,0000,0000,0000,,さぁ? 恥ずかしかったから?
Dialogue: 0,0:18:31.44,0:18:36.05,Default,,0000,0000,0000,,なのかな
Dialogue: 0,0:18:36.05,0:18:39.38,Default,,0000,0000,0000,,結婚
Dialogue: 0,0:18:36.05,0:18:39.38,Default,,0000,0000,0000,,えっ!! 急に何?
Dialogue: 0,0:18:39.38,0:18:42.72,Default,,0000,0000,0000,,いや もしもの話くらい いいんじゃないかと思って
Dialogue: 0,0:18:42.72,0:18:47.06,Default,,0000,0000,0000,,もしもって?
Dialogue: 0,0:18:42.72,0:18:47.06,Default,,0000,0000,0000,,例えば そうだな
Dialogue: 0,0:18:47.06,0:18:50.06,Default,,0000,0000,0000,,俺たちに子どもができたら とか
Dialogue: 0,0:18:50.06,0:18:52.40,Default,,0000,0000,0000,,えっ えっち! えっち!
Dialogue: 0,0:18:52.40,0:18:54.40,Default,,0000,0000,0000,,違うっ そういう意味じゃなくて
Dialogue: 0,0:18:54.40,0:18:56.90,Default,,0000,0000,0000,,フーッ! フーッ!
Dialogue: 0,0:18:54.40,0:18:56.90,Default,,0000,0000,0000,,威嚇しないで
Dialogue: 0,0:18:56.90,0:18:58.90,Default,,0000,0000,0000,,た 単純な話でさ
Dialogue: 0,0:18:58.90,0:19:03.74,Default,,0000,0000,0000,,男の子と女の子だったら どっちがいいかな とか
Dialogue: 0,0:19:03.74,0:19:06.08,Default,,0000,0000,0000,,女の 子?
Dialogue: 0,0:19:06.08,0:19:08.41,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:19:08.41,0:19:11.75,Default,,0000,0000,0000,,あぁ うみだ
Dialogue: 0,0:19:08.41,0:19:11.75,Default,,0000,0000,0000,,どうして
Dialogue: 0,0:19:11.75,0:19:14.42,Default,,0000,0000,0000,,早く うみちゃんのところに 戻らないと
Dialogue: 0,0:19:14.42,0:19:17.76,Default,,0000,0000,0000,,あ あぁ そうだな
Dialogue: 0,0:19:17.76,0:19:19.76,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:21.76,0:19:25.10,Default,,0000,0000,0000,,うみ
Dialogue: 0,0:19:25.10,0:19:29.10,Default,,0000,0000,0000,,ずっと ついてきてたの?
Dialogue: 0,0:19:29.10,0:19:32.37,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:32.37,0:19:36.38,Default,,0000,0000,0000,,一緒にいたのか
Dialogue: 0,0:19:36.38,0:19:41.08,Default,,0000,0000,0000,,写真?
Dialogue: 0,0:19:36.38,0:19:41.08,Default,,0000,0000,0000,,あぁ みんなで写真を撮ろう
Dialogue: 0,0:19:49.05,0:19:53.06,Default,,0000,0000,0000,,あぁ そうだよ
Dialogue: 0,0:19:49.05,0:19:53.06,Default,,0000,0000,0000,,なんで忘れてたんだよ
Dialogue: 0,0:19:53.06,0:19:56.40,Default,,0000,0000,0000,,この夏 俺は うみの願いをかなえてやるって
Dialogue: 0,0:19:56.40,0:19:58.73,Default,,0000,0000,0000,,決めたんじゃないか
Dialogue: 0,0:19:58.73,0:20:04.07,Default,,0000,0000,0000,,お母さんと楽しい夏休みを過ごす
Dialogue: 0,0:19:58.73,0:20:04.07,Default,,0000,0000,0000,,って願いを
Dialogue: 0,0:20:04.07,0:20:09.07,Default,,0000,0000,0000,,なのに うみを忘れたことまで 忘れていた
Dialogue: 0,0:20:09.07,0:20:11.74,Default,,0000,0000,0000,,お父さん
Dialogue: 0,0:20:09.07,0:20:11.74,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:20:11.74,0:20:16.08,Default,,0000,0000,0000,,あ な なんだ?
Dialogue: 0,0:20:16.08,0:20:18.38,Default,,0000,0000,0000,,うみゅ
Dialogue: 0,0:20:22.75,0:20:24.76,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:20:24.76,0:20:27.43,Default,,0000,0000,0000,,うん うん
Dialogue: 0,0:20:27.43,0:20:31.10,Default,,0000,0000,0000,,フフッ それは うみちゃんから言ってあげて
Dialogue: 0,0:20:31.10,0:20:33.80,Default,,0000,0000,0000,,そのほうがお父さん 喜ぶから
Dialogue: 0,0:20:35.77,0:20:43.78,Default,,0000,0000,0000,,お お父さんも
Dialogue: 0,0:20:35.77,0:20:43.78,Default,,0000,0000,0000,,写真 一緒に 写ろ?
Dialogue: 0,0:20:43.78,0:20:45.78,Default,,0000,0000,0000,,うみ
Dialogue: 0,0:20:47.78,0:20:52.45,Default,,0000,0000,0000,,そうだな 一緒に写ろうか
Dialogue: 0,0:20:47.78,0:20:52.45,Default,,0000,0000,0000,,3人で一緒にさ
Dialogue: 0,0:20:52.45,0:20:54.45,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:20:54.45,0:20:57.46,Default,,0000,0000,0000,,じゃあ うみちゃんは 真ん中だね
Dialogue: 0,0:21:02.13,0:21:04.80,Default,,0000,0000,0000,,もっと寄って寄って
Dialogue: 0,0:21:04.80,0:21:07.47,Default,,0000,0000,0000,,じゃあ いくぞ
Dialogue: 0,0:21:07.47,0:21:10.80,Default,,0000,0000,0000,,はい チーズ!
Dialogue: 0,0:21:10.80,0:21:15.47,Default,,0000,0000,0000,,じゃあ 現像に出しとくわね
Dialogue: 0,0:21:10.80,0:21:15.47,Default,,0000,0000,0000,,できたら すぐ連絡するから
Dialogue: 0,0:21:15.47,0:21:19.48,Default,,0000,0000,0000,,そしたら すぐ3人で 取りに来ようね
Dialogue: 0,0:21:15.47,0:21:19.48,Default,,0000,0000,0000,,うん!
Dialogue: 0,0:21:19.48,0:21:23.48,Default,,0000,0000,0000,,でも また うみのことを 忘れてしまったら
Dialogue: 0,0:21:25.82,0:21:29.15,Default,,0000,0000,0000,,あ 花火大会 明日だったわね
Dialogue: 0,0:21:29.15,0:21:32.42,Default,,0000,0000,0000,,この島では 年に一度の大きいやつだよ
Dialogue: 0,0:21:32.42,0:21:34.43,Default,,0000,0000,0000,,夏の終わりを告げるの
Dialogue: 0,0:21:34.43,0:21:37.76,Default,,0000,0000,0000,,夏の 終わり
Dialogue: 0,0:21:37.76,0:21:43.10,Default,,0000,0000,0000,,うみ 一緒に花火 見にいこうな
Dialogue: 0,0:21:37.76,0:21:43.10,Default,,0000,0000,0000,,花火
Dialogue: 0,0:21:43.10,0:21:47.44,Default,,0000,0000,0000,,うん! 楽しみ! エヘヘヘヘ!
Dialogue: 0,0:21:47.44,0:21:51.84,Default,,0000,0000,0000,,約束したんだ
Dialogue: 0,0:21:47.44,0:21:51.84,Default,,0000,0000,0000,,絶対に忘れない
Dialogue: 0,0:21:57.78,0:22:01.09,Default,,0000,0000,0000,,お や すみ
Dialogue: 0,0:22:03.12,0:22:05.82,Default,,0000,0000,0000,,うん おやすみ
Dialogue: 0,0:22:08.13,0:22:10.46,Default,,0000,0000,0000,,そういえば この絵本って
Dialogue: 0,0:22:10.46,0:22:13.47,Default,,0000,0000,0000,,まだ最後まで 読んであげられてないね
Dialogue: 0,0:22:16.80,0:22:22.14,Default,,0000,0000,0000,,きれいな羽を持つチョウが
Dialogue: 0,0:22:16.80,0:22:22.14,Default,,0000,0000,0000,,色のない世界を旅する
Dialogue: 0,0:22:22.14,0:22:27.81,Default,,0000,0000,0000,,旅先で出会う人たちに
Dialogue: 0,0:22:22.14,0:22:27.81,Default,,0000,0000,0000,,自分のきれいな羽の色をあげて
Dialogue: 0,0:22:27.81,0:22:34.42,Default,,0000,0000,0000,,チョウは 羽から色がなくなって
Dialogue: 0,0:22:27.81,0:22:34.42,Default,,0000,0000,0000,,ボロボロになっても旅を続けました
Dialogue: 0,0:22:39.42,0:22:42.83,Default,,0000,0000,0000,,なんで こんな話にしたんだっけ?
