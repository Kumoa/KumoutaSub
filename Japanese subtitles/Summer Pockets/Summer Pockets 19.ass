Dialogue: 0,0:00:46.81,0:00:50.82,Default,,0000,0000,0000,,お母さんが いてくれたらよかったのに
Dialogue: 0,0:01:26.85,0:01:30.19,Default,,0000,0000,0000,,あん
Dialogue: 0,0:01:30.19,0:01:32.19,Default,,0000,0000,0000,,41点
Dialogue: 0,0:01:32.19,0:01:35.13,Default,,0000,0000,0000,,よっしゃ! 赤点回避!
Dialogue: 0,0:01:35.13,0:01:37.13,Default,,0000,0000,0000,,解せない
Dialogue: 0,0:01:37.13,0:01:42.80,Default,,0000,0000,0000,,どうして私の教えた
Dialogue: 0,0:01:37.13,0:01:42.80,Default,,0000,0000,0000,,レシピどおりに作って この味に
Dialogue: 0,0:01:42.80,0:01:46.81,Default,,0000,0000,0000,,もっと修業して お父さん
Dialogue: 0,0:01:42.80,0:01:46.81,Default,,0000,0000,0000,,お父さん言うな
Dialogue: 0,0:03:31.84,0:03:34.11,Default,,0000,0000,0000,,「8月8日 はれ
Dialogue: 0,0:03:34.11,0:03:37.12,Default,,0000,0000,0000,,きょうは おかーさんと プールであそんだ
Dialogue: 0,0:03:37.12,0:03:39.45,Default,,0000,0000,0000,,すべりだいが たのしかった」
Dialogue: 0,0:03:39.45,0:03:42.46,Default,,0000,0000,0000,,わっ! ハハハッ!
Dialogue: 0,0:03:44.46,0:03:48.80,Default,,0000,0000,0000,,プハーッ! お母さん 見てた?
Dialogue: 0,0:03:48.80,0:03:52.13,Default,,0000,0000,0000,,見てたよ すごいね うみちゃん
Dialogue: 0,0:03:52.13,0:03:54.80,Default,,0000,0000,0000,,ありがとな
Dialogue: 0,0:03:52.13,0:03:54.80,Default,,0000,0000,0000,,ヘッ
Dialogue: 0,0:03:54.80,0:03:59.14,Default,,0000,0000,0000,,あんなに喜ばれると 徹夜したかいが あったってもんだぜ
Dialogue: 0,0:03:59.14,0:04:03.48,Default,,0000,0000,0000,,それに うみの魔法の絵日記とやらに 書いてあるんだろう
Dialogue: 0,0:04:03.48,0:04:05.81,Default,,0000,0000,0000,,だったら 何としても実現させないとな
Dialogue: 0,0:04:05.81,0:04:08.48,Default,,0000,0000,0000,,はい 魔法は絶対ですから!
Dialogue: 0,0:04:08.48,0:04:10.48,Default,,0000,0000,0000,,みんな
Dialogue: 0,0:04:10.48,0:04:13.49,Default,,0000,0000,0000,,「8月11日 はれ
Dialogue: 0,0:04:13.49,0:04:15.82,Default,,0000,0000,0000,,おかーさんと かくれんぼをした
Dialogue: 0,0:04:15.82,0:04:19.83,Default,,0000,0000,0000,,みんなもいっしょにあそんだ
Dialogue: 0,0:04:15.82,0:04:19.83,Default,,0000,0000,0000,,すごくたのしかった」
Dialogue: 0,0:04:19.83,0:04:26.50,Default,,0000,0000,0000,,2 3 4 5 6
Dialogue: 0,0:04:26.50,0:04:28.84,Default,,0000,0000,0000,,うみ 早く隠れろ
Dialogue: 0,0:04:28.84,0:04:33.11,Default,,0000,0000,0000,,8 9 10
Dialogue: 0,0:04:28.84,0:04:33.11,Default,,0000,0000,0000,,ハァー
Dialogue: 0,0:04:33.11,0:04:37.11,Default,,0000,0000,0000,,もういいかい?
Dialogue: 0,0:04:33.11,0:04:37.11,Default,,0000,0000,0000,,もういいよ
Dialogue: 0,0:04:37.11,0:04:41.45,Default,,0000,0000,0000,,他の連中 位置バレしないよう 声を出さないのか
Dialogue: 0,0:04:41.45,0:04:45.45,Default,,0000,0000,0000,,うみは 無事か 見つけた
Dialogue: 0,0:04:45.45,0:04:50.79,Default,,0000,0000,0000,,いつの間に!?
Dialogue: 0,0:04:45.45,0:04:50.79,Default,,0000,0000,0000,,あんなに顔を出してたらわかる
Dialogue: 0,0:04:50.79,0:04:52.79,Default,,0000,0000,0000,,マッチ トゥ 加納
Dialogue: 0,0:04:52.79,0:04:55.80,Default,,0000,0000,0000,,シャーッ!!
Dialogue: 0,0:04:52.79,0:04:55.80,Default,,0000,0000,0000,,天善くん 見つけた
Dialogue: 0,0:04:55.80,0:04:58.80,Default,,0000,0000,0000,,しまった!
Dialogue: 0,0:04:55.80,0:04:58.80,Default,,0000,0000,0000,,つい試合の癖が!!
Dialogue: 0,0:04:58.80,0:05:00.80,Default,,0000,0000,0000,,裸祭り
Dialogue: 0,0:05:00.80,0:05:02.80,Default,,0000,0000,0000,,バージ!!
Dialogue: 0,0:05:00.80,0:05:02.80,Default,,0000,0000,0000,,脱ぐな!
Dialogue: 0,0:05:02.80,0:05:05.14,Default,,0000,0000,0000,,ヒギャ!
Dialogue: 0,0:05:02.80,0:05:05.14,Default,,0000,0000,0000,,良一 のみき 見つけた
Dialogue: 0,0:05:05.14,0:05:07.14,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:07.14,0:05:10.48,Default,,0000,0000,0000,,あれ? こんなところに エッチな本が落ちてる
Dialogue: 0,0:05:10.48,0:05:13.15,Default,,0000,0000,0000,,ど どこ? ハッ!?
Dialogue: 0,0:05:13.15,0:05:15.15,Default,,0000,0000,0000,,ち 違うから!
Dialogue: 0,0:05:15.15,0:05:18.82,Default,,0000,0000,0000,,本が捨てられてたら ゴミになっちゃうから!
Dialogue: 0,0:05:18.82,0:05:22.82,Default,,0000,0000,0000,,あとは うみちゃんだけだな どこかな
Dialogue: 0,0:05:27.16,0:05:29.16,Default,,0000,0000,0000,,うみちゃん みっ
Dialogue: 0,0:05:34.77,0:05:38.10,Default,,0000,0000,0000,,うみちゃん みっけ!
Dialogue: 0,0:05:34.77,0:05:38.10,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:05:38.10,0:05:42.11,Default,,0000,0000,0000,,エヘヘ 見つかっちゃった
Dialogue: 0,0:05:38.10,0:05:42.11,Default,,0000,0000,0000,,なんでわかったんだ?
Dialogue: 0,0:05:42.11,0:05:47.78,Default,,0000,0000,0000,,なんとなく あなたのマネを
Dialogue: 0,0:05:42.11,0:05:47.78,Default,,0000,0000,0000,,するんじゃないかなと思って
Dialogue: 0,0:05:47.78,0:05:51.12,Default,,0000,0000,0000,,よし それじゃ 次の鬼は
Dialogue: 0,0:05:51.12,0:05:53.12,Default,,0000,0000,0000,,俺か
Dialogue: 0,0:05:53.12,0:05:56.12,Default,,0000,0000,0000,,天善 みっけ!
Dialogue: 0,0:05:53.12,0:05:56.12,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:05:56.12,0:05:58.96,Default,,0000,0000,0000,,良一 みっけ!
Dialogue: 0,0:05:56.12,0:05:58.96,Default,,0000,0000,0000,,なにぃ!?
Dialogue: 0,0:05:58.96,0:06:02.13,Default,,0000,0000,0000,,のみき みっけ!
Dialogue: 0,0:05:58.96,0:06:02.13,Default,,0000,0000,0000,,しまった!
Dialogue: 0,0:06:02.13,0:06:05.47,Default,,0000,0000,0000,,蒼 みっ
Dialogue: 0,0:06:02.13,0:06:05.47,Default,,0000,0000,0000,,ち ち 違うの!
Dialogue: 0,0:06:05.47,0:06:08.47,Default,,0000,0000,0000,,残るは うみと しろはか
Dialogue: 0,0:06:11.47,0:06:14.47,Default,,0000,0000,0000,,しろは みっ
Dialogue: 0,0:06:11.47,0:06:14.47,Default,,0000,0000,0000,,シー
Dialogue: 0,0:06:14.47,0:06:17.48,Default,,0000,0000,0000,,待ちくたびれて寝ちゃった
Dialogue: 0,0:06:21.48,0:06:25.49,Default,,0000,0000,0000,,「8月12日 くもりのちはれ
Dialogue: 0,0:06:25.49,0:06:28.49,Default,,0000,0000,0000,,おかーさんといっしょに おうたをうたった」
Dialogue: 0,0:06:28.49,0:06:37.10,Default,,0000,0000,0000,,「かもめの水兵さん
Dialogue: 0,0:06:28.49,0:06:37.10,Default,,0000,0000,0000,,ならんだ水兵さん」
Dialogue: 0,0:06:37.10,0:06:41.43,Default,,0000,0000,0000,,「白いぼうし 白いシャツ 白いふく」
Dialogue: 0,0:06:41.43,0:06:45.77,Default,,0000,0000,0000,,「波にチャップ チャップ うかんでる」
Dialogue: 0,0:06:45.77,0:06:47.77,Default,,0000,0000,0000,,くじけました
Dialogue: 0,0:06:47.77,0:06:51.44,Default,,0000,0000,0000,,歌の先生 失格のらく印を 押されました
Dialogue: 0,0:06:51.44,0:06:54.45,Default,,0000,0000,0000,,紬 しっかり!
Dialogue: 0,0:06:51.44,0:06:54.45,Default,,0000,0000,0000,,諦めちゃダメ!
Dialogue: 0,0:06:54.45,0:06:56.45,Default,,0000,0000,0000,,だから言ったのに
Dialogue: 0,0:06:56.45,0:06:59.79,Default,,0000,0000,0000,,私は歌を 独特な個性に変えてしまうって
Dialogue: 0,0:06:59.79,0:07:02.79,Default,,0000,0000,0000,,うみゅ 歌って難しい
Dialogue: 0,0:07:02.79,0:07:05.12,Default,,0000,0000,0000,,2人とも そんなこと言わないで
Dialogue: 0,0:07:05.12,0:07:08.80,Default,,0000,0000,0000,,歌の基本は やっぱり 胸式呼吸よ
Dialogue: 0,0:07:08.80,0:07:11.46,Default,,0000,0000,0000,,いや 腹式呼吸だし
Dialogue: 0,0:07:11.46,0:07:14.13,Default,,0000,0000,0000,,裏切り者
Dialogue: 0,0:07:11.46,0:07:14.13,Default,,0000,0000,0000,,なんで?
Dialogue: 0,0:07:14.13,0:07:16.47,Default,,0000,0000,0000,,でしたら みんなで歌いましょう!
Dialogue: 0,0:07:16.47,0:07:19.14,Default,,0000,0000,0000,,歌は みんなで歌うと楽しいです!
Dialogue: 0,0:07:19.14,0:07:21.47,Default,,0000,0000,0000,,お父さんも
Dialogue: 0,0:07:21.47,0:07:24.14,Default,,0000,0000,0000,,えっ 俺も?
Dialogue: 0,0:07:24.14,0:07:32.15,Default,,0000,0000,0000,,「かもめの水兵さん
Dialogue: 0,0:07:24.14,0:07:32.15,Default,,0000,0000,0000,,ならんだ水兵さん」
Dialogue: 0,0:07:32.15,0:07:37.42,Default,,0000,0000,0000,,フフフッ
Dialogue: 0,0:07:32.15,0:07:37.42,Default,,0000,0000,0000,,なかなか独創的なコーラスね
Dialogue: 0,0:07:37.42,0:07:41.43,Default,,0000,0000,0000,,「8月13日 はれのちあめ
Dialogue: 0,0:07:41.43,0:07:44.76,Default,,0000,0000,0000,,おかーさんが ごほんをよんでくれた」
Dialogue: 0,0:07:44.76,0:07:47.77,Default,,0000,0000,0000,,で うみちゃんは どんなお話が聞きたいのかな?
Dialogue: 0,0:07:47.77,0:07:49.77,Default,,0000,0000,0000,,ふぇ?
Dialogue: 0,0:07:49.77,0:07:51.77,Default,,0000,0000,0000,,うみに読んでやる 何かいい本がないかって
Dialogue: 0,0:07:51.77,0:07:55.11,Default,,0000,0000,0000,,鴎に相談したらさ
Dialogue: 0,0:07:51.77,0:07:55.11,Default,,0000,0000,0000,,だったらいっそのこと
Dialogue: 0,0:07:55.11,0:07:58.78,Default,,0000,0000,0000,,絵本を作っちゃえばって
Dialogue: 0,0:07:55.11,0:07:58.78,Default,,0000,0000,0000,,私も手伝うから
Dialogue: 0,0:07:58.78,0:08:03.78,Default,,0000,0000,0000,,絵本って作れるの?
Dialogue: 0,0:07:58.78,0:08:03.78,Default,,0000,0000,0000,,うん そうよ
Dialogue: 0,0:08:03.78,0:08:07.12,Default,,0000,0000,0000,,ちょうちょ
Dialogue: 0,0:08:03.78,0:08:07.12,Default,,0000,0000,0000,,ちょうちょ?
Dialogue: 0,0:08:07.12,0:08:09.79,Default,,0000,0000,0000,,ちょうちょのお話が聞きたい
Dialogue: 0,0:08:09.79,0:08:13.46,Default,,0000,0000,0000,,すっごくきれいな羽の ちょうちょが飛ぶの
Dialogue: 0,0:08:13.46,0:08:19.80,Default,,0000,0000,0000,,でね ヒラヒラーッて
Dialogue: 0,0:08:13.46,0:08:19.80,Default,,0000,0000,0000,,いろんなところに飛んでいくの
Dialogue: 0,0:08:19.80,0:08:23.14,Default,,0000,0000,0000,,そこは もう少し 明るい色のほうがいいかも
Dialogue: 0,0:08:23.14,0:08:25.14,Default,,0000,0000,0000,,お そうか?
Dialogue: 0,0:08:25.14,0:08:30.14,Default,,0000,0000,0000,,でも これってさ 俺じゃなくて 鴎が1人で作ったほうが
Dialogue: 0,0:08:27.47,0:08:30.14,Default,,0000,0000,0000,,早いんじゃないか?
Dialogue: 0,0:08:30.14,0:08:33.08,Default,,0000,0000,0000,,うん そうかも
Dialogue: 0,0:08:30.14,0:08:33.08,Default,,0000,0000,0000,,アハハハ
Dialogue: 0,0:08:33.08,0:08:35.75,Default,,0000,0000,0000,,でも 羽依里が作るから
Dialogue: 0,0:08:35.75,0:08:40.75,Default,,0000,0000,0000,,この本は うみちゃんにとって 特別な1冊になるんだよ
Dialogue: 0,0:08:40.75,0:08:45.42,Default,,0000,0000,0000,,こう?
Dialogue: 0,0:08:40.75,0:08:45.42,Default,,0000,0000,0000,,うん 上手だよ
Dialogue: 0,0:08:45.42,0:08:47.43,Default,,0000,0000,0000,,よしっ!
Dialogue: 0,0:08:47.43,0:08:49.43,Default,,0000,0000,0000,,できた!
Dialogue: 0,0:08:49.43,0:08:52.10,Default,,0000,0000,0000,,おぉ!
Dialogue: 0,0:08:52.10,0:08:54.10,Default,,0000,0000,0000,,よかったね うみちゃん
Dialogue: 0,0:08:54.10,0:08:58.10,Default,,0000,0000,0000,,お母さん 読んで
Dialogue: 0,0:08:54.10,0:08:58.10,Default,,0000,0000,0000,,うん じゃあ 読むね
Dialogue: 0,0:09:00.11,0:09:04.11,Default,,0000,0000,0000,,「むかしむかし 世界には色がありませんでした
Dialogue: 0,0:09:04.11,0:09:08.45,Default,,0000,0000,0000,,そんな世界に きれいな羽の ちょうちょがいました
Dialogue: 0,0:09:08.45,0:09:12.45,Default,,0000,0000,0000,,羽には たくさんの色がついていて」
Dialogue: 0,0:09:12.45,0:09:16.12,Default,,0000,0000,0000,,どうもおじゃましました
Dialogue: 0,0:09:12.45,0:09:16.12,Default,,0000,0000,0000,,また遊びにいらっしゃい
Dialogue: 0,0:09:16.12,0:09:19.13,Default,,0000,0000,0000,,でもすごいわね 絵本を作っちゃうなんて
Dialogue: 0,0:09:19.13,0:09:23.80,Default,,0000,0000,0000,,エヘヘ でも残念
Dialogue: 0,0:09:19.13,0:09:23.80,Default,,0000,0000,0000,,うみちゃん途中で寝ちゃって
Dialogue: 0,0:09:23.80,0:09:27.80,Default,,0000,0000,0000,,せっかく羽依里が すてきなラストシーンを 付け足してくれたのにね
Dialogue: 0,0:09:27.80,0:09:31.47,Default,,0000,0000,0000,,しかたないさ
Dialogue: 0,0:09:27.80,0:09:31.47,Default,,0000,0000,0000,,まっ 続きは また今度
Dialogue: 0,0:09:31.47,0:09:35.74,Default,,0000,0000,0000,,お母さん帰っちゃうの?
Dialogue: 0,0:09:31.47,0:09:35.74,Default,,0000,0000,0000,,起きたのか?
Dialogue: 0,0:09:35.74,0:09:38.74,Default,,0000,0000,0000,,ごめんね うみちゃん
Dialogue: 0,0:09:35.74,0:09:38.74,Default,,0000,0000,0000,,また明日ね
Dialogue: 0,0:09:38.74,0:09:40.75,Default,,0000,0000,0000,,うん
Dialogue: 0,0:09:40.75,0:09:43.75,Default,,0000,0000,0000,,お父さん 送ってあげて
Dialogue: 0,0:09:40.75,0:09:43.75,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:09:43.75,0:09:48.09,Default,,0000,0000,0000,,大丈夫だよ まだ明るいし
Dialogue: 0,0:09:43.75,0:09:48.09,Default,,0000,0000,0000,,ありがとう うみちゃん
Dialogue: 0,0:09:48.09,0:09:52.43,Default,,0000,0000,0000,,傘持って 雨降るから
Dialogue: 0,0:09:48.09,0:09:52.43,Default,,0000,0000,0000,,雨?
Dialogue: 0,0:09:52.43,0:09:55.13,Default,,0000,0000,0000,,お父さん
Dialogue: 0,0:09:57.76,0:09:59.77,Default,,0000,0000,0000,,わかったよ
Dialogue: 0,0:10:01.77,0:10:04.10,Default,,0000,0000,0000,,今日は ありがとな
Dialogue: 0,0:10:01.77,0:10:04.10,Default,,0000,0000,0000,,ううん
Dialogue: 0,0:10:04.10,0:10:07.77,Default,,0000,0000,0000,,うみちゃんが喜んでくれて よかったよ
Dialogue: 0,0:10:07.77,0:10:12.78,Default,,0000,0000,0000,,そう言えば 最近言わなくなったね
Dialogue: 0,0:10:07.77,0:10:12.78,Default,,0000,0000,0000,,「お父さん言うな」って
Dialogue: 0,0:10:12.78,0:10:16.12,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:10:12.78,0:10:16.12,Default,,0000,0000,0000,,なんか慣れてきたっていうか
Dialogue: 0,0:10:16.12,0:10:18.78,Default,,0000,0000,0000,,まぁ お父さんでもいいかなって
Dialogue: 0,0:10:18.78,0:10:22.12,Default,,0000,0000,0000,,しろはが困らなければだけど
Dialogue: 0,0:10:22.12,0:10:24.46,Default,,0000,0000,0000,,困る かも
Dialogue: 0,0:10:24.46,0:10:27.13,Default,,0000,0000,0000,,えっ? かも?
Dialogue: 0,0:10:27.13,0:10:29.46,Default,,0000,0000,0000,,かも だし
Dialogue: 0,0:10:29.46,0:10:31.46,Default,,0000,0000,0000,,コホン
Dialogue: 0,0:10:29.46,0:10:31.46,Default,,0000,0000,0000,,わっ!
Dialogue: 0,0:10:31.46,0:10:34.13,Default,,0000,0000,0000,,私は この辺りで じゃね!
Dialogue: 0,0:10:34.13,0:10:37.44,Default,,0000,0000,0000,,お父さん&お母さん!
Dialogue: 0,0:10:39.81,0:10:43.48,Default,,0000,0000,0000,,私 ちゃんとお母さん できてるのかな
Dialogue: 0,0:10:43.48,0:10:46.48,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:10:43.48,0:10:46.48,Default,,0000,0000,0000,,前に言ったと思うけど
Dialogue: 0,0:10:46.48,0:10:50.15,Default,,0000,0000,0000,,私 両親がいないの
Dialogue: 0,0:10:50.15,0:10:54.85,Default,,0000,0000,0000,,だから お母さんとの 過ごし方というのを知らなくて
Dialogue: 0,0:10:58.49,0:11:01.49,Default,,0000,0000,0000,,うみちゃんが求めている お母さんを
Dialogue: 0,0:11:01.49,0:11:05.50,Default,,0000,0000,0000,,かなえてあげられているのかな
Dialogue: 0,0:11:05.50,0:11:09.84,Default,,0000,0000,0000,,うみってさ 出会った頃は なんか ぎこちないっていうか
Dialogue: 0,0:11:09.84,0:11:13.17,Default,,0000,0000,0000,,やたら人見知りしててさ
Dialogue: 0,0:11:09.84,0:11:13.17,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:11:13.17,0:11:17.84,Default,,0000,0000,0000,,でも 最近は 毎日楽しそうに笑ってる
Dialogue: 0,0:11:17.84,0:11:21.85,Default,,0000,0000,0000,,しろはのおかげだよ
Dialogue: 0,0:11:21.85,0:11:24.52,Default,,0000,0000,0000,,お母さんに正解なんてないと思う
Dialogue: 0,0:11:24.52,0:11:27.85,Default,,0000,0000,0000,,しろはは 自分がしてほしかったことを
Dialogue: 0,0:11:27.85,0:11:30.52,Default,,0000,0000,0000,,うみにしてあげれば いいんじゃないかな?
Dialogue: 0,0:11:30.52,0:11:36.53,Default,,0000,0000,0000,,私が してほしかったこと
Dialogue: 0,0:11:30.52,0:11:36.53,Default,,0000,0000,0000,,うん
Dialogue: 0,0:11:39.80,0:11:41.80,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:11:41.80,0:11:44.80,Default,,0000,0000,0000,,ちゃんとお母さんが できているなら
Dialogue: 0,0:11:44.80,0:11:47.41,Default,,0000,0000,0000,,うれしいかな
Dialogue: 0,0:11:50.81,0:11:52.81,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:12:02.49,0:12:05.49,Default,,0000,0000,0000,,当たったな うみの天気予報
Dialogue: 0,0:12:25.85,0:12:28.85,Default,,0000,0000,0000,,そしたら次は ここと ここを合わせて
Dialogue: 0,0:12:28.85,0:12:30.85,Default,,0000,0000,0000,,こう?
Dialogue: 0,0:12:28.85,0:12:30.85,Default,,0000,0000,0000,,うん
Dialogue: 0,0:12:30.85,0:12:33.45,Default,,0000,0000,0000,,できた!
Dialogue: 0,0:12:30.85,0:12:33.45,Default,,0000,0000,0000,,うみちゃん 上手
Dialogue: 0,0:12:33.45,0:12:35.45,Default,,0000,0000,0000,,エヘヘ
Dialogue: 0,0:12:37.79,0:12:41.13,Default,,0000,0000,0000,,「はれのちあめ」か
Dialogue: 0,0:12:41.13,0:12:45.43,Default,,0000,0000,0000,,うみが これ書いたのって 何日も前だよな
Dialogue: 0,0:12:48.13,0:12:52.47,Default,,0000,0000,0000,,なんか まるで見てきたみたいだけど
Dialogue: 0,0:12:52.47,0:12:55.47,Default,,0000,0000,0000,,いや ただの偶然だろ
Dialogue: 0,0:12:57.48,0:12:59.88,Default,,0000,0000,0000,,気にすることじゃない
Dialogue: 0,0:13:04.15,0:13:07.49,Default,,0000,0000,0000,,朝から チャーハン?
Dialogue: 0,0:13:07.49,0:13:09.82,Default,,0000,0000,0000,,私が作りました
Dialogue: 0,0:13:09.82,0:13:11.82,Default,,0000,0000,0000,,気持ちいい!
Dialogue: 0,0:13:11.82,0:13:15.16,Default,,0000,0000,0000,,私 16になったら 絶対免許とります
Dialogue: 0,0:13:15.16,0:13:19.50,Default,,0000,0000,0000,,もしもし 起きてください 鷹原さん
Dialogue: 0,0:13:19.50,0:13:21.50,Default,,0000,0000,0000,,羽依里さん
Dialogue: 0,0:13:21.50,0:13:25.84,Default,,0000,0000,0000,,お父さん ん?
Dialogue: 0,0:13:25.84,0:13:28.84,Default,,0000,0000,0000,,お父さん 起きて
Dialogue: 0,0:13:28.84,0:13:33.78,Default,,0000,0000,0000,,あ あぁ ごめん なんか変な夢見てたよ
Dialogue: 0,0:13:33.78,0:13:38.78,Default,,0000,0000,0000,,お父さん ここ持って
Dialogue: 0,0:13:33.78,0:13:38.78,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:13:38.78,0:13:40.79,Default,,0000,0000,0000,,あ あぁ
Dialogue: 0,0:13:40.79,0:13:43.46,Default,,0000,0000,0000,,ここか?
Dialogue: 0,0:13:40.79,0:13:43.46,Default,,0000,0000,0000,,うん
Dialogue: 0,0:13:43.46,0:13:46.79,Default,,0000,0000,0000,,目閉じて
Dialogue: 0,0:13:43.46,0:13:46.79,Default,,0000,0000,0000,,はい
Dialogue: 0,0:13:46.79,0:13:49.46,Default,,0000,0000,0000,,目開けて
Dialogue: 0,0:13:46.79,0:13:49.46,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:13:49.46,0:13:51.80,Default,,0000,0000,0000,,おぉ? どうなってるんだ?
Dialogue: 0,0:13:51.80,0:13:57.14,Default,,0000,0000,0000,,エヘヘ 不思議でしょ?
Dialogue: 0,0:13:51.80,0:13:57.14,Default,,0000,0000,0000,,ホントはね こうなってるの
Dialogue: 0,0:13:57.14,0:14:02.14,Default,,0000,0000,0000,,へぇ すごいなぁ
Dialogue: 0,0:13:57.14,0:14:02.14,Default,,0000,0000,0000,,お母さんに教えてもらったの
Dialogue: 0,0:14:02.14,0:14:05.81,Default,,0000,0000,0000,,お船のお母さん きれいだから
Dialogue: 0,0:14:02.14,0:14:05.81,Default,,0000,0000,0000,,ん?
Dialogue: 0,0:14:05.81,0:14:08.81,Default,,0000,0000,0000,,お母さんね お船に乗るんだよ
Dialogue: 0,0:14:08.81,0:14:10.82,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:14:10.82,0:14:13.15,Default,,0000,0000,0000,,しろは?
Dialogue: 0,0:14:10.82,0:14:13.15,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:14:13.15,0:14:17.16,Default,,0000,0000,0000,,うみゅ?
Dialogue: 0,0:14:13.15,0:14:17.16,Default,,0000,0000,0000,,夏鳥の儀のこと言ってる?
Dialogue: 0,0:14:17.16,0:14:20.49,Default,,0000,0000,0000,,なつどりの ぎ?
Dialogue: 0,0:14:20.49,0:14:23.16,Default,,0000,0000,0000,,夏鳥の儀って
Dialogue: 0,0:14:20.49,0:14:23.16,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:23.16,0:14:26.17,Default,,0000,0000,0000,,この島に伝わる 儀式みたいなもので
Dialogue: 0,0:14:26.17,0:14:28.83,Default,,0000,0000,0000,,簡単に言えばお祭り
Dialogue: 0,0:14:28.83,0:14:31.84,Default,,0000,0000,0000,,じゃあ そこで?
Dialogue: 0,0:14:28.83,0:14:31.84,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:31.84,0:14:35.77,Default,,0000,0000,0000,,でもまだ おじいちゃん以外 知らないはず
Dialogue: 0,0:14:35.77,0:14:40.11,Default,,0000,0000,0000,,うみちゃん 私が船に乗ること 知ってたの?
Dialogue: 0,0:14:40.11,0:14:43.45,Default,,0000,0000,0000,,ん うん
Dialogue: 0,0:14:43.45,0:14:47.15,Default,,0000,0000,0000,,昨日の雨も 知っていた?
Dialogue: 0,0:14:43.45,0:14:47.15,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:49.79,0:14:53.46,Default,,0000,0000,0000,,明日も 知っていた?
Dialogue: 0,0:14:53.46,0:14:58.13,Default,,0000,0000,0000,,明日も? うん!
Dialogue: 0,0:14:58.13,0:15:01.80,Default,,0000,0000,0000,,しろは?
Dialogue: 0,0:15:01.80,0:15:03.80,Default,,0000,0000,0000,,お母さん?
Dialogue: 0,0:15:03.80,0:15:06.14,Default,,0000,0000,0000,,もうおしまい
Dialogue: 0,0:15:03.80,0:15:06.14,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:15:06.14,0:15:09.48,Default,,0000,0000,0000,,もう
Dialogue: 0,0:15:06.14,0:15:09.48,Default,,0000,0000,0000,,お母さんは おしまい
Dialogue: 0,0:15:09.48,0:15:13.15,Default,,0000,0000,0000,,やだ やだ やだ お母さん
Dialogue: 0,0:15:13.15,0:15:15.15,Default,,0000,0000,0000,,近づかないで
Dialogue: 0,0:15:24.16,0:15:27.16,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:15:27.16,0:15:29.16,Default,,0000,0000,0000,,お おい!
Dialogue: 0,0:15:31.16,0:15:33.43,Default,,0000,0000,0000,,うみ?
Dialogue: 0,0:15:33.43,0:15:38.10,Default,,0000,0000,0000,,お父さん 来るよね
Dialogue: 0,0:15:38.10,0:15:41.81,Default,,0000,0000,0000,,お母さん 明日も 来るよね
Dialogue: 0,0:15:45.11,0:15:48.78,Default,,0000,0000,0000,,あぁ 大丈夫だ
Dialogue: 0,0:15:45.11,0:15:48.78,Default,,0000,0000,0000,,きっと来るよ
Dialogue: 0,0:15:48.78,0:15:52.12,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:15:52.12,0:15:54.45,Default,,0000,0000,0000,,おい 待ってくれよ しろは!
Dialogue: 0,0:15:54.45,0:15:56.46,Default,,0000,0000,0000,,しろは!
Dialogue: 0,0:16:00.46,0:16:04.86,Default,,0000,0000,0000,,私は 呪われてるから
Dialogue: 0,0:16:06.80,0:16:08.80,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:16:19.14,0:16:21.81,Default,,0000,0000,0000,,ごめん うみ しろはは
Dialogue: 0,0:16:21.81,0:16:24.48,Default,,0000,0000,0000,,ずっとすれ違いで
Dialogue: 0,0:16:24.48,0:16:31.19,Default,,0000,0000,0000,,でも 逃げないって
Dialogue: 0,0:16:24.48,0:16:31.19,Default,,0000,0000,0000,,この夏は きっと最後だから
Dialogue: 0,0:16:33.76,0:16:37.10,Default,,0000,0000,0000,,うみ それは?
Dialogue: 0,0:16:33.76,0:16:37.10,Default,,0000,0000,0000,,お母さん
Dialogue: 0,0:16:37.10,0:16:40.10,Default,,0000,0000,0000,,お母さんの?
Dialogue: 0,0:16:40.10,0:16:43.10,Default,,0000,0000,0000,,こんな写真 いつの間に?
Dialogue: 0,0:16:43.10,0:16:45.10,Default,,0000,0000,0000,,31日?
Dialogue: 0,0:16:45.10,0:16:48.11,Default,,0000,0000,0000,,どういうことだ? 今日はまだ
Dialogue: 0,0:17:04.79,0:17:09.80,Default,,0000,0000,0000,,傘持って 雨降るから
Dialogue: 0,0:17:04.79,0:17:09.80,Default,,0000,0000,0000,,お母さんね お船に乗るんだよ
Dialogue: 0,0:17:09.80,0:17:13.40,Default,,0000,0000,0000,,明日も 知っていた?
Dialogue: 0,0:17:09.80,0:17:13.40,Default,,0000,0000,0000,,うん
Dialogue: 0,0:17:15.47,0:17:20.17,Default,,0000,0000,0000,,うみ お前さ もしかしたら
Dialogue: 0,0:17:23.14,0:17:27.48,Default,,0000,0000,0000,,私 お母さんに会いにきたの
Dialogue: 0,0:17:27.48,0:17:33.75,Default,,0000,0000,0000,,もう お母さんはいなかったから
Dialogue: 0,0:17:27.48,0:17:33.75,Default,,0000,0000,0000,,お母さんを知らなかったから
Dialogue: 0,0:17:33.75,0:17:36.09,Default,,0000,0000,0000,,だから
Dialogue: 0,0:17:36.09,0:17:40.09,Default,,0000,0000,0000,,だから この島に
Dialogue: 0,0:17:40.09,0:17:45.10,Default,,0000,0000,0000,,未来から 来たのか
Dialogue: 0,0:17:40.09,0:17:45.10,Default,,0000,0000,0000,,うん
Dialogue: 0,0:17:50.77,0:17:55.11,Default,,0000,0000,0000,,えと
Dialogue: 0,0:17:50.77,0:17:55.11,Default,,0000,0000,0000,,私 小さな頃から心だけ
Dialogue: 0,0:17:55.11,0:17:58.78,Default,,0000,0000,0000,,少し過去に戻れる力があったの
Dialogue: 0,0:17:58.78,0:18:02.78,Default,,0000,0000,0000,,嫌なことがあると そこから逃げるみたいに
Dialogue: 0,0:18:02.78,0:18:05.12,Default,,0000,0000,0000,,気が付けば戻ってるの
Dialogue: 0,0:18:05.12,0:18:08.45,Default,,0000,0000,0000,,また同じ未来をたどるけど
Dialogue: 0,0:18:08.45,0:18:11.79,Default,,0000,0000,0000,,私が生まれた頃 この島に住んでたって
Dialogue: 0,0:18:11.79,0:18:13.79,Default,,0000,0000,0000,,お父さんが言ってた
Dialogue: 0,0:18:13.79,0:18:18.46,Default,,0000,0000,0000,,でも お父さんに連れられて この島を出たの
Dialogue: 0,0:18:18.46,0:18:22.80,Default,,0000,0000,0000,,この島には もう近づかないって
Dialogue: 0,0:18:18.46,0:18:22.80,Default,,0000,0000,0000,,忘れろって
Dialogue: 0,0:18:22.80,0:18:27.11,Default,,0000,0000,0000,,お母さんのことも 何も話してくれなかった
Dialogue: 0,0:18:29.81,0:18:34.41,Default,,0000,0000,0000,,お父さん 私のこと嫌いだと思う
Dialogue: 0,0:18:29.81,0:18:34.41,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:18:34.41,0:18:37.42,Default,,0000,0000,0000,,だって 私が生まれたから
Dialogue: 0,0:18:37.42,0:18:40.75,Default,,0000,0000,0000,,私のせいで お母さん死んじゃったから
Dialogue: 0,0:18:40.75,0:18:44.09,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:18:40.75,0:18:44.09,Default,,0000,0000,0000,,でもね お父さん
Dialogue: 0,0:18:44.09,0:18:46.76,Default,,0000,0000,0000,,一度だけ話してくれた
Dialogue: 0,0:18:46.76,0:18:50.10,Default,,0000,0000,0000,,お母さんとの夏休みのこと
Dialogue: 0,0:18:50.10,0:18:54.10,Default,,0000,0000,0000,,この島で偶然出会って お魚釣ったり
Dialogue: 0,0:18:54.10,0:18:57.77,Default,,0000,0000,0000,,紙飛行機 飛ばしたり お歌を歌ったり
Dialogue: 0,0:18:57.77,0:19:00.11,Default,,0000,0000,0000,,プールで遊んだりしたって
Dialogue: 0,0:19:00.11,0:19:02.11,Default,,0000,0000,0000,,うらやましかったの
Dialogue: 0,0:19:02.11,0:19:06.11,Default,,0000,0000,0000,,私 そんな夏休み 知らないから
Dialogue: 0,0:19:06.11,0:19:11.78,Default,,0000,0000,0000,,私も お母さんとそんな夏休みを
Dialogue: 0,0:19:06.11,0:19:11.78,Default,,0000,0000,0000,,過ごしたかった
Dialogue: 0,0:19:11.78,0:19:16.46,Default,,0000,0000,0000,,でも お父さん1人で 島に戻っていた
Dialogue: 0,0:19:16.46,0:19:18.79,Default,,0000,0000,0000,,私を置いて
Dialogue: 0,0:19:18.79,0:19:22.13,Default,,0000,0000,0000,,だから1人で来たの
Dialogue: 0,0:19:18.79,0:19:22.13,Default,,0000,0000,0000,,1人で?
Dialogue: 0,0:19:22.13,0:19:27.47,Default,,0000,0000,0000,,うん スマホのアプリがあれば平気
Dialogue: 0,0:19:22.13,0:19:27.47,Default,,0000,0000,0000,,すまほのあぷ?
Dialogue: 0,0:19:27.47,0:19:32.47,Default,,0000,0000,0000,,島 初めて来たのに なんか すごく懐かしかった
Dialogue: 0,0:19:32.47,0:19:37.08,Default,,0000,0000,0000,,それで じぃじの家に行って お母さんの写真をもらったの
Dialogue: 0,0:19:37.08,0:19:41.08,Default,,0000,0000,0000,,お父さん 昔の写真 全部捨てちゃったから
Dialogue: 0,0:19:41.08,0:19:45.42,Default,,0000,0000,0000,,初めて見たお母さん すっごくきれいだった
Dialogue: 0,0:19:45.42,0:19:49.42,Default,,0000,0000,0000,,でも お父さんに 見つかりそうになって
Dialogue: 0,0:19:49.42,0:19:52.42,Default,,0000,0000,0000,,写真を取り上げられたくなくて
Dialogue: 0,0:19:52.42,0:19:56.13,Default,,0000,0000,0000,,逃げて 逃げて 逃げて
Dialogue: 0,0:20:14.45,0:20:17.45,Default,,0000,0000,0000,,気が付いたら この時代にいたの
Dialogue: 0,0:20:17.45,0:20:20.79,Default,,0000,0000,0000,,心だけじゃなく体も
Dialogue: 0,0:20:20.79,0:20:25.12,Default,,0000,0000,0000,,それから何度も何度も 夏を繰り返してきた
Dialogue: 0,0:20:25.12,0:20:29.80,Default,,0000,0000,0000,,お母さんと一緒に過ごせる 夏休みが欲しかったから
Dialogue: 0,0:20:29.80,0:20:33.80,Default,,0000,0000,0000,,でも 何かがこぼれていくみたいで
Dialogue: 0,0:20:37.80,0:20:42.11,Default,,0000,0000,0000,,この夏が 最後みたいな気がする
Dialogue: 0,0:20:47.48,0:20:49.82,Default,,0000,0000,0000,,もしかして うみのお母さんって!
Dialogue: 0,0:20:49.82,0:20:51.82,Default,,0000,0000,0000,,うん
Dialogue: 0,0:20:51.82,0:20:54.82,Default,,0000,0000,0000,,お母さんってすぐわかった
Dialogue: 0,0:20:54.82,0:20:58.82,Default,,0000,0000,0000,,お父さんの隣にいたから
Dialogue: 0,0:20:58.82,0:21:01.13,Default,,0000,0000,0000,,俺が うみの
Dialogue: 0,0:21:05.50,0:21:09.50,Default,,0000,0000,0000,,そうだったんだ
Dialogue: 0,0:21:09.50,0:21:14.17,Default,,0000,0000,0000,,信じて くれるの?
Dialogue: 0,0:21:14.17,0:21:17.18,Default,,0000,0000,0000,,正直よくわからない
Dialogue: 0,0:21:17.18,0:21:19.51,Default,,0000,0000,0000,,突拍子もないし
Dialogue: 0,0:21:19.51,0:21:23.18,Default,,0000,0000,0000,,いろんなことが突然すぎて 理解できないけど
Dialogue: 0,0:21:23.18,0:21:27.19,Default,,0000,0000,0000,,信じるよ うみが言うんだから
Dialogue: 0,0:21:27.19,0:21:31.19,Default,,0000,0000,0000,,それにしても
Dialogue: 0,0:21:31.19,0:21:34.79,Default,,0000,0000,0000,,ひどいやつだな 未来の俺って
Dialogue: 0,0:21:34.79,0:21:36.80,Default,,0000,0000,0000,,ううん
Dialogue: 0,0:21:34.79,0:21:36.80,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:21:36.80,0:21:42.47,Default,,0000,0000,0000,,たくさん夏を繰り返してきて
Dialogue: 0,0:21:36.80,0:21:42.47,Default,,0000,0000,0000,,その数だけお父さんを見て
Dialogue: 0,0:21:42.47,0:21:45.80,Default,,0000,0000,0000,,その数だけお父さんを知った
Dialogue: 0,0:21:45.80,0:21:48.81,Default,,0000,0000,0000,,優しい人だってわかった
Dialogue: 0,0:21:48.81,0:21:53.48,Default,,0000,0000,0000,,お父さんが うみのお父さんでよかった
Dialogue: 0,0:21:53.48,0:21:55.81,Default,,0000,0000,0000,,うみ
Dialogue: 0,0:21:55.81,0:22:03.42,Default,,0000,0000,0000,,ハァ ハァ
Dialogue: 0,0:22:05.49,0:22:07.49,Default,,0000,0000,0000,,うみちゃん
Dialogue: 0,0:22:11.83,0:22:18.84,Default,,0000,0000,0000,,うみ これまでずっと
Dialogue: 0,0:22:11.83,0:22:18.84,Default,,0000,0000,0000,,1人で長い旅をしてきたんだな
Dialogue: 0,0:22:43.46,0:22:46.47,Default,,0000,0000,0000,,かなえてやるよ うみ
Dialogue: 0,0:22:46.47,0:22:50.87,Default,,0000,0000,0000,,お前の 楽しい夏休みを
