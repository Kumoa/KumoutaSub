Dialogue: 0,0:00:40.51,0:00:43.51,Default,,0000,0000,0000,,僕の部屋に エルフが現れるという
Dialogue: 0,0:00:43.51,0:00:48.01,Default,,0000,0000,0000,,ちょっと いや かなり変わったことが起きて
Dialogue: 0,0:00:48.01,0:00:51.02,Default,,0000,0000,0000,,夢は 現実となった
Dialogue: 0,0:00:53.52,0:00:57.02,Default,,0000,0000,0000,,僕らは 一日中 一緒に歩き回って
Dialogue: 0,0:00:57.02,0:00:59.86,Default,,0000,0000,0000,,最後に 夜桜を見に戻ってきた
Dialogue: 0,0:00:59.86,0:01:03.03,Default,,0000,0000,0000,,うっとりするくらい きれい
Dialogue: 0,0:01:03.03,0:01:05.87,Default,,0000,0000,0000,,魔物がいないと こんな世界になるのかしら
Dialogue: 0,0:01:05.87,0:01:08.54,Default,,0000,0000,0000,,どうかな 魔物がいなければ
Dialogue: 0,0:01:08.54,0:01:11.04,Default,,0000,0000,0000,,今度は人が 敵になるかもしれないし
Dialogue: 0,0:01:11.04,0:01:14.04,Default,,0000,0000,0000,,この国も ずっと平和だったわけじゃない
Dialogue: 0,0:01:14.04,0:01:18.71,Default,,0000,0000,0000,,でも ホントきれいだね
Dialogue: 0,0:01:14.04,0:01:18.71,Default,,0000,0000,0000,,えぇ
Dialogue: 0,0:01:18.71,0:01:21.55,Default,,0000,0000,0000,,この景色が こんなにきれいだって
Dialogue: 0,0:01:21.55,0:01:26.22,Default,,0000,0000,0000,,僕は初めて知った気がする ねぇ カズヒホ
Dialogue: 0,0:01:26.22,0:01:30.06,Default,,0000,0000,0000,,もしも私が元の世界に 帰れなかったら どうなるの?
Dialogue: 0,0:01:30.06,0:01:33.83,Default,,0000,0000,0000,,うん
Dialogue: 0,0:01:30.06,0:01:33.83,Default,,0000,0000,0000,,そのときは一緒に暮らして
Dialogue: 0,0:01:33.83,0:01:38.83,Default,,0000,0000,0000,,日本中 たくさんの場所へ 遊びにいくというのは どうかな?
Dialogue: 0,0:01:36.83,0:01:38.83,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:01:38.83,0:01:42.34,Default,,0000,0000,0000,,温泉やお城や 食と文化に溢れた国だからね
Dialogue: 0,0:01:42.34,0:01:44.50,Default,,0000,0000,0000,,退屈しないと思うけど
Dialogue: 0,0:01:44.50,0:01:47.84,Default,,0000,0000,0000,,そうね 別にかまわないわ
Dialogue: 0,0:01:47.84,0:01:52.15,Default,,0000,0000,0000,,でも ちゃんと 送り届けてあげなきゃね
Dialogue: 0,0:03:32.65,0:03:35.32,Default,,0000,0000,0000,,ただいま
Dialogue: 0,0:03:35.32,0:03:37.32,Default,,0000,0000,0000,,タダイマ?
Dialogue: 0,0:03:35.32,0:03:37.32,Default,,0000,0000,0000,,うん
Dialogue: 0,0:03:37.32,0:03:40.65,Default,,0000,0000,0000,,帰ったら 「ただいま」
Dialogue: 0,0:03:37.32,0:03:40.65,Default,,0000,0000,0000,,タダイマ!
Dialogue: 0,0:03:40.65,0:03:43.16,Default,,0000,0000,0000,,すてきだったわ ヨザクラ
Dialogue: 0,0:03:43.16,0:03:46.83,Default,,0000,0000,0000,,ヤキトーモロコシも 香ばしくておいしかったし
Dialogue: 0,0:03:46.83,0:03:50.16,Default,,0000,0000,0000,,そうだ マリー お風呂に入るかい?
Dialogue: 0,0:03:50.16,0:03:52.83,Default,,0000,0000,0000,,たくさん歩いて疲れたでしょ
Dialogue: 0,0:03:52.83,0:03:55.13,Default,,0000,0000,0000,,あら お風呂まであるの!?
Dialogue: 0,0:03:57.17,0:04:00.01,Default,,0000,0000,0000,,ねぇ マリー 無事に向こうへ戻れたらさ
Dialogue: 0,0:04:00.01,0:04:03.01,Default,,0000,0000,0000,,やっぱり お別れになるのかな
Dialogue: 0,0:04:03.01,0:04:06.18,Default,,0000,0000,0000,,マリーは魔術師ギルドに 戻らなきゃいけないだろうし
Dialogue: 0,0:04:06.18,0:04:08.18,Default,,0000,0000,0000,,ええっ!
Dialogue: 0,0:04:06.18,0:04:08.18,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:04:08.18,0:04:11.85,Default,,0000,0000,0000,,なんでお湯が ドバドバ出ているの?
Dialogue: 0,0:04:08.18,0:04:11.85,Default,,0000,0000,0000,,ボタンを押しただけに見えたけど
Dialogue: 0,0:04:11.85,0:04:16.36,Default,,0000,0000,0000,,まさかついに無詠唱魔法を 覚えたの?
Dialogue: 0,0:04:11.85,0:04:16.36,Default,,0000,0000,0000,,いやいや
Dialogue: 0,0:04:16.36,0:04:19.86,Default,,0000,0000,0000,,はい
Dialogue: 0,0:04:16.36,0:04:19.86,Default,,0000,0000,0000,,んっ? なぁに これ
Dialogue: 0,0:04:19.86,0:04:21.86,Default,,0000,0000,0000,,入浴剤だよ
Dialogue: 0,0:04:21.86,0:04:26.37,Default,,0000,0000,0000,,いろんな香りの湯を楽しめるんだ
Dialogue: 0,0:04:21.86,0:04:26.37,Default,,0000,0000,0000,,好きなのを選んでいいからね
Dialogue: 0,0:04:26.37,0:04:31.04,Default,,0000,0000,0000,,あぁもう! 贅沢すぎるわ!
Dialogue: 0,0:04:26.37,0:04:31.04,Default,,0000,0000,0000,,まるで貴族じゃない!
Dialogue: 0,0:04:31.04,0:04:34.54,Default,,0000,0000,0000,,私はエルフなのに 堕落したりしないかしら
Dialogue: 0,0:04:36.48,0:04:40.48,Default,,0000,0000,0000,,あ どれもすてきっ!
Dialogue: 0,0:04:36.48,0:04:40.48,Default,,0000,0000,0000,,迷っちゃう
Dialogue: 0,0:04:44.65,0:04:48.99,Default,,0000,0000,0000,,んっ? フッ
Dialogue: 0,0:04:48.99,0:04:50.99,Default,,0000,0000,0000,,向こうにいたままだったら
Dialogue: 0,0:04:50.99,0:04:54.16,Default,,0000,0000,0000,,こんなマリーを 知らずにいただろうな
Dialogue: 0,0:04:54.16,0:04:56.16,Default,,0000,0000,0000,,はぁ
Dialogue: 0,0:04:56.16,0:05:00.83,Default,,0000,0000,0000,,そのときは一緒に暮らして 日本中 たくさんの場所へ
Dialogue: 0,0:05:00.83,0:05:03.34,Default,,0000,0000,0000,,遊びにいくというのは どうかな?
Dialogue: 0,0:05:03.34,0:05:07.17,Default,,0000,0000,0000,,えぇ きっとすてきでしょうね
Dialogue: 0,0:05:09.18,0:05:12.68,Default,,0000,0000,0000,,ただいま! すごく気持ちのいい お風呂だったわ
Dialogue: 0,0:05:12.68,0:05:16.68,Default,,0000,0000,0000,,おかえり
Dialogue: 0,0:05:12.68,0:05:16.68,Default,,0000,0000,0000,,わっ 何かしら いい香り!
Dialogue: 0,0:05:16.68,0:05:19.52,Default,,0000,0000,0000,,すぐに出来るから座って待ってて
Dialogue: 0,0:05:19.52,0:05:24.02,Default,,0000,0000,0000,,おいしい
Dialogue: 0,0:05:19.52,0:05:24.02,Default,,0000,0000,0000,,これは絶対においしいわ
Dialogue: 0,0:05:24.02,0:05:26.53,Default,,0000,0000,0000,,アハハ 顔が怖いよ
Dialogue: 0,0:05:36.97,0:05:40.81,Default,,0000,0000,0000,,ほわわわ
Dialogue: 0,0:05:36.97,0:05:40.81,Default,,0000,0000,0000,,よし じゃあ食べようか
Dialogue: 0,0:05:40.81,0:05:44.51,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:05:40.81,0:05:44.51,Default,,0000,0000,0000,,い イタダキマス
Dialogue: 0,0:05:47.48,0:05:51.98,Default,,0000,0000,0000,,んっ おいっしい!
Dialogue: 0,0:05:47.48,0:05:51.98,Default,,0000,0000,0000,,よかった
Dialogue: 0,0:05:51.98,0:05:55.66,Default,,0000,0000,0000,,お総菜のカツを買って 卵でとじるだけなんだけど
Dialogue: 0,0:05:55.66,0:05:59.33,Default,,0000,0000,0000,,いけるよね
Dialogue: 0,0:05:55.66,0:05:59.33,Default,,0000,0000,0000,,もうっ 本当においしいわ!
Dialogue: 0,0:05:59.33,0:06:02.83,Default,,0000,0000,0000,,今日 食べた中で 一番は間違いなくこれ!
Dialogue: 0,0:06:02.83,0:06:05.67,Default,,0000,0000,0000,,まだカツはあるから お弁当も出来るよ
Dialogue: 0,0:06:05.67,0:06:08.67,Default,,0000,0000,0000,,向こうは素材の味からして 微妙だから
Dialogue: 0,0:06:08.67,0:06:12.67,Default,,0000,0000,0000,,ついついお弁当を持っていくんだ
Dialogue: 0,0:06:08.67,0:06:12.67,Default,,0000,0000,0000,,わかるわ
Dialogue: 0,0:06:12.67,0:06:16.34,Default,,0000,0000,0000,,これを食べたら どんな料理も さぞ味気なく感じそう
Dialogue: 0,0:06:16.34,0:06:20.68,Default,,0000,0000,0000,,なぜか お弁当と飲み物だけは 向こうの世界へ運べるんだよね
Dialogue: 0,0:06:20.68,0:06:24.35,Default,,0000,0000,0000,,えっ 「だけは」って 他の物は運べないの?
Dialogue: 0,0:06:24.35,0:06:26.69,Default,,0000,0000,0000,,えっと 時計とか
Dialogue: 0,0:06:26.69,0:06:32.36,Default,,0000,0000,0000,,あと懐中電灯なんかも
Dialogue: 0,0:06:26.69,0:06:32.36,Default,,0000,0000,0000,,だめだったな
Dialogue: 0,0:06:26.69,0:06:32.36,Default,,0000,0000,0000,,カイチュウデントウ?
Dialogue: 0,0:06:32.36,0:06:35.96,Default,,0000,0000,0000,,マリーが光の精霊を呼び出すようには いかないけど
Dialogue: 0,0:06:35.96,0:06:37.96,Default,,0000,0000,0000,,これがあれば
Dialogue: 0,0:06:37.96,0:06:40.07,Default,,0000,0000,0000,,ほら
Dialogue: 0,0:06:42.14,0:06:45.30,Default,,0000,0000,0000,,あれ? あんまり驚かないね
Dialogue: 0,0:06:45.30,0:06:48.64,Default,,0000,0000,0000,,さすがに こちらの文明にも慣れたもの
Dialogue: 0,0:06:48.64,0:06:50.64,Default,,0000,0000,0000,,思うんだけど
Dialogue: 0,0:06:50.64,0:06:54.31,Default,,0000,0000,0000,,この世界の文化なり技術なりが アウトなのかしら?
Dialogue: 0,0:06:54.31,0:06:56.32,Default,,0000,0000,0000,,でも
Dialogue: 0,0:06:56.32,0:06:59.15,Default,,0000,0000,0000,,こういう単純な ペンやノートも だめだったよ
Dialogue: 0,0:06:59.15,0:07:02.82,Default,,0000,0000,0000,,持ち運ぶのには 何か特別な儀式を?
Dialogue: 0,0:06:59.15,0:07:02.82,Default,,0000,0000,0000,,いいや
Dialogue: 0,0:07:02.82,0:07:04.82,Default,,0000,0000,0000,,ただ枕元に置くだけだよ
Dialogue: 0,0:07:04.82,0:07:07.33,Default,,0000,0000,0000,,興味深いわ
Dialogue: 0,0:07:07.33,0:07:10.83,Default,,0000,0000,0000,,そうかなぁ?
Dialogue: 0,0:07:10.83,0:07:14.83,Default,,0000,0000,0000,,お弁当を運べるだけじゃ あまり役に立ちそうもないけど
Dialogue: 0,0:07:14.83,0:07:18.67,Default,,0000,0000,0000,,ううん 違うの
Dialogue: 0,0:07:14.83,0:07:18.67,Default,,0000,0000,0000,,飲食物だけが平気なら
Dialogue: 0,0:07:18.67,0:07:21.34,Default,,0000,0000,0000,,それは誰かが 「管理」していることになる
Dialogue: 0,0:07:21.34,0:07:24.84,Default,,0000,0000,0000,,誰かが決めたルールがあるってこと?
Dialogue: 0,0:07:24.84,0:07:29.68,Default,,0000,0000,0000,,うん そうなると 私を運べた理由も あるでしょうし
Dialogue: 0,0:07:29.68,0:07:33.12,Default,,0000,0000,0000,,あなたには 何かしらの意味や 役割があってしかるべきよ
Dialogue: 0,0:07:33.12,0:07:36.79,Default,,0000,0000,0000,,ひょっとして カズヒホは 何か 使命を受けているんじゃない?
Dialogue: 0,0:07:36.79,0:07:39.96,Default,,0000,0000,0000,,えっ!? 使命? お弁当が?
Dialogue: 0,0:07:39.96,0:07:44.63,Default,,0000,0000,0000,,いえ お弁当は ひとまず忘れてちょうだい
Dialogue: 0,0:07:44.63,0:07:47.80,Default,,0000,0000,0000,,誰かから何かを 頼まれていたりはしない?
Dialogue: 0,0:07:47.80,0:07:51.64,Default,,0000,0000,0000,,いや 誰かに このことを話したこともないし
Dialogue: 0,0:07:51.64,0:07:54.47,Default,,0000,0000,0000,,そもそも夢だと 思っていたからなぁ
Dialogue: 0,0:07:54.47,0:07:58.48,Default,,0000,0000,0000,,じゃあ 夢の世界へ 入れるようになった きっかけはあるかしら?
Dialogue: 0,0:07:58.48,0:08:01.65,Default,,0000,0000,0000,,物心ついたときから 遊んでいたから
Dialogue: 0,0:08:01.65,0:08:04.98,Default,,0000,0000,0000,,覚えていないなぁ
Dialogue: 0,0:08:04.98,0:08:06.99,Default,,0000,0000,0000,,しかたないわね
Dialogue: 0,0:08:06.99,0:08:08.99,Default,,0000,0000,0000,,何か思い出したら 教えてちょうだい
Dialogue: 0,0:08:08.99,0:08:10.99,Default,,0000,0000,0000,,うん そうするよ
Dialogue: 0,0:08:10.99,0:08:15.50,Default,,0000,0000,0000,,それじゃあ まずは 目の前の問題をどうにかしようか
Dialogue: 0,0:08:15.50,0:08:18.50,Default,,0000,0000,0000,,無事にマリーを 送り届けられたとして
Dialogue: 0,0:08:18.50,0:08:22.00,Default,,0000,0000,0000,,目覚めた僕らは どうなると思う?
Dialogue: 0,0:08:18.50,0:08:22.00,Default,,0000,0000,0000,,どうって
Dialogue: 0,0:08:22.00,0:08:25.00,Default,,0000,0000,0000,,あっ そういうことね
Dialogue: 0,0:08:25.00,0:08:28.67,Default,,0000,0000,0000,,私としたことが 遊びほうけて すっかり忘れていたわ
Dialogue: 0,0:08:28.67,0:08:34.28,Default,,0000,0000,0000,,そう 夢の中で目覚めたとき
Dialogue: 0,0:08:28.67,0:08:34.28,Default,,0000,0000,0000,,僕らは同じ場所で起きてしまう
Dialogue: 0,0:08:34.28,0:08:37.08,Default,,0000,0000,0000,,あの魔導竜の待つ寝床で
Dialogue: 0,0:08:39.12,0:08:42.62,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:08:39.12,0:08:42.62,Default,,0000,0000,0000,,さぁ 秘密の作戦会議だ
Dialogue: 0,0:08:45.12,0:08:47.13,Default,,0000,0000,0000,,ねっ そういうわけで
Dialogue: 0,0:08:47.13,0:08:50.30,Default,,0000,0000,0000,,竜の卵を人質にする案も 却下するわ
Dialogue: 0,0:08:50.30,0:08:52.80,Default,,0000,0000,0000,,一時しのぎで逃げられても
Dialogue: 0,0:08:52.80,0:08:56.80,Default,,0000,0000,0000,,寝床を知った人間を 竜が生かしておくはずないもの
Dialogue: 0,0:08:56.80,0:08:59.47,Default,,0000,0000,0000,,同感だね
Dialogue: 0,0:08:59.47,0:09:02.81,Default,,0000,0000,0000,,下手したら ずっと追われることに なりかねないし
Dialogue: 0,0:09:02.81,0:09:06.81,Default,,0000,0000,0000,,僕は不眠症になりそうだ
Dialogue: 0,0:09:06.81,0:09:11.15,Default,,0000,0000,0000,,魔導竜について書かれた文献で 知っていることはない?
Dialogue: 0,0:09:11.15,0:09:15.99,Default,,0000,0000,0000,,ええと 例えば 人よりも高い知性
Dialogue: 0,0:09:15.99,0:09:20.49,Default,,0000,0000,0000,,その呼吸は魔力を生み 決して底をつくことはない
Dialogue: 0,0:09:20.49,0:09:24.50,Default,,0000,0000,0000,,過去の事象として 島の破壊や地底火山噴火の誘発
Dialogue: 0,0:09:24.50,0:09:27.83,Default,,0000,0000,0000,,魔族や人間との戦いは 数えきれないほど
Dialogue: 0,0:09:27.83,0:09:31.17,Default,,0000,0000,0000,,あっ えぇと
Dialogue: 0,0:09:27.83,0:09:31.17,Default,,0000,0000,0000,,そういうのじゃなくて
Dialogue: 0,0:09:31.17,0:09:36.28,Default,,0000,0000,0000,,もっと豆知識とか逸話とか
Dialogue: 0,0:09:31.17,0:09:36.28,Default,,0000,0000,0000,,人となりの わかるものがいいな
Dialogue: 0,0:09:36.28,0:09:39.61,Default,,0000,0000,0000,,人となり? あなた何言ってるの?
Dialogue: 0,0:09:39.61,0:09:42.45,Default,,0000,0000,0000,,竜に性格も何も ないと思うけど
Dialogue: 0,0:09:42.45,0:09:44.45,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:09:44.45,0:09:47.45,Default,,0000,0000,0000,,あなたの望む情報かは わからないけど
Dialogue: 0,0:09:44.45,0:09:47.45,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:09:47.45,0:09:51.29,Default,,0000,0000,0000,,ウロコは魔力を生み出すから 相当な価値があるわ
Dialogue: 0,0:09:51.29,0:09:53.96,Default,,0000,0000,0000,,もし手に入れたら大金持ちね
Dialogue: 0,0:09:53.96,0:09:56.63,Default,,0000,0000,0000,,それから 好奇心が強いのか
Dialogue: 0,0:09:56.63,0:09:59.97,Default,,0000,0000,0000,,人の姿になって 都市に入ったこともあるとか
Dialogue: 0,0:09:59.97,0:10:02.97,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:09:59.97,0:10:02.97,Default,,0000,0000,0000,,まぁ これは眉唾かしら
Dialogue: 0,0:10:02.97,0:10:05.97,Default,,0000,0000,0000,,いや それ詳しく知りたいな
Dialogue: 0,0:10:05.97,0:10:10.48,Default,,0000,0000,0000,,どうして竜がそこへ行ったか 何か理由があるはずだ
Dialogue: 0,0:10:10.48,0:10:13.81,Default,,0000,0000,0000,,それが 何もしなかったそうよ
Dialogue: 0,0:10:13.81,0:10:16.98,Default,,0000,0000,0000,,えっ 何も?
Dialogue: 0,0:10:13.81,0:10:16.98,Default,,0000,0000,0000,,文献には
Dialogue: 0,0:10:16.98,0:10:21.49,Default,,0000,0000,0000,,「数日過ごしたあと どこかへ去った」と書かれていたわ
Dialogue: 0,0:10:21.49,0:10:24.49,Default,,0000,0000,0000,,たしか場所は 港町オッズロイだったかしら
Dialogue: 0,0:10:24.49,0:10:27.99,Default,,0000,0000,0000,,オッズロイ まさか いや
Dialogue: 0,0:10:27.99,0:10:31.80,Default,,0000,0000,0000,,案外それが理由なのかも
Dialogue: 0,0:10:27.99,0:10:31.80,Default,,0000,0000,0000,,カズヒホ?
Dialogue: 0,0:10:34.83,0:10:36.84,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:10:39.67,0:10:43.18,Default,,0000,0000,0000,,うわぁ! やっぱり すごく寝心地がよさそうね!
Dialogue: 0,0:10:43.18,0:10:46.68,Default,,0000,0000,0000,,うんっ ウフフ
Dialogue: 0,0:10:48.68,0:10:52.18,Default,,0000,0000,0000,,ウフッ フカフカで気持ちいいわ
Dialogue: 0,0:10:52.18,0:10:55.69,Default,,0000,0000,0000,,あぁ これは完全に 失念していたなぁ
Dialogue: 0,0:10:55.69,0:10:58.69,Default,,0000,0000,0000,,さっ 「秘密兵器」も準備できたし
Dialogue: 0,0:10:58.69,0:11:01.36,Default,,0000,0000,0000,,元の世界に戻れるか 試してみましょう!
Dialogue: 0,0:11:01.36,0:11:04.70,Default,,0000,0000,0000,,ほら カズヒホも来て!
Dialogue: 0,0:11:04.70,0:11:06.70,Default,,0000,0000,0000,,ウッ
Dialogue: 0,0:11:06.70,0:11:10.04,Default,,0000,0000,0000,,大丈夫か
Dialogue: 0,0:11:10.04,0:11:13.04,Default,,0000,0000,0000,,大丈夫なんだろうな?
Dialogue: 0,0:11:13.04,0:11:15.54,Default,,0000,0000,0000,,信じているぞ 僕!
Dialogue: 0,0:11:15.54,0:11:18.54,Default,,0000,0000,0000,,では実験開始ね えと
Dialogue: 0,0:11:18.54,0:11:21.55,Default,,0000,0000,0000,,しっかりつかまっていたほうが いいのかしら
Dialogue: 0,0:11:21.55,0:11:23.72,Default,,0000,0000,0000,,うん たぶんね
Dialogue: 0,0:11:23.72,0:11:26.89,Default,,0000,0000,0000,,あのとき僕らは しっかり抱き合っていたから
Dialogue: 0,0:11:26.89,0:11:30.39,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:26.89,0:11:30.39,Default,,0000,0000,0000,,あのときの体勢と似せようか
Dialogue: 0,0:11:30.39,0:11:33.49,Default,,0000,0000,0000,,おいで マリー
Dialogue: 0,0:11:33.49,0:11:36.00,Default,,0000,0000,0000,,はい
Dialogue: 0,0:11:36.00,0:11:39.00,Default,,0000,0000,0000,,もっと くっついたほうが いいかしら
Dialogue: 0,0:11:39.00,0:11:43.00,Default,,0000,0000,0000,,うん たぶん ほら もう少し
Dialogue: 0,0:11:47.34,0:11:50.04,Default,,0000,0000,0000,,あったかいね
Dialogue: 0,0:12:07.86,0:12:09.86,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:09.86,0:12:11.86,Default,,0000,0000,0000,,ふわぁ
Dialogue: 0,0:12:11.86,0:12:13.87,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:12:13.87,0:12:17.87,Default,,0000,0000,0000,,どうやら無事に 帰ってこれたようだね
Dialogue: 0,0:12:13.87,0:12:17.87,Default,,0000,0000,0000,,えぇ
Dialogue: 0,0:12:17.87,0:12:20.21,Default,,0000,0000,0000,,危険な目に 遭わせてしまって ごめん
Dialogue: 0,0:12:20.21,0:12:25.38,Default,,0000,0000,0000,,いいの 私は楽しかったわ
Dialogue: 0,0:12:20.21,0:12:25.38,Default,,0000,0000,0000,,いろいろありがとう
Dialogue: 0,0:12:25.38,0:12:27.68,Default,,0000,0000,0000,,さぁ 作戦開始ね
Dialogue: 0,0:12:29.72,0:12:31.72,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:31.72,0:12:33.72,Default,,0000,0000,0000,,わぁ!
Dialogue: 0,0:12:31.72,0:12:33.72,Default,,0000,0000,0000,,キャッ!
Dialogue: 0,0:12:37.49,0:12:39.99,Default,,0000,0000,0000,,グルル
Dialogue: 0,0:12:39.99,0:12:42.66,Default,,0000,0000,0000,,マリー 絶対に離れないで!
Dialogue: 0,0:12:42.66,0:12:46.83,Default,,0000,0000,0000,,あの! 僕はカズヒホといいます!
Dialogue: 0,0:12:46.83,0:12:49.00,Default,,0000,0000,0000,,こちらは マリアーベルです
Dialogue: 0,0:12:49.00,0:12:52.17,Default,,0000,0000,0000,,ごめんなさい 勝手に寝床に入って
Dialogue: 0,0:12:52.17,0:12:57.01,Default,,0000,0000,0000,,あなたの卵を見たくて 僕が彼女を 無理に連れてきたんです
Dialogue: 0,0:12:57.01,0:13:00.51,Default,,0000,0000,0000,,せめて マリーだけでも 逃がしてもらえませんか?
Dialogue: 0,0:13:00.51,0:13:04.52,Default,,0000,0000,0000,,竜の言語
Dialogue: 0,0:13:00.51,0:13:04.52,Default,,0000,0000,0000,,なんて言ってるのかしら
Dialogue: 0,0:13:04.52,0:13:06.52,Default,,0000,0000,0000,,卵を守る竜は
Dialogue: 0,0:13:06.52,0:13:11.36,Default,,0000,0000,0000,,強い防衛本能に突き動かされる
Dialogue: 0,0:13:06.52,0:13:11.36,Default,,0000,0000,0000,,最も重要なのは
Dialogue: 0,0:13:11.36,0:13:15.03,Default,,0000,0000,0000,,敵意がないと伝えること
Dialogue: 0,0:13:11.36,0:13:15.03,Default,,0000,0000,0000,,そして
Dialogue: 0,0:13:15.03,0:13:17.53,Default,,0000,0000,0000,,お詫びの品というわけでは ありませんが
Dialogue: 0,0:13:17.53,0:13:21.03,Default,,0000,0000,0000,,どうか こちらで 怒りを鎮めていただけませんか
Dialogue: 0,0:13:21.03,0:13:25.54,Default,,0000,0000,0000,,相手の意表をついて 我に返らせること
Dialogue: 0,0:13:25.54,0:13:28.04,Default,,0000,0000,0000,,一人で旅ばかりしてきたから
Dialogue: 0,0:13:28.04,0:13:31.04,Default,,0000,0000,0000,,オッズロイも一度 訪ねたことがあってね
Dialogue: 0,0:13:31.04,0:13:34.65,Default,,0000,0000,0000,,大麦麦芽を使った酒が有名なんだ
Dialogue: 0,0:13:34.65,0:13:37.65,Default,,0000,0000,0000,,他に特徴のない小さな街だから
Dialogue: 0,0:13:37.65,0:13:41.15,Default,,0000,0000,0000,,もし逸話が本当なら
Dialogue: 0,0:13:41.15,0:13:43.16,Default,,0000,0000,0000,,魔導竜は
Dialogue: 0,0:13:47.49,0:13:49.50,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:13:49.50,0:13:52.33,Default,,0000,0000,0000,,下級竜の言葉を話し
Dialogue: 0,0:13:52.33,0:13:56.00,Default,,0000,0000,0000,,ワシの楽しみも知っているとは おもしろい人間だ
Dialogue: 0,0:13:56.00,0:13:59.51,Default,,0000,0000,0000,,昨日 確かに 吹き飛ばしたというのに
Dialogue: 0,0:13:59.51,0:14:02.68,Default,,0000,0000,0000,,無傷で目覚めたお前たちが 不思議でもある
Dialogue: 0,0:14:02.68,0:14:06.18,Default,,0000,0000,0000,,どうだ その謎を明かしてくれるなら
Dialogue: 0,0:14:06.18,0:14:10.68,Default,,0000,0000,0000,,命までは奪わぬでおこう
Dialogue: 0,0:14:06.18,0:14:10.68,Default,,0000,0000,0000,,はい! お話しいたします!
Dialogue: 0,0:14:10.68,0:14:14.69,Default,,0000,0000,0000,,マリー 許してくれるって!
Dialogue: 0,0:14:10.68,0:14:14.69,Default,,0000,0000,0000,,ウゥ
Dialogue: 0,0:14:10.68,0:14:14.69,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:14:14.69,0:14:16.69,Default,,0000,0000,0000,,フゥ
Dialogue: 0,0:14:32.20,0:14:36.98,Default,,0000,0000,0000,,フム 夢を通じて 別の世界からやってきたとは
Dialogue: 0,0:14:36.98,0:14:41.15,Default,,0000,0000,0000,,して そのエルフも お主の世界へ行ったと?
Dialogue: 0,0:14:41.15,0:14:44.15,Default,,0000,0000,0000,,なんとも興味をかきたてられる
Dialogue: 0,0:14:44.15,0:14:47.49,Default,,0000,0000,0000,,して 卵を見たいと 言っておったな?
Dialogue: 0,0:14:47.49,0:14:52.32,Default,,0000,0000,0000,,いいだろう ふ化するまで 退屈しておったしの
Dialogue: 0,0:14:52.32,0:14:56.13,Default,,0000,0000,0000,,わぁ! これが魔導竜の卵!
Dialogue: 0,0:14:58.16,0:15:00.50,Default,,0000,0000,0000,,ねぇ 床が温かいわ
Dialogue: 0,0:15:00.50,0:15:03.50,Default,,0000,0000,0000,,地熱で卵を温めているのかな
Dialogue: 0,0:15:03.50,0:15:07.34,Default,,0000,0000,0000,,フーム その匂いが どうにも気になる
Dialogue: 0,0:15:07.34,0:15:11.01,Default,,0000,0000,0000,,カズヒホとやら 何を隠し持っておる
Dialogue: 0,0:15:11.01,0:15:14.81,Default,,0000,0000,0000,,えっ 別に何も あっ
Dialogue: 0,0:15:16.85,0:15:19.18,Default,,0000,0000,0000,,あら お弁当のカツ丼!
Dialogue: 0,0:15:19.18,0:15:23.52,Default,,0000,0000,0000,,うん これが地熱で温まって 匂いがたったみたい
Dialogue: 0,0:15:23.52,0:15:28.03,Default,,0000,0000,0000,,このお弁当の匂いです
Dialogue: 0,0:15:23.52,0:15:28.03,Default,,0000,0000,0000,,嫌でしたら遠くに離します
Dialogue: 0,0:15:28.03,0:15:30.20,Default,,0000,0000,0000,,いや かまわない
Dialogue: 0,0:15:30.20,0:15:34.30,Default,,0000,0000,0000,,フーム それより この体では 話しづらくてかなわぬ
Dialogue: 0,0:15:34.30,0:15:36.64,Default,,0000,0000,0000,,おまけに せっかくの詫び酒も
Dialogue: 0,0:15:36.64,0:15:39.47,Default,,0000,0000,0000,,このままでは舌を湿らすだけで 終わってしまう
Dialogue: 0,0:15:39.47,0:15:41.47,Default,,0000,0000,0000,,よし
Dialogue: 0,0:15:41.47,0:15:45.64,Default,,0000,0000,0000,,ド・イオ・ナムフ・エモケブ
Dialogue: 0,0:15:45.64,0:15:48.81,Default,,0000,0000,0000,,あっ!?
Dialogue: 0,0:15:45.64,0:15:48.81,Default,,0000,0000,0000,,竜魔法! 初めて見るわ!
Dialogue: 0,0:15:48.81,0:15:51.48,Default,,0000,0000,0000,,カズヒホには わからないでしょうけど
Dialogue: 0,0:15:51.48,0:15:53.99,Default,,0000,0000,0000,,今 高密度の魔力が 練られているの!
Dialogue: 0,0:15:53.99,0:15:58.16,Default,,0000,0000,0000,,人の魔術なんて足元にも及ばない 高い次元のものよ!
Dialogue: 0,0:15:58.16,0:16:00.49,Default,,0000,0000,0000,,見てっ 発動するわ!
Dialogue: 0,0:16:18.68,0:16:21.08,Default,,0000,0000,0000,,ひ 人が生まれた!?
Dialogue: 0,0:16:23.02,0:16:25.68,Default,,0000,0000,0000,,違うわ あれは竜人よ!
Dialogue: 0,0:16:25.68,0:16:28.52,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:16:25.68,0:16:28.52,Default,,0000,0000,0000,,伝説が本当のことだったなんて
Dialogue: 0,0:16:28.52,0:16:33.13,Default,,0000,0000,0000,,フーム この姿を生み出したのは 実に久かたぶりである
Dialogue: 0,0:16:33.13,0:16:37.46,Default,,0000,0000,0000,,どうだ 人の目から見て おかしなところはないか?
Dialogue: 0,0:16:37.46,0:16:41.30,Default,,0000,0000,0000,,あっ はい すごくお美しいです
Dialogue: 0,0:16:41.30,0:16:43.30,Default,,0000,0000,0000,,フッフッ ならばよい
Dialogue: 0,0:16:43.30,0:16:47.81,Default,,0000,0000,0000,,では人の子よ!
Dialogue: 0,0:16:43.30,0:16:47.81,Default,,0000,0000,0000,,その酒と馳走をよこすがいい!
Dialogue: 0,0:16:47.81,0:16:49.98,Default,,0000,0000,0000,,えっ このカツ丼ですか?
Dialogue: 0,0:16:49.98,0:16:53.31,Default,,0000,0000,0000,,でも 僕の料理なんて 大したものでは
Dialogue: 0,0:16:53.31,0:16:55.31,Default,,0000,0000,0000,,ぬっ 貴様!
Dialogue: 0,0:16:55.31,0:16:58.48,Default,,0000,0000,0000,,ワシが下級の者どもの 馳走など 欲しがるわけが
Dialogue: 0,0:16:58.48,0:17:02.99,Default,,0000,0000,0000,,ああ いや違う つまり 味見だ味見!
Dialogue: 0,0:17:02.99,0:17:05.16,Default,,0000,0000,0000,,そう これはただの味見じゃ!
Dialogue: 0,0:17:05.16,0:17:08.33,Default,,0000,0000,0000,,あ
Dialogue: 0,0:17:05.16,0:17:08.33,Default,,0000,0000,0000,,ねぇ なんて言ってるの?
Dialogue: 0,0:17:08.33,0:17:11.00,Default,,0000,0000,0000,,ええと カツ丼をね
Dialogue: 0,0:17:11.00,0:17:13.50,Default,,0000,0000,0000,,えっ 何? カツ丼が何?
Dialogue: 0,0:17:13.50,0:17:16.00,Default,,0000,0000,0000,,食べたいんだって
Dialogue: 0,0:17:13.50,0:17:16.00,Default,,0000,0000,0000,,あぁ そうなんだ
Dialogue: 0,0:17:16.00,0:17:18.17,Default,,0000,0000,0000,,食べたいんだって
Dialogue: 0,0:17:18.17,0:17:22.17,Default,,0000,0000,0000,,そうじゃな
Dialogue: 0,0:17:18.17,0:17:22.17,Default,,0000,0000,0000,,礼の一つも ないわけではないぞ
Dialogue: 0,0:17:22.17,0:17:24.18,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:17:24.18,0:17:27.01,Default,,0000,0000,0000,,どうだ ワシのウロコを1枚やろう!
Dialogue: 0,0:17:27.01,0:17:30.02,Default,,0000,0000,0000,,身から落ちて 魔力切れしたものではないぞ
Dialogue: 0,0:17:30.02,0:17:32.45,Default,,0000,0000,0000,,今 生えているものをじゃぞ!
Dialogue: 0,0:17:32.45,0:17:35.62,Default,,0000,0000,0000,,えっ あっ いいのですか?
Dialogue: 0,0:17:35.62,0:17:38.62,Default,,0000,0000,0000,,マリーも欲しがっていましたし うれしいですが
Dialogue: 0,0:17:38.62,0:17:42.63,Default,,0000,0000,0000,,うむ! 交渉成立じゃな!
Dialogue: 0,0:17:38.62,0:17:42.63,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:17:42.63,0:17:44.63,Default,,0000,0000,0000,,あ はむっ
Dialogue: 0,0:17:47.30,0:17:50.64,Default,,0000,0000,0000,,す すごい光景だね
Dialogue: 0,0:17:47.30,0:17:50.64,Default,,0000,0000,0000,,えぇ
Dialogue: 0,0:17:50.64,0:17:54.54,Default,,0000,0000,0000,,はむっ んっ
Dialogue: 0,0:17:50.64,0:17:54.54,Default,,0000,0000,0000,,んまっ んまいのぅ!
Dialogue: 0,0:17:56.48,0:17:58.81,Default,,0000,0000,0000,,んっ んっ
Dialogue: 0,0:17:56.48,0:17:58.81,Default,,0000,0000,0000,,あの ビールもいかがですか?
Dialogue: 0,0:17:58.81,0:18:02.48,Default,,0000,0000,0000,,おぉ!
Dialogue: 0,0:18:02.48,0:18:04.82,Default,,0000,0000,0000,,どうぞ
Dialogue: 0,0:18:02.48,0:18:04.82,Default,,0000,0000,0000,,ほぅ
Dialogue: 0,0:18:04.82,0:18:09.32,Default,,0000,0000,0000,,黄金色のきれいな光景まで 楽しめるとは
Dialogue: 0,0:18:09.32,0:18:11.32,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:18:13.33,0:18:15.33,Default,,0000,0000,0000,,かぁっ!
Dialogue: 0,0:18:15.33,0:18:20.00,Default,,0000,0000,0000,,ぐうっ これはっ!
Dialogue: 0,0:18:15.33,0:18:20.00,Default,,0000,0000,0000,,フム 悪くないぞ
Dialogue: 0,0:18:20.00,0:18:22.33,Default,,0000,0000,0000,,及第点といったところだ
Dialogue: 0,0:18:20.00,0:18:22.33,Default,,0000,0000,0000,,フフフ
Dialogue: 0,0:18:22.33,0:18:27.34,Default,,0000,0000,0000,,ときに このような馳走を
Dialogue: 0,0:18:22.33,0:18:27.34,Default,,0000,0000,0000,,人はみな食しておるのか?
Dialogue: 0,0:18:27.34,0:18:29.34,Default,,0000,0000,0000,,あっ いえ
Dialogue: 0,0:18:29.34,0:18:32.61,Default,,0000,0000,0000,,この酒と料理は この世界では出回ってないかと
Dialogue: 0,0:18:32.61,0:18:34.61,Default,,0000,0000,0000,,なんじゃ せっかく
Dialogue: 0,0:18:34.61,0:18:37.78,Default,,0000,0000,0000,,人里を支配してやろうと 思うたのに
Dialogue: 0,0:18:34.61,0:18:37.78,Default,,0000,0000,0000,,危な
Dialogue: 0,0:18:37.78,0:18:42.12,Default,,0000,0000,0000,,お弁当も 気に入ってくれたみたいで よかったわね
Dialogue: 0,0:18:40.12,0:18:42.12,Default,,0000,0000,0000,,うん
Dialogue: 0,0:18:42.12,0:18:45.29,Default,,0000,0000,0000,,あぁ そうそう お礼にウロコをくれるってさ
Dialogue: 0,0:18:45.29,0:18:48.96,Default,,0000,0000,0000,,なっ!
Dialogue: 0,0:18:45.29,0:18:48.96,Default,,0000,0000,0000,,お弁当一つで魔導竜のウロコを!?
Dialogue: 0,0:18:48.96,0:18:51.96,Default,,0000,0000,0000,,えっ? そんなにすごいものなの?
Dialogue: 0,0:18:51.96,0:18:54.80,Default,,0000,0000,0000,,すごい価値よ!
Dialogue: 0,0:18:51.96,0:18:54.80,Default,,0000,0000,0000,,そうね 魔術師なら
Dialogue: 0,0:18:54.80,0:18:59.47,Default,,0000,0000,0000,,出せる限りの資産を ひねり出すはずと言えばわかるかしら
Dialogue: 0,0:18:59.47,0:19:02.47,Default,,0000,0000,0000,,ウロコをめぐって 戦争が起きたほどよ!
Dialogue: 0,0:18:59.47,0:19:02.47,Default,,0000,0000,0000,,えっ!
Dialogue: 0,0:19:04.98,0:19:07.65,Default,,0000,0000,0000,,なくなってしもうた
Dialogue: 0,0:19:07.65,0:19:13.49,Default,,0000,0000,0000,,なぜじゃ 食べたら消えた
Dialogue: 0,0:19:07.65,0:19:13.49,Default,,0000,0000,0000,,さっきまであったのに ない
Dialogue: 0,0:19:13.49,0:19:17.16,Default,,0000,0000,0000,,あっ もう一つありますが
Dialogue: 0,0:19:13.49,0:19:17.16,Default,,0000,0000,0000,,くれっ!
Dialogue: 0,0:19:17.16,0:19:19.16,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:17.16,0:19:19.16,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:19:21.16,0:19:23.83,Default,,0000,0000,0000,,あぁ もちろん対価は支払おう
Dialogue: 0,0:19:23.83,0:19:27.00,Default,,0000,0000,0000,,ほれ この石はどうじゃ?
Dialogue: 0,0:19:27.00,0:19:32.00,Default,,0000,0000,0000,,人というのは これが好きらしいがワシには価値が まったくわからぬ
Dialogue: 0,0:19:32.00,0:19:37.11,Default,,0000,0000,0000,,何かしら? 青い石?
Dialogue: 0,0:19:32.00,0:19:37.11,Default,,0000,0000,0000,,あの この石はなんですか?
Dialogue: 0,0:19:37.11,0:19:39.78,Default,,0000,0000,0000,,ワシの血が染み込んだ石である
Dialogue: 0,0:19:39.78,0:19:44.78,Default,,0000,0000,0000,,ほれ 卵を産んだじゃろう?
Dialogue: 0,0:19:39.78,0:19:44.78,Default,,0000,0000,0000,,そのとき血が石についたのだ
Dialogue: 0,0:19:44.78,0:19:47.12,Default,,0000,0000,0000,,魔導竜の血だって
Dialogue: 0,0:19:47.12,0:19:49.62,Default,,0000,0000,0000,,竜の血って 青いんだねぇ
Dialogue: 0,0:19:49.62,0:19:52.12,Default,,0000,0000,0000,,か て
Dialogue: 0,0:19:49.62,0:19:52.12,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:19:52.12,0:19:55.63,Default,,0000,0000,0000,,お弁当と その石を 早く換えてあげて!
Dialogue: 0,0:19:55.63,0:19:59.33,Default,,0000,0000,0000,,うむ うむ 交渉成立であるな!
Dialogue: 0,0:20:01.47,0:20:03.97,Default,,0000,0000,0000,,人の子らよ また来るがいい
Dialogue: 0,0:20:03.97,0:20:07.64,Default,,0000,0000,0000,,そして今度は お弁当を3つ いや
Dialogue: 0,0:20:07.64,0:20:10.81,Default,,0000,0000,0000,,4つ! 持ってくるがいいぞ!
Dialogue: 0,0:20:10.81,0:20:13.98,Default,,0000,0000,0000,,4つ! 4つじゃぞ!
Dialogue: 0,0:20:13.98,0:20:16.48,Default,,0000,0000,0000,,りゅ 竜の血
Dialogue: 0,0:20:16.48,0:20:20.59,Default,,0000,0000,0000,,お弁当と交換で 竜の血
Dialogue: 0,0:20:16.48,0:20:20.59,Default,,0000,0000,0000,,大丈夫!?
Dialogue: 0,0:20:22.65,0:20:25.32,Default,,0000,0000,0000,,うん ありがとう
Dialogue: 0,0:20:25.32,0:20:29.49,Default,,0000,0000,0000,,竜の血ってね 万病に効くと言われてるの
Dialogue: 0,0:20:29.49,0:20:32.66,Default,,0000,0000,0000,,ウロコもそうだけど あまりにも価値が高すぎて
Dialogue: 0,0:20:32.66,0:20:35.00,Default,,0000,0000,0000,,困っているわ
Dialogue: 0,0:20:32.66,0:20:35.00,Default,,0000,0000,0000,,じゃあ
Dialogue: 0,0:20:35.00,0:20:38.84,Default,,0000,0000,0000,,適当に売ってしまうか 病気の人にあげればいいかもね
Dialogue: 0,0:20:38.84,0:20:40.84,Default,,0000,0000,0000,,そうはいかないわ
Dialogue: 0,0:20:40.84,0:20:43.18,Default,,0000,0000,0000,,どちらも高値には 違いないけれど
Dialogue: 0,0:20:43.18,0:20:46.85,Default,,0000,0000,0000,,それだけに 必ず 手に入れた場所を聞かれるわ
Dialogue: 0,0:20:46.85,0:20:49.68,Default,,0000,0000,0000,,黙っているなんて絶対に不可能よ
Dialogue: 0,0:20:49.68,0:20:53.02,Default,,0000,0000,0000,,魔導竜の寝床が 知られてしまうのか
Dialogue: 0,0:20:53.02,0:20:55.85,Default,,0000,0000,0000,,あっ そうか
Dialogue: 0,0:20:55.85,0:20:57.86,Default,,0000,0000,0000,,謎が解けたよ
Dialogue: 0,0:20:57.86,0:21:00.86,Default,,0000,0000,0000,,この遺跡の文明が どうして滅んだか
Dialogue: 0,0:21:00.86,0:21:04.86,Default,,0000,0000,0000,,千年に一度 魔導竜は産卵を行う
Dialogue: 0,0:21:04.86,0:21:09.57,Default,,0000,0000,0000,,きっとそのとき ここに暮らしていた人たちは 手を出したんだ
Dialogue: 0,0:21:11.54,0:21:15.71,Default,,0000,0000,0000,,執念深い竜は地下都市まで追い 住民は逃げ出し
Dialogue: 0,0:21:15.71,0:21:18.88,Default,,0000,0000,0000,,そのまま竜の寝床に なったっていうこと?
Dialogue: 0,0:21:18.88,0:21:22.05,Default,,0000,0000,0000,,本当なら ゾッとする話だけど
Dialogue: 0,0:21:22.05,0:21:25.22,Default,,0000,0000,0000,,ちょうど遺跡が滅びた時期と 合っているわ
Dialogue: 0,0:21:25.22,0:21:27.39,Default,,0000,0000,0000,,なら決まりね
Dialogue: 0,0:21:27.39,0:21:32.06,Default,,0000,0000,0000,,これをどうするか考えるのは 魔導竜がここを巣立ったあと
Dialogue: 0,0:21:32.06,0:21:35.99,Default,,0000,0000,0000,,それに持ち主は あなたのほうが絶対に安全よ
Dialogue: 0,0:21:35.99,0:21:39.33,Default,,0000,0000,0000,,えぇ
Dialogue: 0,0:21:35.99,0:21:39.33,Default,,0000,0000,0000,,なくしちゃったら どうしよう
Dialogue: 0,0:21:39.33,0:21:43.17,Default,,0000,0000,0000,,そのときは そのとき
Dialogue: 0,0:21:39.33,0:21:43.17,Default,,0000,0000,0000,,私は怒ったりなんてしないわ
Dialogue: 0,0:21:43.17,0:21:46.17,Default,,0000,0000,0000,,いつか酒場でかっこつけて こう言うの
Dialogue: 0,0:21:46.17,0:21:50.51,Default,,0000,0000,0000,,「俺たちは伝説の魔導竜と 出会ったぜ」ってね
Dialogue: 0,0:21:50.51,0:21:53.68,Default,,0000,0000,0000,,実際は カツ丼食べるのを 見ただけだけど
Dialogue: 0,0:21:53.68,0:21:57.35,Default,,0000,0000,0000,,まぁ 少なくとも 子どもたちには自慢できそうだね
Dialogue: 0,0:21:57.35,0:21:59.35,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:21:57.35,0:21:59.35,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:22:02.69,0:22:04.69,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:22:02.69,0:22:04.69,Default,,0000,0000,0000,,はぁ
Dialogue: 0,0:22:04.69,0:22:08.36,Default,,0000,0000,0000,,カツ丼 食べ損ねたせいで すっかりお腹が空いちゃったね
Dialogue: 0,0:22:08.36,0:22:11.70,Default,,0000,0000,0000,,近くの街に出ましょう
Dialogue: 0,0:22:08.36,0:22:11.70,Default,,0000,0000,0000,,シスルか
Dialogue: 0,0:22:11.70,0:22:16.03,Default,,0000,0000,0000,,どこも薄味なのよね
Dialogue: 0,0:22:11.70,0:22:16.03,Default,,0000,0000,0000,,まぁ たまには しかたない
Dialogue: 0,0:22:16.03,0:22:19.54,Default,,0000,0000,0000,,あっ 夜の宿も探さないとね
Dialogue: 0,0:22:19.54,0:22:24.38,Default,,0000,0000,0000,,僕は日本に帰るから どこでもいいけど マリーは困るでしょ
Dialogue: 0,0:22:24.38,0:22:28.38,Default,,0000,0000,0000,,宿へ送ったら いよいよお別れかな
Dialogue: 0,0:22:28.38,0:22:31.38,Default,,0000,0000,0000,,私もどこでもいいわ
Dialogue: 0,0:22:28.38,0:22:31.38,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:22:31.38,0:22:34.82,Default,,0000,0000,0000,,だって あなたの国に私も行くもの
Dialogue: 0,0:22:34.82,0:22:38.66,Default,,0000,0000,0000,,ねっ これから 日本語を教えてちょうだい
Dialogue: 0,0:22:38.66,0:22:41.56,Default,,0000,0000,0000,,あ うん!
