Dialogue: 0,0:00:37.20,0:00:39.21,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:00:41.21,0:00:43.21,Default,,0000,0000,0000,,んんっ
Dialogue: 0,0:00:43.21,0:00:45.88,Default,,0000,0000,0000,,やめ
Dialogue: 0,0:00:45.88,0:00:48.98,Default,,0000,0000,0000,,フフッ やだ
Dialogue: 0,0:00:51.05,0:00:53.72,Default,,0000,0000,0000,,やめてよ マリー
Dialogue: 0,0:00:53.72,0:00:56.22,Default,,0000,0000,0000,,にゃうぅ
Dialogue: 0,0:00:58.22,0:01:01.56,Default,,0000,0000,0000,,うぅ わっ!
Dialogue: 0,0:01:01.56,0:01:04.23,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:01:04.23,0:01:07.23,Default,,0000,0000,0000,,つつ あっ?
Dialogue: 0,0:01:09.24,0:01:11.24,Default,,0000,0000,0000,,にゃうぅ
Dialogue: 0,0:01:11.24,0:01:14.41,Default,,0000,0000,0000,,何やってるの カズヒホ
Dialogue: 0,0:01:14.41,0:01:16.58,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:01:14.41,0:01:16.58,Default,,0000,0000,0000,,みゃ!?
Dialogue: 0,0:01:16.58,0:01:20.58,Default,,0000,0000,0000,,ちゃんと来られたのね ウリドラ!
Dialogue: 0,0:01:16.58,0:01:20.58,Default,,0000,0000,0000,,にゃう
Dialogue: 0,0:01:20.58,0:01:23.58,Default,,0000,0000,0000,,かわいい
Dialogue: 0,0:01:20.58,0:01:23.58,Default,,0000,0000,0000,,そうだった
Dialogue: 0,0:01:25.59,0:01:29.09,Default,,0000,0000,0000,,ターク・イッシ・アブ
Dialogue: 0,0:01:31.09,0:01:33.06,Default,,0000,0000,0000,,わあっ!
Dialogue: 0,0:01:33.06,0:01:35.06,Default,,0000,0000,0000,,猫ちゃん!
Dialogue: 0,0:01:35.06,0:01:39.37,Default,,0000,0000,0000,,コヤツは人間同様に 見たり聞いたり食ったりして
Dialogue: 0,0:01:39.37,0:01:42.87,Default,,0000,0000,0000,,その感覚をワシと共有できる 使い魔じゃ
Dialogue: 0,0:01:42.87,0:01:46.41,Default,,0000,0000,0000,,ワシの代わりに連れてゆくがよい
Dialogue: 0,0:01:49.74,0:01:52.88,Default,,0000,0000,0000,,いいお天気だよ 旅行日和だ
Dialogue: 0,0:01:52.88,0:01:56.22,Default,,0000,0000,0000,,えぇ ワクワクするわ
Dialogue: 0,0:01:56.22,0:01:59.92,Default,,0000,0000,0000,,楽しみにしていたことが 始まるのね
Dialogue: 0,0:03:45.19,0:03:47.69,Default,,0000,0000,0000,,人でぎっしり!
Dialogue: 0,0:03:47.69,0:03:51.70,Default,,0000,0000,0000,,こっちでは こんなに大勢が 旅をしているのね!
Dialogue: 0,0:03:51.70,0:03:55.03,Default,,0000,0000,0000,,ねぇ見て あんなに小さな子まで
Dialogue: 0,0:03:55.03,0:03:58.74,Default,,0000,0000,0000,,うん マリー 手を貸して
Dialogue: 0,0:04:00.87,0:04:06.55,Default,,0000,0000,0000,,東京駅は広くて複雑で
Dialogue: 0,0:04:00.87,0:04:06.55,Default,,0000,0000,0000,,ちょっとした迷宮なんだ
Dialogue: 0,0:04:06.55,0:04:10.22,Default,,0000,0000,0000,,はぐれたら大変だからね
Dialogue: 0,0:04:10.22,0:04:12.89,Default,,0000,0000,0000,,へ そ そうなの!?
Dialogue: 0,0:04:12.89,0:04:18.89,Default,,0000,0000,0000,,カズヒホ 絶対に離さないでよ!
Dialogue: 0,0:04:12.89,0:04:18.89,Default,,0000,0000,0000,,うん わかった
Dialogue: 0,0:04:21.06,0:04:24.90,Default,,0000,0000,0000,,うわぁ お弁当って こんなに種類があるの
Dialogue: 0,0:04:24.90,0:04:26.90,Default,,0000,0000,0000,,どれもおいしそう
Dialogue: 0,0:04:26.90,0:04:31.24,Default,,0000,0000,0000,,ここから一つを選ぶって
Dialogue: 0,0:04:26.90,0:04:31.24,Default,,0000,0000,0000,,どうしましょう
Dialogue: 0,0:04:31.24,0:04:35.17,Default,,0000,0000,0000,,猫ちゃん あなたも一緒に 考えてちょうだい
Dialogue: 0,0:04:35.17,0:04:37.18,Default,,0000,0000,0000,,にうぅ
Dialogue: 0,0:04:37.18,0:04:40.18,Default,,0000,0000,0000,,ゆっくりどうぞ と言いたいけど
Dialogue: 0,0:04:40.18,0:04:44.52,Default,,0000,0000,0000,,ここも混んでるから急ごうね
Dialogue: 0,0:04:40.18,0:04:44.52,Default,,0000,0000,0000,,あら
Dialogue: 0,0:04:44.52,0:04:48.35,Default,,0000,0000,0000,,あなたみたいに のんびりした人に言われるとは
Dialogue: 0,0:04:48.35,0:04:52.03,Default,,0000,0000,0000,,カズヒホは決まってるの?
Dialogue: 0,0:04:48.35,0:04:52.03,Default,,0000,0000,0000,,あっ いや
Dialogue: 0,0:04:52.03,0:04:54.03,Default,,0000,0000,0000,,どうしようかなぁ
Dialogue: 0,0:04:54.03,0:04:57.03,Default,,0000,0000,0000,,ほらごらんなさい!
Dialogue: 0,0:04:54.03,0:04:57.03,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:04:59.20,0:05:01.40,Default,,0000,0000,0000,,アハハッ!
Dialogue: 0,0:05:01.40,0:05:05.24,Default,,0000,0000,0000,,実物は 映像より ずうっと大きく見えるわ!
Dialogue: 0,0:05:05.24,0:05:09.58,Default,,0000,0000,0000,,いかにも速そうな顔をしてるわね 「はやぶさ」くん!
Dialogue: 0,0:05:09.58,0:05:13.58,Default,,0000,0000,0000,,フフッ やっぱり顔に見えるよね
Dialogue: 0,0:05:13.58,0:05:15.55,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:05:17.92,0:05:20.25,Default,,0000,0000,0000,,わ わぁ 速いっ
Dialogue: 0,0:05:20.25,0:05:24.26,Default,,0000,0000,0000,,どんどん景色が変わっていくわ!
Dialogue: 0,0:05:20.25,0:05:24.26,Default,,0000,0000,0000,,にぅ
Dialogue: 0,0:05:24.26,0:05:27.06,Default,,0000,0000,0000,,にうにう
Dialogue: 0,0:05:24.26,0:05:27.06,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:05:27.06,0:05:29.73,Default,,0000,0000,0000,,すっかり一人で堪能してしまって
Dialogue: 0,0:05:29.73,0:05:33.00,Default,,0000,0000,0000,,あなただって お外を見たいわよね
Dialogue: 0,0:05:33.00,0:05:35.00,Default,,0000,0000,0000,,にぅ!
Dialogue: 0,0:05:35.00,0:05:37.84,Default,,0000,0000,0000,,ではでは
Dialogue: 0,0:05:37.84,0:05:42.44,Default,,0000,0000,0000,,新幹線名物 お弁当タイム!
Dialogue: 0,0:05:37.84,0:05:42.44,Default,,0000,0000,0000,,アハハハ!
Dialogue: 0,0:05:44.68,0:05:47.68,Default,,0000,0000,0000,,わぁ!
Dialogue: 0,0:05:44.68,0:05:47.68,Default,,0000,0000,0000,,ずいぶん迷っていたけど
Dialogue: 0,0:05:47.68,0:05:50.52,Default,,0000,0000,0000,,やっぱり幕の内弁当は きれいだね
Dialogue: 0,0:05:50.52,0:05:52.69,Default,,0000,0000,0000,,色とりどりで楽しいわ
Dialogue: 0,0:05:52.69,0:05:55.86,Default,,0000,0000,0000,,でも あなたのシウマイ弁当も
Dialogue: 0,0:05:55.86,0:05:58.69,Default,,0000,0000,0000,,見た目は地味だけどおいしそうね
Dialogue: 0,0:05:58.69,0:06:01.39,Default,,0000,0000,0000,,これは結構 人気があるんだよ
Dialogue: 0,0:06:03.53,0:06:05.73,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:06:11.04,0:06:13.04,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:06:13.04,0:06:17.04,Default,,0000,0000,0000,,これよこれ 和食の上品な味!
Dialogue: 0,0:06:17.04,0:06:19.88,Default,,0000,0000,0000,,猫ちゃんにも あげていいのかしら?
Dialogue: 0,0:06:19.88,0:06:24.38,Default,,0000,0000,0000,,人間と同じように食べるって ウリドラ言ってたよね
Dialogue: 0,0:06:26.55,0:06:30.06,Default,,0000,0000,0000,,フフッ ウリドラも味わえているかしら
Dialogue: 0,0:06:30.06,0:06:33.33,Default,,0000,0000,0000,,マリー こっちのも味見するよね?
Dialogue: 0,0:06:33.33,0:06:35.33,Default,,0000,0000,0000,,もちろん!
Dialogue: 0,0:06:38.83,0:06:40.83,Default,,0000,0000,0000,,んくっ
Dialogue: 0,0:06:49.51,0:06:52.51,Default,,0000,0000,0000,,おいひい
Dialogue: 0,0:06:52.51,0:06:56.02,Default,,0000,0000,0000,,ねっ これも ウリドラに分けてあげてちょうだい
Dialogue: 0,0:06:56.02,0:06:58.52,Default,,0000,0000,0000,,あ あぁ
Dialogue: 0,0:06:58.52,0:07:00.52,Default,,0000,0000,0000,,うんうん
Dialogue: 0,0:07:02.56,0:07:06.93,Default,,0000,0000,0000,,はしゃぎ過ぎて疲れたかな
Dialogue: 0,0:07:02.56,0:07:06.93,Default,,0000,0000,0000,,しばらくおやすみ
Dialogue: 0,0:07:14.40,0:07:17.40,Default,,0000,0000,0000,,僕が祖父の家に 引き取られたのは
Dialogue: 0,0:07:17.40,0:07:20.57,Default,,0000,0000,0000,,小学校5年生のときだった
Dialogue: 0,0:07:20.57,0:07:23.58,Default,,0000,0000,0000,,それまでは 東京で暮らしていたけど
Dialogue: 0,0:07:23.58,0:07:28.08,Default,,0000,0000,0000,,そのころのことは あまり覚えていない
Dialogue: 0,0:07:28.08,0:07:31.08,Default,,0000,0000,0000,,住んでいた街の景色も
Dialogue: 0,0:07:31.08,0:07:34.19,Default,,0000,0000,0000,,2人暮らしだった母の顔さえ
Dialogue: 0,0:07:34.19,0:07:37.46,Default,,0000,0000,0000,,よく思い出せないくらいだ
Dialogue: 0,0:07:39.86,0:07:43.20,Default,,0000,0000,0000,,僕が 夢の世界のほうの 景色ばかり
Dialogue: 0,0:07:43.20,0:07:45.16,Default,,0000,0000,0000,,見ていたからかもしれない
Dialogue: 0,0:07:49.04,0:07:52.87,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:07:49.04,0:07:52.87,Default,,0000,0000,0000,,東京よりちょっと冷えるわね
Dialogue: 0,0:07:52.87,0:07:56.34,Default,,0000,0000,0000,,マリー こっちこっち!
Dialogue: 0,0:07:59.55,0:08:03.05,Default,,0000,0000,0000,,あなたが住んでる街とは まるで違うわね
Dialogue: 0,0:08:03.05,0:08:06.89,Default,,0000,0000,0000,,景色も空気も
Dialogue: 0,0:08:03.05,0:08:06.89,Default,,0000,0000,0000,,ゆったりしてるわ
Dialogue: 0,0:08:06.89,0:08:11.39,Default,,0000,0000,0000,,都会は ザワザワしているからねぇ
Dialogue: 0,0:08:06.89,0:08:11.39,Default,,0000,0000,0000,,わぁ!
Dialogue: 0,0:08:11.39,0:08:14.89,Default,,0000,0000,0000,,畑がずっと向こうまで 続いているわ
Dialogue: 0,0:08:14.89,0:08:18.90,Default,,0000,0000,0000,,どんなにたくさんの野菜が できるのかしら
Dialogue: 0,0:08:18.90,0:08:20.90,Default,,0000,0000,0000,,マリー
Dialogue: 0,0:08:18.90,0:08:20.90,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:08:20.90,0:08:23.40,Default,,0000,0000,0000,,こっちを見てごらん
Dialogue: 0,0:08:23.40,0:08:25.37,Default,,0000,0000,0000,,このカーブを曲がるとね
Dialogue: 0,0:08:28.24,0:08:30.21,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:33.48,0:08:35.48,Default,,0000,0000,0000,,わっ!
Dialogue: 0,0:08:35.48,0:08:39.99,Default,,0000,0000,0000,,青森で最も標高の高い山 岩木山だよ
Dialogue: 0,0:08:39.99,0:08:45.32,Default,,0000,0000,0000,,大きいっ!
Dialogue: 0,0:08:39.99,0:08:45.32,Default,,0000,0000,0000,,頂上は雪で真っ白 きれいねぇ
Dialogue: 0,0:08:45.32,0:08:51.00,Default,,0000,0000,0000,,不思議なものだな
Dialogue: 0,0:08:45.32,0:08:51.00,Default,,0000,0000,0000,,こうして見ると懐かしい
Dialogue: 0,0:08:51.00,0:08:53.00,Default,,0000,0000,0000,,そういえば
Dialogue: 0,0:08:53.00,0:08:57.00,Default,,0000,0000,0000,,初めて岩木山を見たのは おじいさんの車の中で
Dialogue: 0,0:09:00.34,0:09:03.68,Default,,0000,0000,0000,,久々に聞いた 自分自身の声にも驚いた
Dialogue: 0,0:09:03.68,0:09:07.51,Default,,0000,0000,0000,,そうだ あのときおじいさんが
Dialogue: 0,0:09:07.51,0:09:10.35,Default,,0000,0000,0000,,一廣
Dialogue: 0,0:09:07.51,0:09:10.35,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:09:10.35,0:09:12.65,Default,,0000,0000,0000,,お食べ
Dialogue: 0,0:09:16.36,0:09:18.36,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:09:18.36,0:09:20.96,Default,,0000,0000,0000,,あ
Dialogue: 0,0:09:18.36,0:09:20.96,Default,,0000,0000,0000,,フフッ 食べる?
Dialogue: 0,0:09:28.87,0:09:30.87,Default,,0000,0000,0000,,おいしい?
Dialogue: 0,0:09:30.87,0:09:32.84,Default,,0000,0000,0000,,うん おいしい
Dialogue: 0,0:09:32.84,0:09:36.41,Default,,0000,0000,0000,,あ フフッ
Dialogue: 0,0:09:42.98,0:09:45.65,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:09:45.65,0:09:48.35,Default,,0000,0000,0000,,やっとあなたも お外に出られたわね
Dialogue: 0,0:09:54.03,0:10:00.70,Default,,0000,0000,0000,,あ 広い 気持ちいいっ
Dialogue: 0,0:09:54.03,0:10:00.70,Default,,0000,0000,0000,,ホント けど
Dialogue: 0,0:10:00.70,0:10:03.20,Default,,0000,0000,0000,,本当に何もなさすぎて
Dialogue: 0,0:10:03.20,0:10:08.04,Default,,0000,0000,0000,,こんな景色の中を 毎日学校に通っていたなんて
Dialogue: 0,0:10:08.04,0:10:11.54,Default,,0000,0000,0000,,信じられないや
Dialogue: 0,0:10:08.04,0:10:11.54,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:10:11.54,0:10:18.05,Default,,0000,0000,0000,,カズヒホって どんな子どもだったの?
Dialogue: 0,0:10:11.54,0:10:18.05,Default,,0000,0000,0000,,えっ あ そうだなぁ
Dialogue: 0,0:10:18.05,0:10:20.85,Default,,0000,0000,0000,,きっと あんまり今と変わらない
Dialogue: 0,0:10:20.85,0:10:23.06,Default,,0000,0000,0000,,寝ぼすけさん だったのでしょうね?
Dialogue: 0,0:10:23.06,0:10:26.06,Default,,0000,0000,0000,,あ フフッ 当たってるよ
Dialogue: 0,0:10:26.06,0:10:28.06,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:10:26.06,0:10:28.06,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:10:28.06,0:10:30.93,Default,,0000,0000,0000,,あれ見て カズヒホ!
Dialogue: 0,0:10:28.06,0:10:30.93,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:10:36.90,0:10:39.97,Default,,0000,0000,0000,,モッ
Dialogue: 0,0:10:42.07,0:10:46.08,Default,,0000,0000,0000,,やぁ とうとう 牛まで始めたのか あの人
Dialogue: 0,0:10:46.08,0:10:48.08,Default,,0000,0000,0000,,元気だなぁ
Dialogue: 0,0:10:48.08,0:10:50.92,Default,,0000,0000,0000,,牛 ああっ!
Dialogue: 0,0:10:50.92,0:10:53.59,Default,,0000,0000,0000,,牛乳パックに描いてある 絵の!
Dialogue: 0,0:10:53.59,0:10:55.59,Default,,0000,0000,0000,,ほら マリー
Dialogue: 0,0:10:53.59,0:10:55.59,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:10:55.59,0:10:57.56,Default,,0000,0000,0000,,こっち
Dialogue: 0,0:10:57.56,0:11:04.26,Default,,0000,0000,0000,,あの古くて大きな家
Dialogue: 0,0:10:57.56,0:11:04.26,Default,,0000,0000,0000,,あそこが僕の育った場所だよ
Dialogue: 0,0:11:07.07,0:11:11.47,Default,,0000,0000,0000,,どうした花子 腹でも減ったか?
Dialogue: 0,0:11:14.27,0:11:16.78,Default,,0000,0000,0000,,っと
Dialogue: 0,0:11:16.78,0:11:22.28,Default,,0000,0000,0000,,おぉ 一廣か 大きくなったねぇ
Dialogue: 0,0:11:22.28,0:11:25.25,Default,,0000,0000,0000,,お久しぶりです おじいさん
Dialogue: 0,0:11:32.36,0:11:37.70,Default,,0000,0000,0000,,いやぁ 2人とも
Dialogue: 0,0:11:32.36,0:11:37.70,Default,,0000,0000,0000,,遠い所からよく来たねぇ
Dialogue: 0,0:11:37.70,0:11:41.20,Default,,0000,0000,0000,,まぁ座っておくれ お茶をいれるよ
Dialogue: 0,0:11:41.20,0:11:46.04,Default,,0000,0000,0000,,ハジメマシテ マリアーベルといいます!
Dialogue: 0,0:11:46.04,0:11:49.88,Default,,0000,0000,0000,,おぉ 日本語が上手だねぇ
Dialogue: 0,0:11:49.88,0:11:52.88,Default,,0000,0000,0000,,ハッ フフッ
Dialogue: 0,0:11:52.88,0:11:55.55,Default,,0000,0000,0000,,お世話になります
Dialogue: 0,0:11:55.55,0:11:58.05,Default,,0000,0000,0000,,あの これ
Dialogue: 0,0:11:58.05,0:12:00.55,Default,,0000,0000,0000,,お土産です
Dialogue: 0,0:12:00.55,0:12:04.39,Default,,0000,0000,0000,,ハハハ お前まで 硬くなってどうする
Dialogue: 0,0:12:04.39,0:12:07.19,Default,,0000,0000,0000,,ありがとうよ
Dialogue: 0,0:12:11.10,0:12:13.60,Default,,0000,0000,0000,,ばあさん驚いてるよ
Dialogue: 0,0:12:13.60,0:12:17.57,Default,,0000,0000,0000,,一廣が こんなにきれいな子を 連れてくるなんてね
Dialogue: 0,0:12:17.57,0:12:19.57,Default,,0000,0000,0000,,いやぁ
Dialogue: 0,0:12:19.57,0:12:23.41,Default,,0000,0000,0000,,綿毛みたいに真っ白な きれいな髪だねぇ
Dialogue: 0,0:12:23.41,0:12:28.41,Default,,0000,0000,0000,,まるで妖精みたいだな
Dialogue: 0,0:12:23.41,0:12:28.41,Default,,0000,0000,0000,,夢の中から出てきたようだ
Dialogue: 0,0:12:28.41,0:12:30.42,Default,,0000,0000,0000,,ウウッ!
Dialogue: 0,0:12:30.42,0:12:33.85,Default,,0000,0000,0000,,フハハハ いや 変なことを言ったね
Dialogue: 0,0:12:33.85,0:12:37.86,Default,,0000,0000,0000,,この子は昔から 寝るのが好きでな
Dialogue: 0,0:12:37.86,0:12:40.03,Default,,0000,0000,0000,,あんまり気持ちよさそうだから
Dialogue: 0,0:12:40.03,0:12:44.53,Default,,0000,0000,0000,,「夢の中で遊んでるのかねぇ」 なんて よく話したものさ
Dialogue: 0,0:12:44.53,0:12:47.53,Default,,0000,0000,0000,,なぁ ばあさん?
Dialogue: 0,0:12:49.54,0:12:53.37,Default,,0000,0000,0000,,おぉ なんだ
Dialogue: 0,0:12:49.54,0:12:53.37,Default,,0000,0000,0000,,猫までついてきたのか
Dialogue: 0,0:12:53.37,0:12:56.54,Default,,0000,0000,0000,,よしよし お疲れさんだね
Dialogue: 0,0:12:56.54,0:12:59.88,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:13:07.42,0:13:09.39,Default,,0000,0000,0000,,ねぇ
Dialogue: 0,0:13:07.42,0:13:09.39,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:13:09.39,0:13:12.89,Default,,0000,0000,0000,,おじいさん 夢の世界のことを知ってるの?
Dialogue: 0,0:13:12.89,0:13:15.39,Default,,0000,0000,0000,,いや まさか
Dialogue: 0,0:13:15.39,0:13:21.00,Default,,0000,0000,0000,,けど 昔から妙に
Dialogue: 0,0:13:15.39,0:13:21.00,Default,,0000,0000,0000,,鋭いとこあるんだよな あの人
Dialogue: 0,0:13:23.40,0:13:25.40,Default,,0000,0000,0000,,すてき
Dialogue: 0,0:13:25.40,0:13:28.57,Default,,0000,0000,0000,,アニメで見たおうちの中に 入っちゃったみたい
Dialogue: 0,0:13:30.58,0:13:34.01,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:13:36.02,0:13:38.02,Default,,0000,0000,0000,,この音!
Dialogue: 0,0:13:40.52,0:13:43.36,Default,,0000,0000,0000,,カズヒホ!
Dialogue: 0,0:13:40.52,0:13:43.36,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:13:43.36,0:13:47.03,Default,,0000,0000,0000,,ここ いるわね
Dialogue: 0,0:13:47.03,0:13:50.20,Default,,0000,0000,0000,,ここ? いるって何が?
Dialogue: 0,0:13:50.20,0:13:54.53,Default,,0000,0000,0000,,こういう扉の中に いるのよ あれは
Dialogue: 0,0:13:54.53,0:13:57.54,Default,,0000,0000,0000,,あのアニメに出てきたような
Dialogue: 0,0:13:57.54,0:14:02.71,Default,,0000,0000,0000,,人ではないもの
Dialogue: 0,0:13:57.54,0:14:02.71,Default,,0000,0000,0000,,ちっちゃなモノノケたち
Dialogue: 0,0:14:02.71,0:14:04.71,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:14:04.71,0:14:07.21,Default,,0000,0000,0000,,ねぇ 開けてみてもいいかしら?
Dialogue: 0,0:14:07.21,0:14:09.92,Default,,0000,0000,0000,,んっ どうぞ
Dialogue: 0,0:14:07.21,0:14:09.92,Default,,0000,0000,0000,,わぁ
Dialogue: 0,0:14:15.39,0:14:19.06,Default,,0000,0000,0000,,あら? 何かイメージが違ったわ
Dialogue: 0,0:14:19.06,0:14:24.40,Default,,0000,0000,0000,,ここにはいないようね
Dialogue: 0,0:14:19.06,0:14:24.40,Default,,0000,0000,0000,,うん 物音がしたから
Dialogue: 0,0:14:24.40,0:14:26.40,Default,,0000,0000,0000,,隠れちゃったのかもしれないね
Dialogue: 0,0:14:26.40,0:14:29.07,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:31.07,0:14:33.34,Default,,0000,0000,0000,,へぇ
Dialogue: 0,0:14:33.34,0:14:36.68,Default,,0000,0000,0000,,ここが カズヒホが使っていた お部屋なのね
Dialogue: 0,0:14:36.68,0:14:38.68,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:38.68,0:14:41.51,Default,,0000,0000,0000,,実はね この部屋には
Dialogue: 0,0:14:41.51,0:14:44.68,Default,,0000,0000,0000,,秘密の通路があるんだ
Dialogue: 0,0:14:41.51,0:14:44.68,Default,,0000,0000,0000,,はぁっ!
Dialogue: 0,0:14:44.68,0:14:46.85,Default,,0000,0000,0000,,ウソ! ウソウソ!
Dialogue: 0,0:14:46.85,0:14:49.69,Default,,0000,0000,0000,,どこにあるの?
Dialogue: 0,0:14:46.85,0:14:49.69,Default,,0000,0000,0000,,探してごらん
Dialogue: 0,0:14:49.69,0:14:51.69,Default,,0000,0000,0000,,ウフフ
Dialogue: 0,0:14:51.69,0:14:55.19,Default,,0000,0000,0000,,んっ 冒険開始ね!
Dialogue: 0,0:14:55.19,0:14:57.20,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:57.20,0:15:01.87,Default,,0000,0000,0000,,シーッ 静かに ね
Dialogue: 0,0:15:08.41,0:15:10.41,Default,,0000,0000,0000,,にゃあ
Dialogue: 0,0:15:08.41,0:15:10.41,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:10.41,0:15:13.08,Default,,0000,0000,0000,,にゃあ にゃあ
Dialogue: 0,0:15:13.08,0:15:15.05,Default,,0000,0000,0000,,にゃあ
Dialogue: 0,0:15:18.88,0:15:21.25,Default,,0000,0000,0000,,暗いわね でも
Dialogue: 0,0:15:21.25,0:15:25.56,Default,,0000,0000,0000,,とてもいそうよ 「あれ」が
Dialogue: 0,0:15:25.56,0:15:27.59,Default,,0000,0000,0000,,ひぃっ!
Dialogue: 0,0:15:27.59,0:15:29.93,Default,,0000,0000,0000,,いた! 今何かいたわ!
Dialogue: 0,0:15:29.93,0:15:31.83,Default,,0000,0000,0000,,あ でも暗くて
Dialogue: 0,0:15:31.83,0:15:34.00,Default,,0000,0000,0000,,猫ちゃん あなたが頼りよ!
Dialogue: 0,0:15:34.00,0:15:36.34,Default,,0000,0000,0000,,ほら行きなさい!
Dialogue: 0,0:15:34.00,0:15:36.34,Default,,0000,0000,0000,,なああ!
Dialogue: 0,0:15:36.34,0:15:39.51,Default,,0000,0000,0000,,もうっ あなたったら 魔導竜の使い魔のくせに
Dialogue: 0,0:15:39.51,0:15:42.17,Default,,0000,0000,0000,,そんなに臆病でどうするの!
Dialogue: 0,0:15:39.51,0:15:42.17,Default,,0000,0000,0000,,なああ!
Dialogue: 0,0:15:39.51,0:15:42.17,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:15:42.17,0:15:44.68,Default,,0000,0000,0000,,フフフ
Dialogue: 0,0:15:42.17,0:15:44.68,Default,,0000,0000,0000,,おい お二人さん
Dialogue: 0,0:15:44.68,0:15:46.68,Default,,0000,0000,0000,,飯ができたぞ
Dialogue: 0,0:15:46.68,0:15:48.68,Default,,0000,0000,0000,,しかたないわね
Dialogue: 0,0:15:48.68,0:15:51.18,Default,,0000,0000,0000,,どうやら 隠れてしまったようだし
Dialogue: 0,0:15:51.18,0:15:53.19,Default,,0000,0000,0000,,でも
Dialogue: 0,0:15:53.19,0:15:57.19,Default,,0000,0000,0000,,「あれ」が存在している というのは つかめたわ!
Dialogue: 0,0:16:00.69,0:16:03.20,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:16:03.20,0:16:08.37,Default,,0000,0000,0000,,さぁ どうぞどうぞ
Dialogue: 0,0:16:03.20,0:16:08.37,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:16:08.37,0:16:10.37,Default,,0000,0000,0000,,いただきます!
Dialogue: 0,0:16:15.54,0:16:18.54,Default,,0000,0000,0000,,んっ とけるっ!
Dialogue: 0,0:16:18.54,0:16:25.22,Default,,0000,0000,0000,,トロトロで濃厚で たまらないわ!
Dialogue: 0,0:16:18.54,0:16:25.22,Default,,0000,0000,0000,,アンコウの肝と白子も入ってますね
Dialogue: 0,0:16:25.22,0:16:27.22,Default,,0000,0000,0000,,旬じゃないけどさ
Dialogue: 0,0:16:27.22,0:16:31.06,Default,,0000,0000,0000,,青森のいちばんうまいものを 食べてもらいたくてな
Dialogue: 0,0:16:31.06,0:16:35.53,Default,,0000,0000,0000,,一廣 酒はどうする
Dialogue: 0,0:16:31.06,0:16:35.53,Default,,0000,0000,0000,,もらったいいやつがあるよ
Dialogue: 0,0:16:35.53,0:16:38.36,Default,,0000,0000,0000,,あっ いただきます
Dialogue: 0,0:16:46.17,0:16:48.21,Default,,0000,0000,0000,,ほわっ
Dialogue: 0,0:16:48.21,0:16:50.21,Default,,0000,0000,0000,,ずいぶんおいしそうね
Dialogue: 0,0:16:50.21,0:16:53.35,Default,,0000,0000,0000,,もしかして 飲めるのかな?
Dialogue: 0,0:16:50.21,0:16:53.35,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:16:53.35,0:16:55.35,Default,,0000,0000,0000,,飲めます!
Dialogue: 0,0:16:59.22,0:17:04.39,Default,,0000,0000,0000,,これが日本酒
Dialogue: 0,0:16:59.22,0:17:04.39,Default,,0000,0000,0000,,喉からおなかまで温かくなるわ
Dialogue: 0,0:17:04.39,0:17:08.23,Default,,0000,0000,0000,,さぁ 魚も野菜も たくさんあるからね
Dialogue: 0,0:17:08.23,0:17:10.20,Default,,0000,0000,0000,,どんどん食べて
Dialogue: 0,0:17:12.23,0:17:14.23,Default,,0000,0000,0000,,はいっ
Dialogue: 0,0:17:14.23,0:17:17.90,Default,,0000,0000,0000,,そうそう これも青森のもんでね
Dialogue: 0,0:17:17.90,0:17:20.54,Default,,0000,0000,0000,,開けてごらん
Dialogue: 0,0:17:20.54,0:17:22.54,Default,,0000,0000,0000,,あ なんでしょう
Dialogue: 0,0:17:24.54,0:17:27.38,Default,,0000,0000,0000,,わっ かわいい!
Dialogue: 0,0:17:27.38,0:17:30.38,Default,,0000,0000,0000,,昔から伝わる民芸品でね
Dialogue: 0,0:17:30.38,0:17:35.49,Default,,0000,0000,0000,,「こぎん刺し」っていって
Dialogue: 0,0:17:30.38,0:17:35.49,Default,,0000,0000,0000,,ひと針ずつ手縫いで作るのさ
Dialogue: 0,0:17:35.49,0:17:39.49,Default,,0000,0000,0000,,確かに 人のぬくもりがします
Dialogue: 0,0:17:39.49,0:17:44.16,Default,,0000,0000,0000,,青森のお土産に よかったらどうぞ
Dialogue: 0,0:17:44.16,0:17:47.83,Default,,0000,0000,0000,,ありがとうございます
Dialogue: 0,0:17:47.83,0:17:50.67,Default,,0000,0000,0000,,大事にします
Dialogue: 0,0:17:50.67,0:17:53.34,Default,,0000,0000,0000,,ごちそうさまでした!
Dialogue: 0,0:17:53.34,0:17:56.18,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:17:56.18,0:17:59.18,Default,,0000,0000,0000,,後片づけは僕らがやりますよ
Dialogue: 0,0:17:59.18,0:18:01.98,Default,,0000,0000,0000,,そう じゃ 頼んだよ
Dialogue: 0,0:18:05.72,0:18:09.19,Default,,0000,0000,0000,,大丈夫?
Dialogue: 0,0:18:05.72,0:18:09.19,Default,,0000,0000,0000,,だいぶ飲んでたみたいだけど
Dialogue: 0,0:18:09.19,0:18:16.20,Default,,0000,0000,0000,,えぇ 少し調子に乗りすぎたかも
Dialogue: 0,0:18:09.19,0:18:16.20,Default,,0000,0000,0000,,でも いい気分よ
Dialogue: 0,0:18:16.20,0:18:19.03,Default,,0000,0000,0000,,あとで ちょっと 酔い覚ましに行こうか?
Dialogue: 0,0:18:19.03,0:18:21.03,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:18:25.74,0:18:27.74,Default,,0000,0000,0000,,きれいな月
Dialogue: 0,0:18:27.74,0:18:33.65,Default,,0000,0000,0000,,うん 東京は夜も明るいから
Dialogue: 0,0:18:27.74,0:18:33.65,Default,,0000,0000,0000,,見え方が全然違うよね
Dialogue: 0,0:18:33.65,0:18:35.85,Default,,0000,0000,0000,,けど
Dialogue: 0,0:18:38.15,0:18:42.99,Default,,0000,0000,0000,,真っ暗すぎたかな あっ
Dialogue: 0,0:18:58.67,0:19:03.34,Default,,0000,0000,0000,,光精霊
Dialogue: 0,0:19:03.34,0:19:08.45,Default,,0000,0000,0000,,呼び出せたんだ!
Dialogue: 0,0:19:03.34,0:19:08.45,Default,,0000,0000,0000,,こっちの世界で初めてできたわ
Dialogue: 0,0:19:12.68,0:19:18.02,Default,,0000,0000,0000,,ずっと姿は見えていたんだけど
Dialogue: 0,0:19:12.68,0:19:18.02,Default,,0000,0000,0000,,これまでは反応がなくて
Dialogue: 0,0:19:18.02,0:19:21.36,Default,,0000,0000,0000,,試しに日本語で呼びかけてみたの
Dialogue: 0,0:19:21.36,0:19:26.87,Default,,0000,0000,0000,,言葉そのものより 感情表現って
Dialogue: 0,0:19:21.36,0:19:26.87,Default,,0000,0000,0000,,言ったらいいのかしら
Dialogue: 0,0:19:26.87,0:19:32.00,Default,,0000,0000,0000,,私がこっちの感覚に
Dialogue: 0,0:19:26.87,0:19:32.00,Default,,0000,0000,0000,,慣れてきたから通じたのかも
Dialogue: 0,0:19:32.00,0:19:35.51,Default,,0000,0000,0000,,こんな景色が見られるなんて
Dialogue: 0,0:19:35.51,0:19:38.68,Default,,0000,0000,0000,,ありがとう マリー
Dialogue: 0,0:19:35.51,0:19:38.68,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:38.68,0:19:42.18,Default,,0000,0000,0000,,こっちこそ
Dialogue: 0,0:19:42.18,0:19:47.52,Default,,0000,0000,0000,,私ね 連れてきてもらって
Dialogue: 0,0:19:42.18,0:19:47.52,Default,,0000,0000,0000,,とってもよかったと思ってるの
Dialogue: 0,0:19:47.52,0:19:53.53,Default,,0000,0000,0000,,お鍋もおいしかったし
Dialogue: 0,0:19:47.52,0:19:53.53,Default,,0000,0000,0000,,おじいさんにも会えて
Dialogue: 0,0:19:47.52,0:19:53.53,Default,,0000,0000,0000,,うん
Dialogue: 0,0:19:53.53,0:19:58.53,Default,,0000,0000,0000,,おじいさんは あなたと少し似ているわ
Dialogue: 0,0:19:53.53,0:19:58.53,Default,,0000,0000,0000,,えぇ?
Dialogue: 0,0:19:58.53,0:20:02.87,Default,,0000,0000,0000,,どこか ひょうひょうとしていて なんでも知っていそうなところ
Dialogue: 0,0:20:02.87,0:20:07.54,Default,,0000,0000,0000,,うん そうかなぁ
Dialogue: 0,0:20:02.87,0:20:07.54,Default,,0000,0000,0000,,でもなぜかしら
Dialogue: 0,0:20:07.54,0:20:11.88,Default,,0000,0000,0000,,おじいさんったら カズヒホのこと カズヒロ なんて呼んだりして
Dialogue: 0,0:20:11.88,0:20:15.55,Default,,0000,0000,0000,,おかしいわ フフッ
Dialogue: 0,0:20:15.55,0:20:18.88,Default,,0000,0000,0000,,僕 一廣だよ
Dialogue: 0,0:20:18.88,0:20:21.55,Default,,0000,0000,0000,,はっ?
Dialogue: 0,0:20:21.55,0:20:25.56,Default,,0000,0000,0000,,向こうで最初にやる 名前設定を間違えてさ
Dialogue: 0,0:20:25.56,0:20:28.73,Default,,0000,0000,0000,,カズヒロが本当の名前なんだ
Dialogue: 0,0:20:28.73,0:20:33.50,Default,,0000,0000,0000,,カズヒ 「ホ」じゃなくて?
Dialogue: 0,0:20:28.73,0:20:33.50,Default,,0000,0000,0000,,うん カズヒ 「ロ」
Dialogue: 0,0:20:35.57,0:20:38.74,Default,,0000,0000,0000,,し 信じられないっ!
Dialogue: 0,0:20:38.74,0:20:41.91,Default,,0000,0000,0000,,つまり私は ずっとあなたの名前を 間違えていたの!?
Dialogue: 0,0:20:41.91,0:20:45.08,Default,,0000,0000,0000,,どうして言わないのよ!
Dialogue: 0,0:20:41.91,0:20:45.08,Default,,0000,0000,0000,,えぇと
Dialogue: 0,0:20:45.08,0:20:47.95,Default,,0000,0000,0000,,まあ別にいいかなって
Dialogue: 0,0:20:45.08,0:20:47.95,Default,,0000,0000,0000,,よくないわよ!
Dialogue: 0,0:20:51.75,0:20:53.75,Default,,0000,0000,0000,,か
Dialogue: 0,0:20:53.75,0:20:55.92,Default,,0000,0000,0000,,かずひろさん
Dialogue: 0,0:20:53.75,0:20:55.92,Default,,0000,0000,0000,,いっ!
Dialogue: 0,0:20:55.92,0:20:57.92,Default,,0000,0000,0000,,あの やっぱり
Dialogue: 0,0:20:57.92,0:21:01.26,Default,,0000,0000,0000,,カズヒホのままでよくないかな?
Dialogue: 0,0:20:57.92,0:21:01.26,Default,,0000,0000,0000,,だめよそんなの!
Dialogue: 0,0:21:01.26,0:21:04.26,Default,,0000,0000,0000,,ハァッ かずひろさん!
Dialogue: 0,0:21:04.26,0:21:06.93,Default,,0000,0000,0000,,かずひろさん かずひろさん
Dialogue: 0,0:21:06.93,0:21:09.77,Default,,0000,0000,0000,,かずひろさん かずひろさん
Dialogue: 0,0:21:06.93,0:21:09.77,Default,,0000,0000,0000,,うわ ちょっ
Dialogue: 0,0:21:09.77,0:21:13.74,Default,,0000,0000,0000,,かずひろさん!
Dialogue: 0,0:21:09.77,0:21:13.74,Default,,0000,0000,0000,,やめてっ!
Dialogue: 0,0:21:15.74,0:21:18.91,Default,,0000,0000,0000,,おかえり 散歩はどうだった?
Dialogue: 0,0:21:18.91,0:21:21.21,Default,,0000,0000,0000,,2人とも酔いは さめたかな?
Dialogue: 0,0:21:23.25,0:21:25.25,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:21:25.25,0:21:29.25,Default,,0000,0000,0000,,お お風呂 使わせていただきます
Dialogue: 0,0:21:25.25,0:21:29.25,Default,,0000,0000,0000,,かずひろさん お先にどうぞ!
Dialogue: 0,0:21:29.25,0:21:32.36,Default,,0000,0000,0000,,えっ ま 待ってよマリー!
Dialogue: 0,0:21:32.36,0:21:35.86,Default,,0000,0000,0000,,ほっほっほ さめとらんようだねぇ?
Dialogue: 0,0:21:35.86,0:21:37.86,Default,,0000,0000,0000,,にぅぅ?
Dialogue: 0,0:21:42.53,0:21:44.54,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:44.54,0:21:47.04,Default,,0000,0000,0000,,おかえりなさい
Dialogue: 0,0:21:47.04,0:21:49.71,Default,,0000,0000,0000,,ただい ま
Dialogue: 0,0:21:49.71,0:21:51.88,Default,,0000,0000,0000,,りんごジュース いただいたの
Dialogue: 0,0:21:51.88,0:21:54.55,Default,,0000,0000,0000,,みずみずしくて とてもおいしいわ
Dialogue: 0,0:21:54.55,0:21:58.95,Default,,0000,0000,0000,,うん 冷えてきたね 部屋に入ろう
Dialogue: 0,0:22:00.89,0:22:05.69,Default,,0000,0000,0000,,子どものころの僕に言ったら どんな顔をするだろうな
Dialogue: 0,0:22:10.90,0:22:13.07,Default,,0000,0000,0000,,君はいつか
Dialogue: 0,0:22:13.07,0:22:16.47,Default,,0000,0000,0000,,エルフさんを連れて 帰ってくるよって
Dialogue: 0,0:22:24.08,0:22:28.58,Default,,0000,0000,0000,,一廣 常夜灯の電球 切れてたろう
Dialogue: 0,0:22:28.58,0:22:32.22,Default,,0000,0000,0000,,代わりにこれ 置いとくよ
Dialogue: 0,0:22:32.22,0:22:35.39,Default,,0000,0000,0000,,おや もう寝ちまったか?
Dialogue: 0,0:22:35.39,0:22:37.72,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:22:37.72,0:22:42.39,Default,,0000,0000,0000,,あっ! フフッ
Dialogue: 0,0:22:42.39,0:22:45.96,Default,,0000,0000,0000,,ゆっくり遊んでおいで 2人とも
