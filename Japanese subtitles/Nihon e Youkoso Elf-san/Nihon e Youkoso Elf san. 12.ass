Dialogue: 0,0:00:36.67,0:00:40.51,Default,,0000,0000,0000,,あれ?
Dialogue: 0,0:00:36.67,0:00:40.51,Default,,0000,0000,0000,,今どっちだっけ
Dialogue: 0,0:00:40.51,0:00:43.84,Default,,0000,0000,0000,,迷宮で眠って うちで目覚めるのか
Dialogue: 0,0:00:43.84,0:00:46.35,Default,,0000,0000,0000,,その逆か
Dialogue: 0,0:00:51.52,0:00:55.02,Default,,0000,0000,0000,,どちらにしても そばに君がいる
Dialogue: 0,0:00:55.02,0:01:00.86,Default,,0000,0000,0000,,ねぇマリー ずっとこうして
Dialogue: 0,0:00:55.02,0:01:00.86,Default,,0000,0000,0000,,そばにいてもいいかな?
Dialogue: 0,0:01:00.86,0:01:02.86,Default,,0000,0000,0000,,マリー
Dialogue: 0,0:01:02.86,0:01:06.20,Default,,0000,0000,0000,,フフフ 起きたか
Dialogue: 0,0:01:02.86,0:01:06.20,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:01:06.20,0:01:08.20,Default,,0000,0000,0000,,よっ!
Dialogue: 0,0:01:06.20,0:01:08.20,Default,,0000,0000,0000,,わぁっ!
Dialogue: 0,0:01:08.20,0:01:11.54,Default,,0000,0000,0000,,なんじゃ 何を驚いておる?
Dialogue: 0,0:01:11.54,0:01:16.54,Default,,0000,0000,0000,,えっ だって しばらく子どもたちの所に 帰るんじゃなかったの!?
Dialogue: 0,0:01:16.54,0:01:18.55,Default,,0000,0000,0000,,だから こんな距離は
Dialogue: 0,0:01:18.55,0:01:22.22,Default,,0000,0000,0000,,散歩代わりじゃと 言うておるだろう しかし
Dialogue: 0,0:01:22.22,0:01:26.05,Default,,0000,0000,0000,,昨日の鍋 ありゃ最高じゃったなぁ
Dialogue: 0,0:01:26.05,0:01:28.05,Default,,0000,0000,0000,,ホントホント!
Dialogue: 0,0:01:28.05,0:01:31.06,Default,,0000,0000,0000,,魚ってあんなに 繊細な味だったのねぇ
Dialogue: 0,0:01:31.06,0:01:33.23,Default,,0000,0000,0000,,あっ 起きてたんだね
Dialogue: 0,0:01:33.23,0:01:37.33,Default,,0000,0000,0000,,それに日本酒
Dialogue: 0,0:01:33.23,0:01:37.33,Default,,0000,0000,0000,,あら 使い魔の猫ちゃん
Dialogue: 0,0:01:37.33,0:01:40.17,Default,,0000,0000,0000,,いつの間にか お酒まで飲んでいたのね?
Dialogue: 0,0:01:40.17,0:01:43.34,Default,,0000,0000,0000,,実にすばらしかったのう!
Dialogue: 0,0:01:43.34,0:01:46.67,Default,,0000,0000,0000,,すっきりした味わいに ほんのり甘みがあって
Dialogue: 0,0:01:46.67,0:01:48.68,Default,,0000,0000,0000,,ん そうそうっ!
Dialogue: 0,0:01:48.68,0:01:51.85,Default,,0000,0000,0000,,2人とも ゆうべの余韻に浸ってるな
Dialogue: 0,0:01:51.85,0:01:54.68,Default,,0000,0000,0000,,今日は お休みにしてもいいかもね
Dialogue: 0,0:01:54.68,0:01:57.02,Default,,0000,0000,0000,,あっ そういえばさ
Dialogue: 0,0:01:57.02,0:02:00.85,Default,,0000,0000,0000,,おじいさんの家から 歩いて行ける所に温泉があるんだ
Dialogue: 0,0:02:00.85,0:02:05.69,Default,,0000,0000,0000,,午前中から開いてるし 明日は朝風呂ってのもいいね
Dialogue: 0,0:02:05.69,0:02:07.86,Default,,0000,0000,0000,,アサ
Dialogue: 0,0:02:05.69,0:02:07.86,Default,,0000,0000,0000,,ブロ
Dialogue: 0,0:02:07.86,0:02:09.86,Default,,0000,0000,0000,,んっ? えっ!?
Dialogue: 0,0:02:09.86,0:02:11.90,Default,,0000,0000,0000,,えっ 何 何!?
Dialogue: 0,0:02:11.90,0:02:15.54,Default,,0000,0000,0000,,剣を抜け カズヒホ! 夕刻まで
Dialogue: 0,0:02:15.54,0:02:18.71,Default,,0000,0000,0000,,ワシがこってり絞ってやろう!
Dialogue: 0,0:02:15.54,0:02:18.71,Default,,0000,0000,0000,,へっ!?
Dialogue: 0,0:02:18.71,0:02:23.38,Default,,0000,0000,0000,,私もこの杖の力を 存分に試させてもらうわ!
Dialogue: 0,0:02:23.38,0:02:25.38,Default,,0000,0000,0000,,ちょ ちょっと2人とも!
Dialogue: 0,0:02:25.38,0:02:27.38,Default,,0000,0000,0000,,何いきなり やる気になってるの!?
Dialogue: 0,0:02:27.38,0:02:30.05,Default,,0000,0000,0000,,たわけ!
Dialogue: 0,0:02:27.38,0:02:30.05,Default,,0000,0000,0000,,決まってるじゃない!
Dialogue: 0,0:02:30.05,0:02:34.99,Default,,0000,0000,0000,,お風呂とは
Dialogue: 0,0:02:30.05,0:02:34.99,Default,,0000,0000,0000,,汗をたっぷりかいたあとが
Dialogue: 0,0:02:34.99,0:02:37.82,Default,,0000,0000,0000,,最高じゃからな
Dialogue: 0,0:02:34.99,0:02:37.82,Default,,0000,0000,0000,,ウフッ
Dialogue: 0,0:02:37.82,0:02:40.16,Default,,0000,0000,0000,,はぁ それで
Dialogue: 0,0:02:37.82,0:02:40.16,Default,,0000,0000,0000,,ほれ!
Dialogue: 0,0:02:40.16,0:02:43.00,Default,,0000,0000,0000,,寝ぼけとる場合ではないぞ!
Dialogue: 0,0:02:40.16,0:02:43.00,Default,,0000,0000,0000,,へっ?
Dialogue: 0,0:02:43.00,0:02:48.17,Default,,0000,0000,0000,,うわぁ!
Dialogue: 0,0:02:43.00,0:02:48.17,Default,,0000,0000,0000,,ほれほれ! 汗をかくぞ!
Dialogue: 0,0:02:48.17,0:02:52.27,Default,,0000,0000,0000,,まったり休もうと思ったのに なんで!?
Dialogue: 0,0:04:42.82,0:04:45.02,Default,,0000,0000,0000,,おはよう ウリドラ
Dialogue: 0,0:04:45.02,0:04:48.66,Default,,0000,0000,0000,,おはよう なんて気持ちのいい 朝なのかしら
Dialogue: 0,0:04:48.66,0:04:50.66,Default,,0000,0000,0000,,おはよう マリー
Dialogue: 0,0:04:50.66,0:04:52.66,Default,,0000,0000,0000,,2人ともおはよう
Dialogue: 0,0:04:52.66,0:04:55.83,Default,,0000,0000,0000,,ゆうべはよく眠れたかな?
Dialogue: 0,0:04:52.66,0:04:55.83,Default,,0000,0000,0000,,はい!
Dialogue: 0,0:04:55.83,0:04:57.83,Default,,0000,0000,0000,,ごはん 出来てるよ
Dialogue: 0,0:04:57.83,0:05:00.53,Default,,0000,0000,0000,,はい!
Dialogue: 0,0:04:57.83,0:05:00.53,Default,,0000,0000,0000,,にゃん!
Dialogue: 0,0:05:03.00,0:05:05.00,Default,,0000,0000,0000,,いただきます!
Dialogue: 0,0:05:07.51,0:05:10.51,Default,,0000,0000,0000,,すてき 和風の朝ごはん
Dialogue: 0,0:05:10.51,0:05:14.18,Default,,0000,0000,0000,,パンも好きだけど お米の朝ごはんっていいわね
Dialogue: 0,0:05:14.18,0:05:16.52,Default,,0000,0000,0000,,いやぁ ありがたいなぁ
Dialogue: 0,0:05:16.52,0:05:19.69,Default,,0000,0000,0000,,子どものころは当たり前のように 食べていたけど
Dialogue: 0,0:05:19.69,0:05:22.86,Default,,0000,0000,0000,,はぁ しみる
Dialogue: 0,0:05:22.86,0:05:26.86,Default,,0000,0000,0000,,お味噌汁 おいしい!
Dialogue: 0,0:05:22.86,0:05:26.86,Default,,0000,0000,0000,,いろんな野菜が入ってて
Dialogue: 0,0:05:26.86,0:05:29.86,Default,,0000,0000,0000,,なに 昨日の鍋の残りさ
Dialogue: 0,0:05:29.86,0:05:33.37,Default,,0000,0000,0000,,おいしそうに食べてくれて うれしいよ
Dialogue: 0,0:05:33.37,0:05:36.64,Default,,0000,0000,0000,,ところで 今日は観光に行くんだろ?
Dialogue: 0,0:05:36.64,0:05:41.14,Default,,0000,0000,0000,,俺の車 使うといいよ
Dialogue: 0,0:05:36.64,0:05:41.14,Default,,0000,0000,0000,,ありがとうございます!
Dialogue: 0,0:05:41.14,0:05:44.14,Default,,0000,0000,0000,,あっ それと
Dialogue: 0,0:05:41.14,0:05:44.14,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:05:44.14,0:05:46.65,Default,,0000,0000,0000,,その前に行きたい所が
Dialogue: 0,0:05:46.65,0:05:48.65,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:05:48.65,0:05:52.65,Default,,0000,0000,0000,,いってきます!
Dialogue: 0,0:05:48.65,0:05:52.65,Default,,0000,0000,0000,,はいよ
Dialogue: 0,0:06:00.66,0:06:02.66,Default,,0000,0000,0000,,にゃうっ!
Dialogue: 0,0:06:02.66,0:06:06.00,Default,,0000,0000,0000,,お前さんは 俺と留守番だな
Dialogue: 0,0:06:06.00,0:06:08.50,Default,,0000,0000,0000,,あっ 大変
Dialogue: 0,0:06:06.00,0:06:08.50,Default,,0000,0000,0000,,ありゃ
Dialogue: 0,0:06:08.50,0:06:13.84,Default,,0000,0000,0000,,まぁどのみち 猫は連れてっても
Dialogue: 0,0:06:08.50,0:06:13.84,Default,,0000,0000,0000,,温泉には入れてもらえないか
Dialogue: 0,0:06:13.84,0:06:17.74,Default,,0000,0000,0000,,ウリドラ あなたの分まで 堪能してくるわ
Dialogue: 0,0:06:21.01,0:06:23.02,Default,,0000,0000,0000,,いらっしゃい
Dialogue: 0,0:06:23.02,0:06:26.02,Default,,0000,0000,0000,,まぁ なんてかわいらしい お嬢さんだこと
Dialogue: 0,0:06:26.02,0:06:29.02,Default,,0000,0000,0000,,えっと お二人様ですね
Dialogue: 0,0:06:29.02,0:06:33.03,Default,,0000,0000,0000,,あら その猫ちゃんはお客さんの?
Dialogue: 0,0:06:29.02,0:06:33.03,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:06:33.03,0:06:35.29,Default,,0000,0000,0000,,フーッ フーッ
Dialogue: 0,0:06:35.29,0:06:37.33,Default,,0000,0000,0000,,ああっ!
Dialogue: 0,0:06:37.33,0:06:39.30,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:06:39.30,0:06:42.64,Default,,0000,0000,0000,,すみません この猫 お風呂に興味津々で
Dialogue: 0,0:06:42.64,0:06:46.47,Default,,0000,0000,0000,,あらまぁ お風呂好きの猫ちゃん? 珍しい
Dialogue: 0,0:06:46.47,0:06:49.18,Default,,0000,0000,0000,,うん それじゃあ
Dialogue: 0,0:06:51.68,0:06:55.68,Default,,0000,0000,0000,,はぁっ なんて気持ちいい お湯なのかしら
Dialogue: 0,0:06:55.68,0:06:58.68,Default,,0000,0000,0000,,「ゲンセンカケナガシ」っていうのね
Dialogue: 0,0:06:58.68,0:07:01.15,Default,,0000,0000,0000,,一つまた覚えたわ
Dialogue: 0,0:07:01.15,0:07:06.69,Default,,0000,0000,0000,,ふぅ 秩父で入った温泉とは
Dialogue: 0,0:07:01.15,0:07:06.69,Default,,0000,0000,0000,,またひと味違うわね
Dialogue: 0,0:07:06.69,0:07:12.33,Default,,0000,0000,0000,,ウフフ よかったわね ウリドラ
Dialogue: 0,0:07:06.69,0:07:12.33,Default,,0000,0000,0000,,お店の人が猫ちゃん好きで
Dialogue: 0,0:07:12.33,0:07:15.03,Default,,0000,0000,0000,,特別ですってよ
Dialogue: 0,0:07:12.33,0:07:15.03,Default,,0000,0000,0000,,なう
Dialogue: 0,0:07:15.03,0:07:17.04,Default,,0000,0000,0000,,にゃう?
Dialogue: 0,0:07:17.04,0:07:19.04,Default,,0000,0000,0000,,ピギャー!
Dialogue: 0,0:07:19.04,0:07:21.04,Default,,0000,0000,0000,,あら 見で
Dialogue: 0,0:07:19.04,0:07:21.04,Default,,0000,0000,0000,,あれぇ
Dialogue: 0,0:07:21.04,0:07:23.54,Default,,0000,0000,0000,,めごぇちゃぺが湯さ入ってら
Dialogue: 0,0:07:23.54,0:07:28.21,Default,,0000,0000,0000,,なんぼめごい猫っこだば
Dialogue: 0,0:07:23.54,0:07:28.21,Default,,0000,0000,0000,,よぐ来てけだしね
Dialogue: 0,0:07:28.21,0:07:31.05,Default,,0000,0000,0000,,あれ 飼い主さんもめごぇ
Dialogue: 0,0:07:31.05,0:07:34.22,Default,,0000,0000,0000,,めごぇ めごぇ
Dialogue: 0,0:07:31.05,0:07:34.22,Default,,0000,0000,0000,,何語?
Dialogue: 0,0:07:36.46,0:07:39.29,Default,,0000,0000,0000,,あっ おかえりマリー
Dialogue: 0,0:07:39.29,0:07:42.46,Default,,0000,0000,0000,,お風呂は楽しめた?
Dialogue: 0,0:07:39.29,0:07:42.46,Default,,0000,0000,0000,,フッフッフ
Dialogue: 0,0:07:42.46,0:07:46.63,Default,,0000,0000,0000,,湯さ入って さっぱしたじゃ!
Dialogue: 0,0:07:42.46,0:07:46.63,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:07:46.63,0:07:50.14,Default,,0000,0000,0000,,おばあさま方に 方言を教えてもらったの!
Dialogue: 0,0:07:50.14,0:07:54.64,Default,,0000,0000,0000,,あぁそうか 地元の人たちと 仲よくなったのかな?
Dialogue: 0,0:07:54.64,0:07:57.64,Default,,0000,0000,0000,,ええ また会いましょうって 言ってくれたわ
Dialogue: 0,0:07:57.64,0:07:59.65,Default,,0000,0000,0000,,それはよかった
Dialogue: 0,0:07:59.65,0:08:02.48,Default,,0000,0000,0000,,今度 青森の方言も 勉強してみようかしら
Dialogue: 0,0:08:02.48,0:08:05.99,Default,,0000,0000,0000,,フフッ それはかなり大変だろうね
Dialogue: 0,0:08:09.32,0:08:14.99,Default,,0000,0000,0000,,わぁ これがおじいさんの車?
Dialogue: 0,0:08:09.32,0:08:14.99,Default,,0000,0000,0000,,おもしろい形をしているわね
Dialogue: 0,0:08:14.99,0:08:20.53,Default,,0000,0000,0000,,さあ! 青森観光へ出発よ!
Dialogue: 0,0:08:14.99,0:08:20.53,Default,,0000,0000,0000,,なぁう!
Dialogue: 0,0:08:20.53,0:08:23.50,Default,,0000,0000,0000,,2人とも そろそろ出るよ
Dialogue: 0,0:08:27.84,0:08:31.88,Default,,0000,0000,0000,,あ 空気がおいしいわ あっ!
Dialogue: 0,0:08:31.88,0:08:36.62,Default,,0000,0000,0000,,おじいさん 花ちゃん いってきます!
Dialogue: 0,0:08:36.62,0:08:39.62,Default,,0000,0000,0000,,いってきます!
Dialogue: 0,0:08:36.62,0:08:39.62,Default,,0000,0000,0000,,モッ
Dialogue: 0,0:08:43.96,0:08:48.79,Default,,0000,0000,0000,,あの子が あんなに明るくなるとはね
Dialogue: 0,0:08:55.64,0:08:57.64,Default,,0000,0000,0000,,うわぁ 桜!
Dialogue: 0,0:08:57.64,0:09:01.64,Default,,0000,0000,0000,,どうして咲いてるの?
Dialogue: 0,0:08:57.64,0:09:01.64,Default,,0000,0000,0000,,東京ではとっくに散ったのに
Dialogue: 0,0:09:01.64,0:09:05.14,Default,,0000,0000,0000,,こっちは東京より 開花の時期が遅いんだよ
Dialogue: 0,0:09:05.14,0:09:09.32,Default,,0000,0000,0000,,でも 見頃は過ぎてしまうかと ちょっと心配だったんだ
Dialogue: 0,0:09:09.32,0:09:11.32,Default,,0000,0000,0000,,間に合ってよかった
Dialogue: 0,0:09:11.32,0:09:14.49,Default,,0000,0000,0000,,あら そのことは 内緒にしてたのね
Dialogue: 0,0:09:14.49,0:09:18.49,Default,,0000,0000,0000,,フフ 驚かせたくてね
Dialogue: 0,0:09:14.49,0:09:18.49,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:09:21.49,0:09:24.83,Default,,0000,0000,0000,,ウリドラ あなたは桜は初めてよね
Dialogue: 0,0:09:24.83,0:09:28.17,Default,,0000,0000,0000,,きれいでしょう?
Dialogue: 0,0:09:24.83,0:09:28.17,Default,,0000,0000,0000,,なう
Dialogue: 0,0:09:28.17,0:09:30.34,Default,,0000,0000,0000,,もっと近くで見てみましょうか
Dialogue: 0,0:09:30.34,0:09:32.34,Default,,0000,0000,0000,,マリー ウリドラ
Dialogue: 0,0:09:30.34,0:09:32.34,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:09:34.64,0:09:38.14,Default,,0000,0000,0000,,わっ すごい!
Dialogue: 0,0:09:34.64,0:09:38.14,Default,,0000,0000,0000,,画面に私たちが映ってる!
Dialogue: 0,0:09:38.14,0:09:43.15,Default,,0000,0000,0000,,視覚投影の魔法?
Dialogue: 0,0:09:38.14,0:09:43.15,Default,,0000,0000,0000,,ハハッ これは 「写真」っていうんだ
Dialogue: 0,0:09:43.15,0:09:47.15,Default,,0000,0000,0000,,こちらの世界では こうして旅の思い出を残すんだよ
Dialogue: 0,0:09:47.15,0:09:49.16,Default,,0000,0000,0000,,今日はたくさん撮ろう!
Dialogue: 0,0:09:49.16,0:09:53.33,Default,,0000,0000,0000,,わぁ! じゃあ私にも撮らせて
Dialogue: 0,0:09:53.33,0:09:56.83,Default,,0000,0000,0000,,よし ほら これで自分も撮れるよ
Dialogue: 0,0:09:56.83,0:10:00.83,Default,,0000,0000,0000,,ここを押すと カシャンっていうから
Dialogue: 0,0:09:56.83,0:10:00.83,Default,,0000,0000,0000,,カシャン
Dialogue: 0,0:10:00.83,0:10:03.17,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:10:00.83,0:10:03.17,Default,,0000,0000,0000,,わっ
Dialogue: 0,0:10:05.81,0:10:07.81,Default,,0000,0000,0000,,すごい すごい!
Dialogue: 0,0:10:07.81,0:10:11.14,Default,,0000,0000,0000,,魔法とは比べものに ならないくらい鮮明できれい!
Dialogue: 0,0:10:11.14,0:10:13.48,Default,,0000,0000,0000,,そ それはよかった
Dialogue: 0,0:10:13.48,0:10:16.18,Default,,0000,0000,0000,,さっ 行きましょう 一廣さん
Dialogue: 0,0:10:16.18,0:10:19.75,Default,,0000,0000,0000,,私たちの思い出 たくさん残すんでしょう?
Dialogue: 0,0:10:21.85,0:10:24.22,Default,,0000,0000,0000,,うん
Dialogue: 0,0:10:21.85,0:10:24.22,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:10:27.19,0:10:31.70,Default,,0000,0000,0000,,やっぱり 一廣呼びには慣れないなぁ
Dialogue: 0,0:10:38.54,0:10:43.38,Default,,0000,0000,0000,,「弘前城は 1611年に出来た 津軽氏の居城で
Dialogue: 0,0:10:43.38,0:10:47.55,Default,,0000,0000,0000,,6つのくるわで構成された 平山城である」
Dialogue: 0,0:10:47.55,0:10:50.72,Default,,0000,0000,0000,,昔 落雷による火事で消失して
Dialogue: 0,0:10:50.72,0:10:53.89,Default,,0000,0000,0000,,今ある天守は 再建したものらしいよ
Dialogue: 0,0:10:53.89,0:10:56.22,Default,,0000,0000,0000,,へぇ
Dialogue: 0,0:10:56.22,0:10:58.56,Default,,0000,0000,0000,,あっ 桜の妖精
Dialogue: 0,0:10:58.56,0:11:02.56,Default,,0000,0000,0000,,ウフフ これほど 近づいてくる子は初めて
Dialogue: 0,0:11:02.56,0:11:08.03,Default,,0000,0000,0000,,いらっしゃい ウフフ
Dialogue: 0,0:11:02.56,0:11:08.03,Default,,0000,0000,0000,,やっぱり僕には見えないな
Dialogue: 0,0:11:14.41,0:11:19.75,Default,,0000,0000,0000,,きれいね 桜が映って
Dialogue: 0,0:11:14.41,0:11:19.75,Default,,0000,0000,0000,,ホント 見事だね
Dialogue: 0,0:11:19.75,0:11:22.58,Default,,0000,0000,0000,,でも こういう 「お堀」ってきっと
Dialogue: 0,0:11:22.58,0:11:25.92,Default,,0000,0000,0000,,お城に敵を近づけないために 作られたものよね?
Dialogue: 0,0:11:25.92,0:11:28.25,Default,,0000,0000,0000,,そう よくわかったね
Dialogue: 0,0:11:28.25,0:11:31.82,Default,,0000,0000,0000,,日本のお城に興味があるのかな?
Dialogue: 0,0:11:28.25,0:11:31.82,Default,,0000,0000,0000,,ええ!
Dialogue: 0,0:11:39.33,0:11:43.34,Default,,0000,0000,0000,,へぇ これも武器なの?
Dialogue: 0,0:11:39.33,0:11:43.34,Default,,0000,0000,0000,,そっか
Dialogue: 0,0:11:43.34,0:11:46.34,Default,,0000,0000,0000,,向こうの世界では こういったものはないからね
Dialogue: 0,0:11:46.34,0:11:51.68,Default,,0000,0000,0000,,概念から異なるわ
Dialogue: 0,0:11:46.34,0:11:51.68,Default,,0000,0000,0000,,構造だけで威力を高めるなんて
Dialogue: 0,0:11:51.68,0:11:55.01,Default,,0000,0000,0000,,これを向こうの世界で 応用するには
Dialogue: 0,0:11:55.01,0:11:59.19,Default,,0000,0000,0000,,フッ フフッ
Dialogue: 0,0:11:55.01,0:11:59.19,Default,,0000,0000,0000,,なんか 怖いこと言いだした
Dialogue: 0,0:11:59.19,0:12:03.86,Default,,0000,0000,0000,,じゅ 銃を向こうに持ち込むのは やめておこうか?
Dialogue: 0,0:12:03.86,0:12:06.86,Default,,0000,0000,0000,,あ あれ? ウリドラは?
Dialogue: 0,0:12:08.86,0:12:11.06,Default,,0000,0000,0000,,ぐるるる
Dialogue: 0,0:12:15.20,0:12:19.54,Default,,0000,0000,0000,,ウリドラは日本の剣に夢中なのね!
Dialogue: 0,0:12:15.20,0:12:19.54,Default,,0000,0000,0000,,ふん ふん!
Dialogue: 0,0:12:19.54,0:12:23.04,Default,,0000,0000,0000,,なぜ2人とも 武器にばっかり興味を
Dialogue: 0,0:12:26.55,0:12:29.55,Default,,0000,0000,0000,,フッフーン なるほど
Dialogue: 0,0:12:29.55,0:12:31.88,Default,,0000,0000,0000,,お城の構造が わかってきたわ
Dialogue: 0,0:12:31.88,0:12:35.82,Default,,0000,0000,0000,,攻めやすい場所をあえて用意して 敵を一か所に集め
Dialogue: 0,0:12:35.82,0:12:39.66,Default,,0000,0000,0000,,そこを叩いたのね!
Dialogue: 0,0:12:35.82,0:12:39.66,Default,,0000,0000,0000,,にう!
Dialogue: 0,0:12:39.66,0:12:43.66,Default,,0000,0000,0000,,日本のお城は なかなか したたかで狡猾ね
Dialogue: 0,0:12:43.66,0:12:46.17,Default,,0000,0000,0000,,見習わないと
Dialogue: 0,0:12:43.66,0:12:46.17,Default,,0000,0000,0000,,にうにう
Dialogue: 0,0:12:46.17,0:12:48.67,Default,,0000,0000,0000,,まったく この2人は物騒な
Dialogue: 0,0:12:52.00,0:12:55.84,Default,,0000,0000,0000,,まぁ 小さな窓だけど いい眺めだわ
Dialogue: 0,0:12:55.84,0:12:58.01,Default,,0000,0000,0000,,にう
Dialogue: 0,0:12:55.84,0:12:58.01,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:58.01,0:13:01.68,Default,,0000,0000,0000,,んっ? どうかした?
Dialogue: 0,0:12:58.01,0:13:01.68,Default,,0000,0000,0000,,いや
Dialogue: 0,0:13:01.68,0:13:06.19,Default,,0000,0000,0000,,そういえばここも おじいさんたちに 連れてきてもらったなって
Dialogue: 0,0:13:08.22,0:13:11.22,Default,,0000,0000,0000,,あんまり思い出のない 子ども時代だったけど
Dialogue: 0,0:13:11.22,0:13:15.06,Default,,0000,0000,0000,,こうして来てみたら ちゃんとあるものだな
Dialogue: 0,0:13:15.06,0:13:17.20,Default,,0000,0000,0000,,懐かしい?
Dialogue: 0,0:13:15.06,0:13:17.20,Default,,0000,0000,0000,,うん
Dialogue: 0,0:13:17.20,0:13:21.00,Default,,0000,0000,0000,,青森に帰ってきて よかったなって考えていたよ
Dialogue: 0,0:13:24.87,0:13:27.37,Default,,0000,0000,0000,,あいよ お待ちどおさま
Dialogue: 0,0:13:29.91,0:13:31.91,Default,,0000,0000,0000,,うわぁ いい匂い!
Dialogue: 0,0:13:31.91,0:13:35.28,Default,,0000,0000,0000,,これが 「たこ焼き」だよ
Dialogue: 0,0:13:31.91,0:13:35.28,Default,,0000,0000,0000,,熱いから気をつけて
Dialogue: 0,0:13:37.85,0:13:40.19,Default,,0000,0000,0000,,まるくって かわいい!
Dialogue: 0,0:13:40.19,0:13:43.49,Default,,0000,0000,0000,,フーッ フーッ
Dialogue: 0,0:13:43.49,0:13:45.86,Default,,0000,0000,0000,,んっ んんっ!
Dialogue: 0,0:13:45.86,0:13:49.23,Default,,0000,0000,0000,,トロトロ アツアツで おいひっ!
Dialogue: 0,0:13:55.87,0:13:58.67,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:13:58.67,0:14:02.84,Default,,0000,0000,0000,,か 顔にソースでも付いてる?
Dialogue: 0,0:13:58.67,0:14:02.84,Default,,0000,0000,0000,,いいえ
Dialogue: 0,0:14:02.84,0:14:07.68,Default,,0000,0000,0000,,あなたを見飽きないか 試していたのよ 一廣さん
Dialogue: 0,0:14:05.68,0:14:07.68,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:14:07.68,0:14:10.18,Default,,0000,0000,0000,,な なんでそんなこと
Dialogue: 0,0:14:12.22,0:14:15.79,Default,,0000,0000,0000,,初めて日本に来たときも こんな景色だったわ
Dialogue: 0,0:14:17.86,0:14:20.36,Default,,0000,0000,0000,,うん そうだったね
Dialogue: 0,0:14:20.36,0:14:26.20,Default,,0000,0000,0000,,あの日 朝 マリーがベッドにいて
Dialogue: 0,0:14:20.36,0:14:26.20,Default,,0000,0000,0000,,本当にビックリしたよ
Dialogue: 0,0:14:26.20,0:14:29.70,Default,,0000,0000,0000,,あら こっちこそよ
Dialogue: 0,0:14:26.20,0:14:29.70,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:14:29.70,0:14:34.31,Default,,0000,0000,0000,,たったひとつき前なのに ずいぶんたった気がするな
Dialogue: 0,0:14:34.31,0:14:36.48,Default,,0000,0000,0000,,そうね
Dialogue: 0,0:14:36.48,0:14:38.48,Default,,0000,0000,0000,,あれから とても変わったの
Dialogue: 0,0:14:38.48,0:14:44.15,Default,,0000,0000,0000,,あなたを知るたび楽しくて
Dialogue: 0,0:14:38.48,0:14:44.15,Default,,0000,0000,0000,,フフッ 見飽きることなんてないわ
Dialogue: 0,0:14:44.15,0:14:46.99,Default,,0000,0000,0000,,こっちこそだよ
Dialogue: 0,0:14:46.99,0:14:51.16,Default,,0000,0000,0000,,目に映る景色も どこか変わって見えるの
Dialogue: 0,0:14:51.16,0:14:56.16,Default,,0000,0000,0000,,同じ桜も 前よりもっと色鮮やかで
Dialogue: 0,0:14:56.16,0:14:58.76,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:15:00.83,0:15:04.54,Default,,0000,0000,0000,,あ あっ
Dialogue: 0,0:15:06.51,0:15:12.01,Default,,0000,0000,0000,,一瞬 僕には見えないはずの
Dialogue: 0,0:15:06.51,0:15:12.01,Default,,0000,0000,0000,,桜の精霊が 見えた気がした
Dialogue: 0,0:15:14.01,0:15:16.68,Default,,0000,0000,0000,,あっ 唇に花びらが
Dialogue: 0,0:15:26.03,0:15:30.03,Default,,0000,0000,0000,,きれいだったねぇ
Dialogue: 0,0:15:26.03,0:15:30.03,Default,,0000,0000,0000,,桜吹雪だな
Dialogue: 0,0:15:44.98,0:15:47.81,Default,,0000,0000,0000,,あの 一廣さん?
Dialogue: 0,0:15:44.98,0:15:47.81,Default,,0000,0000,0000,,ふぁいっ!?
Dialogue: 0,0:15:47.81,0:15:52.15,Default,,0000,0000,0000,,ななな 何?
Dialogue: 0,0:15:47.81,0:15:52.15,Default,,0000,0000,0000,,大丈夫?
Dialogue: 0,0:15:52.15,0:15:56.82,Default,,0000,0000,0000,,バスタオル忘れてたみたいだから ここに置いておくわね
Dialogue: 0,0:15:56.82,0:16:01.16,Default,,0000,0000,0000,,あ あぁ そっか
Dialogue: 0,0:15:56.82,0:16:01.16,Default,,0000,0000,0000,,ごめん ありがとう
Dialogue: 0,0:16:01.16,0:16:04.46,Default,,0000,0000,0000,,あのね 今日の その
Dialogue: 0,0:16:06.50,0:16:09.70,Default,,0000,0000,0000,,ううん なんでもないわ
Dialogue: 0,0:16:06.50,0:16:09.70,Default,,0000,0000,0000,,あっ 待って!
Dialogue: 0,0:16:11.67,0:16:16.01,Default,,0000,0000,0000,,さっきのこと だよね
Dialogue: 0,0:16:11.67,0:16:16.01,Default,,0000,0000,0000,,そ そうよ
Dialogue: 0,0:16:16.01,0:16:18.68,Default,,0000,0000,0000,,キ キスのことだけど
Dialogue: 0,0:16:18.68,0:16:23.28,Default,,0000,0000,0000,,今までに同じことをした相手は
Dialogue: 0,0:16:18.68,0:16:23.28,Default,,0000,0000,0000,,いるのかしら
Dialogue: 0,0:16:25.35,0:16:27.69,Default,,0000,0000,0000,,あ やっ
Dialogue: 0,0:16:25.35,0:16:27.69,Default,,0000,0000,0000,,嫌なら答えなくていいわ!
Dialogue: 0,0:16:27.69,0:16:31.19,Default,,0000,0000,0000,,変なこと聞いてごめんなさい!
Dialogue: 0,0:16:27.69,0:16:31.19,Default,,0000,0000,0000,,いっ いやいや!
Dialogue: 0,0:16:31.19,0:16:33.19,Default,,0000,0000,0000,,マリーが初めてだよ
Dialogue: 0,0:16:33.19,0:16:36.96,Default,,0000,0000,0000,,この年で恥ずかしいけど 誰ともしたことがない
Dialogue: 0,0:16:36.96,0:16:38.96,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:16:38.96,0:16:41.47,Default,,0000,0000,0000,,そ そう
Dialogue: 0,0:16:43.47,0:16:48.47,Default,,0000,0000,0000,,い 言っておくけど 私の里には キスという文化は
Dialogue: 0,0:16:45.47,0:16:48.47,Default,,0000,0000,0000,,あまり根づいていないの!
Dialogue: 0,0:16:48.47,0:16:52.14,Default,,0000,0000,0000,,別に 私が モテなかったとかじゃないわ!
Dialogue: 0,0:16:52.14,0:16:57.15,Default,,0000,0000,0000,,だ だから
Dialogue: 0,0:16:52.14,0:16:57.15,Default,,0000,0000,0000,,そう てれることでもないわね
Dialogue: 0,0:16:57.15,0:17:00.15,Default,,0000,0000,0000,,初めて同士なら
Dialogue: 0,0:17:00.15,0:17:02.65,Default,,0000,0000,0000,,じゃ じゃあ ごゆっくり!
Dialogue: 0,0:17:16.04,0:17:19.20,Default,,0000,0000,0000,,何かいいことでもあったかな?
Dialogue: 0,0:17:16.04,0:17:19.20,Default,,0000,0000,0000,,ひゃあ!
Dialogue: 0,0:17:21.17,0:17:25.34,Default,,0000,0000,0000,,ご ごめんなさい!
Dialogue: 0,0:17:21.17,0:17:25.34,Default,,0000,0000,0000,,いや すまんね 驚かせて
Dialogue: 0,0:17:25.34,0:17:28.25,Default,,0000,0000,0000,,あんまりうれしそうに 見えたからさ
Dialogue: 0,0:17:30.68,0:17:33.02,Default,,0000,0000,0000,,一廣と仲がいいねぇ
Dialogue: 0,0:17:33.02,0:17:37.62,Default,,0000,0000,0000,,もう長いつきあいみたいな
Dialogue: 0,0:17:33.02,0:17:37.62,Default,,0000,0000,0000,,幼なじみのようだ
Dialogue: 0,0:17:37.62,0:17:40.29,Default,,0000,0000,0000,,幼なじみ フフッ
Dialogue: 0,0:17:40.29,0:17:45.63,Default,,0000,0000,0000,,みたいなものかもしれません
Dialogue: 0,0:17:40.29,0:17:45.63,Default,,0000,0000,0000,,あっいえ 例え話というか
Dialogue: 0,0:17:45.63,0:17:48.83,Default,,0000,0000,0000,,どう説明すればいいのかしら?
Dialogue: 0,0:17:48.83,0:17:51.67,Default,,0000,0000,0000,,向こうの世界のことは 話せないし
Dialogue: 0,0:17:51.67,0:17:55.31,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:17:51.67,0:17:55.31,Default,,0000,0000,0000,,そうだ マリーちゃん
Dialogue: 0,0:17:55.31,0:17:57.31,Default,,0000,0000,0000,,いいものを見せてあげよう
Dialogue: 0,0:17:59.65,0:18:03.15,Default,,0000,0000,0000,,あ こ これは
Dialogue: 0,0:18:03.15,0:18:08.32,Default,,0000,0000,0000,,写真 「思い出」ですね
Dialogue: 0,0:18:03.15,0:18:08.32,Default,,0000,0000,0000,,あぁ そうだねぇ
Dialogue: 0,0:18:08.32,0:18:11.82,Default,,0000,0000,0000,,俺にとっては 大事な宝もんだよ
Dialogue: 0,0:18:17.00,0:18:19.00,Default,,0000,0000,0000,,あぁ これ
Dialogue: 0,0:18:19.00,0:18:21.67,Default,,0000,0000,0000,,これはアイツが14のころだね
Dialogue: 0,0:18:21.67,0:18:25.34,Default,,0000,0000,0000,,あっ あっちの世界で 見る姿とおんなじ
Dialogue: 0,0:18:25.34,0:18:27.51,Default,,0000,0000,0000,,あ でも
Dialogue: 0,0:18:27.51,0:18:31.01,Default,,0000,0000,0000,,寂しそうな目をしているだろう?
Dialogue: 0,0:18:27.51,0:18:31.01,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:18:31.01,0:18:33.01,Default,,0000,0000,0000,,俺は驚いたよ
Dialogue: 0,0:18:33.01,0:18:36.62,Default,,0000,0000,0000,,あの子の あんなに明るい笑顔が 見られるなんてね
Dialogue: 0,0:18:36.62,0:18:38.62,Default,,0000,0000,0000,,えっ? あの
Dialogue: 0,0:18:38.62,0:18:42.29,Default,,0000,0000,0000,,一廣さんは 笑わなかったんですか?
Dialogue: 0,0:18:38.62,0:18:42.29,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:18:42.29,0:18:45.46,Default,,0000,0000,0000,,今の様子からは想像できんかな?
Dialogue: 0,0:18:45.46,0:18:52.13,Default,,0000,0000,0000,,俺の娘 一廣の母親は
Dialogue: 0,0:18:45.46,0:18:52.13,Default,,0000,0000,0000,,どうしようもないヤツでね
Dialogue: 0,0:18:52.13,0:18:55.30,Default,,0000,0000,0000,,ある日突然 どこかへ行っちまって
Dialogue: 0,0:18:55.30,0:18:59.30,Default,,0000,0000,0000,,それで 俺とばあさんが 一廣を引き取ったんだ
Dialogue: 0,0:18:59.30,0:19:05.14,Default,,0000,0000,0000,,人にも動物にも あの子は何も
Dialogue: 0,0:18:59.30,0:19:05.14,Default,,0000,0000,0000,,興味を示さなくてね
Dialogue: 0,0:19:05.14,0:19:07.48,Default,,0000,0000,0000,,代わりに よく眠っていたよ
Dialogue: 0,0:19:07.48,0:19:11.15,Default,,0000,0000,0000,,起こすのが かわいそうなくらいにさ
Dialogue: 0,0:19:11.15,0:19:13.49,Default,,0000,0000,0000,,東京へ行ったのは
Dialogue: 0,0:19:13.49,0:19:16.82,Default,,0000,0000,0000,,母親に会いたがってるんじゃ ないかと思ってね
Dialogue: 0,0:19:16.82,0:19:20.03,Default,,0000,0000,0000,,もう こっちには 帰ってこないかもなって
Dialogue: 0,0:19:21.99,0:19:26.67,Default,,0000,0000,0000,,それが こんなにかわいい子を 連れて帰ってくるんだもんなぁ
Dialogue: 0,0:19:26.67,0:19:28.67,Default,,0000,0000,0000,,ありがとうね
Dialogue: 0,0:19:28.67,0:19:32.67,Default,,0000,0000,0000,,一廣が笑うようになったのは きっと 君のおかげだ
Dialogue: 0,0:19:34.64,0:19:36.64,Default,,0000,0000,0000,,だから この家にいるときは
Dialogue: 0,0:19:36.64,0:19:40.31,Default,,0000,0000,0000,,なんにも気にしなくていいよ
Dialogue: 0,0:19:36.64,0:19:40.31,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:19:40.31,0:19:42.81,Default,,0000,0000,0000,,そのままの君で いいんだよ
Dialogue: 0,0:19:54.99,0:20:00.33,Default,,0000,0000,0000,,俺くらい長いこと生きてるとね
Dialogue: 0,0:19:54.99,0:20:00.33,Default,,0000,0000,0000,,不思議なことも
Dialogue: 0,0:20:00.33,0:20:03.34,Default,,0000,0000,0000,,そのまんま受け止められるように なるもんさ
Dialogue: 0,0:20:03.34,0:20:08.64,Default,,0000,0000,0000,,夢の土産話を聞けるのは
Dialogue: 0,0:20:03.34,0:20:08.64,Default,,0000,0000,0000,,じいさんの特権なんじゃないかな
Dialogue: 0,0:20:08.64,0:20:11.64,Default,,0000,0000,0000,,あ うぅ
Dialogue: 0,0:20:11.64,0:20:14.68,Default,,0000,0000,0000,,おじいさん!
Dialogue: 0,0:20:11.64,0:20:14.68,Default,,0000,0000,0000,,おっと
Dialogue: 0,0:20:14.68,0:20:18.68,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:20:14.68,0:20:18.68,Default,,0000,0000,0000,,フフフ さすがはエルフさん
Dialogue: 0,0:20:18.68,0:20:21.45,Default,,0000,0000,0000,,夢に見るほどの かわいらしさだ
Dialogue: 0,0:20:26.02,0:20:28.86,Default,,0000,0000,0000,,ふぅ
Dialogue: 0,0:20:26.02,0:20:28.86,Default,,0000,0000,0000,,それでこれが運動会のときでね
Dialogue: 0,0:20:28.86,0:20:30.86,Default,,0000,0000,0000,,うわっ かわいい!
Dialogue: 0,0:20:30.86,0:20:35.87,Default,,0000,0000,0000,,んっ 楽しそうだな
Dialogue: 0,0:20:30.86,0:20:35.87,Default,,0000,0000,0000,,仲よくなってよかった
Dialogue: 0,0:20:35.87,0:20:37.87,Default,,0000,0000,0000,,んがっ!?
Dialogue: 0,0:20:37.87,0:20:39.87,Default,,0000,0000,0000,,耳!
Dialogue: 0,0:20:39.87,0:20:43.54,Default,,0000,0000,0000,,マリー 耳 耳出てる!
Dialogue: 0,0:20:39.87,0:20:43.54,Default,,0000,0000,0000,,耳出てるってば!
Dialogue: 0,0:20:43.54,0:20:46.18,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:20:43.54,0:20:46.18,Default,,0000,0000,0000,,耳! 耳
Dialogue: 0,0:20:46.18,0:20:49.48,Default,,0000,0000,0000,,アハハハ!
Dialogue: 0,0:20:46.18,0:20:49.48,Default,,0000,0000,0000,,えっ えぇ?
Dialogue: 0,0:20:53.02,0:20:55.69,Default,,0000,0000,0000,,お世話になりました
Dialogue: 0,0:20:53.02,0:20:55.69,Default,,0000,0000,0000,,いやいや
Dialogue: 0,0:20:55.69,0:20:59.36,Default,,0000,0000,0000,,久々に楽しかったよ 元気でな
Dialogue: 0,0:20:59.36,0:21:02.76,Default,,0000,0000,0000,,おじいさん ありがとうございました
Dialogue: 0,0:21:04.70,0:21:07.37,Default,,0000,0000,0000,,おぉ ありゃまあ
Dialogue: 0,0:21:07.37,0:21:11.20,Default,,0000,0000,0000,,一廣 うちの仕事を 継ぎたいってんなら
Dialogue: 0,0:21:11.20,0:21:15.37,Default,,0000,0000,0000,,歓迎するぞ
Dialogue: 0,0:21:11.20,0:21:15.37,Default,,0000,0000,0000,,か 考えときます
Dialogue: 0,0:21:15.37,0:21:19.75,Default,,0000,0000,0000,,いつでも遊びにおいで
Dialogue: 0,0:21:15.37,0:21:19.75,Default,,0000,0000,0000,,俺は待ってるからさ
Dialogue: 0,0:21:26.72,0:21:30.56,Default,,0000,0000,0000,,結局 おじいさんが 向こうの世界のことを
Dialogue: 0,0:21:30.56,0:21:33.39,Default,,0000,0000,0000,,どこまで知っているかは わからなかった
Dialogue: 0,0:21:33.39,0:21:36.83,Default,,0000,0000,0000,,でも この世界で僕以外にも
Dialogue: 0,0:21:36.83,0:21:40.33,Default,,0000,0000,0000,,マリーの本当の姿を 知っている人ができたことは
Dialogue: 0,0:21:40.33,0:21:42.33,Default,,0000,0000,0000,,よかった気がする
Dialogue: 0,0:21:48.84,0:21:53.18,Default,,0000,0000,0000,,ねぇ 不思議
Dialogue: 0,0:21:48.84,0:21:53.18,Default,,0000,0000,0000,,帰ってきたという感じがするわ
Dialogue: 0,0:21:53.18,0:21:57.52,Default,,0000,0000,0000,,いつの間にか 私の暮らす場所の 景色になっていたのね
Dialogue: 0,0:21:57.52,0:21:59.52,Default,,0000,0000,0000,,うん
Dialogue: 0,0:21:59.52,0:22:01.69,Default,,0000,0000,0000,,おかえりなさい
Dialogue: 0,0:22:01.69,0:22:05.69,Default,,0000,0000,0000,,ただいま
Dialogue: 0,0:22:01.69,0:22:05.69,Default,,0000,0000,0000,,あなたも おかえりなさい
Dialogue: 0,0:22:05.69,0:22:08.86,Default,,0000,0000,0000,,ただいま
Dialogue: 0,0:22:08.86,0:22:10.86,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:22:12.86,0:22:18.54,Default,,0000,0000,0000,,僕らの関係は
Dialogue: 0,0:22:12.86,0:22:18.54,Default,,0000,0000,0000,,少しだけ 前に進んだのかな
Dialogue: 0,0:22:18.54,0:22:22.04,Default,,0000,0000,0000,,ねぇマリー 一緒に歩いていこう
Dialogue: 0,0:22:22.04,0:22:26.85,Default,,0000,0000,0000,,こちらの世界も あちらの世界も 2人で
Dialogue: 0,0:22:28.88,0:22:31.08,Default,,0000,0000,0000,,にゃっ にゃっ にゃう?
Dialogue: 0,0:22:36.36,0:22:38.86,Default,,0000,0000,0000,,ねぇ 帰ったら何食べよう?
Dialogue: 0,0:22:38.86,0:22:44.20,Default,,0000,0000,0000,,えっとね 鍋!
Dialogue: 0,0:22:38.86,0:22:44.20,Default,,0000,0000,0000,,鍋かぁ よし!
Dialogue: 0,0:22:44.20,0:22:46.67,Default,,0000,0000,0000,,やった!
