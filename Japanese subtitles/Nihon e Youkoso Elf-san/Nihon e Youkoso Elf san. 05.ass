Dialogue: 0,0:00:38.81,0:00:41.47,Default,,0000,0000,0000,,ほらミュイ 見てごらん
Dialogue: 0,0:00:41.47,0:00:46.65,Default,,0000,0000,0000,,お前にいつか これを
Dialogue: 0,0:00:41.47,0:00:46.65,Default,,0000,0000,0000,,見せてやろうと思っていたんだ
Dialogue: 0,0:00:46.65,0:00:49.98,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:00:49.98,0:00:52.65,Default,,0000,0000,0000,,わぁ きれいな色
Dialogue: 0,0:00:52.65,0:00:55.36,Default,,0000,0000,0000,,フフフ 触ってごらん
Dialogue: 0,0:00:57.99,0:01:01.49,Default,,0000,0000,0000,,おおっ! わぁ
Dialogue: 0,0:01:01.49,0:01:05.17,Default,,0000,0000,0000,,ホホホ お前は石に好かれる子だ
Dialogue: 0,0:01:05.17,0:01:08.67,Default,,0000,0000,0000,,わぁ
Dialogue: 0,0:01:08.67,0:01:13.01,Default,,0000,0000,0000,,いいかい ミュイ ワシら一族は
Dialogue: 0,0:01:13.01,0:01:17.34,Default,,0000,0000,0000,,太古の昔から 魔石と呼ばれるものを
Dialogue: 0,0:01:17.34,0:01:21.85,Default,,0000,0000,0000,,扱う力を持っていたんだ
Dialogue: 0,0:01:17.34,0:01:21.85,Default,,0000,0000,0000,,魔石?
Dialogue: 0,0:01:21.85,0:01:26.69,Default,,0000,0000,0000,,その魔石の中でも これは飛び切り上等なものだ
Dialogue: 0,0:01:26.69,0:01:33.36,Default,,0000,0000,0000,,そして悲しいことに ワシらの里を
Dialogue: 0,0:01:26.69,0:01:33.36,Default,,0000,0000,0000,,滅ぼしたものでもある
Dialogue: 0,0:01:45.14,0:01:48.34,Default,,0000,0000,0000,,おじいちゃん
Dialogue: 0,0:03:38.45,0:03:40.95,Default,,0000,0000,0000,,じゃあ 手はずどおり いこうか
Dialogue: 0,0:03:40.95,0:03:45.63,Default,,0000,0000,0000,,目的は 獣人の子の救出と 賊の撃退
Dialogue: 0,0:03:45.63,0:03:49.96,Default,,0000,0000,0000,,何か難しいと判断したときは チャットで伝えるからね
Dialogue: 0,0:03:49.96,0:03:54.47,Default,,0000,0000,0000,,了解 そのときは合流して トレインで脱出ね!
Dialogue: 0,0:03:54.47,0:03:59.14,Default,,0000,0000,0000,,じゃあ作戦開始! トゥイル!
Dialogue: 0,0:03:59.14,0:04:01.34,Default,,0000,0000,0000,,ナー・エルヴィシヴィニ
Dialogue: 0,0:04:04.48,0:04:07.98,Default,,0000,0000,0000,,わぁ 光精霊の姿隠しか
Dialogue: 0,0:04:07.98,0:04:11.15,Default,,0000,0000,0000,,本当に何も見えなくなるものだね
Dialogue: 0,0:04:11.15,0:04:14.65,Default,,0000,0000,0000,,あら 寝ぼすけのあなたにまで 見えてたら
Dialogue: 0,0:04:14.65,0:04:19.49,Default,,0000,0000,0000,,術なんて呼べないわ
Dialogue: 0,0:04:14.65,0:04:19.49,Default,,0000,0000,0000,,けどマリー 絶対に無理しないで
Dialogue: 0,0:04:19.49,0:04:21.66,Default,,0000,0000,0000,,ええ あなたも
Dialogue: 0,0:04:21.66,0:04:24.16,Default,,0000,0000,0000,,わかった じゃあ行くよ
Dialogue: 0,0:04:24.16,0:04:27.17,Default,,0000,0000,0000,,あっ カズヒホ!
Dialogue: 0,0:04:24.16,0:04:27.17,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:04:27.17,0:04:32.17,Default,,0000,0000,0000,,あの 帰ったら 絵本の続きを読んでちょうだいね
Dialogue: 0,0:04:32.17,0:04:35.11,Default,,0000,0000,0000,,うん オーバーロード!
Dialogue: 0,0:04:47.12,0:04:51.62,Default,,0000,0000,0000,,まず 獣人の子の居場所を 捜さないといけないけど
Dialogue: 0,0:04:51.62,0:04:54.96,Default,,0000,0000,0000,,盗賊たちに 見張られているだろうね
Dialogue: 0,0:04:54.96,0:04:58.13,Default,,0000,0000,0000,,だから ヤツらに こっちを見つけてもらう
Dialogue: 0,0:04:58.13,0:05:01.80,Default,,0000,0000,0000,,盗賊は きっとまたあの子に
Dialogue: 0,0:05:01.80,0:05:04.47,Default,,0000,0000,0000,,怪物を 呼び出させようとするから
Dialogue: 0,0:05:04.47,0:05:09.14,Default,,0000,0000,0000,,うん あの子は1人で出てくる
Dialogue: 0,0:05:04.47,0:05:09.14,Default,,0000,0000,0000,,そこへ僕が行く
Dialogue: 0,0:05:09.14,0:05:12.15,Default,,0000,0000,0000,,だったら私が 怪物を引きつけておくわ
Dialogue: 0,0:05:12.15,0:05:14.15,Default,,0000,0000,0000,,ええっ 危険すぎるよ
Dialogue: 0,0:05:14.15,0:05:17.98,Default,,0000,0000,0000,,そうしないと あなたが危険じゃない
Dialogue: 0,0:05:14.15,0:05:17.98,Default,,0000,0000,0000,,でも
Dialogue: 0,0:05:17.98,0:05:22.99,Default,,0000,0000,0000,,忘れてはいないかしら
Dialogue: 0,0:05:17.98,0:05:22.99,Default,,0000,0000,0000,,私は精霊魔術師なのよ
Dialogue: 0,0:05:24.99,0:05:26.99,Default,,0000,0000,0000,,オーバーロード
Dialogue: 0,0:05:31.16,0:05:33.17,Default,,0000,0000,0000,,いたいた
Dialogue: 0,0:05:33.17,0:05:36.60,Default,,0000,0000,0000,,マリー ヤツらの位置は確認した
Dialogue: 0,0:05:36.60,0:05:39.94,Default,,0000,0000,0000,,そっちの準備はどう?
Dialogue: 0,0:05:36.60,0:05:39.94,Default,,0000,0000,0000,,まずまずよ
Dialogue: 0,0:05:39.94,0:05:44.44,Default,,0000,0000,0000,,10体の火とかげを 砂に潜らせたところ
Dialogue: 0,0:05:44.44,0:05:47.61,Default,,0000,0000,0000,,ねぇ 本当に威力を抑えていいの?
Dialogue: 0,0:05:47.61,0:05:51.78,Default,,0000,0000,0000,,うん 威力より 数で翻弄してほしいからね
Dialogue: 0,0:05:51.78,0:05:55.46,Default,,0000,0000,0000,,じゃあ まずは一発 試してもらおうかな
Dialogue: 0,0:05:55.46,0:05:57.96,Default,,0000,0000,0000,,いいわ
Dialogue: 0,0:05:57.96,0:05:59.96,Default,,0000,0000,0000,,スピア!
Dialogue: 0,0:05:59.96,0:06:02.36,Default,,0000,0000,0000,,ハッ ハウッ!
Dialogue: 0,0:06:06.63,0:06:10.14,Default,,0000,0000,0000,,おっ 距離も相当いけるんだね
Dialogue: 0,0:06:10.14,0:06:12.14,Default,,0000,0000,0000,,んっ? あっ
Dialogue: 0,0:06:14.14,0:06:16.64,Default,,0000,0000,0000,,ウッ!
Dialogue: 0,0:06:16.64,0:06:18.98,Default,,0000,0000,0000,,ええっ? クソッ!
Dialogue: 0,0:06:18.98,0:06:21.18,Default,,0000,0000,0000,,ハハッ さて
Dialogue: 0,0:06:24.65,0:06:28.35,Default,,0000,0000,0000,,来るよ
Dialogue: 0,0:06:24.65,0:06:28.35,Default,,0000,0000,0000,,いつでもどうぞ
Dialogue: 0,0:06:34.76,0:06:37.26,Default,,0000,0000,0000,,ギャオー!
Dialogue: 0,0:06:37.26,0:06:39.93,Default,,0000,0000,0000,,クッ マリー 大丈夫?
Dialogue: 0,0:06:39.93,0:06:42.64,Default,,0000,0000,0000,,もちろんよ
Dialogue: 0,0:06:39.93,0:06:42.64,Default,,0000,0000,0000,,それより あの子は?
Dialogue: 0,0:06:46.61,0:06:49.44,Default,,0000,0000,0000,,あっ 見つけた!
Dialogue: 0,0:06:49.44,0:06:52.11,Default,,0000,0000,0000,,じゃあ頼んだよ マリー
Dialogue: 0,0:06:49.44,0:06:52.11,Default,,0000,0000,0000,,あっ!?
Dialogue: 0,0:06:52.11,0:06:55.11,Default,,0000,0000,0000,,「頼んだよ」 ですって
Dialogue: 0,0:06:55.11,0:06:57.12,Default,,0000,0000,0000,,フンッ!
Dialogue: 0,0:06:57.12,0:07:00.12,Default,,0000,0000,0000,,スピア!
Dialogue: 0,0:06:57.12,0:07:00.12,Default,,0000,0000,0000,,アウッ!
Dialogue: 0,0:07:02.96,0:07:05.29,Default,,0000,0000,0000,,ワッ
Dialogue: 0,0:07:05.29,0:07:07.63,Default,,0000,0000,0000,,ワッ!
Dialogue: 0,0:07:07.63,0:07:11.80,Default,,0000,0000,0000,,はぁ なるほど
Dialogue: 0,0:07:07.63,0:07:11.80,Default,,0000,0000,0000,,聞いてはいたけど
Dialogue: 0,0:07:11.80,0:07:14.80,Default,,0000,0000,0000,,一発だけ撃てる ゲリラ戦車みたいなものか
Dialogue: 0,0:07:17.30,0:07:19.31,Default,,0000,0000,0000,,よし その調子よ!
Dialogue: 0,0:07:19.31,0:07:21.64,Default,,0000,0000,0000,,マリーは離れた所から
Dialogue: 0,0:07:21.64,0:07:25.31,Default,,0000,0000,0000,,動く必要もなく標的を陽動できる
Dialogue: 0,0:07:25.31,0:07:29.48,Default,,0000,0000,0000,,精霊魔術って もしかして すごく便利なんじゃないの?
Dialogue: 0,0:07:29.48,0:07:34.89,Default,,0000,0000,0000,,けど 急がないとね
Dialogue: 0,0:07:29.48,0:07:34.89,Default,,0000,0000,0000,,マリーの魔力にも限界があるし
Dialogue: 0,0:07:36.76,0:07:39.76,Default,,0000,0000,0000,,な 何 何が起こっているの?
Dialogue: 0,0:07:39.76,0:07:42.26,Default,,0000,0000,0000,,ウッ!
Dialogue: 0,0:07:42.26,0:07:47.93,Default,,0000,0000,0000,,怖いよう 助けて 誰か
Dialogue: 0,0:07:47.93,0:07:50.94,Default,,0000,0000,0000,,おじいちゃん
Dialogue: 0,0:07:50.94,0:07:53.27,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:07:53.27,0:07:56.44,Default,,0000,0000,0000,,やあ
Dialogue: 0,0:07:56.44,0:08:00.28,Default,,0000,0000,0000,,わっ!? わぁっ!
Dialogue: 0,0:07:56.44,0:08:00.28,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:08:00.28,0:08:05.28,Default,,0000,0000,0000,,どうしてここに?
Dialogue: 0,0:08:00.28,0:08:05.28,Default,,0000,0000,0000,,し 仕返しにきたの?
Dialogue: 0,0:08:05.28,0:08:07.29,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:07.29,0:08:09.62,Default,,0000,0000,0000,,うん やっぱり猫族だ
Dialogue: 0,0:08:09.62,0:08:14.83,Default,,0000,0000,0000,,相当おびえてるな
Dialogue: 0,0:08:09.62,0:08:14.83,Default,,0000,0000,0000,,無理もないか
Dialogue: 0,0:08:16.80,0:08:20.63,Default,,0000,0000,0000,,怖がらないでいいよ
Dialogue: 0,0:08:16.80,0:08:20.63,Default,,0000,0000,0000,,危害を加えたりしない
Dialogue: 0,0:08:20.63,0:08:22.64,Default,,0000,0000,0000,,君に会いにきたんだ
Dialogue: 0,0:08:22.64,0:08:25.64,Default,,0000,0000,0000,,あっ 獣人語をしゃべって
Dialogue: 0,0:08:25.64,0:08:29.14,Default,,0000,0000,0000,,ボ ボクらの言葉 わかるのデス?
Dialogue: 0,0:08:29.14,0:08:33.15,Default,,0000,0000,0000,,うん 言葉を覚えるのは 僕の趣味なんだ
Dialogue: 0,0:08:33.15,0:08:37.08,Default,,0000,0000,0000,,ボクらの言葉を話す ニンゲンがいるなんて
Dialogue: 0,0:08:37.08,0:08:41.25,Default,,0000,0000,0000,,君 1人?
Dialogue: 0,0:08:37.08,0:08:41.25,Default,,0000,0000,0000,,他に捕まってる仲間はいない?
Dialogue: 0,0:08:41.25,0:08:43.92,Default,,0000,0000,0000,,ボクだけ デス
Dialogue: 0,0:08:43.92,0:08:47.76,Default,,0000,0000,0000,,ボ ボクら猫族は とっても弱いから
Dialogue: 0,0:08:47.76,0:08:51.10,Default,,0000,0000,0000,,おじいちゃんと2人で 隠れて暮らしていたんデス
Dialogue: 0,0:08:51.10,0:08:55.60,Default,,0000,0000,0000,,ニンゲンに見つかったら ひ ひどいことされるって
Dialogue: 0,0:08:55.60,0:08:59.61,Default,,0000,0000,0000,,でも 突然 アイツらが来て
Dialogue: 0,0:08:59.61,0:09:02.61,Default,,0000,0000,0000,,おじいちゃんは
Dialogue: 0,0:09:07.78,0:09:10.95,Default,,0000,0000,0000,,そう
Dialogue: 0,0:09:10.95,0:09:14.62,Default,,0000,0000,0000,,ゆっくり君と話したいけど あまり時間がないんだ
Dialogue: 0,0:09:14.62,0:09:18.46,Default,,0000,0000,0000,,ここから逃げ出そう
Dialogue: 0,0:09:14.62,0:09:18.46,Default,,0000,0000,0000,,僕でよかったら 手を貸すよ
Dialogue: 0,0:09:18.46,0:09:20.46,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:09:20.46,0:09:24.96,Default,,0000,0000,0000,,どうして?
Dialogue: 0,0:09:20.46,0:09:24.96,Default,,0000,0000,0000,,ニンゲンの僕じゃ 信用できないかな?
Dialogue: 0,0:09:33.31,0:09:37.41,Default,,0000,0000,0000,,助けてクダサイ!
Dialogue: 0,0:09:33.31,0:09:37.41,Default,,0000,0000,0000,,もう こんなのは嫌なのデス!
Dialogue: 0,0:09:37.41,0:09:42.25,Default,,0000,0000,0000,,石で魔物を呼び出して 罪もない旅人を襲うなんて!
Dialogue: 0,0:09:42.25,0:09:44.25,Default,,0000,0000,0000,,わかった
Dialogue: 0,0:09:44.25,0:09:46.25,Default,,0000,0000,0000,,んっ!?
Dialogue: 0,0:09:46.25,0:09:48.25,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:09:48.25,0:09:52.06,Default,,0000,0000,0000,,よく戻ってきたなぁ クソガキ
Dialogue: 0,0:09:54.09,0:09:58.43,Default,,0000,0000,0000,,昨日どうやってあの場から 消えたのかわかったぞ
Dialogue: 0,0:09:58.43,0:10:02.27,Default,,0000,0000,0000,,お前は移動系のスキルに 特化したクソガキだ
Dialogue: 0,0:10:02.27,0:10:05.61,Default,,0000,0000,0000,,そのスキルでエルフを連れて 逃げたんだろう?
Dialogue: 0,0:10:05.61,0:10:08.77,Default,,0000,0000,0000,,あ うん だいぶ近いね
Dialogue: 0,0:10:08.77,0:10:13.11,Default,,0000,0000,0000,,それで よければ この子の足かせを 外してくれない?
Dialogue: 0,0:10:13.11,0:10:16.78,Default,,0000,0000,0000,,見たところ ただの鉄の輪じゃ なさそうだからね
Dialogue: 0,0:10:16.78,0:10:18.78,Default,,0000,0000,0000,,なら取り引きだ
Dialogue: 0,0:10:18.78,0:10:21.79,Default,,0000,0000,0000,,宝の詰まった お前のカバンをよこしな
Dialogue: 0,0:10:21.79,0:10:25.63,Default,,0000,0000,0000,,そうすりゃ こんなもんは砕いてやるよ
Dialogue: 0,0:10:25.63,0:10:29.13,Default,,0000,0000,0000,,へぇ 宝の詰まったカバンね
Dialogue: 0,0:10:29.13,0:10:31.80,Default,,0000,0000,0000,,そっちは探知スキルでも 持ってるのかな?
Dialogue: 0,0:10:31.80,0:10:33.90,Default,,0000,0000,0000,,フン それがどうした?
Dialogue: 0,0:10:36.80,0:10:41.31,Default,,0000,0000,0000,,何が取り引きだ
Dialogue: 0,0:10:36.80,0:10:41.31,Default,,0000,0000,0000,,そんな見え透いたウソ
Dialogue: 0,0:10:41.31,0:10:44.31,Default,,0000,0000,0000,,社会人には通用しないよ!
Dialogue: 0,0:10:48.98,0:10:50.98,Default,,0000,0000,0000,,ククッ
Dialogue: 0,0:10:50.98,0:10:54.82,Default,,0000,0000,0000,,そうかそうか
Dialogue: 0,0:10:50.98,0:10:54.82,Default,,0000,0000,0000,,よぉくわかった
Dialogue: 0,0:10:54.82,0:11:00.33,Default,,0000,0000,0000,,両手両足 切り落としてから
Dialogue: 0,0:10:54.82,0:11:00.33,Default,,0000,0000,0000,,まんべんなく塩を塗ってやる!
Dialogue: 0,0:11:00.33,0:11:03.33,Default,,0000,0000,0000,,叩き斬れ!
Dialogue: 0,0:11:00.33,0:11:03.33,Default,,0000,0000,0000,,やっちまえ!
Dialogue: 0,0:11:00.33,0:11:03.33,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:03.33,0:11:05.83,Default,,0000,0000,0000,,えい たっ!
Dialogue: 0,0:11:05.83,0:11:09.17,Default,,0000,0000,0000,,おおっ!? フンッ!
Dialogue: 0,0:11:09.17,0:11:12.67,Default,,0000,0000,0000,,チィッ すばしっこいヤツめ
Dialogue: 0,0:11:09.17,0:11:12.67,Default,,0000,0000,0000,,どけ!
Dialogue: 0,0:11:12.67,0:11:16.01,Default,,0000,0000,0000,,俺がやる
Dialogue: 0,0:11:16.01,0:11:19.01,Default,,0000,0000,0000,,フンッ!
Dialogue: 0,0:11:19.01,0:11:23.02,Default,,0000,0000,0000,,生身の腕で? ニヒッ
Dialogue: 0,0:11:26.19,0:11:30.36,Default,,0000,0000,0000,,装甲が コイツ タンクか
Dialogue: 0,0:11:30.36,0:11:33.36,Default,,0000,0000,0000,,ウウッ
Dialogue: 0,0:11:33.36,0:11:36.96,Default,,0000,0000,0000,,ハッハァ! 油断したな!
Dialogue: 0,0:11:36.96,0:11:39.80,Default,,0000,0000,0000,,クッ それなら
Dialogue: 0,0:11:39.80,0:11:42.30,Default,,0000,0000,0000,,ヒッヒー オラオラァ!
Dialogue: 0,0:11:42.30,0:11:45.14,Default,,0000,0000,0000,,そのまま落ちちまえ!
Dialogue: 0,0:11:45.14,0:11:48.64,Default,,0000,0000,0000,,代わりにどうぞ
Dialogue: 0,0:11:48.64,0:11:52.98,Default,,0000,0000,0000,,うわあっ!? ぬおぉ!
Dialogue: 0,0:11:55.15,0:11:57.95,Default,,0000,0000,0000,,何してる 絶対逃がすな!
Dialogue: 0,0:12:02.49,0:12:04.82,Default,,0000,0000,0000,,うまく隠れたね
Dialogue: 0,0:12:02.49,0:12:04.82,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:04.82,0:12:07.49,Default,,0000,0000,0000,,い 今 あなたは くにゃってなって
Dialogue: 0,0:12:07.49,0:12:11.16,Default,,0000,0000,0000,,消えたみたいに見えまシタ
Dialogue: 0,0:12:07.49,0:12:11.16,Default,,0000,0000,0000,,どうなっているのデス?
Dialogue: 0,0:12:11.16,0:12:14.67,Default,,0000,0000,0000,,あれは 僕のファーストスキル ファントムさ
Dialogue: 0,0:12:14.67,0:12:17.50,Default,,0000,0000,0000,,自分自身の幻影を 生み出すスキルだよ
Dialogue: 0,0:12:17.50,0:12:19.67,Default,,0000,0000,0000,,たぶん この能力が
Dialogue: 0,0:12:19.67,0:12:23.51,Default,,0000,0000,0000,,夢幻剣士という 僕の職業名の由来かな
Dialogue: 0,0:12:23.51,0:12:25.85,Default,,0000,0000,0000,,夢幻剣士
Dialogue: 0,0:12:25.85,0:12:30.18,Default,,0000,0000,0000,,単に弱いから 逃げ足を 鍛えてきただけなんだけどね
Dialogue: 0,0:12:30.18,0:12:33.52,Default,,0000,0000,0000,,えっ? 弱い? ホントですか?
Dialogue: 0,0:12:33.52,0:12:37.29,Default,,0000,0000,0000,,あぁ しょっちゅう 魔物にやられてばっかりさ
Dialogue: 0,0:12:37.29,0:12:40.79,Default,,0000,0000,0000,,あっ だから守るのは あんまり得意じゃないんだ
Dialogue: 0,0:12:40.79,0:12:44.13,Default,,0000,0000,0000,,君は見つからないよう 気をつけてくれるかな
Dialogue: 0,0:12:44.13,0:12:46.30,Default,,0000,0000,0000,,あっ はい!
Dialogue: 0,0:12:46.30,0:12:48.80,Default,,0000,0000,0000,,じゃあ もう少し待っていてね
Dialogue: 0,0:12:48.80,0:12:52.30,Default,,0000,0000,0000,,あの ボクの名前 ミュイ デス
Dialogue: 0,0:12:52.30,0:12:56.31,Default,,0000,0000,0000,,ミュイ 僕はカズヒホ よろしくね
Dialogue: 0,0:13:06.99,0:13:09.49,Default,,0000,0000,0000,,クソッ どこへ行きやがった?
Dialogue: 0,0:13:11.66,0:13:14.16,Default,,0000,0000,0000,,あっ! お前の後ろだ!
Dialogue: 0,0:13:11.66,0:13:14.16,Default,,0000,0000,0000,,へっ?
Dialogue: 0,0:13:14.16,0:13:17.16,Default,,0000,0000,0000,,うおっ!
Dialogue: 0,0:13:17.16,0:13:19.17,Default,,0000,0000,0000,,あっ ウッ
Dialogue: 0,0:13:21.17,0:13:24.34,Default,,0000,0000,0000,,あぁっ!
Dialogue: 0,0:13:21.17,0:13:24.34,Default,,0000,0000,0000,,チィ!
Dialogue: 0,0:13:24.34,0:13:28.17,Default,,0000,0000,0000,,ぬあっ!
Dialogue: 0,0:13:28.17,0:13:31.84,Default,,0000,0000,0000,,はっ!? また消えた! クソが!
Dialogue: 0,0:13:31.84,0:13:34.85,Default,,0000,0000,0000,,どこへ消えた!? 捜せ!
Dialogue: 0,0:13:36.78,0:13:40.62,Default,,0000,0000,0000,,カズヒホ! 無事なの?
Dialogue: 0,0:13:36.78,0:13:40.62,Default,,0000,0000,0000,,うん マリー 順調だよ
Dialogue: 0,0:13:40.62,0:13:43.96,Default,,0000,0000,0000,,今 怪物が 泉の中へ逃げ込んでいったの
Dialogue: 0,0:13:43.96,0:13:47.13,Default,,0000,0000,0000,,数で翻弄する作戦が うまくいったみたい
Dialogue: 0,0:13:47.13,0:13:49.46,Default,,0000,0000,0000,,もちろん 見張っているけど
Dialogue: 0,0:13:49.46,0:13:52.30,Default,,0000,0000,0000,,そうか 合流するチャンスだね
Dialogue: 0,0:13:52.30,0:13:56.30,Default,,0000,0000,0000,,もう少しだけ待ってて
Dialogue: 0,0:13:52.30,0:13:56.30,Default,,0000,0000,0000,,ちょっと気になることがあって
Dialogue: 0,0:13:56.30,0:13:58.60,Default,,0000,0000,0000,,わかった 待ってるわ!
Dialogue: 0,0:14:00.97,0:14:06.81,Default,,0000,0000,0000,,アイツが頭領だよな
Dialogue: 0,0:14:00.97,0:14:06.81,Default,,0000,0000,0000,,さっきから あそこで何を
Dialogue: 0,0:14:06.81,0:14:09.82,Default,,0000,0000,0000,,背後を部下2人に守らせて
Dialogue: 0,0:14:09.82,0:14:13.32,Default,,0000,0000,0000,,怪物の動きを見ているのか?
Dialogue: 0,0:14:13.32,0:14:15.82,Default,,0000,0000,0000,,嫌な予感がするな
Dialogue: 0,0:14:15.82,0:14:20.43,Default,,0000,0000,0000,,魔物と違って 人間相手の戦いはこれだから
Dialogue: 0,0:14:26.67,0:14:29.17,Default,,0000,0000,0000,,フッ いたぞ!
Dialogue: 0,0:14:29.17,0:14:32.34,Default,,0000,0000,0000,,エルフが下に隠れてやがる!
Dialogue: 0,0:14:29.17,0:14:32.34,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:14:32.34,0:14:35.94,Default,,0000,0000,0000,,探知スキルで マリーを捜していたのか
Dialogue: 0,0:14:35.94,0:14:38.44,Default,,0000,0000,0000,,向かいの茂みだ お前ら
Dialogue: 0,0:14:38.44,0:14:41.65,Default,,0000,0000,0000,,捕まえて引きずり出してこい!
Dialogue: 0,0:14:38.44,0:14:41.65,Default,,0000,0000,0000,,へい!
Dialogue: 0,0:14:45.95,0:14:50.12,Default,,0000,0000,0000,,それはちょっと困るかな うおっ!
Dialogue: 0,0:14:50.12,0:14:52.12,Default,,0000,0000,0000,,フッ そこまでだ
Dialogue: 0,0:14:52.12,0:14:54.63,Default,,0000,0000,0000,,灰になりな!
Dialogue: 0,0:14:54.63,0:14:57.96,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:14:54.63,0:14:57.96,Default,,0000,0000,0000,,なっ
Dialogue: 0,0:14:57.96,0:14:59.97,Default,,0000,0000,0000,,ウッ
Dialogue: 0,0:14:59.97,0:15:01.97,Default,,0000,0000,0000,,ギャーッ!
Dialogue: 0,0:15:01.97,0:15:03.97,Default,,0000,0000,0000,,ウッ
Dialogue: 0,0:15:07.64,0:15:11.31,Default,,0000,0000,0000,,アイツ ただの賊じゃない
Dialogue: 0,0:15:07.64,0:15:11.31,Default,,0000,0000,0000,,魔術師だ
Dialogue: 0,0:15:11.31,0:15:14.48,Default,,0000,0000,0000,,部下を巻き添えにして
Dialogue: 0,0:15:14.48,0:15:17.15,Default,,0000,0000,0000,,そんなに宝が欲しいのか
Dialogue: 0,0:15:17.15,0:15:21.49,Default,,0000,0000,0000,,フン あれをよけたか
Dialogue: 0,0:15:17.15,0:15:21.49,Default,,0000,0000,0000,,大したもんだぜ
Dialogue: 0,0:15:21.49,0:15:24.66,Default,,0000,0000,0000,,だが お前がいくら 逃げ回ったところで
Dialogue: 0,0:15:24.66,0:15:28.16,Default,,0000,0000,0000,,出てくる先がわかりゃ こっちのもんだ
Dialogue: 0,0:15:28.16,0:15:33.00,Default,,0000,0000,0000,,なぁ 次はどこに出てくるか 当ててやろうか?
Dialogue: 0,0:15:33.00,0:15:34.93,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:15:34.93,0:15:37.60,Default,,0000,0000,0000,,ここだ ここ
Dialogue: 0,0:15:34.93,0:15:37.60,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:15:37.60,0:15:43.61,Default,,0000,0000,0000,,コイツを助けにやってくるんだ
Dialogue: 0,0:15:37.60,0:15:43.61,Default,,0000,0000,0000,,優しい クソガキのお前はな
Dialogue: 0,0:15:43.61,0:15:46.11,Default,,0000,0000,0000,,あ ごめんなさい
Dialogue: 0,0:15:46.11,0:15:48.28,Default,,0000,0000,0000,,クッ
Dialogue: 0,0:15:48.28,0:15:53.12,Default,,0000,0000,0000,,ほれ! モタモタしてると このチビを焼いて食っちまうぞ!
Dialogue: 0,0:15:53.12,0:15:55.42,Default,,0000,0000,0000,,んっ オーバーロード
Dialogue: 0,0:15:57.46,0:15:59.46,Default,,0000,0000,0000,,それでいい
Dialogue: 0,0:15:59.46,0:16:01.63,Default,,0000,0000,0000,,わかってるぞ ガキ
Dialogue: 0,0:15:59.46,0:16:01.63,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:16:01.63,0:16:05.80,Default,,0000,0000,0000,,お前の移動スキルには 重量制限があるな?
Dialogue: 0,0:16:05.80,0:16:10.47,Default,,0000,0000,0000,,じゃなきゃ 最初から そのチビを連れて逃げたはずだ
Dialogue: 0,0:16:10.47,0:16:13.64,Default,,0000,0000,0000,,悔しいが そのとおりだ
Dialogue: 0,0:16:13.64,0:16:18.14,Default,,0000,0000,0000,,さっさと諦めて その剣を捨てろ
Dialogue: 0,0:16:18.14,0:16:20.15,Default,,0000,0000,0000,,そうだね
Dialogue: 0,0:16:20.15,0:16:23.15,Default,,0000,0000,0000,,はい!
Dialogue: 0,0:16:20.15,0:16:23.15,Default,,0000,0000,0000,,んっ!?
Dialogue: 0,0:16:23.15,0:16:27.99,Default,,0000,0000,0000,,これで重量制限はクリアだ! あっ!?
Dialogue: 0,0:16:25.65,0:16:27.99,Default,,0000,0000,0000,,しっかりつかまって
Dialogue: 0,0:16:27.99,0:16:30.69,Default,,0000,0000,0000,,オーバーロード!
Dialogue: 0,0:16:27.99,0:16:30.69,Default,,0000,0000,0000,,なっ!
Dialogue: 0,0:16:33.33,0:16:35.26,Default,,0000,0000,0000,,あぁ!
Dialogue: 0,0:16:33.33,0:16:35.26,Default,,0000,0000,0000,,ごめん 距離が足りない!
Dialogue: 0,0:16:35.26,0:16:37.43,Default,,0000,0000,0000,,あとは落ちるよ!
Dialogue: 0,0:16:35.26,0:16:37.43,Default,,0000,0000,0000,,ヒッ!
Dialogue: 0,0:16:37.43,0:16:40.13,Default,,0000,0000,0000,,ふぁ!
Dialogue: 0,0:16:37.43,0:16:40.13,Default,,0000,0000,0000,,ウッ!
Dialogue: 0,0:16:42.77,0:16:44.77,Default,,0000,0000,0000,,ウッ ウゥ
Dialogue: 0,0:16:44.77,0:16:47.27,Default,,0000,0000,0000,,大丈夫? ケガはないかい?
Dialogue: 0,0:16:47.27,0:16:51.28,Default,,0000,0000,0000,,は はい あなたは?
Dialogue: 0,0:16:47.27,0:16:51.28,Default,,0000,0000,0000,,うん 平気
Dialogue: 0,0:16:51.28,0:16:53.45,Default,,0000,0000,0000,,下が砂地で助かったよ
Dialogue: 0,0:16:53.45,0:16:56.12,Default,,0000,0000,0000,,急ごう もう一度つかまって
Dialogue: 0,0:16:56.12,0:16:59.45,Default,,0000,0000,0000,,オーバーロード!
Dialogue: 0,0:16:59.45,0:17:02.45,Default,,0000,0000,0000,,クソッ!
Dialogue: 0,0:16:59.45,0:17:02.45,Default,,0000,0000,0000,,また消えやがって どこ行った!?
Dialogue: 0,0:17:02.45,0:17:04.46,Default,,0000,0000,0000,,チッ
Dialogue: 0,0:17:04.46,0:17:08.66,Default,,0000,0000,0000,,逃がすものか!
Dialogue: 0,0:17:04.46,0:17:08.66,Default,,0000,0000,0000,,それは俺の魔石だ!
Dialogue: 0,0:17:10.80,0:17:14.60,Default,,0000,0000,0000,,ハッ!? ウゥ
Dialogue: 0,0:17:20.47,0:17:22.64,Default,,0000,0000,0000,,あぁ!
Dialogue: 0,0:17:22.64,0:17:25.64,Default,,0000,0000,0000,,あっ うおっ
Dialogue: 0,0:17:25.64,0:17:28.15,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:17:28.15,0:17:32.85,Default,,0000,0000,0000,,グオーッ!
Dialogue: 0,0:17:38.42,0:17:40.93,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:17:40.93,0:17:43.76,Default,,0000,0000,0000,,あ あぁ
Dialogue: 0,0:17:43.76,0:17:46.27,Default,,0000,0000,0000,,グルル
Dialogue: 0,0:17:46.27,0:17:51.77,Default,,0000,0000,0000,,うわぁ やっぱり大きいなぁ
Dialogue: 0,0:17:46.27,0:17:51.77,Default,,0000,0000,0000,,さすがに逃げきれないか
Dialogue: 0,0:17:51.77,0:17:56.61,Default,,0000,0000,0000,,このまま死ねば またいつもみたいに 日本に帰れるけど
Dialogue: 0,0:17:56.61,0:17:59.95,Default,,0000,0000,0000,,でも それじゃマリーは
Dialogue: 0,0:17:59.95,0:18:01.95,Default,,0000,0000,0000,,グッ だめだ
Dialogue: 0,0:18:01.95,0:18:05.12,Default,,0000,0000,0000,,ここじゃ絶対に死ねない
Dialogue: 0,0:18:05.12,0:18:08.79,Default,,0000,0000,0000,,あれ?
Dialogue: 0,0:18:05.12,0:18:08.79,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:18:08.79,0:18:13.89,Default,,0000,0000,0000,,グルル
Dialogue: 0,0:18:08.79,0:18:13.89,Default,,0000,0000,0000,,攻撃してこない?
Dialogue: 0,0:18:18.80,0:18:20.97,Default,,0000,0000,0000,,ヒッ!
Dialogue: 0,0:18:20.97,0:18:25.97,Default,,0000,0000,0000,,なんだろう
Dialogue: 0,0:18:20.97,0:18:25.97,Default,,0000,0000,0000,,何かを探しているような?
Dialogue: 0,0:18:25.97,0:18:28.31,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:18:28.31,0:18:30.81,Default,,0000,0000,0000,,んっ ハッ!
Dialogue: 0,0:18:33.75,0:18:36.25,Default,,0000,0000,0000,,それが 魔石なのか
Dialogue: 0,0:18:36.25,0:18:40.75,Default,,0000,0000,0000,,そういえば おじいちゃんから 聞いたことがありマス
Dialogue: 0,0:18:40.75,0:18:45.42,Default,,0000,0000,0000,,魔石の中でも これは飛び切り上等なものだ
Dialogue: 0,0:18:45.42,0:18:50.60,Default,,0000,0000,0000,,そして悲しいことに
Dialogue: 0,0:18:45.42,0:18:50.60,Default,,0000,0000,0000,,ワシらの里を滅ぼしたものでもある
Dialogue: 0,0:18:50.60,0:18:55.27,Default,,0000,0000,0000,,古い言い伝えによると この石を掘り起こしたせいで
Dialogue: 0,0:18:55.27,0:18:59.61,Default,,0000,0000,0000,,深い地の底で 怪物が目を覚ましたのだと
Dialogue: 0,0:18:59.61,0:19:04.61,Default,,0000,0000,0000,,地上に現れた怪物は暴れ 祖先たちは皆
Dialogue: 0,0:19:04.61,0:19:08.61,Default,,0000,0000,0000,,ウジャーピークの地を 逃げ出すしかなかった
Dialogue: 0,0:19:08.61,0:19:13.12,Default,,0000,0000,0000,,以来 猫族は 魔物からも人間からも隠れ
Dialogue: 0,0:19:13.12,0:19:16.96,Default,,0000,0000,0000,,ひっそり 暮らすようになったのさ
Dialogue: 0,0:19:16.96,0:19:22.29,Default,,0000,0000,0000,,そうか この怪物はずっと
Dialogue: 0,0:19:16.96,0:19:22.29,Default,,0000,0000,0000,,この魔石を求めて
Dialogue: 0,0:19:22.29,0:19:24.80,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:24.80,0:19:29.13,Default,,0000,0000,0000,,ミュイ 君の思ったとおりに するといいよ
Dialogue: 0,0:19:29.13,0:19:32.14,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:32.14,0:19:34.91,Default,,0000,0000,0000,,あ あの
Dialogue: 0,0:19:34.91,0:19:38.74,Default,,0000,0000,0000,,何度も呼び出してしまってゴメンナサイ
Dialogue: 0,0:19:38.74,0:19:42.58,Default,,0000,0000,0000,,ご先祖様から伝わる 飛び切りの魔石を
Dialogue: 0,0:19:42.58,0:19:46.25,Default,,0000,0000,0000,,今 あなたに お返しシマス
Dialogue: 0,0:19:54.76,0:19:58.36,Default,,0000,0000,0000,,クオォー!
Dialogue: 0,0:20:01.93,0:20:03.94,Default,,0000,0000,0000,,うわぁ
Dialogue: 0,0:20:05.94,0:20:08.94,Default,,0000,0000,0000,,怪物は かえっていく
Dialogue: 0,0:20:08.94,0:20:12.78,Default,,0000,0000,0000,,魔石を求めた理由を教えぬまま
Dialogue: 0,0:20:12.78,0:20:17.78,Default,,0000,0000,0000,,この地が滅びたのは 200年前
Dialogue: 0,0:20:17.78,0:20:20.45,Default,,0000,0000,0000,,長い間 求めていたものを見つけ
Dialogue: 0,0:20:20.45,0:20:23.79,Default,,0000,0000,0000,,これでやっと オアシスの底で
Dialogue: 0,0:20:23.79,0:20:26.79,Default,,0000,0000,0000,,眠りにつくのだろうか
Dialogue: 0,0:20:26.79,0:20:30.30,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:20:26.79,0:20:30.30,Default,,0000,0000,0000,,な なんだこれ
Dialogue: 0,0:20:32.30,0:20:35.30,Default,,0000,0000,0000,,地下迷宮だ!
Dialogue: 0,0:20:35.30,0:20:38.47,Default,,0000,0000,0000,,あぁ
Dialogue: 0,0:20:35.30,0:20:38.47,Default,,0000,0000,0000,,カズヒホー!
Dialogue: 0,0:20:35.30,0:20:38.47,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:20:38.47,0:20:40.97,Default,,0000,0000,0000,,ハァ ハァ ハァ
Dialogue: 0,0:20:40.97,0:20:43.98,Default,,0000,0000,0000,,アハハ ハァ ハァ
Dialogue: 0,0:20:40.97,0:20:43.98,Default,,0000,0000,0000,,マリーの顔を見たのが
Dialogue: 0,0:20:43.98,0:20:47.31,Default,,0000,0000,0000,,ものすごく 久しぶりのような気がした
Dialogue: 0,0:20:47.31,0:20:50.32,Default,,0000,0000,0000,,マリー 大丈夫だった?
Dialogue: 0,0:20:47.31,0:20:50.32,Default,,0000,0000,0000,,ええ!
Dialogue: 0,0:20:50.32,0:20:54.99,Default,,0000,0000,0000,,でも すごい音と砂煙で
Dialogue: 0,0:20:50.32,0:20:54.99,Default,,0000,0000,0000,,いったい 何があったの!?
Dialogue: 0,0:20:54.99,0:20:59.16,Default,,0000,0000,0000,,僕にも よくわからないんだ
Dialogue: 0,0:20:54.99,0:20:59.16,Default,,0000,0000,0000,,これを見てよ!
Dialogue: 0,0:20:59.16,0:21:01.66,Default,,0000,0000,0000,,ウソ!?
Dialogue: 0,0:21:01.66,0:21:04.66,Default,,0000,0000,0000,,い 遺跡の下にこんなものが
Dialogue: 0,0:21:04.66,0:21:07.33,Default,,0000,0000,0000,,大発見じゃない!
Dialogue: 0,0:21:04.66,0:21:07.33,Default,,0000,0000,0000,,うん
Dialogue: 0,0:21:07.33,0:21:10.00,Default,,0000,0000,0000,,信じられないよ
Dialogue: 0,0:21:07.33,0:21:10.00,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:10.00,0:21:12.67,Default,,0000,0000,0000,,まぁ! 猫ちゃん!?
Dialogue: 0,0:21:10.00,0:21:12.67,Default,,0000,0000,0000,,うにゅ!
Dialogue: 0,0:21:12.67,0:21:17.18,Default,,0000,0000,0000,,やっぱり猫ちゃんだったのね!
Dialogue: 0,0:21:12.67,0:21:17.18,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:21:17.18,0:21:22.18,Default,,0000,0000,0000,,無事でよかった!
Dialogue: 0,0:21:17.18,0:21:22.18,Default,,0000,0000,0000,,あ 会えてうれしいわ!
Dialogue: 0,0:21:22.18,0:21:25.02,Default,,0000,0000,0000,,あなたは なんてかわいいのかしら
Dialogue: 0,0:21:25.02,0:21:27.19,Default,,0000,0000,0000,,も モフモフー!
Dialogue: 0,0:21:25.02,0:21:27.19,Default,,0000,0000,0000,,うにゅっ
Dialogue: 0,0:21:27.19,0:21:31.39,Default,,0000,0000,0000,,うにゃあ!
Dialogue: 0,0:21:40.13,0:21:43.97,Default,,0000,0000,0000,,盗賊の残党は 我々が責任を持って追う
Dialogue: 0,0:21:43.97,0:21:47.64,Default,,0000,0000,0000,,このところ ここで事件が多発していたんだ
Dialogue: 0,0:21:47.64,0:21:51.14,Default,,0000,0000,0000,,君の通報に感謝する
Dialogue: 0,0:21:47.64,0:21:51.14,Default,,0000,0000,0000,,ええ
Dialogue: 0,0:21:51.14,0:21:55.48,Default,,0000,0000,0000,,それより あの猫族の子の 保護をお願いしたいのですが
Dialogue: 0,0:21:55.48,0:21:57.98,Default,,0000,0000,0000,,あぁ もしこれから
Dialogue: 0,0:21:57.98,0:22:00.65,Default,,0000,0000,0000,,魔石といわれるものが 採掘されるとなれば
Dialogue: 0,0:22:00.65,0:22:03.82,Default,,0000,0000,0000,,猫族の協力が必要になる
Dialogue: 0,0:22:03.82,0:22:06.63,Default,,0000,0000,0000,,国が 大事に扱うよ
Dialogue: 0,0:22:08.66,0:22:10.66,Default,,0000,0000,0000,,しかし驚いた
Dialogue: 0,0:22:10.66,0:22:14.67,Default,,0000,0000,0000,,10代の少年からの報告というから 半信半疑だったが
Dialogue: 0,0:22:14.67,0:22:18.84,Default,,0000,0000,0000,,まさか これほど巨大な 地下迷宮が見つかるとは
Dialogue: 0,0:22:18.84,0:22:21.51,Default,,0000,0000,0000,,大がかりな調査になるだろう
Dialogue: 0,0:22:21.51,0:22:25.84,Default,,0000,0000,0000,,この国 アリライに 多大な益をもたらすか
Dialogue: 0,0:22:25.84,0:22:32.02,Default,,0000,0000,0000,,それとも 厄災を生み出すか
Dialogue: 0,0:22:25.84,0:22:32.02,Default,,0000,0000,0000,,どちらかは わからないが
