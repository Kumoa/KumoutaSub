Dialogue: 0,0:00:03.34,0:00:05.51,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:03.34,0:00:05.51,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:05.51,0:00:07.51,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:05.51,0:00:07.51,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:00:11.85,0:00:17.02,Default,,0000,0000,0000,,んっ こいつは
Dialogue: 0,0:00:17.02,0:00:19.52,Default,,0000,0000,0000,,あっ! ガーフ
Dialogue: 0,0:00:17.02,0:00:19.52,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:00:19.52,0:00:22.52,Default,,0000,0000,0000,,なっ!
Dialogue: 0,0:00:22.52,0:00:27.69,Default,,0000,0000,0000,,あの2人 すご強い
Dialogue: 0,0:00:22.52,0:00:27.69,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:27.69,0:00:31.03,Default,,0000,0000,0000,,ハッ! おもしれえ
Dialogue: 0,0:00:27.69,0:00:31.03,Default,,0000,0000,0000,,だっ だめ!
Dialogue: 0,0:00:27.69,0:00:31.03,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:31.03,0:00:35.37,Default,,0000,0000,0000,,ガーフ だめ!
Dialogue: 0,0:00:31.03,0:00:35.37,Default,,0000,0000,0000,,ミミとガーフだけじゃ無理!
Dialogue: 0,0:00:35.37,0:00:37.54,Default,,0000,0000,0000,,尻尾 巻いて 逃げようったって
Dialogue: 0,0:00:37.54,0:00:40.71,Default,,0000,0000,0000,,逃がしちゃくれめえよ
Dialogue: 0,0:00:37.54,0:00:40.71,Default,,0000,0000,0000,,やるしかねえ!
Dialogue: 0,0:00:40.71,0:00:43.38,Default,,0000,0000,0000,,じゃ じゃあ 1回だけ!
Dialogue: 0,0:00:40.71,0:00:43.38,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:00:43.38,0:00:47.21,Default,,0000,0000,0000,,ガンッて ぶつかって どけて 逃げる
Dialogue: 0,0:00:43.38,0:00:47.21,Default,,0000,0000,0000,,じゃなきゃだめ!
Dialogue: 0,0:00:47.21,0:00:50.12,Default,,0000,0000,0000,,なんのために来たの!
Dialogue: 0,0:00:47.21,0:00:50.12,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:53.22,0:00:55.22,Default,,0000,0000,0000,,わあった
Dialogue: 0,0:00:55.22,0:00:58.22,Default,,0000,0000,0000,,1発 思いっ切り ぶつかって いったん 離脱
Dialogue: 0,0:00:58.22,0:01:02.50,Default,,0000,0000,0000,,それでいいんだな?
Dialogue: 0,0:00:58.22,0:01:02.50,Default,,0000,0000,0000,,うん! そう! それでいこう!
Dialogue: 0,0:01:02.50,0:01:04.50,Default,,0000,0000,0000,,いくぜ
Dialogue: 0,0:01:23.52,0:01:27.69,Default,,0000,0000,0000,,副団長 どういうおつもりですか?
Dialogue: 0,0:01:27.69,0:01:30.02,Default,,0000,0000,0000,,見て わからねえのか?
Dialogue: 0,0:01:30.02,0:01:32.86,Default,,0000,0000,0000,,動くな お前は そこにいろ
Dialogue: 0,0:01:32.86,0:01:36.03,Default,,0000,0000,0000,,魔女教の やっかいさは 知ってんだろ?
Dialogue: 0,0:01:36.03,0:01:40.53,Default,,0000,0000,0000,,お前は 大切な あるじと 実の父親を見捨てて
Dialogue: 0,0:01:40.53,0:01:44.20,Default,,0000,0000,0000,,顔も知らない連中を 助けに走るのか?
Dialogue: 0,0:01:40.53,0:01:44.20,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:01:44.20,0:01:47.37,Default,,0000,0000,0000,,おい ポンコツ
Dialogue: 0,0:01:44.20,0:01:47.37,Default,,0000,0000,0000,,お前 何してんだ?
Dialogue: 0,0:01:44.20,0:01:47.37,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:01:47.37,0:01:51.38,Default,,0000,0000,0000,,こんなんは 口だけの脅しだ
Dialogue: 0,0:01:47.37,0:01:51.38,Default,,0000,0000,0000,,心配しなくても
Dialogue: 0,0:01:51.38,0:01:53.55,Default,,0000,0000,0000,,試してみるか?
Dialogue: 0,0:01:51.38,0:01:53.55,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:01:53.55,0:01:56.05,Default,,0000,0000,0000,,難しい話じゃない
Dialogue: 0,0:01:56.05,0:01:59.39,Default,,0000,0000,0000,,騎士の本分を全うしろってだけだ
Dialogue: 0,0:01:59.39,0:02:03.16,Default,,0000,0000,0000,,アストレア家の家督について 話したいんだろ?
Dialogue: 0,0:02:03.16,0:02:05.99,Default,,0000,0000,0000,,行けって 行け!
Dialogue: 0,0:02:05.99,0:02:08.66,Default,,0000,0000,0000,,フェルト様
Dialogue: 0,0:02:08.66,0:02:12.33,Default,,0000,0000,0000,,僕は
Dialogue: 0,0:02:12.33,0:02:14.83,Default,,0000,0000,0000,,魔女の遺骨って
Dialogue: 0,0:02:14.83,0:02:19.01,Default,,0000,0000,0000,,嫉妬の魔女は死んじゃいない
Dialogue: 0,0:02:14.83,0:02:19.01,Default,,0000,0000,0000,,だって
Dialogue: 0,0:02:23.84,0:02:27.68,Default,,0000,0000,0000,,んっ だって
Dialogue: 0,0:02:23.84,0:02:27.68,Default,,0000,0000,0000,,落ち着けよ 兄弟
Dialogue: 0,0:02:23.84,0:02:27.68,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:27.68,0:02:29.85,Default,,0000,0000,0000,,魔女の骨ったって あれだ
Dialogue: 0,0:02:29.85,0:02:33.69,Default,,0000,0000,0000,,別に 嫉妬の魔女の骨に 限った話じゃねえだろ
Dialogue: 0,0:02:33.69,0:02:37.19,Default,,0000,0000,0000,,そう 記録には ほとんど残されてへんけど
Dialogue: 0,0:02:37.19,0:02:39.69,Default,,0000,0000,0000,,そんな口伝も なくはないんよ
Dialogue: 0,0:02:39.69,0:02:42.20,Default,,0000,0000,0000,,そして この都市には
Dialogue: 0,0:02:42.20,0:02:46.20,Default,,0000,0000,0000,,嫉妬の魔女以外の骨が 残されていると
Dialogue: 0,0:02:46.20,0:02:49.20,Default,,0000,0000,0000,,どこにあるのか ご存じなのですか?
Dialogue: 0,0:02:49.20,0:02:54.71,Default,,0000,0000,0000,,ううん 魔女の遺骨は
Dialogue: 0,0:02:49.20,0:02:54.71,Default,,0000,0000,0000,,水門都市の重要機密
Dialogue: 0,0:02:54.71,0:02:57.88,Default,,0000,0000,0000,,知ってるとしたら 十人会の人間やね
Dialogue: 0,0:02:57.88,0:03:01.15,Default,,0000,0000,0000,,十人会 キリタカか?
Dialogue: 0,0:02:57.88,0:03:01.15,Default,,0000,0000,0000,,うん
Dialogue: 0,0:03:01.15,0:03:03.82,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:03:03.82,0:03:06.32,Default,,0000,0000,0000,,それで? んなもんを要求してる
Dialogue: 0,0:03:06.32,0:03:09.49,Default,,0000,0000,0000,,カペラ・エメラダ・ルグニカってのは なんなんだ?
Dialogue: 0,0:03:09.49,0:03:14.33,Default,,0000,0000,0000,,家名に ルグニカって入るのは それこそ 王族だけのはずだろ?
Dialogue: 0,0:03:14.33,0:03:16.33,Default,,0000,0000,0000,,おちょくってんじゃねえの?
Dialogue: 0,0:03:16.33,0:03:20.00,Default,,0000,0000,0000,,王族が みんな 病死したってのは 有名な話だしよ
Dialogue: 0,0:03:20.00,0:03:23.17,Default,,0000,0000,0000,,カペラの名については わかりかねますが
Dialogue: 0,0:03:23.17,0:03:25.84,Default,,0000,0000,0000,,かつて エメラダ・ルグニカの名を持つ方が
Dialogue: 0,0:03:25.84,0:03:29.34,Default,,0000,0000,0000,,王家に名を連ねていたことは 確かです
Dialogue: 0,0:03:25.84,0:03:29.34,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:03:29.34,0:03:33.85,Default,,0000,0000,0000,,ご存命だったのは 50年以上も前のことです
Dialogue: 0,0:03:33.85,0:03:37.02,Default,,0000,0000,0000,,非常に美しく そうめいな方だったそうですが
Dialogue: 0,0:03:37.02,0:03:40.02,Default,,0000,0000,0000,,その性格は 残忍極まりなく
Dialogue: 0,0:03:40.02,0:03:42.36,Default,,0000,0000,0000,,国民は 皆 彼女を恐れていたと
Dialogue: 0,0:03:40.02,0:03:42.36,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:03:42.36,0:03:45.36,Default,,0000,0000,0000,,あっ 待って 待って!
Dialogue: 0,0:03:42.36,0:03:45.36,Default,,0000,0000,0000,,鏡が反応してる
Dialogue: 0,0:03:45.36,0:03:47.56,Default,,0000,0000,0000,,んっ ユリウス?
Dialogue: 0,0:03:50.53,0:03:52.70,Default,,0000,0000,0000,,全員 そろっているようだね
Dialogue: 0,0:03:52.70,0:03:57.04,Default,,0000,0000,0000,,私は見えているだろうか?
Dialogue: 0,0:03:52.70,0:03:57.04,Default,,0000,0000,0000,,連絡がないから心配したわ
Dialogue: 0,0:03:57.04,0:03:59.54,Default,,0000,0000,0000,,外の様子は どうなん?
Dialogue: 0,0:03:57.04,0:03:59.54,Default,,0000,0000,0000,,それが
Dialogue: 0,0:03:59.54,0:04:01.64,Default,,0000,0000,0000,,おっ お嬢!
Dialogue: 0,0:03:59.54,0:04:01.64,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:04:01.64,0:04:03.64,Default,,0000,0000,0000,,大変です!
Dialogue: 0,0:04:01.64,0:04:03.64,Default,,0000,0000,0000,,そっちに お姉ちゃんは
Dialogue: 0,0:04:03.64,0:04:07.15,Default,,0000,0000,0000,,戻っていませんですか?
Dialogue: 0,0:04:03.64,0:04:07.15,Default,,0000,0000,0000,,ううん 戻ってへん
Dialogue: 0,0:04:07.15,0:04:09.15,Default,,0000,0000,0000,,うちらも心配してて
Dialogue: 0,0:04:09.15,0:04:11.99,Default,,0000,0000,0000,,お嬢! お嬢 おるか?
Dialogue: 0,0:04:09.15,0:04:11.99,Default,,0000,0000,0000,,ヘータローが!
Dialogue: 0,0:04:11.99,0:04:15.66,Default,,0000,0000,0000,,お姉ちゃんが
Dialogue: 0,0:04:11.99,0:04:15.66,Default,,0000,0000,0000,,お姉ちゃんが
Dialogue: 0,0:04:15.66,0:04:19.83,Default,,0000,0000,0000,,ヘータロー 落ち着き
Dialogue: 0,0:04:15.66,0:04:19.83,Default,,0000,0000,0000,,何があったん? ゆっくり話し
Dialogue: 0,0:04:19.83,0:04:24.33,Default,,0000,0000,0000,,かっ 加護の影響が お姉ちゃんから 流れ込んできてて
Dialogue: 0,0:04:24.33,0:04:27.00,Default,,0000,0000,0000,,そっ それが すごい傷で
Dialogue: 0,0:04:27.00,0:04:29.50,Default,,0000,0000,0000,,加護 三分の加護やね?
Dialogue: 0,0:04:29.50,0:04:31.50,Default,,0000,0000,0000,,つまり ミミが どこかで けがして
Dialogue: 0,0:04:31.50,0:04:34.84,Default,,0000,0000,0000,,やっほ! やっほほ!
Dialogue: 0,0:04:31.50,0:04:34.84,Default,,0000,0000,0000,,やっほっほ!
Dialogue: 0,0:04:34.84,0:04:39.68,Default,,0000,0000,0000,,くず肉の皆さん 元気にしてやがります?
Dialogue: 0,0:04:39.68,0:04:41.85,Default,,0000,0000,0000,,麗しい私の美声に
Dialogue: 0,0:04:41.85,0:04:45.85,Default,,0000,0000,0000,,大興奮しちゃってくれてます?
Dialogue: 0,0:04:41.85,0:04:45.85,Default,,0000,0000,0000,,キャハハ!
Dialogue: 0,0:04:45.85,0:04:48.19,Default,,0000,0000,0000,,じ・つ・は!
Dialogue: 0,0:04:48.19,0:04:50.19,Default,,0000,0000,0000,,不届きな連中が
Dialogue: 0,0:04:48.19,0:04:50.19,Default,,0000,0000,0000,,何やつ!?
Dialogue: 0,0:04:50.19,0:04:53.86,Default,,0000,0000,0000,,都市庁舎に 仕掛けてきやがって 私
Dialogue: 0,0:04:53.86,0:04:56.03,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:04:53.86,0:04:56.03,Default,,0000,0000,0000,,すまねえ
Dialogue: 0,0:04:56.03,0:04:59.53,Default,,0000,0000,0000,,すっ すまねえ 大将!
Dialogue: 0,0:04:59.53,0:05:02.64,Default,,0000,0000,0000,,俺様 俺は
Dialogue: 0,0:05:02.64,0:05:04.64,Default,,0000,0000,0000,,役立たずの
Dialogue: 0,0:05:02.64,0:05:04.64,Default,,0000,0000,0000,,ガーフィール
Dialogue: 0,0:05:04.64,0:05:06.64,Default,,0000,0000,0000,,能なしだ!
Dialogue: 0,0:05:14.81,0:05:21.32,Default,,0000,0000,0000,,あっ なんで?
Dialogue: 0,0:05:14.81,0:05:21.32,Default,,0000,0000,0000,,傷が塞がらない! 包帯を
Dialogue: 0,0:05:21.32,0:05:23.32,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:23.32,0:05:26.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:26.83,0:05:28.83,Default,,0000,0000,0000,,キャハハハハハハ!
Dialogue: 0,0:05:26.83,0:05:28.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:28.83,0:05:30.83,Default,,0000,0000,0000,,カチコミかけた連中も
Dialogue: 0,0:05:30.83,0:05:34.67,Default,,0000,0000,0000,,ろくなことにならねえって わかったころじゃねえですか?
Dialogue: 0,0:05:34.67,0:05:37.67,Default,,0000,0000,0000,,アハハハハハハハ!
Dialogue: 0,0:05:34.67,0:05:37.67,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:05:37.67,0:05:39.67,Default,,0000,0000,0000,,はぁあ
Dialogue: 0,0:05:37.67,0:05:39.67,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:39.67,0:05:41.67,Default,,0000,0000,0000,,カチコミの代償として
Dialogue: 0,0:05:41.67,0:05:44.68,Default,,0000,0000,0000,,手始めに この建物にいる連中から
Dialogue: 0,0:05:44.68,0:05:48.01,Default,,0000,0000,0000,,ぐずぐずの くず肉にしてやります!
Dialogue: 0,0:05:50.35,0:05:54.02,Default,,0000,0000,0000,,あっ! なっ なんだ?
Dialogue: 0,0:05:54.02,0:05:58.19,Default,,0000,0000,0000,,ぐっ!
Dialogue: 0,0:05:54.02,0:05:58.19,Default,,0000,0000,0000,,それが嫌なら 私の要求は 1個だけ!
Dialogue: 0,0:05:58.19,0:06:01.96,Default,,0000,0000,0000,,魔女の遺骨!
Dialogue: 0,0:05:58.19,0:06:01.96,Default,,0000,0000,0000,,以上 おしまいです!
Dialogue: 0,0:06:01.96,0:06:04.46,Default,,0000,0000,0000,,あっ! 水門の制御塔には
Dialogue: 0,0:06:04.46,0:06:07.47,Default,,0000,0000,0000,,私たちが それぞれ 陣取ってますんで
Dialogue: 0,0:06:07.47,0:06:11.80,Default,,0000,0000,0000,,下手なこと 考えねえことです
Dialogue: 0,0:06:07.47,0:06:11.80,Default,,0000,0000,0000,,キャハハハハハハハ!
Dialogue: 0,0:06:11.80,0:06:14.64,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:06:14.64,0:06:17.48,Default,,0000,0000,0000,,ふざけやがって
Dialogue: 0,0:06:17.48,0:06:20.31,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:17.48,0:06:20.31,Default,,0000,0000,0000,,皆さん ご無事でしたか
Dialogue: 0,0:06:20.31,0:06:24.48,Default,,0000,0000,0000,,キリタカ 無事だったか!
Dialogue: 0,0:06:20.31,0:06:24.48,Default,,0000,0000,0000,,んっ どうにか
Dialogue: 0,0:06:24.48,0:06:27.32,Default,,0000,0000,0000,,オッ オットーは 一緒じゃないのか?
Dialogue: 0,0:06:27.32,0:06:30.66,Default,,0000,0000,0000,,んっ 申し訳ないですが
Dialogue: 0,0:06:27.32,0:06:30.66,Default,,0000,0000,0000,,そうか
Dialogue: 0,0:06:30.66,0:06:35.83,Default,,0000,0000,0000,,あいつのことだから
Dialogue: 0,0:06:30.66,0:06:35.83,Default,,0000,0000,0000,,めったなことはないだろうけど
Dialogue: 0,0:06:35.83,0:06:40.17,Default,,0000,0000,0000,,んっ 皆さん お聞きになったとおりです
Dialogue: 0,0:06:40.17,0:06:44.17,Default,,0000,0000,0000,,人質の命は 一刻の猶予もありません
Dialogue: 0,0:06:44.17,0:06:46.51,Default,,0000,0000,0000,,単刀直入に聞くわ
Dialogue: 0,0:06:46.51,0:06:50.84,Default,,0000,0000,0000,,魔女の遺骨は 実在するんよね?
Dialogue: 0,0:06:46.51,0:06:50.84,Default,,0000,0000,0000,,はい 確かに
Dialogue: 0,0:06:50.84,0:06:54.51,Default,,0000,0000,0000,,ですが 魔女の遺骨は 動かすことができません
Dialogue: 0,0:06:54.51,0:06:58.52,Default,,0000,0000,0000,,従って 相手の要求に 応えることはできない
Dialogue: 0,0:06:58.52,0:07:02.79,Default,,0000,0000,0000,,その 動かせないというのは キリタカ様の ご意見ですか?
Dialogue: 0,0:07:02.79,0:07:05.12,Default,,0000,0000,0000,,いいえ 言葉どおり
Dialogue: 0,0:07:05.12,0:07:08.13,Default,,0000,0000,0000,,物理的な意味で動かせないのです
Dialogue: 0,0:07:08.13,0:07:12.47,Default,,0000,0000,0000,,魔女の遺骨には 特別な力が宿っています
Dialogue: 0,0:07:12.47,0:07:15.64,Default,,0000,0000,0000,,遺骨を動かせば 過去に都市を水没させて
Dialogue: 0,0:07:15.64,0:07:17.64,Default,,0000,0000,0000,,魔女を滅ぼした当時と
Dialogue: 0,0:07:17.64,0:07:21.14,Default,,0000,0000,0000,,いえ それ以上の被害を生んで
Dialogue: 0,0:07:23.31,0:07:26.31,Default,,0000,0000,0000,,この都市は崩壊するでしょう
Dialogue: 0,0:07:26.31,0:07:30.32,Default,,0000,0000,0000,,「テュフォンが大水の中に沈められ」か
Dialogue: 0,0:07:26.31,0:07:30.32,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:07:30.32,0:07:32.49,Default,,0000,0000,0000,,遺骨は渡せん!
Dialogue: 0,0:07:32.49,0:07:36.16,Default,,0000,0000,0000,,くだらん要求も聞かん
Dialogue: 0,0:07:32.49,0:07:36.16,Default,,0000,0000,0000,,そこは変わらんやろ
Dialogue: 0,0:07:36.16,0:07:38.66,Default,,0000,0000,0000,,お姉ちゃん!
Dialogue: 0,0:07:38.66,0:07:41.99,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:07:38.66,0:07:41.99,Default,,0000,0000,0000,,お姉ちゃん! お姉ちゃん!
Dialogue: 0,0:07:41.99,0:07:45.00,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:07:45.00,0:07:47.00,Default,,0000,0000,0000,,ハッ あっ
Dialogue: 0,0:07:49.00,0:07:51.17,Default,,0000,0000,0000,,あっ んっ
Dialogue: 0,0:07:51.17,0:07:53.67,Default,,0000,0000,0000,,礼が遅れたわ
Dialogue: 0,0:07:51.17,0:07:53.67,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:07:53.67,0:07:56.68,Default,,0000,0000,0000,,兄ちゃんが ここに運んでくれんかったら
Dialogue: 0,0:07:56.68,0:07:59.85,Default,,0000,0000,0000,,ミミが死んどったのは間違いない
Dialogue: 0,0:07:56.68,0:07:59.85,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:07:59.85,0:08:01.95,Default,,0000,0000,0000,,せやから 恩に着る
Dialogue: 0,0:08:01.95,0:08:05.12,Default,,0000,0000,0000,,助かった ほんまに おおきに
Dialogue: 0,0:08:05.12,0:08:07.79,Default,,0000,0000,0000,,やめてくれ! 俺は
Dialogue: 0,0:08:07.79,0:08:09.79,Default,,0000,0000,0000,,ガーフィール
Dialogue: 0,0:08:07.79,0:08:09.79,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:09.79,0:08:14.29,Default,,0000,0000,0000,,聞かせてくれ
Dialogue: 0,0:08:09.79,0:08:14.29,Default,,0000,0000,0000,,この街を襲ってる大ばか野郎を
Dialogue: 0,0:08:14.29,0:08:16.63,Default,,0000,0000,0000,,全員 ぶっ倒さなきゃならないんだ
Dialogue: 0,0:08:16.63,0:08:19.97,Default,,0000,0000,0000,,そのために お前の力がいる
Dialogue: 0,0:08:19.97,0:08:22.64,Default,,0000,0000,0000,,いつまでも へこんだままじゃ いさせられねえ
Dialogue: 0,0:08:22.64,0:08:24.64,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:27.47,0:08:29.98,Default,,0000,0000,0000,,放送を聞いて
Dialogue: 0,0:08:29.98,0:08:35.65,Default,,0000,0000,0000,,チビっ子と俺は
Dialogue: 0,0:08:29.98,0:08:35.65,Default,,0000,0000,0000,,都市庁舎に向かったんだ
Dialogue: 0,0:08:35.65,0:08:39.99,Default,,0000,0000,0000,,うぅ はぁ!
Dialogue: 0,0:08:39.99,0:08:43.82,Default,,0000,0000,0000,,うっ! ハッ! うっ!
Dialogue: 0,0:08:43.82,0:08:46.16,Default,,0000,0000,0000,,ハァ もらっ
Dialogue: 0,0:08:46.16,0:08:48.49,Default,,0000,0000,0000,,あっ! ぐはっ!
Dialogue: 0,0:08:46.16,0:08:48.49,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:08:48.49,0:08:51.66,Default,,0000,0000,0000,,ぐっ
Dialogue: 0,0:08:51.66,0:08:55.50,Default,,0000,0000,0000,,殺してから 初めて あなたを愛すわ
Dialogue: 0,0:08:55.50,0:08:58.50,Default,,0000,0000,0000,,ガーフィール・ティンゼル うぅ!
Dialogue: 0,0:08:58.50,0:09:00.61,Default,,0000,0000,0000,,がぁ!
Dialogue: 0,0:09:00.61,0:09:04.11,Default,,0000,0000,0000,,うぅっ! うお!
Dialogue: 0,0:09:04.11,0:09:06.28,Default,,0000,0000,0000,,何?
Dialogue: 0,0:09:06.28,0:09:08.78,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:09:08.78,0:09:12.95,Default,,0000,0000,0000,,ハッ! くっ
Dialogue: 0,0:09:12.95,0:09:15.96,Default,,0000,0000,0000,,んっ! ちょやさ!
Dialogue: 0,0:09:15.96,0:09:18.76,Default,,0000,0000,0000,,ハッ! フッ!
Dialogue: 0,0:09:15.96,0:09:18.76,Default,,0000,0000,0000,,お!
Dialogue: 0,0:09:23.96,0:09:25.97,Default,,0000,0000,0000,,あっ んっ
Dialogue: 0,0:09:30.14,0:09:32.14,Default,,0000,0000,0000,,チビっ子?
Dialogue: 0,0:09:35.31,0:09:37.48,Default,,0000,0000,0000,,ハッ! あっ
Dialogue: 0,0:09:37.48,0:09:41.15,Default,,0000,0000,0000,,あ!!
Dialogue: 0,0:09:41.15,0:09:46.15,Default,,0000,0000,0000,,多腕の大男に 女
Dialogue: 0,0:09:46.15,0:09:50.66,Default,,0000,0000,0000,,ヴィルヘルムさん?
Dialogue: 0,0:09:46.15,0:09:50.66,Default,,0000,0000,0000,,んっ あっ
Dialogue: 0,0:09:50.66,0:09:54.16,Default,,0000,0000,0000,,ミミ殿の塞がらない傷
Dialogue: 0,0:09:54.16,0:09:57.83,Default,,0000,0000,0000,,恐らく 死神の加護によるものです
Dialogue: 0,0:09:57.83,0:10:02.00,Default,,0000,0000,0000,,チビっ子は
Dialogue: 0,0:09:57.83,0:10:02.00,Default,,0000,0000,0000,,あいつは 俺をかばって
Dialogue: 0,0:10:02.00,0:10:04.17,Default,,0000,0000,0000,,それは ミミの選んだことや
Dialogue: 0,0:10:04.17,0:10:07.51,Default,,0000,0000,0000,,わかってる わかってらあ
Dialogue: 0,0:10:07.51,0:10:11.34,Default,,0000,0000,0000,,誰も 誰も 俺を責めやしねえ
Dialogue: 0,0:10:11.34,0:10:15.85,Default,,0000,0000,0000,,だっけどな 俺は そうじゃねえ!
Dialogue: 0,0:10:11.34,0:10:15.85,Default,,0000,0000,0000,,ほう
Dialogue: 0,0:10:15.85,0:10:20.35,Default,,0000,0000,0000,,だから あいつは 俺が ぶっちめんだ!
Dialogue: 0,0:10:20.35,0:10:24.86,Default,,0000,0000,0000,,よう ほえたわ 男に 二言はない
Dialogue: 0,0:10:24.86,0:10:29.03,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:10:24.86,0:10:29.03,Default,,0000,0000,0000,,立って 戦うっちゅうんやな?
Dialogue: 0,0:10:29.03,0:10:33.03,Default,,0000,0000,0000,,あっ ああ! 当っ然だ!
Dialogue: 0,0:10:33.03,0:10:36.87,Default,,0000,0000,0000,,俺が やってやらあ!
Dialogue: 0,0:10:33.03,0:10:36.87,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:10:36.87,0:10:39.21,Default,,0000,0000,0000,,それで スバル
Dialogue: 0,0:10:36.87,0:10:39.21,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:10:39.21,0:10:41.87,Default,,0000,0000,0000,,君なら これから どう動く?
Dialogue: 0,0:10:41.87,0:10:46.05,Default,,0000,0000,0000,,そらまた ずいぶん アバウトな話の振り方だな おい
Dialogue: 0,0:10:46.05,0:10:51.72,Default,,0000,0000,0000,,怠惰との戦いを思い出した
Dialogue: 0,0:10:46.05,0:10:51.72,Default,,0000,0000,0000,,君が特効薬になるのではとね
Dialogue: 0,0:10:51.72,0:10:54.39,Default,,0000,0000,0000,,うぅ むちゃぶりすんな!
Dialogue: 0,0:10:54.39,0:10:58.56,Default,,0000,0000,0000,,俺が 魔女教の特効薬なら こんな脚になってねえよ!
Dialogue: 0,0:10:58.56,0:11:00.49,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:11:00.49,0:11:03.16,Default,,0000,0000,0000,,エミリアを連れていったのは強欲だ
Dialogue: 0,0:11:03.16,0:11:07.50,Default,,0000,0000,0000,,1秒だって あんな野郎に エミリアを預けておきたくねえ
Dialogue: 0,0:11:07.50,0:11:12.61,Default,,0000,0000,0000,,ということは 君は
Dialogue: 0,0:11:07.50,0:11:12.61,Default,,0000,0000,0000,,エミリア様の奪還を優先すると?
Dialogue: 0,0:11:15.01,0:11:17.84,Default,,0000,0000,0000,,当然だ
Dialogue: 0,0:11:15.01,0:11:17.84,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:11:17.84,0:11:19.85,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:11:17.84,0:11:19.85,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:19.85,0:11:22.52,Default,,0000,0000,0000,,て言いたいところだけどな
Dialogue: 0,0:11:22.52,0:11:27.02,Default,,0000,0000,0000,,あのミーティアが よくない
Dialogue: 0,0:11:22.52,0:11:27.02,Default,,0000,0000,0000,,フッ 同感だ
Dialogue: 0,0:11:27.02,0:11:31.52,Default,,0000,0000,0000,,あの 一方的に 聞く者の精神をむしばむ声
Dialogue: 0,0:11:31.52,0:11:36.36,Default,,0000,0000,0000,,ミーティアが 都市の全員を縛りつける 鎖の役割をしている
Dialogue: 0,0:11:36.36,0:11:38.86,Default,,0000,0000,0000,,んっ 攻略する順番は
Dialogue: 0,0:11:38.86,0:11:42.87,Default,,0000,0000,0000,,色欲がいる 都市庁舎が最優先だ
Dialogue: 0,0:11:42.87,0:11:47.71,Default,,0000,0000,0000,,普通に歩いとるとこ見ると 大丈夫そうやな
Dialogue: 0,0:11:47.71,0:11:51.88,Default,,0000,0000,0000,,まあ 厳密には 大丈夫じゃねえんだけど
Dialogue: 0,0:11:51.88,0:11:54.88,Default,,0000,0000,0000,,フェリスは 街の人たちを 治療しなきゃならねえし
Dialogue: 0,0:11:54.88,0:11:59.05,Default,,0000,0000,0000,,ヘータローたちは 加護で ミミの傷を分け合ってて動けねえ
Dialogue: 0,0:11:59.05,0:12:02.82,Default,,0000,0000,0000,,戦力は 1人でも多いほうがいいだろ
Dialogue: 0,0:12:02.82,0:12:07.33,Default,,0000,0000,0000,,というか ここまで ついてきてもらってなんだけど
Dialogue: 0,0:12:07.33,0:12:09.33,Default,,0000,0000,0000,,クルシュさんは戦えるのか?
Dialogue: 0,0:12:09.33,0:12:12.33,Default,,0000,0000,0000,,ヴィルヘルムに師事して 鍛え直しました
Dialogue: 0,0:12:12.33,0:12:15.84,Default,,0000,0000,0000,,足手まといには ならないつもりですよ
Dialogue: 0,0:12:15.84,0:12:18.84,Default,,0000,0000,0000,,クルシュ様の天ぴんは 衰えておりません
Dialogue: 0,0:12:18.84,0:12:21.51,Default,,0000,0000,0000,,私が保証しましょう
Dialogue: 0,0:12:21.51,0:12:25.85,Default,,0000,0000,0000,,フッ で お前は?
Dialogue: 0,0:12:21.51,0:12:25.85,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:12:25.85,0:12:28.18,Default,,0000,0000,0000,,戦ってるとこ 見たことねえんだけど
Dialogue: 0,0:12:28.18,0:12:31.52,Default,,0000,0000,0000,,あ それなんだがよ 兄弟
Dialogue: 0,0:12:31.52,0:12:35.19,Default,,0000,0000,0000,,この流れで言うのも 勇気がいるんだが
Dialogue: 0,0:12:31.52,0:12:35.19,Default,,0000,0000,0000,,なんだよ?
Dialogue: 0,0:12:35.19,0:12:39.69,Default,,0000,0000,0000,,悪いんだが 俺は 姫さん捜して 合流しなきゃならねえ
Dialogue: 0,0:12:39.69,0:12:43.86,Default,,0000,0000,0000,,ここで お別れだ
Dialogue: 0,0:12:39.69,0:12:43.86,Default,,0000,0000,0000,,はぁ!? お前 何 言いだすんだよ!
Dialogue: 0,0:12:43.86,0:12:46.53,Default,,0000,0000,0000,,だから 悪いって 言ってるじゃねえか
Dialogue: 0,0:12:43.86,0:12:46.53,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:46.53,0:12:49.20,Default,,0000,0000,0000,,他の みんなも ほんと 申し訳ねえっての
Dialogue: 0,0:12:49.20,0:12:53.37,Default,,0000,0000,0000,,あるじのことを思うのは 従者として当然のこと
Dialogue: 0,0:12:53.37,0:12:56.71,Default,,0000,0000,0000,,私は それを非難しませんよ
Dialogue: 0,0:12:53.37,0:12:56.71,Default,,0000,0000,0000,,そいつは どうも
Dialogue: 0,0:12:56.71,0:12:59.71,Default,,0000,0000,0000,,うん マジかよ
Dialogue: 0,0:12:59.71,0:13:02.98,Default,,0000,0000,0000,,となると いよいよ 俺が 足手まとい確定枠か
Dialogue: 0,0:13:02.98,0:13:06.49,Default,,0000,0000,0000,,なんでや!
Dialogue: 0,0:13:02.98,0:13:06.49,Default,,0000,0000,0000,,兄ちゃんがおったら百人力や
Dialogue: 0,0:13:06.49,0:13:08.49,Default,,0000,0000,0000,,頼りにしとるぞ
Dialogue: 0,0:13:06.49,0:13:08.49,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:13:08.49,0:13:11.32,Default,,0000,0000,0000,,白鯨のときも 怠惰のときも
Dialogue: 0,0:13:11.32,0:13:14.16,Default,,0000,0000,0000,,兄ちゃんが気張っとったんを みんな 見とる
Dialogue: 0,0:13:14.16,0:13:19.17,Default,,0000,0000,0000,,私も心強いです
Dialogue: 0,0:13:14.16,0:13:19.17,Default,,0000,0000,0000,,頼りにしています スバル様
Dialogue: 0,0:13:19.17,0:13:21.17,Default,,0000,0000,0000,,そっ そうですか
Dialogue: 0,0:13:21.17,0:13:24.00,Default,,0000,0000,0000,,んっ なんか 変な気分だな
Dialogue: 0,0:13:24.00,0:13:26.67,Default,,0000,0000,0000,,じゃあ 1個だけ アドバイスだ
Dialogue: 0,0:13:24.00,0:13:26.67,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:13:26.67,0:13:30.51,Default,,0000,0000,0000,,暴食と出くわしたら 本名は聞かせるな
Dialogue: 0,0:13:30.51,0:13:32.85,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:30.51,0:13:32.85,Default,,0000,0000,0000,,今 この街に
Dialogue: 0,0:13:32.85,0:13:35.85,Default,,0000,0000,0000,,大罪司教が 全員 そろってる可能性がある
Dialogue: 0,0:13:35.85,0:13:37.85,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:35.85,0:13:37.85,Default,,0000,0000,0000,,何!?
Dialogue: 0,0:13:37.85,0:13:40.02,Default,,0000,0000,0000,,ハッ あっ
Dialogue: 0,0:13:40.02,0:13:43.52,Default,,0000,0000,0000,,お互い 運がありゃ 無事で会おうぜ 兄弟
Dialogue: 0,0:13:52.70,0:13:54.70,Default,,0000,0000,0000,,血ぃの臭いや
Dialogue: 0,0:13:54.70,0:13:57.37,Default,,0000,0000,0000,,フゥー
Dialogue: 0,0:13:54.70,0:13:57.37,Default,,0000,0000,0000,,それも ごっつい量やな
Dialogue: 0,0:13:57.37,0:14:00.97,Default,,0000,0000,0000,,スバル
Dialogue: 0,0:13:57.37,0:14:00.97,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:57.37,0:14:00.97,Default,,0000,0000,0000,,入れ込み過ぎだ
Dialogue: 0,0:14:00.97,0:14:05.98,Default,,0000,0000,0000,,あっ 悪い
Dialogue: 0,0:14:00.97,0:14:05.98,Default,,0000,0000,0000,,確かに 入れ込み過ぎてる
Dialogue: 0,0:14:05.98,0:14:10.48,Default,,0000,0000,0000,,無理もない
Dialogue: 0,0:14:05.98,0:14:10.48,Default,,0000,0000,0000,,暴食は 因縁のある相手だ
Dialogue: 0,0:14:10.48,0:14:15.82,Default,,0000,0000,0000,,仮に 私が 君の立場なら
Dialogue: 0,0:14:10.48,0:14:15.82,Default,,0000,0000,0000,,平静を装えたかは怪しいものだ
Dialogue: 0,0:14:15.82,0:14:18.66,Default,,0000,0000,0000,,なんだ? お前 気持ち悪いな
Dialogue: 0,0:14:18.66,0:14:20.66,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:14:18.66,0:14:20.66,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:14:23.16,0:14:25.66,Default,,0000,0000,0000,,ハァー
Dialogue: 0,0:14:25.66,0:14:29.34,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:14:25.66,0:14:29.34,Default,,0000,0000,0000,,打ち合わせどおりにいこう
Dialogue: 0,0:14:29.34,0:14:31.50,Default,,0000,0000,0000,,基本は 複数人で 1人をしとめる
Dialogue: 0,0:14:31.50,0:14:36.18,Default,,0000,0000,0000,,各個撃破して 都市庁舎を奪還だ
Dialogue: 0,0:14:31.50,0:14:36.18,Default,,0000,0000,0000,,ただし
Dialogue: 0,0:14:36.18,0:14:38.18,Default,,0000,0000,0000,,不利だと思えば
Dialogue: 0,0:14:38.18,0:14:43.18,Default,,0000,0000,0000,,即時の撤退を 決断することですね
Dialogue: 0,0:14:38.18,0:14:43.18,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:14:43.18,0:14:45.18,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:48.19,0:14:51.02,Default,,0000,0000,0000,,広場 衛兵の死体だらけっだ
Dialogue: 0,0:14:51.02,0:14:53.69,Default,,0000,0000,0000,,ビビって 足 止めんじゃあねえ!
Dialogue: 0,0:14:53.69,0:14:56.70,Default,,0000,0000,0000,,いくぞ!
Dialogue: 0,0:14:56.70,0:14:59.87,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:14:56.70,0:14:59.87,Default,,0000,0000,0000,,兄ちゃん
Dialogue: 0,0:14:56.70,0:14:59.87,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:14:59.87,0:15:01.80,Default,,0000,0000,0000,,ちょっと失礼するで
Dialogue: 0,0:14:59.87,0:15:01.80,Default,,0000,0000,0000,,えっ? あっ
Dialogue: 0,0:15:01.80,0:15:05.00,Default,,0000,0000,0000,,舌 かむなや いくで!
Dialogue: 0,0:15:01.80,0:15:05.00,Default,,0000,0000,0000,,あっ あっ あ! あ!
Dialogue: 0,0:15:09.98,0:15:11.98,Default,,0000,0000,0000,,んっ あっ!
Dialogue: 0,0:15:15.81,0:15:18.15,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:15:15.81,0:15:18.15,Default,,0000,0000,0000,,これは
Dialogue: 0,0:15:18.15,0:15:21.15,Default,,0000,0000,0000,,ハッ! やつらだ!
Dialogue: 0,0:15:23.66,0:15:26.36,Default,,0000,0000,0000,,いきます! はぁ!
Dialogue: 0,0:15:31.66,0:15:33.67,Default,,0000,0000,0000,,はぁ!
Dialogue: 0,0:15:36.00,0:15:38.34,Default,,0000,0000,0000,,うぅ!
Dialogue: 0,0:15:38.34,0:15:41.01,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:15:41.01,0:15:43.51,Default,,0000,0000,0000,,フッ! ハッ!
Dialogue: 0,0:15:43.51,0:15:47.51,Default,,0000,0000,0000,,ハッ! ぐっ!
Dialogue: 0,0:15:47.51,0:15:51.35,Default,,0000,0000,0000,,やはり!
Dialogue: 0,0:15:51.35,0:15:55.35,Default,,0000,0000,0000,,んっ フッ!
Dialogue: 0,0:15:51.35,0:15:55.35,Default,,0000,0000,0000,,フン! おら!
Dialogue: 0,0:15:55.35,0:15:58.36,Default,,0000,0000,0000,,4本腕が なんぼのもんや!
Dialogue: 0,0:16:00.29,0:16:03.30,Default,,0000,0000,0000,,もろた!
Dialogue: 0,0:16:03.30,0:16:06.80,Default,,0000,0000,0000,,うっ! なんてな
Dialogue: 0,0:16:08.97,0:16:11.30,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:16:11.30,0:16:14.31,Default,,0000,0000,0000,,今だ!
Dialogue: 0,0:16:11.30,0:16:14.31,Default,,0000,0000,0000,,おう!
Dialogue: 0,0:16:17.64,0:16:19.65,Default,,0000,0000,0000,,なんじゃ? そら!
Dialogue: 0,0:16:19.65,0:16:22.98,Default,,0000,0000,0000,,させるかよ!
Dialogue: 0,0:16:22.98,0:16:26.29,Default,,0000,0000,0000,,合成魔法 ウルゴーラ!
Dialogue: 0,0:16:32.32,0:16:35.66,Default,,0000,0000,0000,,一気に仕掛けて 戦果 ゼロかよ
Dialogue: 0,0:16:35.66,0:16:38.33,Default,,0000,0000,0000,,結構 ショック でかいぜ
Dialogue: 0,0:16:38.33,0:16:40.50,Default,,0000,0000,0000,,みんな もう一度だ!
Dialogue: 0,0:16:40.50,0:16:42.67,Default,,0000,0000,0000,,ユリウスとクルシュさんの 遠距離攻撃を主力に
Dialogue: 0,0:16:42.67,0:16:44.67,Default,,0000,0000,0000,,キャハハハハハ!
Dialogue: 0,0:16:42.67,0:16:44.67,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:16:44.67,0:16:48.34,Default,,0000,0000,0000,,ほんとに 来やがってるじゃねえですか!
Dialogue: 0,0:16:48.34,0:16:51.18,Default,,0000,0000,0000,,アーハハハハハハハハ!
Dialogue: 0,0:16:48.34,0:16:51.18,Default,,0000,0000,0000,,なっ
Dialogue: 0,0:16:51.18,0:16:54.68,Default,,0000,0000,0000,,んじゃ 改めまして 名乗ります
Dialogue: 0,0:16:54.68,0:16:59.02,Default,,0000,0000,0000,,私が 魔女教大罪司教 色欲担当
Dialogue: 0,0:16:59.02,0:17:03.96,Default,,0000,0000,0000,,カペラ・エメラダ・ルグニカちゃん様です!
Dialogue: 0,0:16:59.02,0:17:03.96,Default,,0000,0000,0000,,キャーハハ!
Dialogue: 0,0:17:03.96,0:17:07.46,Default,,0000,0000,0000,,死ね! 腐れくず肉どもが!
Dialogue: 0,0:17:07.46,0:17:12.13,Default,,0000,0000,0000,,マジかよ ぞっとするくらい 表情豊かなドラゴンだな
Dialogue: 0,0:17:12.13,0:17:14.80,Default,,0000,0000,0000,,ありゃあ?
Dialogue: 0,0:17:12.13,0:17:14.80,Default,,0000,0000,0000,,そこにいる てめえは
Dialogue: 0,0:17:14.80,0:17:17.97,Default,,0000,0000,0000,,負け犬じゃなくて 負け猫でしたっけ?
Dialogue: 0,0:17:17.97,0:17:19.97,Default,,0000,0000,0000,,ニャーニャー ニャーニャー
Dialogue: 0,0:17:19.97,0:17:24.64,Default,,0000,0000,0000,,つがいの猫ちゃんが死んだから って 泣いてんのかにゃ?
Dialogue: 0,0:17:24.64,0:17:27.98,Default,,0000,0000,0000,,あっ! 大将
Dialogue: 0,0:17:27.98,0:17:34.15,Default,,0000,0000,0000,,黙れよ お前が しゃべるたんびに
Dialogue: 0,0:17:27.98,0:17:34.15,Default,,0000,0000,0000,,俺の中のドラゴン像が汚される
Dialogue: 0,0:17:34.15,0:17:37.16,Default,,0000,0000,0000,,はぁ? てめえって なんなの?
Dialogue: 0,0:17:37.16,0:17:42.16,Default,,0000,0000,0000,,他の くず肉の中でも てめえは 一等 場違いのにおいが しやがりますけど
Dialogue: 0,0:17:42.16,0:17:45.16,Default,,0000,0000,0000,,大体 てめえらのやり方が 大ざっぱなんだよ!
Dialogue: 0,0:17:45.16,0:17:48.17,Default,,0000,0000,0000,,幹部は もっと もったいぶって 1人ずつ 出てこい!
Dialogue: 0,0:17:48.17,0:17:51.17,Default,,0000,0000,0000,,様式美ってもんが 全っ然 わかってやがらねえ!
Dialogue: 0,0:17:51.17,0:17:55.01,Default,,0000,0000,0000,,何様だ?
Dialogue: 0,0:17:51.17,0:17:55.01,Default,,0000,0000,0000,,神様気取りかよ! ああ?
Dialogue: 0,0:17:55.01,0:17:57.68,Default,,0000,0000,0000,,はい 時間稼ぎ 終了
Dialogue: 0,0:17:57.68,0:17:59.68,Default,,0000,0000,0000,,やったれ ユリウス!
Dialogue: 0,0:17:59.68,0:18:06.29,Default,,0000,0000,0000,,君の無鉄砲には
Dialogue: 0,0:17:59.68,0:18:06.29,Default,,0000,0000,0000,,時折 心の底から驚かされる
Dialogue: 0,0:18:06.29,0:18:09.12,Default,,0000,0000,0000,,虹の光に焼かれるがいい!
Dialogue: 0,0:18:09.12,0:18:12.12,Default,,0000,0000,0000,,アルクラウゼリア!
Dialogue: 0,0:18:12.12,0:18:14.13,Default,,0000,0000,0000,,私様に 小細工を
Dialogue: 0,0:18:14.13,0:18:17.46,Default,,0000,0000,0000,,うっ ギャー!
Dialogue: 0,0:18:17.46,0:18:20.13,Default,,0000,0000,0000,,ハァ あっ うっ!
Dialogue: 0,0:18:20.13,0:18:24.64,Default,,0000,0000,0000,,あ やだやだ 人のこと えっぐい角度から見つめて
Dialogue: 0,0:18:24.64,0:18:27.84,Default,,0000,0000,0000,,興奮してんじゃねえってんですよ
Dialogue: 0,0:18:32.14,0:18:36.32,Default,,0000,0000,0000,,傷が 治っていく?
Dialogue: 0,0:18:32.14,0:18:36.32,Default,,0000,0000,0000,,冗談じゃねえぞ
Dialogue: 0,0:18:36.32,0:18:39.32,Default,,0000,0000,0000,,とっとっとっとっと フフッ
Dialogue: 0,0:18:39.32,0:18:41.65,Default,,0000,0000,0000,,ばあ!
Dialogue: 0,0:18:39.32,0:18:41.65,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:18:41.65,0:18:43.66,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:18:43.66,0:18:46.99,Default,,0000,0000,0000,,なんだ 約束のお時間じゃねえですか
Dialogue: 0,0:18:46.99,0:18:50.16,Default,,0000,0000,0000,,中に戻らせてもらっちゃいます
Dialogue: 0,0:18:50.16,0:18:52.16,Default,,0000,0000,0000,,はぁ? あっ 待て!
Dialogue: 0,0:18:52.16,0:18:54.33,Default,,0000,0000,0000,,この虫かごの連中が
Dialogue: 0,0:18:54.33,0:18:58.00,Default,,0000,0000,0000,,どんな あんばいに苦しむか 乞うご期待
Dialogue: 0,0:18:58.00,0:19:01.94,Default,,0000,0000,0000,,キャハハハハハ! アーハハハハハハハ!
Dialogue: 0,0:19:01.94,0:19:04.28,Default,,0000,0000,0000,,人質を処刑する気か
Dialogue: 0,0:19:04.28,0:19:08.78,Default,,0000,0000,0000,,くそ 中に入るしかねえってのか この状況で
Dialogue: 0,0:19:08.78,0:19:13.62,Default,,0000,0000,0000,,迷っとる暇はないぞ!
Dialogue: 0,0:19:08.78,0:19:13.62,Default,,0000,0000,0000,,あの2人は わいらがやる!
Dialogue: 0,0:19:13.62,0:19:15.62,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:15.62,0:19:20.13,Default,,0000,0000,0000,,ガーフィール 負けんなよ!
Dialogue: 0,0:19:15.62,0:19:20.13,Default,,0000,0000,0000,,ああ! やってこいや 大将!
Dialogue: 0,0:19:20.13,0:19:24.03,Default,,0000,0000,0000,,ヴィルヘルム 任せました
Dialogue: 0,0:19:20.13,0:19:24.03,Default,,0000,0000,0000,,御意に
Dialogue: 0,0:19:26.30,0:19:29.80,Default,,0000,0000,0000,,スバル クルシュ様を任せた!
Dialogue: 0,0:19:26.30,0:19:29.80,Default,,0000,0000,0000,,えっ? ちょちょ
Dialogue: 0,0:19:31.80,0:19:35.64,Default,,0000,0000,0000,,おまっ クルシュさん 失礼!
Dialogue: 0,0:19:31.80,0:19:35.64,Default,,0000,0000,0000,,んっ? あっ キャー!
Dialogue: 0,0:19:35.64,0:19:38.14,Default,,0000,0000,0000,,あっ うわ!
Dialogue: 0,0:19:35.64,0:19:38.14,Default,,0000,0000,0000,,うっ うわ!
Dialogue: 0,0:19:40.15,0:19:44.32,Default,,0000,0000,0000,,しっかり つかまって!
Dialogue: 0,0:19:40.15,0:19:44.32,Default,,0000,0000,0000,,はい!
Dialogue: 0,0:19:44.32,0:19:46.99,Default,,0000,0000,0000,,うっ! フッ!
Dialogue: 0,0:19:46.99,0:19:49.66,Default,,0000,0000,0000,,うぅ うわ!
Dialogue: 0,0:19:46.99,0:19:49.66,Default,,0000,0000,0000,,あたたたたたたた!
Dialogue: 0,0:19:49.66,0:19:52.49,Default,,0000,0000,0000,,たっ! うわ うぅ
Dialogue: 0,0:19:49.66,0:19:52.49,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:52.49,0:19:55.83,Default,,0000,0000,0000,,クッ クッ クルシュさん 無事?
Dialogue: 0,0:19:55.83,0:20:00.33,Default,,0000,0000,0000,,わっ 私は平気です
Dialogue: 0,0:19:55.83,0:20:00.33,Default,,0000,0000,0000,,でも スバル様の脚が
Dialogue: 0,0:20:00.33,0:20:05.00,Default,,0000,0000,0000,,だっ 大丈夫 大丈夫
Dialogue: 0,0:20:00.33,0:20:05.00,Default,,0000,0000,0000,,痛くない
Dialogue: 0,0:20:05.00,0:20:07.01,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:20:09.34,0:20:11.51,Default,,0000,0000,0000,,アッハハ!
Dialogue: 0,0:20:11.51,0:20:15.51,Default,,0000,0000,0000,,落ち着きなよ
Dialogue: 0,0:20:11.51,0:20:15.51,Default,,0000,0000,0000,,お兄さんたちと お姉さん
Dialogue: 0,0:20:15.51,0:20:18.85,Default,,0000,0000,0000,,うれしいな うれしいね
Dialogue: 0,0:20:18.85,0:20:22.35,Default,,0000,0000,0000,,うれしいさ うれしいとも
Dialogue: 0,0:20:22.35,0:20:26.36,Default,,0000,0000,0000,,うれしすぎるから うれしいと思えるから
Dialogue: 0,0:20:26.36,0:20:32.70,Default,,0000,0000,0000,,うれしいを感じられるからこそ
Dialogue: 0,0:20:26.36,0:20:32.70,Default,,0000,0000,0000,,暴飲暴食!
Dialogue: 0,0:20:32.70,0:20:35.87,Default,,0000,0000,0000,,待ち焦がれたものほど
Dialogue: 0,0:20:35.87,0:20:38.70,Default,,0000,0000,0000,,腹をすかしておけばおくほど
Dialogue: 0,0:20:38.70,0:20:45.04,Default,,0000,0000,0000,,最初の1口が
Dialogue: 0,0:20:38.70,0:20:45.04,Default,,0000,0000,0000,,うまくなるってもんさ!
Dialogue: 0,0:20:45.04,0:20:47.55,Default,,0000,0000,0000,,あっれ? お兄さん
Dialogue: 0,0:20:47.55,0:20:52.38,Default,,0000,0000,0000,,僕たち 俺たちに 何か 恨みとかある人だったりする?
Dialogue: 0,0:20:52.38,0:20:55.39,Default,,0000,0000,0000,,ほら 僕たちって 頭が悪いし
Dialogue: 0,0:20:55.39,0:20:59.89,Default,,0000,0000,0000,,俺たちって 記憶力がないからさ
Dialogue: 0,0:20:55.39,0:20:59.89,Default,,0000,0000,0000,,ぐっ
Dialogue: 0,0:20:59.89,0:21:04.00,Default,,0000,0000,0000,,なあ くそがき
Dialogue: 0,0:20:59.89,0:21:04.00,Default,,0000,0000,0000,,お前が ただの うっかりで
Dialogue: 0,0:21:04.00,0:21:06.83,Default,,0000,0000,0000,,ここに迷い込んだ 方向音痴ってんなら
Dialogue: 0,0:21:06.83,0:21:11.34,Default,,0000,0000,0000,,今のうちに白状しろ まだ許せる
Dialogue: 0,0:21:06.83,0:21:11.34,Default,,0000,0000,0000,,だけど
Dialogue: 0,0:21:11.34,0:21:14.67,Default,,0000,0000,0000,,僕たちは 魔女教大罪司教
Dialogue: 0,0:21:11.34,0:21:14.67,Default,,0000,0000,0000,,ぐっ
Dialogue: 0,0:21:14.67,0:21:20.08,Default,,0000,0000,0000,,暴食担当 ロイ・アルファルド
Dialogue: 0,0:21:14.67,0:21:20.08,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:21:22.68,0:21:27.19,Default,,0000,0000,0000,,くっ 暴食!
Dialogue: 0,0:23:00.31,0:23:03.15,Default,,0000,0000,0000,,んっ あっ
Dialogue: 0,0:23:03.15,0:23:05.65,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:23:05.65,0:23:08.65,Default,,0000,0000,0000,,ここ どこなの?
Dialogue: 0,0:23:08.65,0:23:11.66,Default,,0000,0000,0000,,そうだ
Dialogue: 0,0:23:11.66,0:23:16.83,Default,,0000,0000,0000,,私 広場で
Dialogue: 0,0:23:11.66,0:23:16.83,Default,,0000,0000,0000,,包帯の女の人と戦いになって
Dialogue: 0,0:23:16.83,0:23:20.83,Default,,0000,0000,0000,,って あれ? 私 裸?
Dialogue: 0,0:23:20.83,0:23:24.50,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:23:20.83,0:23:24.50,Default,,0000,0000,0000,,ああ 目覚めたみたいだね
Dialogue: 0,0:23:24.50,0:23:30.01,Default,,0000,0000,0000,,本当によかった
Dialogue: 0,0:23:24.50,0:23:30.01,Default,,0000,0000,0000,,君が無事で 心から安心したよ
Dialogue: 0,0:23:30.01,0:23:33.01,Default,,0000,0000,0000,,えっと あなたは?
Dialogue: 0,0:23:33.01,0:23:37.02,Default,,0000,0000,0000,,自己紹介の前に 大事な質問に答えてほしい
Dialogue: 0,0:23:37.02,0:23:41.52,Default,,0000,0000,0000,,僕たちの未来に重要なことなんだ
Dialogue: 0,0:23:37.02,0:23:41.52,Default,,0000,0000,0000,,僕たちの?
Dialogue: 0,0:23:41.52,0:23:44.86,Default,,0000,0000,0000,,エミリア 君は 処女かな?
Dialogue: 0,0:23:44.86,0:23:48.56,Default,,0000,0000,0000,,それだけは 本当に大事なことだからさ
