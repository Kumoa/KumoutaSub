Dialogue: 0,0:00:02.00,0:00:04.00,Default,,0000,0000,0000,,エミリア 君は 処女かな?
Dialogue: 0,0:00:04.00,0:00:07.01,Default,,0000,0000,0000,,それだけは 本当に大事なことだからさ
Dialogue: 0,0:00:07.01,0:00:10.01,Default,,0000,0000,0000,,あっ んっ?
Dialogue: 0,0:00:10.01,0:00:12.18,Default,,0000,0000,0000,,ごめん ごめん
Dialogue: 0,0:00:12.18,0:00:15.18,Default,,0000,0000,0000,,いきなりで 驚かせてしまったみたいだね
Dialogue: 0,0:00:15.18,0:00:17.18,Default,,0000,0000,0000,,素直に謝罪するよ
Dialogue: 0,0:00:17.18,0:00:22.52,Default,,0000,0000,0000,,僕は 非を認められない
Dialogue: 0,0:00:17.18,0:00:22.52,Default,,0000,0000,0000,,卑せんな連中とは違うからさ
Dialogue: 0,0:00:22.52,0:00:26.53,Default,,0000,0000,0000,,素直に謝れるのは大事よね
Dialogue: 0,0:00:26.53,0:00:29.20,Default,,0000,0000,0000,,こんな当たり前のことが わからない人間が
Dialogue: 0,0:00:29.20,0:00:32.20,Default,,0000,0000,0000,,世の中 ことのほか多い
Dialogue: 0,0:00:32.20,0:00:35.37,Default,,0000,0000,0000,,やっぱり 君は すばらしい女性だ
Dialogue: 0,0:00:35.37,0:00:38.37,Default,,0000,0000,0000,,それで 改めて聞きたい
Dialogue: 0,0:00:38.37,0:00:41.54,Default,,0000,0000,0000,,エミリア 君は 処女かな?
Dialogue: 0,0:00:41.54,0:00:44.71,Default,,0000,0000,0000,,どうなんだい?
Dialogue: 0,0:00:44.71,0:00:47.38,Default,,0000,0000,0000,,あの ショジョって 何?
Dialogue: 0,0:00:47.38,0:00:50.22,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:00:47.38,0:00:50.22,Default,,0000,0000,0000,,聞いたことがなくて
Dialogue: 0,0:00:50.22,0:00:52.22,Default,,0000,0000,0000,,すばらしい!
Dialogue: 0,0:00:52.22,0:00:55.89,Default,,0000,0000,0000,,君は 僕が思い描いた 理想の乙女そのものだよ
Dialogue: 0,0:00:55.89,0:00:58.73,Default,,0000,0000,0000,,体が処女なのは当たり前
Dialogue: 0,0:00:58.73,0:01:03.00,Default,,0000,0000,0000,,本当に大事なのは その心まで処女であること
Dialogue: 0,0:01:03.00,0:01:06.33,Default,,0000,0000,0000,,君は 僕に 新たな真理を示してくれた
Dialogue: 0,0:01:06.33,0:01:10.00,Default,,0000,0000,0000,,そうなの?
Dialogue: 0,0:01:06.33,0:01:10.00,Default,,0000,0000,0000,,そうだとも
Dialogue: 0,0:01:10.00,0:01:12.67,Default,,0000,0000,0000,,おっと 自己紹介が遅れたね
Dialogue: 0,0:01:12.67,0:01:15.34,Default,,0000,0000,0000,,僕は レグルス・コルニアス
Dialogue: 0,0:01:15.34,0:01:21.18,Default,,0000,0000,0000,,君の大事な旦那様で
Dialogue: 0,0:01:15.34,0:01:21.18,Default,,0000,0000,0000,,君は 僕の愛する 79番目の妻だ
Dialogue: 0,0:01:21.18,0:01:24.18,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:01:21.18,0:01:24.18,Default,,0000,0000,0000,,着替えは 用意してある
Dialogue: 0,0:01:29.19,0:01:33.03,Default,,0000,0000,0000,,184番 79番に着替えを
Dialogue: 0,0:01:33.03,0:01:38.70,Default,,0000,0000,0000,,君たちと同じ立場になる子だ
Dialogue: 0,0:01:33.03,0:01:38.70,Default,,0000,0000,0000,,仲よく 面倒を見てあげるんだよ
Dialogue: 0,0:01:38.70,0:01:43.04,Default,,0000,0000,0000,,いい子だ 言いつけどおり 笑わなくなったじゃないか
Dialogue: 0,0:01:43.04,0:01:46.87,Default,,0000,0000,0000,,んっ あっ
Dialogue: 0,0:01:46.87,0:01:51.04,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:01:46.87,0:01:51.04,Default,,0000,0000,0000,,それじゃあ またあとで
Dialogue: 0,0:01:51.04,0:01:53.05,Default,,0000,0000,0000,,ええ
Dialogue: 0,0:01:57.55,0:02:00.15,Default,,0000,0000,0000,,お着替えを
Dialogue: 0,0:01:57.55,0:02:00.15,Default,,0000,0000,0000,,あなたは?
Dialogue: 0,0:02:00.15,0:02:04.32,Default,,0000,0000,0000,,184番です
Dialogue: 0,0:02:00.15,0:02:04.32,Default,,0000,0000,0000,,あなたと同じ 彼の妻の
Dialogue: 0,0:02:04.32,0:02:08.66,Default,,0000,0000,0000,,私 あの人の奥さんに なったつもりなんてないんだけど
Dialogue: 0,0:02:08.66,0:02:10.66,Default,,0000,0000,0000,,彼は そのつもりです
Dialogue: 0,0:02:10.66,0:02:13.17,Default,,0000,0000,0000,,彼が そのつもりであるということは
Dialogue: 0,0:02:13.17,0:02:15.84,Default,,0000,0000,0000,,あなたの意思は 関係ないということです
Dialogue: 0,0:02:15.84,0:02:20.01,Default,,0000,0000,0000,,んっ そんなの おかしいわ
Dialogue: 0,0:02:20.01,0:02:24.01,Default,,0000,0000,0000,,なんだか あの人 本で読んだ 悪い王様みたい
Dialogue: 0,0:02:24.01,0:02:27.35,Default,,0000,0000,0000,,フゥ 言い得て妙です
Dialogue: 0,0:02:24.01,0:02:27.35,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:02:27.35,0:02:30.52,Default,,0000,0000,0000,,彼の在り方は 確かに王様
Dialogue: 0,0:02:30.52,0:02:33.12,Default,,0000,0000,0000,,小さな王の名に ふさわしいでしょうね
Dialogue: 0,0:02:35.86,0:02:37.86,Default,,0000,0000,0000,,お着替えを
Dialogue: 0,0:02:40.03,0:02:42.03,Default,,0000,0000,0000,,スバル
Dialogue: 0,0:04:24.16,0:04:26.17,Default,,0000,0000,0000,,暴食!
Dialogue: 0,0:04:26.17,0:04:28.67,Default,,0000,0000,0000,,フフッ あっ!
Dialogue: 0,0:04:26.17,0:04:28.67,Default,,0000,0000,0000,,あっ! くっ くっ
Dialogue: 0,0:04:28.67,0:04:30.67,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:04:28.67,0:04:30.67,Default,,0000,0000,0000,,ヒヒッ!
Dialogue: 0,0:04:30.67,0:04:34.84,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:04:30.67,0:04:34.84,Default,,0000,0000,0000,,んっ フフッ
Dialogue: 0,0:04:34.84,0:04:38.34,Default,,0000,0000,0000,,んっ あっ!
Dialogue: 0,0:04:34.84,0:04:38.34,Default,,0000,0000,0000,,目的を思い出せ 幼女使い!
Dialogue: 0,0:04:38.34,0:04:40.35,Default,,0000,0000,0000,,くっ んっ
Dialogue: 0,0:04:40.35,0:04:44.18,Default,,0000,0000,0000,,暴食と出くわしたら 本名は聞かせるな
Dialogue: 0,0:04:44.18,0:04:46.19,Default,,0000,0000,0000,,私たちは なんのために ここに来た?
Dialogue: 0,0:04:46.19,0:04:50.02,Default,,0000,0000,0000,,おいおいおい 逃げちゃっていいのかい?
Dialogue: 0,0:04:50.02,0:04:54.03,Default,,0000,0000,0000,,お兄さん 俺たちに 恨みがあるんじゃないの?
Dialogue: 0,0:04:54.03,0:04:57.03,Default,,0000,0000,0000,,ぐっ
Dialogue: 0,0:04:54.03,0:04:57.03,Default,,0000,0000,0000,,因縁の相手ってやつは
Dialogue: 0,0:04:57.03,0:05:00.13,Default,,0000,0000,0000,,味わい深い食の極みさ
Dialogue: 0,0:05:00.13,0:05:05.14,Default,,0000,0000,0000,,暴飲暴食されておくれよ!
Dialogue: 0,0:05:00.13,0:05:05.14,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:05:08.47,0:05:11.81,Default,,0000,0000,0000,,ごめん レム
Dialogue: 0,0:05:08.47,0:05:11.81,Default,,0000,0000,0000,,もうちょっとだけ待っててくれ
Dialogue: 0,0:05:11.81,0:05:13.81,Default,,0000,0000,0000,,行きたまえ! 戦乙女様を頼む!
Dialogue: 0,0:05:13.81,0:05:15.82,Default,,0000,0000,0000,,負けんじゃねえぞ ユーリ!
Dialogue: 0,0:05:17.82,0:05:20.82,Default,,0000,0000,0000,,はっ 離さないでくださいね!
Dialogue: 0,0:05:20.82,0:05:24.52,Default,,0000,0000,0000,,だら!
Dialogue: 0,0:05:20.82,0:05:24.52,Default,,0000,0000,0000,,キャー!
Dialogue: 0,0:05:27.16,0:05:29.16,Default,,0000,0000,0000,,んっ これが ミーティア?
Dialogue: 0,0:05:29.16,0:05:31.16,Default,,0000,0000,0000,,ハッ! スバル様!
Dialogue: 0,0:05:29.16,0:05:31.16,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:36.34,0:05:39.17,Default,,0000,0000,0000,,あれ!
Dialogue: 0,0:05:36.34,0:05:39.17,Default,,0000,0000,0000,,うっ うぅ
Dialogue: 0,0:05:36.34,0:05:39.17,Default,,0000,0000,0000,,人質を
Dialogue: 0,0:05:39.17,0:05:42.34,Default,,0000,0000,0000,,させるかよ!
Dialogue: 0,0:05:39.17,0:05:42.34,Default,,0000,0000,0000,,やあ!
Dialogue: 0,0:05:42.34,0:05:46.68,Default,,0000,0000,0000,,はぁ!
Dialogue: 0,0:05:46.68,0:05:49.35,Default,,0000,0000,0000,,しゃ! ぐっ
Dialogue: 0,0:05:49.35,0:05:51.52,Default,,0000,0000,0000,,これで終わりです!
Dialogue: 0,0:05:58.52,0:06:02.13,Default,,0000,0000,0000,,周囲を警戒します
Dialogue: 0,0:05:58.52,0:06:02.13,Default,,0000,0000,0000,,スバル様は その子を
Dialogue: 0,0:06:02.13,0:06:04.63,Default,,0000,0000,0000,,おっ おお わかった
Dialogue: 0,0:06:07.13,0:06:11.64,Default,,0000,0000,0000,,大丈夫だ おっかない竜は お姉ちゃんが やっつけてくれたから
Dialogue: 0,0:06:11.64,0:06:15.81,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:11.64,0:06:15.81,Default,,0000,0000,0000,,他の人たちは?
Dialogue: 0,0:06:11.64,0:06:15.81,Default,,0000,0000,0000,,どこにいるか わかるか?
Dialogue: 0,0:06:15.81,0:06:18.11,Default,,0000,0000,0000,,あっ あっちのお部屋に
Dialogue: 0,0:06:22.32,0:06:26.65,Default,,0000,0000,0000,,あっ んっ
Dialogue: 0,0:06:26.65,0:06:28.86,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:06:34.16,0:06:37.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:37.83,0:06:41.33,Default,,0000,0000,0000,,あっ ああ
Dialogue: 0,0:06:41.33,0:06:43.67,Default,,0000,0000,0000,,あっ ハァ
Dialogue: 0,0:06:43.67,0:06:46.51,Default,,0000,0000,0000,,ハァハァハァ
Dialogue: 0,0:06:46.51,0:06:49.34,Default,,0000,0000,0000,,だっ これ
Dialogue: 0,0:06:49.34,0:06:52.51,Default,,0000,0000,0000,,あっ スバルさ
Dialogue: 0,0:06:49.34,0:06:52.51,Default,,0000,0000,0000,,ハッ! クルシュさん!
Dialogue: 0,0:06:52.51,0:06:55.01,Default,,0000,0000,0000,,キャハハハハハハ!
Dialogue: 0,0:06:55.01,0:06:58.35,Default,,0000,0000,0000,,なんで てめえらって そんなに おめでたいの?
Dialogue: 0,0:06:58.35,0:07:00.45,Default,,0000,0000,0000,,お前
Dialogue: 0,0:06:58.35,0:07:00.45,Default,,0000,0000,0000,,けなげで か弱い
Dialogue: 0,0:07:00.45,0:07:04.79,Default,,0000,0000,0000,,人質の女の子だとでも思った?
Dialogue: 0,0:07:04.79,0:07:10.30,Default,,0000,0000,0000,,ん ばあ! アハハハハハ!
Dialogue: 0,0:07:10.30,0:07:13.30,Default,,0000,0000,0000,,足を どけろ
Dialogue: 0,0:07:10.30,0:07:13.30,Default,,0000,0000,0000,,はぁ?
Dialogue: 0,0:07:13.30,0:07:18.64,Default,,0000,0000,0000,,私の 美しい おみ足に
Dialogue: 0,0:07:13.30,0:07:18.64,Default,,0000,0000,0000,,ご執心ってわけですか?
Dialogue: 0,0:07:18.64,0:07:21.31,Default,,0000,0000,0000,,それとも この雌肉に?
Dialogue: 0,0:07:21.31,0:07:23.81,Default,,0000,0000,0000,,ふん
Dialogue: 0,0:07:23.81,0:07:27.31,Default,,0000,0000,0000,,エッロい体つき してやがりますからね
Dialogue: 0,0:07:27.31,0:07:29.65,Default,,0000,0000,0000,,その人は てめえが
Dialogue: 0,0:07:29.65,0:07:32.32,Default,,0000,0000,0000,,足元に敷いていい人じゃねえって 言ってんだ!
Dialogue: 0,0:07:32.32,0:07:34.99,Default,,0000,0000,0000,,当たれ!
Dialogue: 0,0:07:32.32,0:07:34.99,Default,,0000,0000,0000,,いいですよ
Dialogue: 0,0:07:34.99,0:07:36.99,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:07:36.99,0:07:41.83,Default,,0000,0000,0000,,あっ あっ フフフフッ
Dialogue: 0,0:07:41.83,0:07:45.00,Default,,0000,0000,0000,,アハハ
Dialogue: 0,0:07:41.83,0:07:45.00,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:07:45.00,0:07:50.17,Default,,0000,0000,0000,,うっ! うわっ! ぐっ!
Dialogue: 0,0:07:50.17,0:07:52.67,Default,,0000,0000,0000,,キャハッ! なんです? その面
Dialogue: 0,0:07:52.67,0:07:56.51,Default,,0000,0000,0000,,私の美しさに 声も出ねえってとこですか?
Dialogue: 0,0:07:56.51,0:07:58.51,Default,,0000,0000,0000,,なんだ? それ
Dialogue: 0,0:07:58.51,0:08:02.95,Default,,0000,0000,0000,,さて くず肉ちゃんには 何に見えやがります?
Dialogue: 0,0:08:02.95,0:08:06.95,Default,,0000,0000,0000,,まさか 人に化ける竜なのか?
Dialogue: 0,0:08:06.95,0:08:12.12,Default,,0000,0000,0000,,はい! 低能丸出しの暴論
Dialogue: 0,0:08:06.95,0:08:12.12,Default,,0000,0000,0000,,頂きました!
Dialogue: 0,0:08:12.12,0:08:14.29,Default,,0000,0000,0000,,ハッ! ハッ!
Dialogue: 0,0:08:12.12,0:08:14.29,Default,,0000,0000,0000,,うっ! うっ!
Dialogue: 0,0:08:14.29,0:08:16.60,Default,,0000,0000,0000,,うぅ ハハッ!
Dialogue: 0,0:08:18.97,0:08:21.97,Default,,0000,0000,0000,,あい!
Dialogue: 0,0:08:21.97,0:08:25.81,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:08:21.97,0:08:25.81,Default,,0000,0000,0000,,ぐはっ!
Dialogue: 0,0:08:21.97,0:08:25.81,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:08:25.81,0:08:28.14,Default,,0000,0000,0000,,ぐっ がはっ! うっ
Dialogue: 0,0:08:28.14,0:08:32.81,Default,,0000,0000,0000,,ハァハァ 変身した?
Dialogue: 0,0:08:32.81,0:08:34.81,Default,,0000,0000,0000,,ウフフフフ
Dialogue: 0,0:08:34.81,0:08:40.15,Default,,0000,0000,0000,,私は
Dialogue: 0,0:08:34.81,0:08:40.15,Default,,0000,0000,0000,,魔女教大罪司教 色欲担当の
Dialogue: 0,0:08:40.15,0:08:43.16,Default,,0000,0000,0000,,カペラ・エメラダ・ルグニカ
Dialogue: 0,0:08:43.16,0:08:49.00,Default,,0000,0000,0000,,てめえ好みの美少女にだって
Dialogue: 0,0:08:43.16,0:08:49.00,Default,,0000,0000,0000,,変身してやりますよ
Dialogue: 0,0:08:53.00,0:08:55.00,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:08:55.00,0:08:59.84,Default,,0000,0000,0000,,そろそろ そこに倒れてる とかげと 奥の部屋の はえの正体
Dialogue: 0,0:08:59.84,0:09:02.94,Default,,0000,0000,0000,,くず肉でも 理解できたんじゃねえですか?
Dialogue: 0,0:09:02.94,0:09:06.45,Default,,0000,0000,0000,,待て
Dialogue: 0,0:09:02.94,0:09:06.45,Default,,0000,0000,0000,,待て 待て 待て 待ってくれ
Dialogue: 0,0:09:06.45,0:09:09.78,Default,,0000,0000,0000,,あれは 全部 ここにいた人たちを お前が
Dialogue: 0,0:09:09.78,0:09:13.95,Default,,0000,0000,0000,,はい 正解! でも 遅すぎたんで 賞品は なし!
Dialogue: 0,0:09:13.95,0:09:17.62,Default,,0000,0000,0000,,理解できねえ
Dialogue: 0,0:09:17.62,0:09:20.79,Default,,0000,0000,0000,,なんで
Dialogue: 0,0:09:17.62,0:09:20.79,Default,,0000,0000,0000,,なんで あんなまねができる?
Dialogue: 0,0:09:20.79,0:09:22.96,Default,,0000,0000,0000,,人を はえに
Dialogue: 0,0:09:22.96,0:09:25.63,Default,,0000,0000,0000,,なんの意味が!
Dialogue: 0,0:09:22.96,0:09:25.63,Default,,0000,0000,0000,,おぞましいって?
Dialogue: 0,0:09:25.63,0:09:28.80,Default,,0000,0000,0000,,身の毛が よだつ!
Dialogue: 0,0:09:25.63,0:09:28.80,Default,,0000,0000,0000,,お前は お前らは
Dialogue: 0,0:09:28.80,0:09:32.97,Default,,0000,0000,0000,,そう おぞましくて 気持ち悪くて 嫌悪する
Dialogue: 0,0:09:32.97,0:09:35.14,Default,,0000,0000,0000,,それなんですよ
Dialogue: 0,0:09:35.14,0:09:37.81,Default,,0000,0000,0000,,あれを見て てめえは 生理的に嫌悪した
Dialogue: 0,0:09:37.81,0:09:39.81,Default,,0000,0000,0000,,それで正解
Dialogue: 0,0:09:39.81,0:09:43.48,Default,,0000,0000,0000,,あんな生き物は 誰も愛せねえんです
Dialogue: 0,0:09:43.48,0:09:47.82,Default,,0000,0000,0000,,いっそ 殺せよ
Dialogue: 0,0:09:43.48,0:09:47.82,Default,,0000,0000,0000,,はっ? なんで?
Dialogue: 0,0:09:47.82,0:09:51.99,Default,,0000,0000,0000,,私は 博愛主義なんで そんな 野蛮なまねはしねえんですよ
Dialogue: 0,0:09:51.99,0:09:56.50,Default,,0000,0000,0000,,1人でも多く 1秒でも長く ひと言でも深く
Dialogue: 0,0:09:56.50,0:10:00.17,Default,,0000,0000,0000,,私を愛してほしい!
Dialogue: 0,0:09:56.50,0:10:00.17,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:10:00.17,0:10:06.17,Default,,0000,0000,0000,,ねっ? それが 私の お・ね・が・い
Dialogue: 0,0:10:06.17,0:10:09.18,Default,,0000,0000,0000,,うっ あっ あ!!
Dialogue: 0,0:10:09.18,0:10:12.35,Default,,0000,0000,0000,,フフフ
Dialogue: 0,0:10:09.18,0:10:12.35,Default,,0000,0000,0000,,うっ クルシュさん!
Dialogue: 0,0:10:12.35,0:10:15.35,Default,,0000,0000,0000,,ほら 結局は そうやって 雌肉が欲しくて
Dialogue: 0,0:10:15.35,0:10:18.18,Default,,0000,0000,0000,,よだれ垂らしてやがるんじゃ ねえですか!
Dialogue: 0,0:10:18.18,0:10:21.85,Default,,0000,0000,0000,,勝手 抜かすな!
Dialogue: 0,0:10:18.18,0:10:21.85,Default,,0000,0000,0000,,俺と この人とは
Dialogue: 0,0:10:21.85,0:10:25.19,Default,,0000,0000,0000,,うるせえんだよ!
Dialogue: 0,0:10:21.85,0:10:25.19,Default,,0000,0000,0000,,やらしいこと 考えたこと
Dialogue: 0,0:10:25.19,0:10:29.36,Default,,0000,0000,0000,,1秒たりともねえって 誓えんですかよ!?
Dialogue: 0,0:10:25.19,0:10:29.36,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:10:29.36,0:10:32.03,Default,,0000,0000,0000,,髪が なでてえんじゃねえですか?
Dialogue: 0,0:10:32.03,0:10:34.70,Default,,0000,0000,0000,,唇に触れてえんじゃねえですか?
Dialogue: 0,0:10:34.70,0:10:37.70,Default,,0000,0000,0000,,大っぴらに吐き出せねえ劣情を
Dialogue: 0,0:10:37.70,0:10:42.88,Default,,0000,0000,0000,,愛なんて言葉で
Dialogue: 0,0:10:37.70,0:10:42.88,Default,,0000,0000,0000,,飾るんじゃねえってんですよ!!
Dialogue: 0,0:10:42.88,0:10:45.21,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:10:45.21,0:10:48.38,Default,,0000,0000,0000,,これを見て また 言っちまいやがるんですか?
Dialogue: 0,0:10:48.38,0:10:50.38,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:10:50.38,0:10:54.72,Default,,0000,0000,0000,,お決まりの お約束の反論を
Dialogue: 0,0:10:54.72,0:10:56.72,Default,,0000,0000,0000,,あっ あっ あっ
Dialogue: 0,0:10:56.72,0:11:02.16,Default,,0000,0000,0000,,僕が 彼女を愛するのは
Dialogue: 0,0:10:56.72,0:11:02.16,Default,,0000,0000,0000,,彼女の心根に引かれたからだ
Dialogue: 0,0:11:02.16,0:11:05.00,Default,,0000,0000,0000,,彼女だけが 僕を認めてくれたから
Dialogue: 0,0:11:05.00,0:11:07.50,Default,,0000,0000,0000,,つらいとき そばにいてくれたから
Dialogue: 0,0:11:07.50,0:11:11.50,Default,,0000,0000,0000,,彼女の前でなら 自分を偽らずにいられるから
Dialogue: 0,0:11:11.50,0:11:16.01,Default,,0000,0000,0000,,あなたといると すべてが色鮮やかに見えるから
Dialogue: 0,0:11:16.01,0:11:18.84,Default,,0000,0000,0000,,もう1人じゃ生きていけないから
Dialogue: 0,0:11:18.84,0:11:25.35,Default,,0000,0000,0000,,うそだらけの生き方の中で
Dialogue: 0,0:11:18.84,0:11:25.35,Default,,0000,0000,0000,,この気持ちだけは 本物だから!
Dialogue: 0,0:11:27.35,0:11:29.36,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:11:29.36,0:11:32.69,Default,,0000,0000,0000,,全部 全部 きれい事じゃねえか!
Dialogue: 0,0:11:32.69,0:11:34.86,Default,,0000,0000,0000,,本気で 愛が 2人を結ぶってんなら
Dialogue: 0,0:11:34.86,0:11:38.86,Default,,0000,0000,0000,,相手が はえになっても愛せるか 試してみろってんですよ!
Dialogue: 0,0:11:38.86,0:11:43.04,Default,,0000,0000,0000,,愛せるか? 愛せねえだろ?
Dialogue: 0,0:11:38.86,0:11:43.04,Default,,0000,0000,0000,,おぞましいもんな!
Dialogue: 0,0:11:43.04,0:11:46.54,Default,,0000,0000,0000,,てめえが はっきり そう言ったんだろうが!
Dialogue: 0,0:11:46.54,0:11:50.04,Default,,0000,0000,0000,,あっ ああ
Dialogue: 0,0:11:50.04,0:11:53.21,Default,,0000,0000,0000,,くず肉が 私様を見てろ!
Dialogue: 0,0:11:50.04,0:11:53.21,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:53.21,0:11:55.55,Default,,0000,0000,0000,,ぐっ うぅ! あっ!
Dialogue: 0,0:11:55.55,0:11:59.05,Default,,0000,0000,0000,,うっ! ハハッ!
Dialogue: 0,0:11:55.55,0:11:59.05,Default,,0000,0000,0000,,あっ! がっ!
Dialogue: 0,0:11:59.05,0:12:05.32,Default,,0000,0000,0000,,ハァ 頭 痛い
Dialogue: 0,0:11:59.05,0:12:05.32,Default,,0000,0000,0000,,興奮して 取り乱しちまいました
Dialogue: 0,0:12:05.32,0:12:07.33,Default,,0000,0000,0000,,恥ずかし キャハッ!
Dialogue: 0,0:12:07.33,0:12:11.16,Default,,0000,0000,0000,,ぐぅ! あ! うぅ!
Dialogue: 0,0:12:11.16,0:12:15.33,Default,,0000,0000,0000,,あらら 死にそうじゃねえですか
Dialogue: 0,0:12:11.16,0:12:15.33,Default,,0000,0000,0000,,こっちもか
Dialogue: 0,0:12:15.33,0:12:19.04,Default,,0000,0000,0000,,ハァハァ ハァハァ うぅ!
Dialogue: 0,0:12:15.33,0:12:19.04,Default,,0000,0000,0000,,あっ そうだ!
Dialogue: 0,0:12:21.34,0:12:24.01,Default,,0000,0000,0000,,がっ 何を
Dialogue: 0,0:12:24.01,0:12:28.18,Default,,0000,0000,0000,,てめえらが どんな見苦しい肉の塊になるか
Dialogue: 0,0:12:28.18,0:12:31.02,Default,,0000,0000,0000,,私が試してやろうじゃねえですか
Dialogue: 0,0:12:28.18,0:12:31.02,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:12:31.02,0:12:35.19,Default,,0000,0000,0000,,アハハハハハ!
Dialogue: 0,0:12:31.02,0:12:35.19,Default,,0000,0000,0000,,苦しい? ねえねえ 苦しい?
Dialogue: 0,0:12:35.19,0:12:39.53,Default,,0000,0000,0000,,私の血には 龍の血が 混ざってやがりますからね
Dialogue: 0,0:12:39.53,0:12:42.53,Default,,0000,0000,0000,,血の呪いに負けたら すげえことになる
Dialogue: 0,0:12:42.53,0:12:48.03,Default,,0000,0000,0000,,雌肉と てめえと
Dialogue: 0,0:12:42.53,0:12:48.03,Default,,0000,0000,0000,,どっちが もちますことやら
Dialogue: 0,0:12:48.03,0:12:52.87,Default,,0000,0000,0000,,うっ! あっ! あ!!
Dialogue: 0,0:12:52.87,0:12:56.71,Default,,0000,0000,0000,,うぅ! うっ うぅ!
Dialogue: 0,0:12:52.87,0:12:56.71,Default,,0000,0000,0000,,ヘヘッ
Dialogue: 0,0:12:56.71,0:12:59.98,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:12:59.98,0:13:04.65,Default,,0000,0000,0000,,あらら やるじゃねえですか
Dialogue: 0,0:13:04.65,0:13:06.65,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:13:06.65,0:13:08.99,Default,,0000,0000,0000,,フッ! んっ! フン!
Dialogue: 0,0:13:08.99,0:13:10.99,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:13:08.99,0:13:10.99,Default,,0000,0000,0000,,うぅ!
Dialogue: 0,0:13:10.99,0:13:15.33,Default,,0000,0000,0000,,フッ! んっ うおっ!
Dialogue: 0,0:13:10.99,0:13:15.33,Default,,0000,0000,0000,,んっ! うっ!
Dialogue: 0,0:13:15.33,0:13:18.00,Default,,0000,0000,0000,,しゃらくさい腕やのう
Dialogue: 0,0:13:18.00,0:13:22.33,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:13:18.00,0:13:22.33,Default,,0000,0000,0000,,死角っから飛んできやがる
Dialogue: 0,0:13:22.33,0:13:25.17,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:13:25.17,0:13:27.17,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:29.68,0:13:31.84,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:13:31.84,0:13:33.85,Default,,0000,0000,0000,,大将!
Dialogue: 0,0:13:36.52,0:13:38.68,Default,,0000,0000,0000,,わかった
Dialogue: 0,0:13:38.68,0:13:41.85,Default,,0000,0000,0000,,アナスタシア様 まずいことが判明しました
Dialogue: 0,0:13:41.85,0:13:43.86,Default,,0000,0000,0000,,何があったん?
Dialogue: 0,0:13:43.86,0:13:47.19,Default,,0000,0000,0000,,十人会と 連絡が取れないようなのです
Dialogue: 0,0:13:47.19,0:13:50.53,Default,,0000,0000,0000,,まず 間違いなく 魔女教の仕業かと
Dialogue: 0,0:13:50.53,0:13:53.70,Default,,0000,0000,0000,,キリタカさん わかっとるやろうけど
Dialogue: 0,0:13:53.70,0:13:57.20,Default,,0000,0000,0000,,私も標的の1人でしょう
Dialogue: 0,0:13:57.20,0:14:01.64,Default,,0000,0000,0000,,アナスタシア様 避難の準備を
Dialogue: 0,0:13:57.20,0:14:01.64,Default,,0000,0000,0000,,キリタカさんは どないするん?
Dialogue: 0,0:14:01.64,0:14:05.31,Default,,0000,0000,0000,,命を粗末にするのは あかんよ
Dialogue: 0,0:14:05.31,0:14:07.31,Default,,0000,0000,0000,,何があっても生きな
Dialogue: 0,0:14:07.31,0:14:10.98,Default,,0000,0000,0000,,フッ 驚きました
Dialogue: 0,0:14:10.98,0:14:15.15,Default,,0000,0000,0000,,アナスタシア様は もっと 割り切った 考え方をされる方かと
Dialogue: 0,0:14:15.15,0:14:20.16,Default,,0000,0000,0000,,うちが 血も涙もない
Dialogue: 0,0:14:15.15,0:14:20.16,Default,,0000,0000,0000,,金の亡者やなくて驚いたん?
Dialogue: 0,0:14:20.16,0:14:23.50,Default,,0000,0000,0000,,「親愛なる お客様の隣人」 って モットーで
Dialogue: 0,0:14:23.50,0:14:26.00,Default,,0000,0000,0000,,うちは商っとるんよ
Dialogue: 0,0:14:23.50,0:14:26.00,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:14:26.00,0:14:28.67,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:14:28.67,0:14:31.84,Default,,0000,0000,0000,,何事だ!? 誰か 報告を!
Dialogue: 0,0:14:28.67,0:14:31.84,Default,,0000,0000,0000,,ごめんね ありがとう!
Dialogue: 0,0:14:31.84,0:14:36.01,Default,,0000,0000,0000,,あ すばらしい! アハハ!
Dialogue: 0,0:14:36.01,0:14:41.51,Default,,0000,0000,0000,,助け合い 委ね合う気持ちが
Dialogue: 0,0:14:36.01,0:14:41.51,Default,,0000,0000,0000,,互いを生かした
Dialogue: 0,0:14:41.51,0:14:45.85,Default,,0000,0000,0000,,拍手!
Dialogue: 0,0:14:41.51,0:14:45.85,Default,,0000,0000,0000,,憤怒の大罪司教
Dialogue: 0,0:14:45.85,0:14:52.02,Default,,0000,0000,0000,,あら 知ってくださっているなんて
Dialogue: 0,0:14:45.85,0:14:52.02,Default,,0000,0000,0000,,なんだか恥ずかしいですね
Dialogue: 0,0:14:52.02,0:14:55.53,Default,,0000,0000,0000,,悪いうわさではないと いいのですが
Dialogue: 0,0:14:55.53,0:15:00.13,Default,,0000,0000,0000,,憤怒担当 シリウス・ロマネコンティと申します
Dialogue: 0,0:15:00.13,0:15:03.14,Default,,0000,0000,0000,,以後 よしなに
Dialogue: 0,0:15:03.14,0:15:06.04,Default,,0000,0000,0000,,立てますか?
Dialogue: 0,0:15:03.14,0:15:06.04,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:15:09.98,0:15:13.31,Default,,0000,0000,0000,,んっ うわっ!
Dialogue: 0,0:15:09.98,0:15:13.31,Default,,0000,0000,0000,,アナスタシア様! あっ
Dialogue: 0,0:15:13.31,0:15:16.48,Default,,0000,0000,0000,,フフッ ウフフフフ
Dialogue: 0,0:15:13.31,0:15:16.48,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:16.48,0:15:19.29,Default,,0000,0000,0000,,うぅ はぁ!
Dialogue: 0,0:15:16.48,0:15:19.29,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:21.49,0:15:23.49,Default,,0000,0000,0000,,ヘータロー! ティビー!
Dialogue: 0,0:15:23.49,0:15:25.99,Default,,0000,0000,0000,,お嬢!
Dialogue: 0,0:15:23.49,0:15:25.99,Default,,0000,0000,0000,,無事ですですか?
Dialogue: 0,0:15:25.99,0:15:28.66,Default,,0000,0000,0000,,平気や! でも ミミは? まさか
Dialogue: 0,0:15:28.66,0:15:30.66,Default,,0000,0000,0000,,違います アナスタシア様!
Dialogue: 0,0:15:28.66,0:15:30.66,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:30.66,0:15:33.00,Default,,0000,0000,0000,,フェリちゃんが禁じ手を使いました!
Dialogue: 0,0:15:33.00,0:15:36.17,Default,,0000,0000,0000,,スバルきゅんの脚と同じ むちゃを!
Dialogue: 0,0:15:33.00,0:15:36.17,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:36.17,0:15:39.17,Default,,0000,0000,0000,,お嬢!
Dialogue: 0,0:15:36.17,0:15:39.17,Default,,0000,0000,0000,,お前を向かなきゃだめです!
Dialogue: 0,0:15:39.17,0:15:43.84,Default,,0000,0000,0000,,お姉ちゃんなら 痛くても 苦しくても お嬢を助けろって 言ったはずだよ!
Dialogue: 0,0:15:43.84,0:15:47.35,Default,,0000,0000,0000,,お嬢は? お嬢は どうするの?
Dialogue: 0,0:15:47.35,0:15:50.68,Default,,0000,0000,0000,,うちは
Dialogue: 0,0:15:50.68,0:15:55.02,Default,,0000,0000,0000,,んっ 時間稼ぎや
Dialogue: 0,0:15:50.68,0:15:55.02,Default,,0000,0000,0000,,2分 いける?
Dialogue: 0,0:15:55.02,0:15:57.86,Default,,0000,0000,0000,,お姉ちゃんなら お任されって言うよね!
Dialogue: 0,0:15:57.86,0:16:00.79,Default,,0000,0000,0000,,ここで やり遂げたら かっこいいですです!
Dialogue: 0,0:16:00.79,0:16:03.80,Default,,0000,0000,0000,,ああ かわいらしい兄弟愛
Dialogue: 0,0:16:03.80,0:16:06.13,Default,,0000,0000,0000,,双子でしょうか!?
Dialogue: 0,0:16:06.13,0:16:09.64,Default,,0000,0000,0000,,あいにくだけど!
Dialogue: 0,0:16:06.13,0:16:09.64,Default,,0000,0000,0000,,3つ子の弟2人です!
Dialogue: 0,0:16:09.64,0:16:11.80,Default,,0000,0000,0000,,フェリスさん ミミたちを連れ出したって!
Dialogue: 0,0:16:11.80,0:16:13.97,Default,,0000,0000,0000,,外で合流や!
Dialogue: 0,0:16:11.80,0:16:13.97,Default,,0000,0000,0000,,わかりました!
Dialogue: 0,0:16:13.97,0:16:15.98,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:16:15.98,0:16:18.64,Default,,0000,0000,0000,,んっ 若旦那!
Dialogue: 0,0:16:15.98,0:16:18.64,Default,,0000,0000,0000,,無事か?
Dialogue: 0,0:16:18.64,0:16:20.65,Default,,0000,0000,0000,,んっ あちらから外に
Dialogue: 0,0:16:20.65,0:16:24.32,Default,,0000,0000,0000,,私は 部下たちと あれの気を引きます
Dialogue: 0,0:16:20.65,0:16:24.32,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:16:24.32,0:16:27.49,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:16:24.32,0:16:27.49,Default,,0000,0000,0000,,ニッ
Dialogue: 0,0:16:24.32,0:16:27.49,Default,,0000,0000,0000,,ヘヘッ
Dialogue: 0,0:16:27.49,0:16:32.29,Default,,0000,0000,0000,,アナスタシア様 この都市を
Dialogue: 0,0:16:27.49,0:16:32.29,Default,,0000,0000,0000,,プリステラを お願いします
Dialogue: 0,0:16:35.66,0:16:40.17,Default,,0000,0000,0000,,この 美しい水の都を 我が いとしの歌姫を
Dialogue: 0,0:16:40.17,0:16:42.84,Default,,0000,0000,0000,,悪辣なる やつばらから お守りください
Dialogue: 0,0:16:42.84,0:16:47.04,Default,,0000,0000,0000,,んっ ずるいわ そんなん
Dialogue: 0,0:16:56.18,0:16:58.18,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:16:58.18,0:17:00.12,Default,,0000,0000,0000,,飲むか?
Dialogue: 0,0:17:00.12,0:17:03.12,Default,,0000,0000,0000,,話しかけんな 酒臭えんだよ
Dialogue: 0,0:17:03.12,0:17:05.12,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:17:07.29,0:17:10.13,Default,,0000,0000,0000,,プハッ! んっ んっ?
Dialogue: 0,0:17:10.13,0:17:12.13,Default,,0000,0000,0000,,あっ んっ?
Dialogue: 0,0:17:15.47,0:17:18.57,Default,,0000,0000,0000,,うえっ ゾッダかよ うっ
Dialogue: 0,0:17:21.47,0:17:23.81,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:17:23.81,0:17:27.81,Default,,0000,0000,0000,,うっ あっ!
Dialogue: 0,0:17:23.81,0:17:27.81,Default,,0000,0000,0000,,うわ! ごめんなさい!
Dialogue: 0,0:17:23.81,0:17:27.81,Default,,0000,0000,0000,,おい!
Dialogue: 0,0:17:27.81,0:17:31.32,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:17:27.81,0:17:31.32,Default,,0000,0000,0000,,ごっ
Dialogue: 0,0:17:31.32,0:17:34.32,Default,,0000,0000,0000,,んっ くっ んっ
Dialogue: 0,0:17:34.32,0:17:39.32,Default,,0000,0000,0000,,で? どうするんだ?
Dialogue: 0,0:17:34.32,0:17:39.32,Default,,0000,0000,0000,,実の父親を斬るってのか?
Dialogue: 0,0:17:39.32,0:17:41.49,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:17:39.32,0:17:41.49,Default,,0000,0000,0000,,おい
Dialogue: 0,0:17:39.32,0:17:41.49,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:17:41.49,0:17:44.30,Default,,0000,0000,0000,,ぶあっ!
Dialogue: 0,0:17:41.49,0:17:44.30,Default,,0000,0000,0000,,ハッ フェルト様
Dialogue: 0,0:17:46.33,0:17:49.67,Default,,0000,0000,0000,,いいから 縛れよ
Dialogue: 0,0:17:49.67,0:17:54.84,Default,,0000,0000,0000,,チッ! あ ずっと
Dialogue: 0,0:17:49.67,0:17:54.84,Default,,0000,0000,0000,,同じ体勢でいたから けつが痛え
Dialogue: 0,0:17:54.84,0:17:58.68,Default,,0000,0000,0000,,状況は よくわからなかったんですが
Dialogue: 0,0:17:58.68,0:18:00.95,Default,,0000,0000,0000,,これで よかったんですか?
Dialogue: 0,0:18:00.95,0:18:04.78,Default,,0000,0000,0000,,君は スバルの
Dialogue: 0,0:18:00.95,0:18:04.78,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:18:04.78,0:18:08.29,Default,,0000,0000,0000,,そうか
Dialogue: 0,0:18:04.78,0:18:08.29,Default,,0000,0000,0000,,さっきのゾッダ虫は 君の仕業か
Dialogue: 0,0:18:08.29,0:18:10.29,Default,,0000,0000,0000,,ありがとう 助かったよ
Dialogue: 0,0:18:10.29,0:18:12.29,Default,,0000,0000,0000,,助かってねえよ!
Dialogue: 0,0:18:10.29,0:18:12.29,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:18:12.29,0:18:16.63,Default,,0000,0000,0000,,剣を突きつけられてるより100倍は 死ぬかと思ったっつうの
Dialogue: 0,0:18:16.63,0:18:18.63,Default,,0000,0000,0000,,慰謝料 よこせよ
Dialogue: 0,0:18:18.63,0:18:22.13,Default,,0000,0000,0000,,たぶん 僕は 命の恩人なんじゃないですかね
Dialogue: 0,0:18:22.13,0:18:25.47,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:18:22.13,0:18:25.47,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:18:22.13,0:18:25.47,Default,,0000,0000,0000,,なぜ ここに?
Dialogue: 0,0:18:25.47,0:18:28.14,Default,,0000,0000,0000,,君は スバルと一緒にいると 思っていたが
Dialogue: 0,0:18:28.14,0:18:30.31,Default,,0000,0000,0000,,それが たまたまなんですよ
Dialogue: 0,0:18:30.31,0:18:34.31,Default,,0000,0000,0000,,とにかく 身を隠せる場所をと思って
Dialogue: 0,0:18:34.31,0:18:38.32,Default,,0000,0000,0000,,暴食の大罪司教と?
Dialogue: 0,0:18:34.31,0:18:38.32,Default,,0000,0000,0000,,よく無事で
Dialogue: 0,0:18:38.32,0:18:40.99,Default,,0000,0000,0000,,白竜の鱗の皆さんのおかげです
Dialogue: 0,0:18:40.99,0:18:44.66,Default,,0000,0000,0000,,あの方たちがいなければ 今頃
Dialogue: 0,0:18:44.66,0:18:48.33,Default,,0000,0000,0000,,スバルたちの安否は?
Dialogue: 0,0:18:44.66,0:18:48.33,Default,,0000,0000,0000,,存じ上げません
Dialogue: 0,0:18:48.33,0:18:52.33,Default,,0000,0000,0000,,あの人のことですから しぶとく 立ち回っていると思いますが
Dialogue: 0,0:18:52.33,0:18:54.33,Default,,0000,0000,0000,,おい ポンコツ
Dialogue: 0,0:18:52.33,0:18:54.33,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:18:54.33,0:18:57.17,Default,,0000,0000,0000,,これで心配はなくなっただろ
Dialogue: 0,0:18:57.17,0:19:00.94,Default,,0000,0000,0000,,お前は とっとと 助けに行け!
Dialogue: 0,0:18:57.17,0:19:00.94,Default,,0000,0000,0000,,いえ 僕は おそばに
Dialogue: 0,0:19:00.94,0:19:05.28,Default,,0000,0000,0000,,さっきの体たらくで 私を助けるってのか?
Dialogue: 0,0:19:00.94,0:19:05.28,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:05.28,0:19:09.11,Default,,0000,0000,0000,,私は こいつを連れて 近くの避難所へ向かう
Dialogue: 0,0:19:09.11,0:19:14.12,Default,,0000,0000,0000,,いいから お前は 全部 まとめて
Dialogue: 0,0:19:09.11,0:19:14.12,Default,,0000,0000,0000,,まるっと解決してこい!
Dialogue: 0,0:19:14.12,0:19:17.62,Default,,0000,0000,0000,,ラインハルト!
Dialogue: 0,0:19:14.12,0:19:17.62,Default,,0000,0000,0000,,御意に
Dialogue: 0,0:19:17.62,0:19:19.96,Default,,0000,0000,0000,,どうか むちゃはされませんよう
Dialogue: 0,0:19:19.96,0:19:24.30,Default,,0000,0000,0000,,お前は むちゃしてこい
Dialogue: 0,0:19:19.96,0:19:24.30,Default,,0000,0000,0000,,目に物 見せてやれ
Dialogue: 0,0:19:24.30,0:19:26.30,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:19:29.64,0:19:32.64,Default,,0000,0000,0000,,さてと どうしたもんかな?
Dialogue: 0,0:19:32.64,0:19:34.64,Default,,0000,0000,0000,,背負うのは さすがに しんどいか?
Dialogue: 0,0:19:34.64,0:19:37.64,Default,,0000,0000,0000,,なんで おいらが こんな 使いっ走りみたいなこと
Dialogue: 0,0:19:37.64,0:19:40.15,Default,,0000,0000,0000,,しょうがねえだろ
Dialogue: 0,0:19:37.64,0:19:42.31,Default,,0000,0000,0000,,避難所の食い物が 底を尽きそうなんだからよ
Dialogue: 0,0:19:40.15,0:19:42.31,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:42.31,0:19:44.82,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:19:44.82,0:19:49.82,Default,,0000,0000,0000,,初めてじゃねえか? お前らが ちょうどいいときに来るなんて
Dialogue: 0,0:19:47.32,0:19:49.82,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:19:49.82,0:19:52.66,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:19:49.82,0:19:52.66,Default,,0000,0000,0000,,おっ
Dialogue: 0,0:19:52.66,0:19:55.83,Default,,0000,0000,0000,,なんや? あいつら いつの間に
Dialogue: 0,0:19:55.83,0:19:57.83,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:19:57.83,0:20:00.00,Default,,0000,0000,0000,,おいおい おいおい 冗談やないぞ
Dialogue: 0,0:19:57.83,0:20:00.00,Default,,0000,0000,0000,,上へ!
Dialogue: 0,0:20:00.00,0:20:02.00,Default,,0000,0000,0000,,あっ うっ!
Dialogue: 0,0:20:14.68,0:20:16.68,Default,,0000,0000,0000,,ガーフィール殿!
Dialogue: 0,0:20:16.68,0:20:21.39,Default,,0000,0000,0000,,プハッ! くそが!
Dialogue: 0,0:20:16.68,0:20:21.39,Default,,0000,0000,0000,,何が どうなって
Dialogue: 0,0:20:28.03,0:20:31.53,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:20:31.53,0:20:33.53,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:20:36.87,0:20:38.87,Default,,0000,0000,0000,,大将?
Dialogue: 0,0:20:41.21,0:20:44.71,Default,,0000,0000,0000,,うっ! あっ 待って
Dialogue: 0,0:20:44.71,0:20:46.71,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:21:01.16,0:21:03.66,Default,,0000,0000,0000,,大将!
Dialogue: 0,0:22:42.03,0:22:45.20,Default,,0000,0000,0000,,そんな 街が
Dialogue: 0,0:22:45.20,0:22:47.37,Default,,0000,0000,0000,,その顔は いけません
Dialogue: 0,0:22:47.37,0:22:50.37,Default,,0000,0000,0000,,旦那様が嫌がります
Dialogue: 0,0:22:47.37,0:22:50.37,Default,,0000,0000,0000,,何 言ってるの?
Dialogue: 0,0:22:50.37,0:22:52.37,Default,,0000,0000,0000,,そんな場合じゃ
Dialogue: 0,0:22:50.37,0:22:52.37,Default,,0000,0000,0000,,あ! あ!
Dialogue: 0,0:22:52.37,0:22:54.54,Default,,0000,0000,0000,,くず肉の皆さん!
Dialogue: 0,0:22:52.37,0:22:54.54,Default,,0000,0000,0000,,ハッ なっ なんなの?
Dialogue: 0,0:22:54.54,0:22:58.21,Default,,0000,0000,0000,,今日も元気に 震えて 縮こまってやがりますか?
Dialogue: 0,0:22:58.21,0:23:01.15,Default,,0000,0000,0000,,色欲の大罪司教 カペラちゃん様の
Dialogue: 0,0:23:01.15,0:23:04.82,Default,,0000,0000,0000,,美声放送でやがります!
Dialogue: 0,0:23:01.15,0:23:04.82,Default,,0000,0000,0000,,キャハハハハ!
Dialogue: 0,0:23:04.82,0:23:07.32,Default,,0000,0000,0000,,さてさて あれだけ言ってやったのに
Dialogue: 0,0:23:07.32,0:23:12.16,Default,,0000,0000,0000,,まんまと 私様に カチコミかけてきた くず肉が大量発生!
Dialogue: 0,0:23:12.16,0:23:14.16,Default,,0000,0000,0000,,私様は傷つきました
Dialogue: 0,0:23:14.16,0:23:16.66,Default,,0000,0000,0000,,なので 魔女の遺骨に加えて
Dialogue: 0,0:23:16.66,0:23:20.83,Default,,0000,0000,0000,,もう あと3つ 要求することにしやがります!
Dialogue: 0,0:23:20.83,0:23:24.17,Default,,0000,0000,0000,,1つは この都市に 持ち込まれてやがるはずの
Dialogue: 0,0:23:24.17,0:23:26.34,Default,,0000,0000,0000,,叡智の書の献上
Dialogue: 0,0:23:26.34,0:23:29.67,Default,,0000,0000,0000,,1つは この都市で のうのうとしてやがるはずの
Dialogue: 0,0:23:29.67,0:23:32.18,Default,,0000,0000,0000,,人工精霊の献上
Dialogue: 0,0:23:32.18,0:23:35.51,Default,,0000,0000,0000,,そして 最後に この都市で行われる
Dialogue: 0,0:23:35.51,0:23:38.68,Default,,0000,0000,0000,,銀髪の乙女との結婚式
Dialogue: 0,0:23:38.68,0:23:42.02,Default,,0000,0000,0000,,まあ 邪魔すんなっつう話でしょうね
Dialogue: 0,0:23:42.02,0:23:44.69,Default,,0000,0000,0000,,知らねえよって話ですけど!
Dialogue: 0,0:23:44.69,0:23:49.39,Default,,0000,0000,0000,,キャハハハハハハハ! キャーハッハッハッハッハッハッ!
