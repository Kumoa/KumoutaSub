Dialogue: 0,0:00:03.17,0:00:06.01,Default,,0000,0000,0000,,エル・ミーニャ!
Dialogue: 0,0:00:06.01,0:00:09.18,Default,,0000,0000,0000,,あら?
Dialogue: 0,0:00:06.01,0:00:09.18,Default,,0000,0000,0000,,ベアトリス様ったら 容赦のない
Dialogue: 0,0:00:09.18,0:00:12.18,Default,,0000,0000,0000,,お前にくれてやる 容赦と遠慮だけは
Dialogue: 0,0:00:12.18,0:00:17.02,Default,,0000,0000,0000,,この世のどこにも 在庫がないのよ!
Dialogue: 0,0:00:17.02,0:00:19.52,Default,,0000,0000,0000,,へぇ
Dialogue: 0,0:00:19.52,0:00:23.19,Default,,0000,0000,0000,,この威力なら いくらなんでも
Dialogue: 0,0:00:23.19,0:00:25.36,Default,,0000,0000,0000,,いや 来るぞ!
Dialogue: 0,0:00:25.36,0:00:28.36,Default,,0000,0000,0000,,ウヒャヒャ! うわ!
Dialogue: 0,0:00:28.36,0:00:31.53,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:00:28.36,0:00:31.53,Default,,0000,0000,0000,,ムラク
Dialogue: 0,0:00:28.36,0:00:31.53,Default,,0000,0000,0000,,あっ おっ
Dialogue: 0,0:00:31.53,0:00:33.53,Default,,0000,0000,0000,,うおっ!
Dialogue: 0,0:00:31.53,0:00:33.53,Default,,0000,0000,0000,,フフッ!
Dialogue: 0,0:00:33.53,0:00:35.70,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:33.53,0:00:35.70,Default,,0000,0000,0000,,ハッハー!
Dialogue: 0,0:00:35.70,0:00:39.21,Default,,0000,0000,0000,,ベアトリス様ってば さっすが!
Dialogue: 0,0:00:39.21,0:00:42.21,Default,,0000,0000,0000,,いいね いいよ いいさ!
Dialogue: 0,0:00:42.21,0:00:44.88,Default,,0000,0000,0000,,いいかも いいとも!
Dialogue: 0,0:00:42.21,0:00:44.88,Default,,0000,0000,0000,,やかましいやつかしら
Dialogue: 0,0:00:44.88,0:00:48.55,Default,,0000,0000,0000,,いつまで調子に乗ってられるか 見ものなのよ
Dialogue: 0,0:00:48.55,0:00:51.55,Default,,0000,0000,0000,,あと5発かしら
Dialogue: 0,0:00:48.55,0:00:51.55,Default,,0000,0000,0000,,へっ?
Dialogue: 0,0:00:51.55,0:00:55.05,Default,,0000,0000,0000,,魔晶石! それって まさか
Dialogue: 0,0:00:55.05,0:00:58.39,Default,,0000,0000,0000,,にーちゃの復活に必要な 魔晶石なのよ
Dialogue: 0,0:00:58.39,0:01:01.69,Default,,0000,0000,0000,,これ1個で 大魔法1回の計算かしら
Dialogue: 0,0:01:01.69,0:01:04.36,Default,,0000,0000,0000,,最後に 1つは 残しておかなくちゃだから
Dialogue: 0,0:01:04.36,0:01:08.00,Default,,0000,0000,0000,,使える大技は あと5発なのよ
Dialogue: 0,0:01:04.36,0:01:08.00,Default,,0000,0000,0000,,むちゃぶりだな!
Dialogue: 0,0:01:08.00,0:01:11.00,Default,,0000,0000,0000,,やっぱり ナツキさんの契約精霊ですよね!
Dialogue: 0,0:01:11.00,0:01:15.01,Default,,0000,0000,0000,,おっ うわ!
Dialogue: 0,0:01:11.00,0:01:15.01,Default,,0000,0000,0000,,それは ベティーにとっての
Dialogue: 0,0:01:15.01,0:01:17.01,Default,,0000,0000,0000,,褒め言葉かしら!
Dialogue: 0,0:01:19.51,0:01:23.68,Default,,0000,0000,0000,,アル・ミーニャ!
Dialogue: 0,0:01:19.51,0:01:23.68,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:01:23.68,0:01:27.52,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:01:23.68,0:01:27.52,Default,,0000,0000,0000,,うそなのよ! ベー!
Dialogue: 0,0:01:27.52,0:01:30.02,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:01:27.52,0:01:30.02,Default,,0000,0000,0000,,うお!
Dialogue: 0,0:01:33.53,0:01:36.36,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:01:33.53,0:01:36.36,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:01:36.36,0:01:40.20,Default,,0000,0000,0000,,うぅ がはっ!
Dialogue: 0,0:01:40.20,0:01:42.37,Default,,0000,0000,0000,,偉いね ガストン
Dialogue: 0,0:01:42.37,0:01:46.04,Default,,0000,0000,0000,,凡人が努力したんだね 血へどを吐いて
Dialogue: 0,0:01:46.04,0:01:50.71,Default,,0000,0000,0000,,でも残念! 一生懸命 頑張ったけど だめでした!
Dialogue: 0,0:01:50.71,0:01:54.71,Default,,0000,0000,0000,,うぐっ!
Dialogue: 0,0:01:50.71,0:01:54.71,Default,,0000,0000,0000,,こんの野郎!
Dialogue: 0,0:01:54.71,0:01:58.05,Default,,0000,0000,0000,,ベネット・モッサ アウグスト・バレン
Dialogue: 0,0:01:54.71,0:01:58.05,Default,,0000,0000,0000,,うっ! がっ!
Dialogue: 0,0:01:58.05,0:02:01.35,Default,,0000,0000,0000,,カルシフス・フィンレル
Dialogue: 0,0:02:01.35,0:02:03.32,Default,,0000,0000,0000,,くそ!
Dialogue: 0,0:02:12.67,0:02:14.83,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:02:12.67,0:02:14.83,Default,,0000,0000,0000,,ベアトリスちゃん!
Dialogue: 0,0:02:14.83,0:02:17.17,Default,,0000,0000,0000,,倒れた人たちは 僕たちの仲間ですが
Dialogue: 0,0:02:17.17,0:02:20.01,Default,,0000,0000,0000,,名前は わかりません!
Dialogue: 0,0:02:17.17,0:02:20.01,Default,,0000,0000,0000,,今は それだけでいい!
Dialogue: 0,0:02:20.01,0:02:23.38,Default,,0000,0000,0000,,この
Dialogue: 0,0:02:23.38,0:02:26.05,Default,,0000,0000,0000,,チッ!
Dialogue: 0,0:02:23.38,0:02:26.05,Default,,0000,0000,0000,,ウル・ミーニャ!
Dialogue: 0,0:02:29.05,0:02:33.05,Default,,0000,0000,0000,,大盤振る舞い! さすが ベアトリス様!
Dialogue: 0,0:02:33.05,0:02:35.52,Default,,0000,0000,0000,,ロズワール様のまねですか?
Dialogue: 0,0:02:35.52,0:02:39.53,Default,,0000,0000,0000,,言うに事欠いて なんたる暴言かしら!
Dialogue: 0,0:02:42.73,0:02:46.07,Default,,0000,0000,0000,,やりましたか!?
Dialogue: 0,0:02:42.73,0:02:46.07,Default,,0000,0000,0000,,ブハッ!
Dialogue: 0,0:02:46.07,0:02:48.07,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:02:46.07,0:02:48.07,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:02:48.07,0:02:51.74,Default,,0000,0000,0000,,うあっ!
Dialogue: 0,0:02:48.07,0:02:51.74,Default,,0000,0000,0000,,シャマク!
Dialogue: 0,0:02:51.74,0:02:55.24,Default,,0000,0000,0000,,うがっ!
Dialogue: 0,0:02:55.24,0:02:58.21,Default,,0000,0000,0000,,やってくれるな ベアトリス様
Dialogue: 0,0:02:58.21,0:03:01.31,Default,,0000,0000,0000,,これが 数の力なのよ!
Dialogue: 0,0:02:58.21,0:03:01.31,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:03:01.31,0:03:04.18,Default,,0000,0000,0000,,待たせたな ばか野郎ども!
Dialogue: 0,0:03:04.18,0:03:10.69,Default,,0000,0000,0000,,そら ラインハルトも泣きべそかく 一発
Dialogue: 0,0:03:04.18,0:03:10.69,Default,,0000,0000,0000,,味わってみろや!
Dialogue: 0,0:03:10.69,0:03:12.66,Default,,0000,0000,0000,,どうだ?
Dialogue: 0,0:03:14.69,0:03:18.00,Default,,0000,0000,0000,,これが 剣聖を泣かす 一撃?
Dialogue: 0,0:03:18.00,0:03:20.20,Default,,0000,0000,0000,,冗談でしょ?
Dialogue: 0,0:03:20.20,0:03:22.20,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:03:20.20,0:03:22.20,Default,,0000,0000,0000,,フェルト様!
Dialogue: 0,0:03:22.20,0:03:25.37,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:03:22.20,0:03:25.37,Default,,0000,0000,0000,,フェルトちゃん
Dialogue: 0,0:03:25.37,0:03:28.54,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:03:25.37,0:03:28.54,Default,,0000,0000,0000,,いただきます
Dialogue: 0,0:03:30.51,0:03:32.51,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:03:38.69,0:03:42.22,Default,,0000,0000,0000,,うあっ うっ! ああ あっ
Dialogue: 0,0:03:42.22,0:03:45.19,Default,,0000,0000,0000,,あっ んっ?
Dialogue: 0,0:03:42.22,0:03:45.19,Default,,0000,0000,0000,,おっ ああ あっ うぅ
Dialogue: 0,0:03:45.19,0:03:47.19,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:03:47.19,0:03:51.20,Default,,0000,0000,0000,,んっ うぅ おっ
Dialogue: 0,0:03:47.19,0:03:51.20,Default,,0000,0000,0000,,ぐっ! うあっ
Dialogue: 0,0:03:51.20,0:03:53.23,Default,,0000,0000,0000,,構えるかしら!
Dialogue: 0,0:03:51.20,0:03:53.23,Default,,0000,0000,0000,,おっ!
Dialogue: 0,0:03:53.23,0:03:55.70,Default,,0000,0000,0000,,使い方が間違っているのよ
Dialogue: 0,0:03:55.70,0:03:57.70,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:04:08.82,0:04:11.99,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:04:08.82,0:04:11.99,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:04:11.99,0:04:15.32,Default,,0000,0000,0000,,なっ! うっ! あっ
Dialogue: 0,0:04:15.32,0:04:17.49,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:04:15.32,0:04:17.49,Default,,0000,0000,0000,,ヘヘッ
Dialogue: 0,0:04:17.49,0:04:20.49,Default,,0000,0000,0000,,あっ くっ!
Dialogue: 0,0:04:20.49,0:04:22.50,Default,,0000,0000,0000,,ぶっ散れ!
Dialogue: 0,0:04:33.51,0:04:37.68,Default,,0000,0000,0000,,うっ なんつう威力だ
Dialogue: 0,0:04:37.68,0:04:41.18,Default,,0000,0000,0000,,お母様
Dialogue: 0,0:04:41.18,0:04:44.02,Default,,0000,0000,0000,,ベアトリスちゃん フェルト様!
Dialogue: 0,0:04:41.18,0:04:44.02,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:04:41.18,0:04:44.02,Default,,0000,0000,0000,,ご無事ですか?
Dialogue: 0,0:04:44.02,0:04:48.02,Default,,0000,0000,0000,,ああ このチビっ子が 使い方 知ってたおかげで 助かったぜ!
Dialogue: 0,0:04:48.02,0:04:50.02,Default,,0000,0000,0000,,誰が チビっ子かしら
Dialogue: 0,0:04:50.02,0:04:53.63,Default,,0000,0000,0000,,たまたま 懐かしい物と出くわしたのよ
Dialogue: 0,0:04:58.03,0:05:01.17,Default,,0000,0000,0000,,ハァ くっ
Dialogue: 0,0:05:01.17,0:05:03.34,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:05:06.97,0:05:09.28,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:06.97,0:05:09.28,Default,,0000,0000,0000,,危ない!
Dialogue: 0,0:05:12.98,0:05:16.48,Default,,0000,0000,0000,,フゥ
Dialogue: 0,0:05:12.98,0:05:16.48,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:05:12.98,0:05:16.48,Default,,0000,0000,0000,,いっ! うっ
Dialogue: 0,0:05:16.48,0:05:21.19,Default,,0000,0000,0000,,ハッ! あっ ああ
Dialogue: 0,0:05:21.19,0:05:23.52,Default,,0000,0000,0000,,うぅ うわ!!
Dialogue: 0,0:05:23.52,0:05:27.36,Default,,0000,0000,0000,,ほんと 出来の悪い兄を持つと
Dialogue: 0,0:05:27.36,0:05:30.70,Default,,0000,0000,0000,,妹ってのは 苦労させられるんだからさ
Dialogue: 0,0:05:30.70,0:05:33.03,Default,,0000,0000,0000,,誰だ? てめえは!
Dialogue: 0,0:05:33.03,0:05:36.67,Default,,0000,0000,0000,,あれれ? あなたのほうが それ 言っちゃうわけ?
Dialogue: 0,0:05:36.67,0:05:41.37,Default,,0000,0000,0000,,私たち相手に偽名を使うなんて 小ざかしいことしておきながら?
Dialogue: 0,0:05:41.37,0:05:44.38,Default,,0000,0000,0000,,偽名? 何 言ってやがる
Dialogue: 0,0:05:41.37,0:05:44.38,Default,,0000,0000,0000,,ぐっ! うっ
Dialogue: 0,0:05:44.38,0:05:48.18,Default,,0000,0000,0000,,暴食の 大罪司教?
Dialogue: 0,0:05:48.18,0:05:51.18,Default,,0000,0000,0000,,へぇ まだ口が利けるんだ!
Dialogue: 0,0:05:51.18,0:05:55.19,Default,,0000,0000,0000,,すごいね お兄さん!
Dialogue: 0,0:05:51.18,0:05:55.19,Default,,0000,0000,0000,,頑張るね お兄さん!
Dialogue: 0,0:05:55.19,0:05:57.69,Default,,0000,0000,0000,,いい!
Dialogue: 0,0:05:57.69,0:06:00.46,Default,,0000,0000,0000,,いいね いいわね いいよね!
Dialogue: 0,0:06:00.46,0:06:03.30,Default,,0000,0000,0000,,いいじゃない いいだろうからこそ!
Dialogue: 0,0:06:03.30,0:06:08.63,Default,,0000,0000,0000,,あたしたちも 私たちも
Dialogue: 0,0:06:03.30,0:06:08.63,Default,,0000,0000,0000,,食卓を囲む価値を あなたに見る
Dialogue: 0,0:06:08.63,0:06:10.64,Default,,0000,0000,0000,,アハッ!
Dialogue: 0,0:06:13.14,0:06:15.14,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:15.14,0:06:20.98,Default,,0000,0000,0000,,魔女教大罪司教 暴食担当
Dialogue: 0,0:06:15.14,0:06:20.98,Default,,0000,0000,0000,,ルイ・アルネブ
Dialogue: 0,0:06:20.98,0:06:24.82,Default,,0000,0000,0000,,黙って聞いてりゃ なんの 悪ふざけしてやがんだ てめえは
Dialogue: 0,0:06:24.82,0:06:27.65,Default,,0000,0000,0000,,あれ? 偽名のお姫様は
Dialogue: 0,0:06:27.65,0:06:30.66,Default,,0000,0000,0000,,こういう趣向は お気に召さなかったかな?
Dialogue: 0,0:06:30.66,0:06:32.99,Default,,0000,0000,0000,,何が偽名だ ふざけんな!
Dialogue: 0,0:06:32.99,0:06:37.33,Default,,0000,0000,0000,,私は もう 15年 ロム爺にもらった フェルトって名前で生きてんだ!
Dialogue: 0,0:06:37.33,0:06:42.17,Default,,0000,0000,0000,,あ そっか
Dialogue: 0,0:06:37.33,0:06:42.17,Default,,0000,0000,0000,,当人に 偽名の自覚がないんだ
Dialogue: 0,0:06:42.17,0:06:45.51,Default,,0000,0000,0000,,じゃあ あなたの名前は フェルトじゃないんだよ
Dialogue: 0,0:06:45.51,0:06:50.01,Default,,0000,0000,0000,,育ての親がくれる前の ほんとのお名前があるってこと
Dialogue: 0,0:06:50.01,0:06:53.68,Default,,0000,0000,0000,,私を路地裏に捨てた くそ親が付けた名前か?
Dialogue: 0,0:06:53.68,0:06:57.35,Default,,0000,0000,0000,,なら きっと 厄介者か ゴミってところだろうぜ
Dialogue: 0,0:06:57.35,0:07:00.62,Default,,0000,0000,0000,,そんなに身構えなくても いいってば
Dialogue: 0,0:07:00.62,0:07:03.62,Default,,0000,0000,0000,,私たち 今日は ここで引っ込むからさ
Dialogue: 0,0:07:03.62,0:07:05.79,Default,,0000,0000,0000,,本気で言っているのかしら?
Dialogue: 0,0:07:05.79,0:07:10.63,Default,,0000,0000,0000,,お兄ちゃんは ぼろ負けだし 兄様だって あの女の言いなりだもん
Dialogue: 0,0:07:10.63,0:07:15.47,Default,,0000,0000,0000,,私たちは 美食だの 悪食だの どうでもいいからさ
Dialogue: 0,0:07:15.47,0:07:17.80,Default,,0000,0000,0000,,ほんと わかってないよね
Dialogue: 0,0:07:17.80,0:07:22.98,Default,,0000,0000,0000,,食事は 何を食べるかじゃなくて
Dialogue: 0,0:07:17.80,0:07:22.98,Default,,0000,0000,0000,,誰と食べるかなのにさ
Dialogue: 0,0:07:22.98,0:07:24.98,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:07:22.98,0:07:24.98,Default,,0000,0000,0000,,てめえ
Dialogue: 0,0:07:24.98,0:07:28.48,Default,,0000,0000,0000,,ダイナス・トラサルディ ガストン
Dialogue: 0,0:07:28.48,0:07:30.52,Default,,0000,0000,0000,,うぅ ああ
Dialogue: 0,0:07:28.48,0:07:30.52,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:07:30.52,0:07:33.52,Default,,0000,0000,0000,,どうする? まだ戦う?
Dialogue: 0,0:07:33.52,0:07:36.82,Default,,0000,0000,0000,,それとも このまま見逃す?
Dialogue: 0,0:07:36.82,0:07:38.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:07:40.99,0:07:46.83,Default,,0000,0000,0000,,賢いって 悲しいね
Dialogue: 0,0:07:40.99,0:07:46.83,Default,,0000,0000,0000,,でも よくできました!
Dialogue: 0,0:07:46.83,0:07:49.17,Default,,0000,0000,0000,,くそっ!
Dialogue: 0,0:07:46.83,0:07:51.67,Default,,0000,0000,0000,,とにかく 今は オットーたちの治療が優先なのよ
Dialogue: 0,0:07:51.67,0:07:55.84,Default,,0000,0000,0000,,決着は それから
Dialogue: 0,0:07:51.67,0:07:55.84,Default,,0000,0000,0000,,プリステラ市民の皆さん!
Dialogue: 0,0:07:55.84,0:08:00.11,Default,,0000,0000,0000,,四方の制御塔を奪還し 都市を脅かしていた 卑劣な魔女教は
Dialogue: 0,0:08:00.11,0:08:02.11,Default,,0000,0000,0000,,すべて 撃退されました!
Dialogue: 0,0:08:02.11,0:08:04.78,Default,,0000,0000,0000,,これにより 都市の安全は確保!
Dialogue: 0,0:08:04.78,0:08:08.29,Default,,0000,0000,0000,,水門都市 プリステラの勝利です!
Dialogue: 0,0:08:08.29,0:08:12.46,Default,,0000,0000,0000,,これで しまい?
Dialogue: 0,0:08:08.29,0:08:12.46,Default,,0000,0000,0000,,喜べねえよ ちくしょう!
Dialogue: 0,0:08:12.46,0:08:14.76,Default,,0000,0000,0000,,スバル
Dialogue: 0,0:08:18.16,0:08:20.17,Default,,0000,0000,0000,,スバル これって
Dialogue: 0,0:08:20.17,0:08:23.30,Default,,0000,0000,0000,,俺が出たときは こんなんじゃなかったのに
Dialogue: 0,0:08:23.30,0:08:25.47,Default,,0000,0000,0000,,一体 どうなって
Dialogue: 0,0:08:25.47,0:08:27.64,Default,,0000,0000,0000,,やっと戻ってきたかしら
Dialogue: 0,0:08:25.47,0:08:27.64,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:27.64,0:08:29.98,Default,,0000,0000,0000,,2人とも 待ちくたびれたのよ
Dialogue: 0,0:08:27.64,0:08:29.98,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:29.98,0:08:32.14,Default,,0000,0000,0000,,んっ ベア子!
Dialogue: 0,0:08:29.98,0:08:32.14,Default,,0000,0000,0000,,ベアトリス!
Dialogue: 0,0:08:32.14,0:08:35.15,Default,,0000,0000,0000,,お前 起きてて大丈夫なのか?
Dialogue: 0,0:08:35.15,0:08:38.65,Default,,0000,0000,0000,,マナの使い過ぎで 肝心なときに お眠だったのに
Dialogue: 0,0:08:38.65,0:08:42.49,Default,,0000,0000,0000,,そのベティーに 非があるように 聞こえる言い方は やめるかしら
Dialogue: 0,0:08:42.49,0:08:46.16,Default,,0000,0000,0000,,スバルの脚があるのは ベティーの献身のおかげなのよ
Dialogue: 0,0:08:46.16,0:08:49.50,Default,,0000,0000,0000,,感謝と だっこが足りないかしら!
Dialogue: 0,0:08:49.50,0:08:53.00,Default,,0000,0000,0000,,わあってる わかってるって
Dialogue: 0,0:08:49.50,0:08:53.00,Default,,0000,0000,0000,,ん
Dialogue: 0,0:08:53.00,0:08:56.34,Default,,0000,0000,0000,,また俺の留守中に 頑張ってくれてたのか
Dialogue: 0,0:08:56.34,0:08:59.34,Default,,0000,0000,0000,,いつも悪いな 迷惑ばっかりかけて
Dialogue: 0,0:08:59.34,0:09:02.61,Default,,0000,0000,0000,,スバルが ベティーに迷惑をかけるのは 当たり前だから
Dialogue: 0,0:09:02.61,0:09:04.78,Default,,0000,0000,0000,,気にする必要ないのよ
Dialogue: 0,0:09:04.78,0:09:07.45,Default,,0000,0000,0000,,エミリアも 無事で安心したかしら
Dialogue: 0,0:09:07.45,0:09:10.45,Default,,0000,0000,0000,,お前に 何かあったら にーちゃが悲しむのよ
Dialogue: 0,0:09:10.45,0:09:14.95,Default,,0000,0000,0000,,うん そうよね ベアトリスも 心配してくれて ありがとう
Dialogue: 0,0:09:14.95,0:09:18.96,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:09:14.95,0:09:18.96,Default,,0000,0000,0000,,で 他のみんなは?
Dialogue: 0,0:09:18.96,0:09:22.13,Default,,0000,0000,0000,,ずいぶんと 派手に やっちまったみてえだけど
Dialogue: 0,0:09:22.13,0:09:24.13,Default,,0000,0000,0000,,心配せんでええよ
Dialogue: 0,0:09:24.13,0:09:27.97,Default,,0000,0000,0000,,話せば長くなるけど これも作戦のうちやから
Dialogue: 0,0:09:27.97,0:09:29.97,Default,,0000,0000,0000,,アナスタシアさん
Dialogue: 0,0:09:29.97,0:09:32.97,Default,,0000,0000,0000,,とにもかくにも 2人とも無事でよかったわ
Dialogue: 0,0:09:32.97,0:09:36.14,Default,,0000,0000,0000,,ナツキ君も ちゃんと 男の子やね
Dialogue: 0,0:09:36.14,0:09:40.81,Default,,0000,0000,0000,,うん スバルは 男の子よ
Dialogue: 0,0:09:36.14,0:09:40.81,Default,,0000,0000,0000,,その評価も気になるけど
Dialogue: 0,0:09:40.81,0:09:43.48,Default,,0000,0000,0000,,他のみんなは無事なのか?
Dialogue: 0,0:09:43.48,0:09:47.32,Default,,0000,0000,0000,,全員 ちゃんと戻っとるよ
Dialogue: 0,0:09:43.48,0:09:47.32,Default,,0000,0000,0000,,欠員なし
Dialogue: 0,0:09:47.32,0:09:49.49,Default,,0000,0000,0000,,うちらの勝ちや!
Dialogue: 0,0:09:49.49,0:09:52.16,Default,,0000,0000,0000,,さすがだぜ 大将
Dialogue: 0,0:09:52.16,0:09:55.83,Default,,0000,0000,0000,,エミリア様 助け出して 男 見せたっじゃあねえか!
Dialogue: 0,0:09:55.83,0:09:59.33,Default,,0000,0000,0000,,当然!
Dialogue: 0,0:09:55.83,0:09:59.33,Default,,0000,0000,0000,,けど お前こそ 大丈夫なのか?
Dialogue: 0,0:09:59.33,0:10:01.83,Default,,0000,0000,0000,,ボロボロで ひでえ面だぞ
Dialogue: 0,0:10:01.83,0:10:05.17,Default,,0000,0000,0000,,面のこと 大将にゃあ言われったくねえよ
Dialogue: 0,0:10:05.17,0:10:07.51,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:10:05.17,0:10:07.51,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:10:07.51,0:10:11.51,Default,,0000,0000,0000,,よかった ガーフィールも 見た目より ずっと元気みたいで
Dialogue: 0,0:10:11.51,0:10:13.51,Default,,0000,0000,0000,,元気すぎるかしら
Dialogue: 0,0:10:13.51,0:10:16.68,Default,,0000,0000,0000,,ちょっとは けが人らしいほうが 静かでいいのよ
Dialogue: 0,0:10:16.68,0:10:20.52,Default,,0000,0000,0000,,お! ガーフ いた!
Dialogue: 0,0:10:16.68,0:10:20.52,Default,,0000,0000,0000,,どんどこどん!
Dialogue: 0,0:10:20.52,0:10:24.86,Default,,0000,0000,0000,,ぐおっ! てっ てめえ 人の上で はしゃいでんじゃ
Dialogue: 0,0:10:24.86,0:10:28.03,Default,,0000,0000,0000,,フフーン! ミミ お嬢に言われてんの!
Dialogue: 0,0:10:28.03,0:10:31.36,Default,,0000,0000,0000,,男は なんか 尻に敷くのがいいみたいな?
Dialogue: 0,0:10:31.36,0:10:33.37,Default,,0000,0000,0000,,で 敷いてみた!
Dialogue: 0,0:10:31.36,0:10:33.37,Default,,0000,0000,0000,,うお!
Dialogue: 0,0:10:33.37,0:10:36.70,Default,,0000,0000,0000,,やれやれ
Dialogue: 0,0:10:33.37,0:10:36.70,Default,,0000,0000,0000,,ベアトリスちゃんの言うとおり
Dialogue: 0,0:10:36.70,0:10:38.87,Default,,0000,0000,0000,,けが人らしくしてほしいですね
Dialogue: 0,0:10:38.87,0:10:41.04,Default,,0000,0000,0000,,なんだ いたのかよ オットー
Dialogue: 0,0:10:41.04,0:10:43.71,Default,,0000,0000,0000,,最初からいましたけど!?
Dialogue: 0,0:10:41.04,0:10:43.71,Default,,0000,0000,0000,,しらじらしい!
Dialogue: 0,0:10:43.71,0:10:46.88,Default,,0000,0000,0000,,オットー君 傷の具合は 大丈夫なの?
Dialogue: 0,0:10:46.88,0:10:51.88,Default,,0000,0000,0000,,しばらく 歩くのに難儀しそうですがちゃんと治るそうですよ
Dialogue: 0,0:10:51.88,0:10:56.56,Default,,0000,0000,0000,,ウキャー! 痛ひ!
Dialogue: 0,0:10:51.88,0:10:56.56,Default,,0000,0000,0000,,ベア子に聞いたぞ 武闘派内政官
Dialogue: 0,0:10:56.56,0:10:59.23,Default,,0000,0000,0000,,危ないまねするなら ひと言 相談しろよ
Dialogue: 0,0:10:59.23,0:11:02.50,Default,,0000,0000,0000,,友達なんだろ
Dialogue: 0,0:10:59.23,0:11:02.50,Default,,0000,0000,0000,,エミリア様をさらわれ
Dialogue: 0,0:11:02.50,0:11:05.33,Default,,0000,0000,0000,,都市の命運まで背負わされた あなたに
Dialogue: 0,0:11:05.33,0:11:09.00,Default,,0000,0000,0000,,更に やっかいな荷物を?
Dialogue: 0,0:11:05.33,0:11:09.00,Default,,0000,0000,0000,,僕は 自分の友達に
Dialogue: 0,0:11:09.00,0:11:11.84,Default,,0000,0000,0000,,そんな押しつけばっかり するつもりはありません
Dialogue: 0,0:11:11.84,0:11:14.84,Default,,0000,0000,0000,,けっ!
Dialogue: 0,0:11:11.84,0:11:14.84,Default,,0000,0000,0000,,ほんとに生き汚い野郎だぜ
Dialogue: 0,0:11:14.84,0:11:19.85,Default,,0000,0000,0000,,残念ながら
Dialogue: 0,0:11:14.84,0:11:19.85,Default,,0000,0000,0000,,暴食は取り逃がしました
Dialogue: 0,0:11:19.85,0:11:23.85,Default,,0000,0000,0000,,でも 収穫がないわけじゃ ありません
Dialogue: 0,0:11:19.85,0:11:23.85,Default,,0000,0000,0000,,何?
Dialogue: 0,0:11:23.85,0:11:29.19,Default,,0000,0000,0000,,プリシラ様が 大罪司教の1人を
Dialogue: 0,0:11:23.85,0:11:29.19,Default,,0000,0000,0000,,捕らえたんです
Dialogue: 0,0:11:23.85,0:11:29.19,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:29.19,0:11:33.19,Default,,0000,0000,0000,,アハッ!
Dialogue: 0,0:11:33.19,0:11:36.40,Default,,0000,0000,0000,,来てくれたんですね あなた
Dialogue: 0,0:11:36.40,0:11:38.73,Default,,0000,0000,0000,,わざわざ ごめんね? ありがと
Dialogue: 0,0:11:38.73,0:11:43.04,Default,,0000,0000,0000,,うっ! 女の形をした精霊が
Dialogue: 0,0:11:43.04,0:11:46.54,Default,,0000,0000,0000,,私のいとしいペテルギウスに近寄るな!
Dialogue: 0,0:11:46.54,0:11:50.38,Default,,0000,0000,0000,,この状況で かみつけるなんて ずいぶん余裕だな
Dialogue: 0,0:11:50.38,0:11:54.05,Default,,0000,0000,0000,,スバル この手のやからに 反省とか共感とか
Dialogue: 0,0:11:54.05,0:11:57.22,Default,,0000,0000,0000,,そんな人間らしさを求めるだけ 無駄かしら
Dialogue: 0,0:11:57.22,0:12:01.49,Default,,0000,0000,0000,,危ないと思ったら すぐ割って入るからね
Dialogue: 0,0:11:57.22,0:12:01.49,Default,,0000,0000,0000,,うん
Dialogue: 0,0:12:01.49,0:12:04.16,Default,,0000,0000,0000,,お望みどおり 俺が話し相手だ
Dialogue: 0,0:12:04.16,0:12:06.66,Default,,0000,0000,0000,,先に言っとくが 助けは来ないぞ
Dialogue: 0,0:12:06.66,0:12:09.83,Default,,0000,0000,0000,,お仲間連中は 全員 やられるか 撤退した
Dialogue: 0,0:12:09.83,0:12:12.67,Default,,0000,0000,0000,,助けなんて期待していませんよ
Dialogue: 0,0:12:12.67,0:12:16.17,Default,,0000,0000,0000,,そんな わかりきった話をして てれ隠しだなんて
Dialogue: 0,0:12:16.17,0:12:20.34,Default,,0000,0000,0000,,ほんとに かわいい人ですね あなたは
Dialogue: 0,0:12:20.34,0:12:24.34,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:12:20.34,0:12:24.34,Default,,0000,0000,0000,,お前たちの目的は なんなんだ?
Dialogue: 0,0:12:24.34,0:12:29.35,Default,,0000,0000,0000,,全員で示し合わせて 叡智の書だの
Dialogue: 0,0:12:24.34,0:12:29.35,Default,,0000,0000,0000,,人工精霊だのを要求して
Dialogue: 0,0:12:29.35,0:12:31.35,Default,,0000,0000,0000,,何が目的だったんだ?
Dialogue: 0,0:12:31.35,0:12:35.52,Default,,0000,0000,0000,,他の連中の考えなんて 知りたくもありませんが
Dialogue: 0,0:12:35.52,0:12:39.69,Default,,0000,0000,0000,,私たちが都市へ集ったのは 福音書の指示ですよ
Dialogue: 0,0:12:39.69,0:12:41.86,Default,,0000,0000,0000,,また福音書か
Dialogue: 0,0:12:41.86,0:12:45.03,Default,,0000,0000,0000,,なんだって そんな本の言いなりに なってるんだ?
Dialogue: 0,0:12:45.03,0:12:49.37,Default,,0000,0000,0000,,お前らの大好きな嫉妬の魔女の 復活に 役立つからか?
Dialogue: 0,0:12:49.37,0:12:53.37,Default,,0000,0000,0000,,勘違いしないでください
Dialogue: 0,0:12:49.37,0:12:53.37,Default,,0000,0000,0000,,勘違い?
Dialogue: 0,0:12:53.37,0:12:56.54,Default,,0000,0000,0000,,私が愛しているのは あなただけ
Dialogue: 0,0:12:56.54,0:12:58.88,Default,,0000,0000,0000,,あなた1人だけなんです
Dialogue: 0,0:12:58.88,0:13:02.82,Default,,0000,0000,0000,,嫉妬の魔女なんて 私にとっては どうでもいい
Dialogue: 0,0:13:02.82,0:13:07.69,Default,,0000,0000,0000,,全部 あなたに たどりつくために 必要なだけのもの!
Dialogue: 0,0:13:07.69,0:13:11.66,Default,,0000,0000,0000,,どうでもいいって
Dialogue: 0,0:13:07.69,0:13:11.66,Default,,0000,0000,0000,,他のやつらは?
Dialogue: 0,0:13:11.66,0:13:14.83,Default,,0000,0000,0000,,お前たちは 最終的に 何が望みなんだ?
Dialogue: 0,0:13:14.83,0:13:16.83,Default,,0000,0000,0000,,さあ? ごめんね
Dialogue: 0,0:13:16.83,0:13:20.83,Default,,0000,0000,0000,,あなた以外のことには 興味がなくて わかりません
Dialogue: 0,0:13:20.83,0:13:22.87,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:13:22.87,0:13:26.17,Default,,0000,0000,0000,,あなた のまれていますね?
Dialogue: 0,0:13:22.87,0:13:26.17,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:26.17,0:13:32.55,Default,,0000,0000,0000,,あなたは 本当に 私がいなくては
Dialogue: 0,0:13:26.17,0:13:32.55,Default,,0000,0000,0000,,だめな人なんですから!
Dialogue: 0,0:13:32.55,0:13:35.21,Default,,0000,0000,0000,,ひっ! うっ!
Dialogue: 0,0:13:32.55,0:13:35.21,Default,,0000,0000,0000,,えいや!
Dialogue: 0,0:13:35.21,0:13:38.22,Default,,0000,0000,0000,,がっ! ぐっ! うっ
Dialogue: 0,0:13:38.22,0:13:40.19,Default,,0000,0000,0000,,おかしなまねはしないで!
Dialogue: 0,0:13:40.19,0:13:43.36,Default,,0000,0000,0000,,私 おっちょこちょいだから うまく手加減できないの!
Dialogue: 0,0:13:43.36,0:13:48.06,Default,,0000,0000,0000,,これ以上 話すだけ無駄なのよ
Dialogue: 0,0:13:43.36,0:13:48.06,Default,,0000,0000,0000,,んっ ああ
Dialogue: 0,0:13:48.06,0:13:54.73,Default,,0000,0000,0000,,「それでも あさは おとずれる」
Dialogue: 0,0:13:54.73,0:13:57.20,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:13:54.73,0:13:57.20,Default,,0000,0000,0000,,「だれのもとにも」
Dialogue: 0,0:13:57.20,0:14:01.14,Default,,0000,0000,0000,,あっ うっ
Dialogue: 0,0:13:57.20,0:14:01.14,Default,,0000,0000,0000,,「おとずれる」
Dialogue: 0,0:14:01.14,0:14:07.65,Default,,0000,0000,0000,,「あさやけをおいこす」
Dialogue: 0,0:14:01.14,0:14:07.65,Default,,0000,0000,0000,,やめろ なんのつもりだ?
Dialogue: 0,0:14:07.65,0:14:11.98,Default,,0000,0000,0000,,「あおいそら」 やめろって言ってんだろ!
Dialogue: 0,0:14:11.98,0:14:16.32,Default,,0000,0000,0000,,ああ ごめんね?
Dialogue: 0,0:14:11.98,0:14:16.32,Default,,0000,0000,0000,,でも 歌は いいですよね
Dialogue: 0,0:14:16.32,0:14:18.32,Default,,0000,0000,0000,,そう教わったばかりなんです
Dialogue: 0,0:14:18.32,0:14:21.66,Default,,0000,0000,0000,,お前の歌と リリアナの歌を 一緒にするな!
Dialogue: 0,0:14:21.66,0:14:23.83,Default,,0000,0000,0000,,お前のは違う 別物だ!
Dialogue: 0,0:14:23.83,0:14:27.50,Default,,0000,0000,0000,,それは あなたにも言えること
Dialogue: 0,0:14:23.83,0:14:27.50,Default,,0000,0000,0000,,何?
Dialogue: 0,0:14:27.50,0:14:30.17,Default,,0000,0000,0000,,ペテルギウスは あなたの中にいる
Dialogue: 0,0:14:30.17,0:14:35.54,Default,,0000,0000,0000,,魂と魂が溶け合い
Dialogue: 0,0:14:30.17,0:14:35.54,Default,,0000,0000,0000,,肉体と肉体が混ざり合っている
Dialogue: 0,0:14:35.54,0:14:40.18,Default,,0000,0000,0000,,だから あなたの中から あの人を引きずり出す
Dialogue: 0,0:14:40.18,0:14:43.18,Default,,0000,0000,0000,,あの人の目覚めを いちばんそばで見届ける!
Dialogue: 0,0:14:43.18,0:14:46.52,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:14:43.18,0:14:46.52,Default,,0000,0000,0000,,ありがと ごめんね?
Dialogue: 0,0:14:46.52,0:14:50.69,Default,,0000,0000,0000,,その日まで 体と心を 大事にしていてくださいね
Dialogue: 0,0:14:50.69,0:14:52.69,Default,,0000,0000,0000,,スバル もう行くかしら
Dialogue: 0,0:14:52.69,0:14:56.20,Default,,0000,0000,0000,,この女は危険なだけなのよ
Dialogue: 0,0:14:52.69,0:14:56.20,Default,,0000,0000,0000,,あっ ああ
Dialogue: 0,0:14:56.20,0:14:59.37,Default,,0000,0000,0000,,1つだけ忠告を
Dialogue: 0,0:14:56.20,0:14:59.37,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:14:59.37,0:15:01.63,Default,,0000,0000,0000,,暴食に気を付けて
Dialogue: 0,0:15:01.63,0:15:07.54,Default,,0000,0000,0000,,美食家も 悪食も 飽食さえも
Dialogue: 0,0:15:01.63,0:15:07.54,Default,,0000,0000,0000,,あなたを奪おうとするでしょう
Dialogue: 0,0:15:10.98,0:15:13.98,Default,,0000,0000,0000,,どうよ?
Dialogue: 0,0:15:10.98,0:15:13.98,Default,,0000,0000,0000,,得られるものなんて何もねえ
Dialogue: 0,0:15:13.98,0:15:16.32,Default,,0000,0000,0000,,ただ 嫌な気分に なっただけだったろ?
Dialogue: 0,0:15:16.32,0:15:18.82,Default,,0000,0000,0000,,勝手に 手ぶら扱いすんなよ
Dialogue: 0,0:15:18.82,0:15:21.49,Default,,0000,0000,0000,,一応 聞けた話も なかったわけじゃない
Dialogue: 0,0:15:21.49,0:15:25.82,Default,,0000,0000,0000,,ほんとかよ 兄弟 連中に気に入られやすいのかね?
Dialogue: 0,0:15:25.82,0:15:28.49,Default,,0000,0000,0000,,んっ ぞっとすること 言うなよ
Dialogue: 0,0:15:28.49,0:15:31.66,Default,,0000,0000,0000,,スバル あんまり なれ合うんじゃないのよ
Dialogue: 0,0:15:31.66,0:15:33.67,Default,,0000,0000,0000,,なんだよ 連れねえな
Dialogue: 0,0:15:33.67,0:15:35.83,Default,,0000,0000,0000,,起きるの 手伝ってやったじゃねえか ベア子
Dialogue: 0,0:15:35.83,0:15:39.84,Default,,0000,0000,0000,,ベティーが その呼び方を許すのは スバルだけかしら
Dialogue: 0,0:15:39.84,0:15:41.84,Default,,0000,0000,0000,,ハァ やれやれ
Dialogue: 0,0:15:41.84,0:15:45.68,Default,,0000,0000,0000,,アル スバルに 伝言 伝えてくれて ありがとね
Dialogue: 0,0:15:45.68,0:15:49.01,Default,,0000,0000,0000,,おう
Dialogue: 0,0:15:49.01,0:15:51.68,Default,,0000,0000,0000,,嬢ちゃんも無事でよかったな
Dialogue: 0,0:15:51.68,0:15:55.69,Default,,0000,0000,0000,,どうした? ベア子
Dialogue: 0,0:15:51.68,0:15:55.69,Default,,0000,0000,0000,,アルと 何かあったのか?
Dialogue: 0,0:15:55.69,0:15:59.86,Default,,0000,0000,0000,,これなのよ あの男が持ってきたかしら
Dialogue: 0,0:15:59.86,0:16:02.96,Default,,0000,0000,0000,,ベティーが起きられたのは これのおかげなのよ
Dialogue: 0,0:16:02.96,0:16:06.97,Default,,0000,0000,0000,,キリタカの魔晶石
Dialogue: 0,0:16:02.96,0:16:06.97,Default,,0000,0000,0000,,どうやって これを
Dialogue: 0,0:16:06.97,0:16:08.97,Default,,0000,0000,0000,,わからないかしら
Dialogue: 0,0:16:08.97,0:16:12.64,Default,,0000,0000,0000,,そして それは聞くなと 当人に言われているのよ
Dialogue: 0,0:16:12.64,0:16:15.31,Default,,0000,0000,0000,,アルのやつ 何1人で 暗躍してやがったんだよ
Dialogue: 0,0:16:15.31,0:16:17.31,Default,,0000,0000,0000,,怪しすぎるだろ
Dialogue: 0,0:16:17.31,0:16:21.65,Default,,0000,0000,0000,,でも アルは 悪い人じゃ ないと思うの
Dialogue: 0,0:16:17.31,0:16:21.65,Default,,0000,0000,0000,,エミリアたん
Dialogue: 0,0:16:21.65,0:16:24.48,Default,,0000,0000,0000,,だって おかげで ベアトリスが起きられて
Dialogue: 0,0:16:24.48,0:16:26.99,Default,,0000,0000,0000,,オットー君たちも助かったんでしょ?
Dialogue: 0,0:16:26.99,0:16:30.32,Default,,0000,0000,0000,,なくなったら大弱りだった 魔晶石も見つけてくれて
Dialogue: 0,0:16:30.32,0:16:33.49,Default,,0000,0000,0000,,ねっ?
Dialogue: 0,0:16:30.32,0:16:33.49,Default,,0000,0000,0000,,むぐぐ かしら
Dialogue: 0,0:16:33.49,0:16:37.66,Default,,0000,0000,0000,,やれやれ エミリアたんには かなわねえな
Dialogue: 0,0:16:37.66,0:16:42.37,Default,,0000,0000,0000,,うちは あの大罪司教を 生かしておくのは反対
Dialogue: 0,0:16:42.37,0:16:44.37,Default,,0000,0000,0000,,絶対 ろくなことにならんよ
Dialogue: 0,0:16:44.37,0:16:47.84,Default,,0000,0000,0000,,それじゃ クルシュ様を 助ける手がかりがなくなる!
Dialogue: 0,0:16:47.84,0:16:51.84,Default,,0000,0000,0000,,憤怒の口から 暴食や色欲のことを 聞き出せるなんて
Dialogue: 0,0:16:51.84,0:16:54.68,Default,,0000,0000,0000,,そんな都合のいいことあると 本気で思うん?
Dialogue: 0,0:16:54.68,0:16:56.85,Default,,0000,0000,0000,,そんなの ただの推測じゃない!
Dialogue: 0,0:16:56.85,0:16:59.85,Default,,0000,0000,0000,,俺は 憤怒から話を聞くのが
Dialogue: 0,0:16:59.85,0:17:02.79,Default,,0000,0000,0000,,全くの無駄足になるとは思わない
Dialogue: 0,0:17:02.79,0:17:06.96,Default,,0000,0000,0000,,だけど あいつを捕まえておくのが 不安って考えも わかる
Dialogue: 0,0:17:06.96,0:17:10.30,Default,,0000,0000,0000,,どっちつかずなこと言って!
Dialogue: 0,0:17:06.96,0:17:10.30,Default,,0000,0000,0000,,スバル君は どっちの味方なわけ!?
Dialogue: 0,0:17:10.30,0:17:14.13,Default,,0000,0000,0000,,俺が言いたいのは 急いで 結論を出すなってことだよ
Dialogue: 0,0:17:14.13,0:17:16.47,Default,,0000,0000,0000,,フェリス 座りなさい
Dialogue: 0,0:17:16.47,0:17:19.14,Default,,0000,0000,0000,,ひとまず スバル殿のほうが正しい
Dialogue: 0,0:17:19.14,0:17:21.81,Default,,0000,0000,0000,,わかってる わかってるから
Dialogue: 0,0:17:21.81,0:17:24.48,Default,,0000,0000,0000,,僕も 憤怒の処刑には反対です
Dialogue: 0,0:17:24.48,0:17:26.65,Default,,0000,0000,0000,,クルシュ様のことは もちろんですが
Dialogue: 0,0:17:26.65,0:17:30.48,Default,,0000,0000,0000,,王国にとっても 魔女教を知る またとない機会だ
Dialogue: 0,0:17:30.48,0:17:34.32,Default,,0000,0000,0000,,速やかに王都へ移送して 騎士団に引き渡すべきでしょう
Dialogue: 0,0:17:34.32,0:17:36.49,Default,,0000,0000,0000,,逃げられる心配は?
Dialogue: 0,0:17:36.49,0:17:38.99,Default,,0000,0000,0000,,大罪司教なら 護送するのだって楽じゃない
Dialogue: 0,0:17:38.99,0:17:40.99,Default,,0000,0000,0000,,その役目は 僕が
Dialogue: 0,0:17:40.99,0:17:44.33,Default,,0000,0000,0000,,ラインハルトが行くなら 私も行く
Dialogue: 0,0:17:44.33,0:17:46.83,Default,,0000,0000,0000,,無事に 王都まで引っ張ってってやるよ
Dialogue: 0,0:17:46.83,0:17:50.67,Default,,0000,0000,0000,,猫耳も それなら文句ねえだろ?
Dialogue: 0,0:17:50.67,0:17:54.17,Default,,0000,0000,0000,,あとは はえの人らと名なしの人ら
Dialogue: 0,0:17:54.17,0:17:58.01,Default,,0000,0000,0000,,特に 色欲の被害者を どうするかやね
Dialogue: 0,0:17:58.01,0:18:00.45,Default,,0000,0000,0000,,あれは 私でも治せない
Dialogue: 0,0:18:00.45,0:18:03.62,Default,,0000,0000,0000,,ううん 治るとか 治らないとかじゃなくて
Dialogue: 0,0:18:03.62,0:18:06.95,Default,,0000,0000,0000,,ああいう生き物に 作り替えられてしまってるの
Dialogue: 0,0:18:06.95,0:18:10.29,Default,,0000,0000,0000,,おぞましき虫けらに 姿を変えられた者どもは
Dialogue: 0,0:18:10.29,0:18:12.62,Default,,0000,0000,0000,,死を望んでおるじゃろうよ
Dialogue: 0,0:18:12.62,0:18:15.96,Default,,0000,0000,0000,,元の姿に戻す見通しが 立たぬのならば
Dialogue: 0,0:18:15.96,0:18:17.96,Default,,0000,0000,0000,,そうしてやるのも慈悲であろう
Dialogue: 0,0:18:17.96,0:18:20.47,Default,,0000,0000,0000,,プリシラ それは
Dialogue: 0,0:18:17.96,0:18:20.47,Default,,0000,0000,0000,,黙れ 凡愚
Dialogue: 0,0:18:20.47,0:18:23.64,Default,,0000,0000,0000,,口先だけの理想論など なんの価値もない
Dialogue: 0,0:18:23.64,0:18:27.14,Default,,0000,0000,0000,,待って その問題 私に任せてもらえない?
Dialogue: 0,0:18:27.14,0:18:30.81,Default,,0000,0000,0000,,おもしろい!
Dialogue: 0,0:18:27.14,0:18:30.81,Default,,0000,0000,0000,,半魔風情に何ができる?
Dialogue: 0,0:18:30.81,0:18:33.31,Default,,0000,0000,0000,,今すぐ治してはあげられない
Dialogue: 0,0:18:33.31,0:18:37.32,Default,,0000,0000,0000,,でも そのための方法を 探す時間なら作れると思うの
Dialogue: 0,0:18:37.32,0:18:41.82,Default,,0000,0000,0000,,氷の中で眠らせて
Dialogue: 0,0:18:37.32,0:18:41.82,Default,,0000,0000,0000,,そうか コールドスリープ!
Dialogue: 0,0:18:41.82,0:18:44.32,Default,,0000,0000,0000,,確かに それなら時間稼ぎができる!
Dialogue: 0,0:18:44.32,0:18:48.16,Default,,0000,0000,0000,,凍らせて 眠らせる?
Dialogue: 0,0:18:44.32,0:18:48.16,Default,,0000,0000,0000,,それ 大丈夫なん?
Dialogue: 0,0:18:48.16,0:18:51.66,Default,,0000,0000,0000,,ただ氷漬けにして 死なせてしまう だけなんやないの?
Dialogue: 0,0:18:51.66,0:18:55.83,Default,,0000,0000,0000,,心配ご無用!
Dialogue: 0,0:18:51.66,0:18:55.83,Default,,0000,0000,0000,,エミリア様は 失敗などされません!
Dialogue: 0,0:18:55.83,0:18:59.67,Default,,0000,0000,0000,,あっ なぜなら!
Dialogue: 0,0:18:55.83,0:18:59.67,Default,,0000,0000,0000,,歴史に名を残す偉人とは
Dialogue: 0,0:18:59.67,0:19:02.61,Default,,0000,0000,0000,,こういった試練を 乗り越えるものだからです!
Dialogue: 0,0:19:02.61,0:19:05.94,Default,,0000,0000,0000,,ずいぶんと うため 大口をたたいたものじゃな 歌女
Dialogue: 0,0:19:05.94,0:19:08.95,Default,,0000,0000,0000,,仮に 貴様の見立てが外れれば どうなる?
Dialogue: 0,0:19:08.95,0:19:12.28,Default,,0000,0000,0000,,そのときは 私の首を差し出すまで
Dialogue: 0,0:19:12.28,0:19:15.95,Default,,0000,0000,0000,,このリリアナ 吐いた唾は飲まんぜよ!
Dialogue: 0,0:19:15.95,0:19:22.29,Default,,0000,0000,0000,,よい 歌女のさえずりに免じて
Dialogue: 0,0:19:15.95,0:19:22.29,Default,,0000,0000,0000,,わらわの慈悲は預けてやろう
Dialogue: 0,0:19:22.29,0:19:26.67,Default,,0000,0000,0000,,任せて 必ず うまくやるわ
Dialogue: 0,0:19:26.67,0:19:29.50,Default,,0000,0000,0000,,フン! やってみせるがいい
Dialogue: 0,0:19:29.50,0:19:34.34,Default,,0000,0000,0000,,それをもって 貴様を わらわの敵と認めてやる
Dialogue: 0,0:19:34.34,0:19:44.48,Default,,0000,0000,0000,,「新しい朝は
Dialogue: 0,0:19:34.34,0:19:44.48,Default,,0000,0000,0000,,空を紅黄色に染める」
Dialogue: 0,0:19:44.48,0:19:47.82,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:47.82,0:19:51.66,Default,,0000,0000,0000,,この度は 都市の防衛のために 尽力していただき
Dialogue: 0,0:19:51.66,0:19:53.83,Default,,0000,0000,0000,,本当に 感謝の念に堪えません
Dialogue: 0,0:19:53.83,0:19:58.66,Default,,0000,0000,0000,,感謝の気持ちは受け取るとして キリタカも よく無事だったな
Dialogue: 0,0:19:58.66,0:20:03.50,Default,,0000,0000,0000,,私自身 死を覚悟しました
Dialogue: 0,0:19:58.66,0:20:03.50,Default,,0000,0000,0000,,しかし
Dialogue: 0,0:20:03.50,0:20:08.34,Default,,0000,0000,0000,,リリアナの歌声を思い出して なんとか生き延びた
Dialogue: 0,0:20:14.01,0:20:24.22,Default,,0000,0000,0000,,「夜を追い払い
Dialogue: 0,0:20:14.01,0:20:24.22,Default,,0000,0000,0000,,新しい1日が始まる」
Dialogue: 0,0:20:24.22,0:20:35.03,Default,,0000,0000,0000,,「紅黄色の朝焼けを追い越して」
Dialogue: 0,0:20:35.03,0:20:46.08,Default,,0000,0000,0000,,「本物の朝が やってくる」
Dialogue: 0,0:20:46.08,0:20:51.75,Default,,0000,0000,0000,,「朝焼けを追い越す空」
Dialogue: 0,0:20:51.75,0:20:56.76,Default,,0000,0000,0000,,「どんな夜を向かえようと」
Dialogue: 0,0:20:56.76,0:21:04.83,Default,,0000,0000,0000,,「望まぬ夢に苛まれようと」
Dialogue: 0,0:21:04.83,0:21:11.34,Default,,0000,0000,0000,,「それでも朝は訪れる」
Dialogue: 0,0:21:11.34,0:21:15.84,Default,,0000,0000,0000,,「誰の元にも訪れる」
Dialogue: 0,0:21:15.84,0:21:19.68,Default,,0000,0000,0000,,スバル
Dialogue: 0,0:21:15.84,0:21:19.68,Default,,0000,0000,0000,,ラインハルトか
Dialogue: 0,0:21:19.68,0:21:23.68,Default,,0000,0000,0000,,お前がいなきゃ エミリアも 助けられなかったかもしれない
Dialogue: 0,0:21:23.68,0:21:27.52,Default,,0000,0000,0000,,改めて 礼を言う
Dialogue: 0,0:21:23.68,0:21:27.52,Default,,0000,0000,0000,,ほんと ありがとよ
Dialogue: 0,0:21:27.52,0:21:30.19,Default,,0000,0000,0000,,僕も 君の あっ
Dialogue: 0,0:21:30.19,0:21:34.69,Default,,0000,0000,0000,,友人の力になれたのなら光栄だ
Dialogue: 0,0:21:34.69,0:21:38.03,Default,,0000,0000,0000,,ご静聴 ありがっべした!
Dialogue: 0,0:21:38.03,0:21:40.03,Default,,0000,0000,0000,,ヘヘッ
Dialogue: 0,0:21:44.20,0:21:48.71,Default,,0000,0000,0000,,また会えるまで あと少しの辛抱だからね パック
Dialogue: 0,0:21:48.71,0:21:51.71,Default,,0000,0000,0000,,それも これも ベア子の頑張りと
Dialogue: 0,0:21:51.71,0:21:54.71,Default,,0000,0000,0000,,あとは キリタカの厚意に感謝だね
Dialogue: 0,0:21:54.71,0:21:57.72,Default,,0000,0000,0000,,それに スバルと他のみんなにも
Dialogue: 0,0:21:57.72,0:21:59.72,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:59.72,0:22:03.16,Default,,0000,0000,0000,,ねえ スバル あそこ 見て
Dialogue: 0,0:21:59.72,0:22:03.16,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:22:03.16,0:22:05.19,Default,,0000,0000,0000,,あれは
Dialogue: 0,0:22:05.19,0:22:07.19,Default,,0000,0000,0000,,ルスベルとティーナ
Dialogue: 0,0:22:07.19,0:22:11.86,Default,,0000,0000,0000,,そういや あの子たちを 助けようとしたことから 全部 始まったんだよな
Dialogue: 0,0:22:11.86,0:22:14.20,Default,,0000,0000,0000,,2人とも 無事で ほんとによかった
Dialogue: 0,0:22:14.20,0:22:18.87,Default,,0000,0000,0000,,街も こんなに なっちまったし あの2人の無事だけを 喜ぶってのは
Dialogue: 0,0:22:18.87,0:22:21.04,Default,,0000,0000,0000,,不謹慎かもしれねえけど
Dialogue: 0,0:22:21.04,0:22:23.51,Default,,0000,0000,0000,,ううん 喜ばなくっちゃ
Dialogue: 0,0:22:23.51,0:22:26.35,Default,,0000,0000,0000,,だって スバルと それから私たち
Dialogue: 0,0:22:26.35,0:22:30.02,Default,,0000,0000,0000,,みんなで頑張って やり遂げたことだから
Dialogue: 0,0:22:26.35,0:22:30.02,Default,,0000,0000,0000,,だな
Dialogue: 0,0:22:30.02,0:22:32.02,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:22:34.35,0:22:36.69,Default,,0000,0000,0000,,リカード!
Dialogue: 0,0:22:34.35,0:22:36.69,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:22:36.69,0:22:39.02,Default,,0000,0000,0000,,お!
Dialogue: 0,0:22:36.69,0:22:39.02,Default,,0000,0000,0000,,兄ちゃんも無事やったか!
Dialogue: 0,0:22:39.02,0:22:41.03,Default,,0000,0000,0000,,お前 その腕
Dialogue: 0,0:22:41.03,0:22:43.03,Default,,0000,0000,0000,,ああ ちょっと ドジってもうた
Dialogue: 0,0:22:43.03,0:22:45.03,Default,,0000,0000,0000,,そうか
Dialogue: 0,0:22:45.03,0:22:49.03,Default,,0000,0000,0000,,けど 腕1本で済んだんは 奇跡みたいなもんや
Dialogue: 0,0:22:49.03,0:22:51.37,Default,,0000,0000,0000,,まあ 気にし過ぎんなや!
Dialogue: 0,0:22:49.03,0:22:51.37,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:22:51.37,0:22:54.21,Default,,0000,0000,0000,,なっ?
Dialogue: 0,0:22:51.37,0:22:54.21,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:22:54.21,0:22:58.21,Default,,0000,0000,0000,,そういや ユリウスは
Dialogue: 0,0:22:54.21,0:22:58.21,Default,,0000,0000,0000,,って いるじゃねえか!
Dialogue: 0,0:22:58.21,0:23:00.81,Default,,0000,0000,0000,,なんだよ 心配させんじゃねえよ!
Dialogue: 0,0:23:00.81,0:23:02.81,Default,,0000,0000,0000,,おい この野郎!
Dialogue: 0,0:23:00.81,0:23:04.82,Default,,0000,0000,0000,,お前 なんだって みんなが 忙しくしてるときに
Dialogue: 0,0:23:04.82,0:23:07.99,Default,,0000,0000,0000,,ふらふらしてやがんだよ! ユリウス!
Dialogue: 0,0:23:07.99,0:23:10.99,Default,,0000,0000,0000,,んっ 顔が見えねえと 心配になるだろうが
Dialogue: 0,0:23:10.99,0:23:14.16,Default,,0000,0000,0000,,いや 一般的な意見だが!
Dialogue: 0,0:23:14.16,0:23:16.16,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:23:16.16,0:23:20.67,Default,,0000,0000,0000,,スバル 君は 私のことが
Dialogue: 0,0:23:16.16,0:23:20.67,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:23:20.67,0:23:23.50,Default,,0000,0000,0000,,どうしたの? スバル 取り込み中?
Dialogue: 0,0:23:23.50,0:23:27.17,Default,,0000,0000,0000,,ああ ユリウスが変なんだ
Dialogue: 0,0:23:27.17,0:23:29.17,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:23:31.51,0:23:33.85,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:23:33.85,0:23:35.85,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:23:39.68,0:23:43.19,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:23:39.68,0:23:43.19,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:23:43.19,0:23:46.19,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:23:46.19,0:23:50.36,Default,,0000,0000,0000,,ユリウスさんって
Dialogue: 0,0:23:50.36,0:23:52.86,Default,,0000,0000,0000,,スバルの知り合いの人?
Dialogue: 0,0:23:52.86,0:23:54.87,Default,,0000,0000,0000,,はっ?
