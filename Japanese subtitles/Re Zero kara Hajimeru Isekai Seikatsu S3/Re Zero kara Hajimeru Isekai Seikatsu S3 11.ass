Dialogue: 0,0:00:02.00,0:00:04.00,Default,,0000,0000,0000,,あっ 寄ってらっさい 見てらっさい!
Dialogue: 0,0:00:04.00,0:00:08.84,Default,,0000,0000,0000,,風の吹くまま 気の向くまま 吟遊詩人 マスカレード一座!
Dialogue: 0,0:00:08.84,0:00:11.85,Default,,0000,0000,0000,,お代は見ての お楽し
Dialogue: 0,0:00:11.85,0:00:14.68,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:11.85,0:00:14.68,Default,,0000,0000,0000,,あ痛っ!
Dialogue: 0,0:00:11.85,0:00:14.68,Default,,0000,0000,0000,,盛大に かんでんじゃないよ!
Dialogue: 0,0:00:14.68,0:00:17.18,Default,,0000,0000,0000,,エヘッ 大変 失礼しました
Dialogue: 0,0:00:19.35,0:00:22.86,Default,,0000,0000,0000,,さあさあ 遠からん人は 音に聴けい!
Dialogue: 0,0:00:22.86,0:00:25.36,Default,,0000,0000,0000,,近い人は 踊りも見ろ!
Dialogue: 0,0:00:25.36,0:00:29.70,Default,,0000,0000,0000,,マスカレード一座 歌って 奏でて 踊ります!
Dialogue: 0,0:00:29.70,0:00:33.70,Default,,0000,0000,0000,,「飲めや歌えや 飽きもせずに」
Dialogue: 0,0:00:33.70,0:00:37.04,Default,,0000,0000,0000,,「今日の苦労は 今日 忘れよう」
Dialogue: 0,0:00:37.04,0:00:40.37,Default,,0000,0000,0000,,「飲めや歌えや 夜が更けても」
Dialogue: 0,0:00:40.37,0:00:44.38,Default,,0000,0000,0000,,「まだ みな 杯 交わそう」
Dialogue: 0,0:00:44.38,0:00:47.88,Default,,0000,0000,0000,,「そうだ 喜びの歌を」
Dialogue: 0,0:00:47.88,0:00:51.55,Default,,0000,0000,0000,,「そうだ 月まで届けよう」
Dialogue: 0,0:00:51.55,0:01:00.06,Default,,0000,0000,0000,,「そうだ 明日も さあ
Dialogue: 0,0:00:51.55,0:01:00.06,Default,,0000,0000,0000,,飲んで歌い そして 笑え」
Dialogue: 0,0:01:03.83,0:01:06.83,Default,,0000,0000,0000,,んっ? んっ うっ
Dialogue: 0,0:01:06.83,0:01:09.50,Default,,0000,0000,0000,,うぅ だぁ!
Dialogue: 0,0:01:09.50,0:01:11.50,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:01:15.01,0:01:17.68,Default,,0000,0000,0000,,あの星と この星をつなげると
Dialogue: 0,0:01:17.68,0:01:22.52,Default,,0000,0000,0000,,ちょうど ギルティラウの牙の形に
Dialogue: 0,0:01:22.52,0:01:24.68,Default,,0000,0000,0000,,ひらめきました!
Dialogue: 0,0:01:24.68,0:01:27.52,Default,,0000,0000,0000,,「まだまだ諦めないギルティラウ」!
Dialogue: 0,0:01:27.52,0:01:32.19,Default,,0000,0000,0000,,「あ 進めー 火の中 水の中ー」
Dialogue: 0,0:01:32.19,0:01:34.36,Default,,0000,0000,0000,,「牙があるかぎりい」
Dialogue: 0,0:01:34.36,0:01:37.53,Default,,0000,0000,0000,,訳わかんない歌 歌ってないで 早く寝る!
Dialogue: 0,0:01:37.53,0:01:39.53,Default,,0000,0000,0000,,あしたの朝も早いよ!
Dialogue: 0,0:01:37.53,0:01:39.53,Default,,0000,0000,0000,,あ!
Dialogue: 0,0:01:39.53,0:01:43.54,Default,,0000,0000,0000,,うひ! あ!
Dialogue: 0,0:01:45.54,0:01:49.54,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:01:49.54,0:01:51.54,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:01:54.71,0:01:57.88,Default,,0000,0000,0000,,あ! あっ
Dialogue: 0,0:01:57.88,0:02:00.49,Default,,0000,0000,0000,,え なんで!?
Dialogue: 0,0:02:00.49,0:02:04.16,Default,,0000,0000,0000,,でっかい街ん商売は 興行師が仕切っとお
Dialogue: 0,0:02:04.16,0:02:07.16,Default,,0000,0000,0000,,うちは 小さか村で 気楽に歌うだけさ
Dialogue: 0,0:02:07.16,0:02:09.16,Default,,0000,0000,0000,,うん!
Dialogue: 0,0:02:11.66,0:02:16.17,Default,,0000,0000,0000,,ねえねえ おかさん!
Dialogue: 0,0:02:11.66,0:02:16.17,Default,,0000,0000,0000,,次は 「剣聖レイド」 やろうよ!
Dialogue: 0,0:02:16.17,0:02:19.34,Default,,0000,0000,0000,,ビシッ! バシッ! ズババーンって!
Dialogue: 0,0:02:19.34,0:02:22.51,Default,,0000,0000,0000,,オーホッホッホッ!
Dialogue: 0,0:02:19.34,0:02:22.51,Default,,0000,0000,0000,,あんたみたいな小娘が
Dialogue: 0,0:02:22.51,0:02:25.51,Default,,0000,0000,0000,,演目を決めるなんて 10年 早いよ!
Dialogue: 0,0:02:25.51,0:02:28.52,Default,,0000,0000,0000,,え?
Dialogue: 0,0:02:25.51,0:02:28.52,Default,,0000,0000,0000,,ハッハッハッ!
Dialogue: 0,0:02:25.51,0:02:28.52,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:28.52,0:02:30.52,Default,,0000,0000,0000,,生意気を言う子には
Dialogue: 0,0:02:30.52,0:02:33.85,Default,,0000,0000,0000,,わなんかかった うさぎん肉は お預けやぞ?
Dialogue: 0,0:02:33.85,0:02:35.86,Default,,0000,0000,0000,,んっ せからしか!
Dialogue: 0,0:02:35.86,0:02:37.86,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:35.86,0:02:37.86,Default,,0000,0000,0000,,リリアナ!
Dialogue: 0,0:02:37.86,0:02:39.86,Default,,0000,0000,0000,,なんばしっとか!
Dialogue: 0,0:02:37.86,0:02:42.36,Default,,0000,0000,0000,,おとさん おかさんは 勝手にしたらええでないの!
Dialogue: 0,0:02:39.86,0:02:42.36,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:42.36,0:02:46.53,Default,,0000,0000,0000,,わだすは 都会さ行くだ!
Dialogue: 0,0:02:42.36,0:02:46.53,Default,,0000,0000,0000,,フン! んっ くっ
Dialogue: 0,0:02:46.53,0:02:48.70,Default,,0000,0000,0000,,ウハハハハハハハ!
Dialogue: 0,0:02:48.70,0:02:50.87,Default,,0000,0000,0000,,今に見さらせ!
Dialogue: 0,0:02:50.87,0:02:54.57,Default,,0000,0000,0000,,吟遊王に 私はなる!
Dialogue: 0,0:04:37.34,0:04:40.55,Default,,0000,0000,0000,,ハッ プリシラ様!
Dialogue: 0,0:04:44.35,0:04:48.66,Default,,0000,0000,0000,,くっ 騒ぐな
Dialogue: 0,0:04:53.53,0:04:57.03,Default,,0000,0000,0000,,わらわの首飾りの返礼 高くつくぞ?
Dialogue: 0,0:04:57.03,0:05:00.30,Default,,0000,0000,0000,,なるほど
Dialogue: 0,0:04:57.03,0:05:00.30,Default,,0000,0000,0000,,自分にとって価値のある物に
Dialogue: 0,0:05:00.30,0:05:02.80,Default,,0000,0000,0000,,傷を肩代わりさせるのですか
Dialogue: 0,0:05:02.80,0:05:06.14,Default,,0000,0000,0000,,それは とても傲慢な在り方
Dialogue: 0,0:05:06.14,0:05:11.31,Default,,0000,0000,0000,,アイリスと茨の王も真っ青ですね?
Dialogue: 0,0:05:06.14,0:05:11.31,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:05:11.31,0:05:15.15,Default,,0000,0000,0000,,他人の過去をあさる 浅ましき やからよ
Dialogue: 0,0:05:15.15,0:05:19.49,Default,,0000,0000,0000,,その悪趣味 万死であっても あがなえぬ!
Dialogue: 0,0:05:19.49,0:05:21.99,Default,,0000,0000,0000,,そう怒らないでください
Dialogue: 0,0:05:21.99,0:05:25.83,Default,,0000,0000,0000,,憤怒だなんて この世で 最も 忌むべき感情
Dialogue: 0,0:05:25.83,0:05:30.16,Default,,0000,0000,0000,,人の心は 常に 喜びで 満たされているべきなのです
Dialogue: 0,0:05:30.16,0:05:34.17,Default,,0000,0000,0000,,だから 私は 権能によって 皆の胸襟を開き
Dialogue: 0,0:05:34.17,0:05:37.50,Default,,0000,0000,0000,,共感して 心で通じ合ってもらう
Dialogue: 0,0:05:37.50,0:05:40.01,Default,,0000,0000,0000,,それこそが 相互理解
Dialogue: 0,0:05:40.01,0:05:42.84,Default,,0000,0000,0000,,愛の第1歩なのです!
Dialogue: 0,0:05:42.84,0:05:45.68,Default,,0000,0000,0000,,えっ ばかなんですか?
Dialogue: 0,0:05:45.68,0:05:48.68,Default,,0000,0000,0000,,はい?
Dialogue: 0,0:05:48.68,0:05:51.52,Default,,0000,0000,0000,,周囲の方々が見えてますか?
Dialogue: 0,0:05:51.52,0:05:54.35,Default,,0000,0000,0000,,これで わかり合ったと おっしゃるんで?
Dialogue: 0,0:05:54.35,0:05:57.36,Default,,0000,0000,0000,,共感が呼び込んだ あるべき姿だと?
Dialogue: 0,0:05:57.36,0:05:59.36,Default,,0000,0000,0000,,気持ち悪いんですよ!
Dialogue: 0,0:05:59.36,0:06:01.96,Default,,0000,0000,0000,,本気で 誰かと わかち合いたいなら
Dialogue: 0,0:06:01.96,0:06:05.63,Default,,0000,0000,0000,,黙って 私の歌を 聴きやがれってなもんです!
Dialogue: 0,0:06:05.63,0:06:07.63,Default,,0000,0000,0000,,んっ フン!
Dialogue: 0,0:06:10.14,0:06:13.97,Default,,0000,0000,0000,,いよいよ 地金を出したな
Dialogue: 0,0:06:10.14,0:06:13.97,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:06:13.97,0:06:16.98,Default,,0000,0000,0000,,都合の悪いことを黙らせんとした
Dialogue: 0,0:06:16.98,0:06:20.15,Default,,0000,0000,0000,,わらわではなく うため この歌女に通用せなんだが
Dialogue: 0,0:06:20.15,0:06:22.32,Default,,0000,0000,0000,,よほど こたえたか
Dialogue: 0,0:06:22.32,0:06:25.65,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:06:22.32,0:06:25.65,Default,,0000,0000,0000,,いえ いえいえ いえいえいえ
Dialogue: 0,0:06:25.65,0:06:27.65,Default,,0000,0000,0000,,そんな そんな ばかなこと!
Dialogue: 0,0:06:27.65,0:06:31.32,Default,,0000,0000,0000,,私が そんな 衝動に身を任せたことなんて
Dialogue: 0,0:06:31.32,0:06:35.16,Default,,0000,0000,0000,,貴様は 今 耳心地の悪い言葉を聞いた
Dialogue: 0,0:06:35.16,0:06:37.16,Default,,0000,0000,0000,,故に激高した
Dialogue: 0,0:06:37.16,0:06:40.83,Default,,0000,0000,0000,,ただ それだけの 安い憤怒よ
Dialogue: 0,0:06:40.83,0:06:47.17,Default,,0000,0000,0000,,くっ 私と あの人の憤怒を
Dialogue: 0,0:06:40.83,0:06:47.17,Default,,0000,0000,0000,,そんな安っぽく 触れ回るな!
Dialogue: 0,0:06:47.17,0:06:50.01,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:06:47.17,0:06:50.01,Default,,0000,0000,0000,,憤怒は 私が夫から
Dialogue: 0,0:06:50.01,0:06:53.01,Default,,0000,0000,0000,,あの人から もらった 唯一無二の贈りもの!
Dialogue: 0,0:06:53.01,0:06:57.18,Default,,0000,0000,0000,,夫から献上されたのが 怒りだけとは笑わせる
Dialogue: 0,0:06:57.18,0:07:01.45,Default,,0000,0000,0000,,わらわは 8人の夫を持ったがどれも わらわの気を引くために
Dialogue: 0,0:07:01.45,0:07:05.46,Default,,0000,0000,0000,,次から次へと 物をよこしたぞ
Dialogue: 0,0:07:01.45,0:07:05.46,Default,,0000,0000,0000,,8人!
Dialogue: 0,0:07:05.46,0:07:09.80,Default,,0000,0000,0000,,私が たった1人の あの人と 心から結ばれるのに
Dialogue: 0,0:07:09.80,0:07:12.80,Default,,0000,0000,0000,,こんなに 一生懸命 時を費やしているのに!
Dialogue: 0,0:07:12.80,0:07:16.47,Default,,0000,0000,0000,,己の魅力のなさを わらわのせいにするでない
Dialogue: 0,0:07:16.47,0:07:20.31,Default,,0000,0000,0000,,その分じゃと 貴様に思われる 哀れな男とやらも
Dialogue: 0,0:07:20.31,0:07:22.98,Default,,0000,0000,0000,,貴様を見ているか怪しいものよな
Dialogue: 0,0:07:22.98,0:07:27.78,Default,,0000,0000,0000,,私と あの人は 深く愛し合っている!
Dialogue: 0,0:07:38.49,0:07:40.49,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:07:46.33,0:07:49.34,Default,,0000,0000,0000,,プリシラ様!
Dialogue: 0,0:07:46.33,0:07:49.34,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:07:49.34,0:07:51.34,Default,,0000,0000,0000,,よそ見をするな!
Dialogue: 0,0:07:51.34,0:07:55.51,Default,,0000,0000,0000,,今 私の憤怒が お前を焼くところだろうが!
Dialogue: 0,0:07:55.51,0:07:58.51,Default,,0000,0000,0000,,貴様の相手など 片手間
Dialogue: 0,0:07:58.51,0:08:01.81,Default,,0000,0000,0000,,わらわの行いに 口出しするでないわ
Dialogue: 0,0:08:08.12,0:08:10.46,Default,,0000,0000,0000,,不細工な焼き打ちよ!
Dialogue: 0,0:08:10.46,0:08:15.56,Default,,0000,0000,0000,,わらわが炎のパイオニアとして
Dialogue: 0,0:08:10.46,0:08:15.56,Default,,0000,0000,0000,,手本を見せてやろう!
Dialogue: 0,0:08:20.97,0:08:22.97,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:20.97,0:08:22.97,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:08:22.97,0:08:27.31,Default,,0000,0000,0000,,この炎は わらわの望むものだけを焼く
Dialogue: 0,0:08:27.31,0:08:31.48,Default,,0000,0000,0000,,舞台は整えた
Dialogue: 0,0:08:27.31,0:08:31.48,Default,,0000,0000,0000,,せいぜい わらわを興じさせよ
Dialogue: 0,0:08:31.48,0:08:33.98,Default,,0000,0000,0000,,あっ ええい!
Dialogue: 0,0:08:33.98,0:08:36.48,Default,,0000,0000,0000,,合点承知!
Dialogue: 0,0:08:41.32,0:08:44.82,Default,,0000,0000,0000,,あっ うわっ! 熱ちちちち!
Dialogue: 0,0:08:44.82,0:08:46.83,Default,,0000,0000,0000,,ひぃ!
Dialogue: 0,0:08:46.83,0:08:50.66,Default,,0000,0000,0000,,ハァ ああ ちょっと走っただけで この消耗!
Dialogue: 0,0:08:50.66,0:08:56.17,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:08:50.66,0:08:56.17,Default,,0000,0000,0000,,私 この街で 楽 し過ぎました
Dialogue: 0,0:08:56.17,0:09:01.77,Default,,0000,0000,0000,,これも 全部 何もかも
Dialogue: 0,0:08:56.17,0:09:01.77,Default,,0000,0000,0000,,キリタカさんや皆さんのせいですよ
Dialogue: 0,0:09:01.77,0:09:04.11,Default,,0000,0000,0000,,でも だからこそ
Dialogue: 0,0:09:04.11,0:09:08.78,Default,,0000,0000,0000,,ここで くじけるわけにはいかんでふ!
Dialogue: 0,0:09:08.78,0:09:14.62,Default,,0000,0000,0000,,一世一代の大舞台
Dialogue: 0,0:09:08.78,0:09:14.62,Default,,0000,0000,0000,,ってやつですよ! ハァハァ
Dialogue: 0,0:09:14.62,0:09:18.46,Default,,0000,0000,0000,,熱い思いの丈を
Dialogue: 0,0:09:18.46,0:09:23.80,Default,,0000,0000,0000,,全部 ぶちまけてやろうじゃ
Dialogue: 0,0:09:18.46,0:09:23.80,Default,,0000,0000,0000,,ありませんか!
Dialogue: 0,0:09:23.80,0:09:27.80,Default,,0000,0000,0000,,さあさあ 遠からん人は 音に聴けい!
Dialogue: 0,0:09:27.80,0:09:30.14,Default,,0000,0000,0000,,近い人は 踊りも見ろ!
Dialogue: 0,0:09:30.14,0:09:33.97,Default,,0000,0000,0000,,もっと遠い人には もっと大きい声を出すから
Dialogue: 0,0:09:33.97,0:09:35.98,Default,,0000,0000,0000,,それを聴けい!
Dialogue: 0,0:09:35.98,0:09:40.98,Default,,0000,0000,0000,,女 リリアナ・マスカレード 歌って 奏でて 踊ります!
Dialogue: 0,0:09:40.98,0:09:43.15,Default,,0000,0000,0000,,聴きさらせ!
Dialogue: 0,0:09:43.15,0:09:45.99,Default,,0000,0000,0000,,「朝焼けを追い越す空」!
Dialogue: 0,0:11:21.85,0:11:26.52,Default,,0000,0000,0000,,これぞ 歌に寄り添い 歌と共に生きる
Dialogue: 0,0:11:26.52,0:11:30.02,Default,,0000,0000,0000,,吟遊詩人の在り方
Dialogue: 0,0:11:30.02,0:11:33.53,Default,,0000,0000,0000,,胸が 弾みますよ
Dialogue: 0,0:11:33.53,0:11:37.03,Default,,0000,0000,0000,,弾むほどありませんが
Dialogue: 0,0:11:39.53,0:11:41.53,Default,,0000,0000,0000,,んっ くっ
Dialogue: 0,0:11:41.53,0:11:44.04,Default,,0000,0000,0000,,英雄なら うぅ
Dialogue: 0,0:11:44.04,0:11:47.71,Default,,0000,0000,0000,,こんなときは 死なないもんですよ
Dialogue: 0,0:11:47.71,0:11:52.55,Default,,0000,0000,0000,,そう 英雄なら
Dialogue: 0,0:11:52.55,0:11:58.38,Default,,0000,0000,0000,,ハァ 私は 英雄じゃない
Dialogue: 0,0:11:58.38,0:12:03.66,Default,,0000,0000,0000,,だって レイドやフリューゲルなら
Dialogue: 0,0:11:58.38,0:12:03.66,Default,,0000,0000,0000,,こんなことにはならない
Dialogue: 0,0:12:03.66,0:12:07.16,Default,,0000,0000,0000,,私は あの人たちの物語を
Dialogue: 0,0:12:07.16,0:12:12.33,Default,,0000,0000,0000,,勝手に みんなに伝えるだけの
Dialogue: 0,0:12:07.16,0:12:12.33,Default,,0000,0000,0000,,ただの ぬすっとだ
Dialogue: 0,0:12:12.33,0:12:16.00,Default,,0000,0000,0000,,だったら だったら
Dialogue: 0,0:12:16.00,0:12:19.67,Default,,0000,0000,0000,,吟遊詩人って
Dialogue: 0,0:12:19.67,0:12:21.67,Default,,0000,0000,0000,,何?
Dialogue: 0,0:12:28.35,0:12:30.35,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:12:30.35,0:12:34.05,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:36.69,0:12:42.19,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:12:42.19,0:12:47.87,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:12:47.87,0:12:51.70,Default,,0000,0000,0000,,ハァハァ ハァハァハァ
Dialogue: 0,0:12:51.70,0:12:53.71,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:12:53.71,0:12:55.88,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:12:55.88,0:12:57.88,Default,,0000,0000,0000,,プハッ!
Dialogue: 0,0:13:01.15,0:13:04.55,Default,,0000,0000,0000,,プハッ! ハァハァ
Dialogue: 0,0:13:19.67,0:13:23.50,Default,,0000,0000,0000,,これは 歌だ
Dialogue: 0,0:13:23.50,0:13:26.84,Default,,0000,0000,0000,,あっ うっ
Dialogue: 0,0:13:37.68,0:13:39.69,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:42.02,0:13:44.02,Default,,0000,0000,0000,,ひらめきました!
Dialogue: 0,0:13:53.20,0:13:59.87,Default,,0000,0000,0000,,「それでも朝は訪れる」
Dialogue: 0,0:13:59.87,0:14:06.31,Default,,0000,0000,0000,,「誰のもとにも訪れる」
Dialogue: 0,0:14:06.31,0:14:17.02,Default,,0000,0000,0000,,「あーあーあー
Dialogue: 0,0:14:06.31,0:14:17.02,Default,,0000,0000,0000,,朝焼けを追い越す青い空」
Dialogue: 0,0:14:39.85,0:14:49.19,Default,,0000,0000,0000,,「新しい朝は
Dialogue: 0,0:14:39.85,0:14:49.19,Default,,0000,0000,0000,,空を紅黄色に染める」
Dialogue: 0,0:14:49.19,0:14:59.87,Default,,0000,0000,0000,,「昨日の喧騒
Dialogue: 0,0:14:49.19,0:14:59.87,Default,,0000,0000,0000,,忘れたように静かに」
Dialogue: 0,0:14:59.87,0:15:02.30,Default,,0000,0000,0000,,無駄なことを!
Dialogue: 0,0:15:02.30,0:15:09.14,Default,,0000,0000,0000,,そんな場所から そんな声で
Dialogue: 0,0:15:02.30,0:15:09.14,Default,,0000,0000,0000,,歌など 誰に届くものか!
Dialogue: 0,0:15:09.14,0:15:19.32,Default,,0000,0000,0000,,「夜を追い払い
Dialogue: 0,0:15:09.14,0:15:19.32,Default,,0000,0000,0000,,新しい1日が始まる」
Dialogue: 0,0:15:19.32,0:15:29.50,Default,,0000,0000,0000,,「紅黄色の朝焼けを追い越して」
Dialogue: 0,0:15:29.50,0:15:41.01,Default,,0000,0000,0000,,「本物の朝が やってくる」
Dialogue: 0,0:15:41.01,0:15:46.51,Default,,0000,0000,0000,,あなたの姿は
Dialogue: 0,0:15:41.01,0:15:46.51,Default,,0000,0000,0000,,僕が独り占めしたい
Dialogue: 0,0:15:46.51,0:15:50.68,Default,,0000,0000,0000,,ですが 歌声は 独り占めにすべきではない
Dialogue: 0,0:15:50.68,0:15:54.85,Default,,0000,0000,0000,,歌姫は 皆に リリアナは 僕に
Dialogue: 0,0:15:54.85,0:15:57.06,Default,,0000,0000,0000,,そう願ってはいけませんか?
Dialogue: 0,0:15:59.86,0:16:02.96,Default,,0000,0000,0000,,「それでも朝は」
Dialogue: 0,0:16:02.96,0:16:06.30,Default,,0000,0000,0000,,リリアナよ 僕の歌姫よ!
Dialogue: 0,0:16:06.30,0:16:12.81,Default,,0000,0000,0000,,あなたの歌声は
Dialogue: 0,0:16:06.30,0:16:12.81,Default,,0000,0000,0000,,すべての人を幸せにできる!
Dialogue: 0,0:16:12.81,0:16:24.32,Default,,0000,0000,0000,,「あーあーあー
Dialogue: 0,0:16:12.81,0:16:24.32,Default,,0000,0000,0000,,朝焼けを追い越す青い空」
Dialogue: 0,0:16:30.99,0:16:33.33,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:16:33.33,0:16:37.66,Default,,0000,0000,0000,,やはり あれを見込んだ わらわの目は 確かであったな
Dialogue: 0,0:16:37.66,0:16:41.00,Default,,0000,0000,0000,,なんで
Dialogue: 0,0:16:37.66,0:16:41.00,Default,,0000,0000,0000,,あれの ばかさは 小気味よい
Dialogue: 0,0:16:41.00,0:16:43.67,Default,,0000,0000,0000,,愚かと ばかは 似て非なるものよ
Dialogue: 0,0:16:43.67,0:16:46.67,Default,,0000,0000,0000,,愚か者に生きる価値はないが
Dialogue: 0,0:16:46.67,0:16:49.68,Default,,0000,0000,0000,,ばかには 愉快という とりえがある
Dialogue: 0,0:16:49.68,0:16:55.51,Default,,0000,0000,0000,,あれは その上 愉快以上の価値を
Dialogue: 0,0:16:49.68,0:16:55.51,Default,,0000,0000,0000,,己で証明してみせた
Dialogue: 0,0:16:55.51,0:16:59.95,Default,,0000,0000,0000,,よって その働きに褒美を与える!
Dialogue: 0,0:16:59.95,0:17:03.29,Default,,0000,0000,0000,,うるさいんだよ!!
Dialogue: 0,0:17:03.29,0:17:08.29,Default,,0000,0000,0000,,砕けて 燃え尽きろ!
Dialogue: 0,0:17:03.29,0:17:08.29,Default,,0000,0000,0000,,ペテンの歌姫!
Dialogue: 0,0:17:11.30,0:17:13.30,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:17:15.30,0:17:19.14,Default,,0000,0000,0000,,くっ 愚物が!
Dialogue: 0,0:17:15.30,0:17:19.14,Default,,0000,0000,0000,,わらわのものに なんとする!
Dialogue: 0,0:17:19.14,0:17:22.04,Default,,0000,0000,0000,,お前もだ 高慢ちき!
Dialogue: 0,0:17:28.48,0:17:30.48,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:17:32.48,0:17:34.82,Default,,0000,0000,0000,,貴様
Dialogue: 0,0:17:34.82,0:17:40.99,Default,,0000,0000,0000,,「ラララーララー」
Dialogue: 0,0:17:34.82,0:17:40.99,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:17:40.99,0:17:44.33,Default,,0000,0000,0000,,「ラーララー」
Dialogue: 0,0:17:44.33,0:17:47.33,Default,,0000,0000,0000,,その意 大義である!
Dialogue: 0,0:17:47.33,0:17:50.17,Default,,0000,0000,0000,,笑わせるな!
Dialogue: 0,0:17:50.17,0:17:53.84,Default,,0000,0000,0000,,わかり合い 溶け合うことが 人の望みだ!
Dialogue: 0,0:17:53.84,0:17:57.51,Default,,0000,0000,0000,,匹婦めが
Dialogue: 0,0:17:53.84,0:17:57.51,Default,,0000,0000,0000,,愛は 1つになることだ!
Dialogue: 0,0:17:57.51,0:18:02.45,Default,,0000,0000,0000,,違うな 愛とは 違ってもいいと 寛容に受け入れることよ
Dialogue: 0,0:18:02.45,0:18:06.45,Default,,0000,0000,0000,,皆が皆 同じ方向を見て 同じように思い
Dialogue: 0,0:18:06.45,0:18:09.56,Default,,0000,0000,0000,,同じように感ずるなど 虫ずが走る!
Dialogue: 0,0:18:13.29,0:18:15.29,Default,,0000,0000,0000,,終わりじゃ
Dialogue: 0,0:18:15.29,0:18:18.30,Default,,0000,0000,0000,,さあ どうかしら?
Dialogue: 0,0:18:18.30,0:18:21.13,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:18:21.13,0:18:23.64,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:21.13,0:18:23.64,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:18:23.64,0:18:27.47,Default,,0000,0000,0000,,ん!
Dialogue: 0,0:18:23.64,0:18:27.47,Default,,0000,0000,0000,,この少女を哀れむ心!
Dialogue: 0,0:18:27.47,0:18:32.31,Default,,0000,0000,0000,,それこそが あなたの心に芽生えた愛!
Dialogue: 0,0:18:32.31,0:18:35.01,Default,,0000,0000,0000,,くどい
Dialogue: 0,0:18:32.31,0:18:35.01,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:38.82,0:18:42.99,Default,,0000,0000,0000,,あらら? ハッ!
Dialogue: 0,0:18:42.99,0:18:46.16,Default,,0000,0000,0000,,わらわの陽剣は 焼きたいものを焼き
Dialogue: 0,0:18:46.16,0:18:48.33,Default,,0000,0000,0000,,斬りたいものを斬る
Dialogue: 0,0:18:48.33,0:18:54.33,Default,,0000,0000,0000,,ハッ この 私の痛みを あなたは?
Dialogue: 0,0:18:54.33,0:18:56.67,Default,,0000,0000,0000,,知ったことか
Dialogue: 0,0:18:56.67,0:19:01.94,Default,,0000,0000,0000,,貴様は 妄言を抱えたまま
Dialogue: 0,0:18:56.67,0:19:01.94,Default,,0000,0000,0000,,1人きりで死ぬがいい
Dialogue: 0,0:19:17.62,0:19:21.46,Default,,0000,0000,0000,,日照が終わり 日輪が陰ったか
Dialogue: 0,0:19:21.46,0:19:25.46,Default,,0000,0000,0000,,悪運の強い俗悪め
Dialogue: 0,0:19:25.46,0:19:27.47,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:32.30,0:19:35.64,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:19:32.30,0:19:35.64,Default,,0000,0000,0000,,大丈夫か?
Dialogue: 0,0:19:35.64,0:19:39.65,Default,,0000,0000,0000,,騒がしき夜に 騒がしき連中よ
Dialogue: 0,0:19:39.65,0:19:43.15,Default,,0000,0000,0000,,この場にこそ うた 詩歌の出番であろうに
Dialogue: 0,0:19:43.15,0:19:46.82,Default,,0000,0000,0000,,歌姫は 無事か?
Dialogue: 0,0:19:43.15,0:19:46.82,Default,,0000,0000,0000,,怠慢以外の何物でもないな
Dialogue: 0,0:19:46.82,0:19:52.66,Default,,0000,0000,0000,,つまらぬことよ
Dialogue: 0,0:19:46.82,0:19:52.66,Default,,0000,0000,0000,,じゃが 悪くはなかった
Dialogue: 0,0:19:52.66,0:19:56.33,Default,,0000,0000,0000,,褒めて遣わす
Dialogue: 0,0:19:56.33,0:20:00.17,Default,,0000,0000,0000,,ああ あ うぅ ハァ
Dialogue: 0,0:20:00.17,0:20:02.83,Default,,0000,0000,0000,,そろそろ 限界ですかね
Dialogue: 0,0:20:02.83,0:20:08.34,Default,,0000,0000,0000,,いろいろありましたが
Dialogue: 0,0:20:02.83,0:20:08.34,Default,,0000,0000,0000,,総合的に楽しい人生でした
Dialogue: 0,0:20:08.34,0:20:11.64,Default,,0000,0000,0000,,リリアナー!
Dialogue: 0,0:20:14.35,0:20:18.02,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:20:14.35,0:20:18.02,Default,,0000,0000,0000,,プハッ! ハァ 大丈夫かい? リリアナ!
Dialogue: 0,0:20:18.02,0:20:21.69,Default,,0000,0000,0000,,キッ キリタカさん!
Dialogue: 0,0:20:18.02,0:20:21.69,Default,,0000,0000,0000,,どげんしてたんですか?
Dialogue: 0,0:20:21.69,0:20:25.02,Default,,0000,0000,0000,,亜獣に追われ 錯乱して 逃げ惑っていたが
Dialogue: 0,0:20:25.02,0:20:27.03,Default,,0000,0000,0000,,君の歌で 我に返った
Dialogue: 0,0:20:27.03,0:20:32.20,Default,,0000,0000,0000,,そっ それは それは
Dialogue: 0,0:20:27.03,0:20:32.20,Default,,0000,0000,0000,,キリタカさんも ずいぶんな醜態を
Dialogue: 0,0:20:32.20,0:20:34.70,Default,,0000,0000,0000,,リリアナ! リリアナ!
Dialogue: 0,0:20:34.70,0:20:38.70,Default,,0000,0000,0000,,今 私 すごく眠たいんで ちょっと寝ます
Dialogue: 0,0:20:38.70,0:20:40.71,Default,,0000,0000,0000,,もう ほんと 限界
Dialogue: 0,0:20:40.71,0:20:44.54,Default,,0000,0000,0000,,でも 死にませんから
Dialogue: 0,0:20:40.71,0:20:44.54,Default,,0000,0000,0000,,リリアナ!
Dialogue: 0,0:20:44.54,0:20:49.38,Default,,0000,0000,0000,,これは 直接 言うつもりはないけれど
Dialogue: 0,0:20:49.38,0:20:53.59,Default,,0000,0000,0000,,あなたの歌姫で よかった
Dialogue: 0,0:22:24.34,0:22:29.68,Default,,0000,0000,0000,,お前ら 大罪司教の名前は
Dialogue: 0,0:22:24.34,0:22:29.68,Default,,0000,0000,0000,,俺の故郷の星の名前と一緒だ
Dialogue: 0,0:22:29.68,0:22:34.85,Default,,0000,0000,0000,,で その権能も
Dialogue: 0,0:22:29.68,0:22:34.85,Default,,0000,0000,0000,,星の名前の語源として関係してる
Dialogue: 0,0:22:34.85,0:22:38.19,Default,,0000,0000,0000,,ペテルギウスの語源は ジャウザーの手
Dialogue: 0,0:22:38.19,0:22:40.86,Default,,0000,0000,0000,,つまり 見えざる手だ
Dialogue: 0,0:22:40.86,0:22:44.36,Default,,0000,0000,0000,,でもって 獅子座を意味する レグルスの語源は
Dialogue: 0,0:22:44.36,0:22:47.37,Default,,0000,0000,0000,,小さな王と あと もう1つ
Dialogue: 0,0:22:47.37,0:22:50.70,Default,,0000,0000,0000,,コル・レオニス
Dialogue: 0,0:22:50.70,0:22:53.37,Default,,0000,0000,0000,,獅子の心臓って意味だ
Dialogue: 0,0:22:53.37,0:22:56.54,Default,,0000,0000,0000,,お前の権能は 無敵化じゃなく
Dialogue: 0,0:22:56.54,0:22:59.98,Default,,0000,0000,0000,,時間停止じゃねえか?
Dialogue: 0,0:22:56.54,0:22:59.98,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:22:59.98,0:23:04.65,Default,,0000,0000,0000,,体の時間が止まってるってことは 変化しないってことだ
Dialogue: 0,0:23:04.65,0:23:07.65,Default,,0000,0000,0000,,けがもしないし 水に ぬれたりもしない
Dialogue: 0,0:23:07.65,0:23:10.49,Default,,0000,0000,0000,,投げた砂 飛ばした水も 時間が止まってるから
Dialogue: 0,0:23:10.49,0:23:15.83,Default,,0000,0000,0000,,あのさ 君の考えがどうとか
Dialogue: 0,0:23:10.49,0:23:15.83,Default,,0000,0000,0000,,全然 興味がないんだけど!
Dialogue: 0,0:23:15.83,0:23:20.00,Default,,0000,0000,0000,,聞くだけ無駄だったよ ほんとにさ!
Dialogue: 0,0:23:20.00,0:23:22.30,Default,,0000,0000,0000,,うおっ! うっ
Dialogue: 0,0:23:25.00,0:23:27.17,Default,,0000,0000,0000,,ハァハァ くっ
Dialogue: 0,0:23:27.17,0:23:30.51,Default,,0000,0000,0000,,あそこが 小さな王が君臨する
Dialogue: 0,0:23:30.51,0:23:33.01,Default,,0000,0000,0000,,花嫁たちの小さな王国
Dialogue: 0,0:23:33.01,0:23:37.02,Default,,0000,0000,0000,,レグルスの権能にも 必ず 制限があるはず
Dialogue: 0,0:23:37.02,0:23:41.85,Default,,0000,0000,0000,,花嫁の人数か距離 なんらかの条件が必ず
Dialogue: 0,0:23:41.85,0:23:44.19,Default,,0000,0000,0000,,頼むぜ エミリア
Dialogue: 0,0:23:44.19,0:23:48.03,Default,,0000,0000,0000,,花嫁たちを 小さな王国から連れ出してくれ
Dialogue: 0,0:23:48.03,0:23:50.03,Default,,0000,0000,0000,,ハァ
