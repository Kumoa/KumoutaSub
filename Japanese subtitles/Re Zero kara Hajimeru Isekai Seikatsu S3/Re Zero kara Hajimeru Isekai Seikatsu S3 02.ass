Dialogue: 0,0:00:02.00,0:00:04.30,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:00:02.00,0:00:04.30,Default,,0000,0000,0000,,スバル 大丈夫?
Dialogue: 0,0:00:06.34,0:00:09.51,Default,,0000,0000,0000,,落ち着いたかしら?
Dialogue: 0,0:00:06.34,0:00:09.51,Default,,0000,0000,0000,,だっ 大丈夫
Dialogue: 0,0:00:09.51,0:00:11.85,Default,,0000,0000,0000,,ちょっと 立ちくらみしただけ
Dialogue: 0,0:00:11.85,0:00:14.35,Default,,0000,0000,0000,,ありがと
Dialogue: 0,0:00:11.85,0:00:14.35,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:16.35,0:00:18.69,Default,,0000,0000,0000,,死に戻り したのか
Dialogue: 0,0:00:18.69,0:00:22.19,Default,,0000,0000,0000,,ふひょ!
Dialogue: 0,0:00:18.69,0:00:22.19,Default,,0000,0000,0000,,驚きましたよ ナツキ様
Dialogue: 0,0:00:18.69,0:00:22.19,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:00:22.19,0:00:27.19,Default,,0000,0000,0000,,不肖 このリリアナ 鎮魂歌 あまり練習してないもので
Dialogue: 0,0:00:27.19,0:00:31.87,Default,,0000,0000,0000,,うそだろ?
Dialogue: 0,0:00:27.19,0:00:31.87,Default,,0000,0000,0000,,この場所 会話 今って
Dialogue: 0,0:00:31.87,0:00:35.54,Default,,0000,0000,0000,,ハッ! あの直前に戻った!
Dialogue: 0,0:00:35.54,0:00:38.54,Default,,0000,0000,0000,,急がねえと! ベアトリス!
Dialogue: 0,0:00:35.54,0:00:38.54,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:00:38.54,0:00:40.87,Default,,0000,0000,0000,,俺と ぐっ
Dialogue: 0,0:00:38.54,0:00:40.87,Default,,0000,0000,0000,,だめだ
Dialogue: 0,0:00:40.87,0:00:44.38,Default,,0000,0000,0000,,ペテルギウスは 執ように エミリアを狙った
Dialogue: 0,0:00:44.38,0:00:48.05,Default,,0000,0000,0000,,なら 同じ大罪司教の シリウスの目的も
Dialogue: 0,0:00:48.05,0:00:51.05,Default,,0000,0000,0000,,なんなのよ?
Dialogue: 0,0:00:48.05,0:00:51.05,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:51.05,0:00:53.72,Default,,0000,0000,0000,,俺と同じ 甘い物で大丈夫か?
Dialogue: 0,0:00:53.72,0:00:55.89,Default,,0000,0000,0000,,エミリアと一緒にいてくれ
Dialogue: 0,0:00:55.89,0:00:59.39,Default,,0000,0000,0000,,んっ また ベティーにも 言えないことなのかしら
Dialogue: 0,0:00:59.39,0:01:02.16,Default,,0000,0000,0000,,悪い でも 何かあったとき
Dialogue: 0,0:01:02.16,0:01:04.83,Default,,0000,0000,0000,,俺が いちばん最初に頼るのは お前だ
Dialogue: 0,0:01:04.83,0:01:08.00,Default,,0000,0000,0000,,あ さて ちょっと ひとっ走り 気分転換がてら
Dialogue: 0,0:01:08.00,0:01:10.00,Default,,0000,0000,0000,,飲み物でも買ってくるよ
Dialogue: 0,0:01:10.00,0:01:12.84,Default,,0000,0000,0000,,フゥ
Dialogue: 0,0:01:10.00,0:01:12.84,Default,,0000,0000,0000,,スバル!
Dialogue: 0,0:01:12.84,0:01:16.68,Default,,0000,0000,0000,,お願いだから 気を付けて
Dialogue: 0,0:01:12.84,0:01:16.68,Default,,0000,0000,0000,,むちゃしちゃだめだからね
Dialogue: 0,0:01:16.68,0:01:20.01,Default,,0000,0000,0000,,ああ もちろん
Dialogue: 0,0:01:16.68,0:01:20.01,Default,,0000,0000,0000,,信じて 待っててくれ
Dialogue: 0,0:01:20.01,0:01:22.35,Default,,0000,0000,0000,,君は 俺が守るから
Dialogue: 0,0:01:22.35,0:01:27.85,Default,,0000,0000,0000,,ハッ うん 気を付けてね
Dialogue: 0,0:01:22.35,0:01:27.85,Default,,0000,0000,0000,,うん
Dialogue: 0,0:01:27.85,0:01:30.16,Default,,0000,0000,0000,,お気を付けて
Dialogue: 0,0:03:24.50,0:03:27.51,Default,,0000,0000,0000,,あっ うっ!
Dialogue: 0,0:03:27.51,0:03:29.51,Default,,0000,0000,0000,,あいつは いない
Dialogue: 0,0:03:29.51,0:03:33.18,Default,,0000,0000,0000,,てか 自分で 鎖を 巻かせやがったのか あいつ!
Dialogue: 0,0:03:33.18,0:03:36.85,Default,,0000,0000,0000,,大丈夫か? ルスベル!
Dialogue: 0,0:03:33.18,0:03:36.85,Default,,0000,0000,0000,,もう いい! もう いいんだ!
Dialogue: 0,0:03:36.85,0:03:40.35,Default,,0000,0000,0000,,もう こんなことする必要は
Dialogue: 0,0:03:36.85,0:03:40.35,Default,,0000,0000,0000,,でっ でも
Dialogue: 0,0:03:40.35,0:03:45.02,Default,,0000,0000,0000,,ぼっ 僕が 約束 守らなきゃ ティーナが
Dialogue: 0,0:03:45.02,0:03:47.86,Default,,0000,0000,0000,,うっ うっ ティーナが!
Dialogue: 0,0:03:47.86,0:03:50.36,Default,,0000,0000,0000,,んっ 大丈夫だ
Dialogue: 0,0:03:50.36,0:03:53.70,Default,,0000,0000,0000,,この街には 今 頼りになる人が いっぱいいて
Dialogue: 0,0:03:53.70,0:03:57.70,Default,,0000,0000,0000,,だっ 大丈夫なんだ
Dialogue: 0,0:03:53.70,0:03:57.70,Default,,0000,0000,0000,,だから だから
Dialogue: 0,0:03:57.70,0:04:01.98,Default,,0000,0000,0000,,うっ 止まれよ 足の震え!
Dialogue: 0,0:04:01.98,0:04:05.31,Default,,0000,0000,0000,,ハァハァ ウエッ!
Dialogue: 0,0:04:05.31,0:04:09.48,Default,,0000,0000,0000,,ルスベル!? うぅ うっ! オエッ!
Dialogue: 0,0:04:09.48,0:04:11.65,Default,,0000,0000,0000,,ハァハァハァ
Dialogue: 0,0:04:11.65,0:04:15.15,Default,,0000,0000,0000,,あなたが そんなに恐怖するのは
Dialogue: 0,0:04:15.15,0:04:18.49,Default,,0000,0000,0000,,あなたが優しい証拠なのです
Dialogue: 0,0:04:18.49,0:04:21.49,Default,,0000,0000,0000,,うっ! ぐっ! うわ!
Dialogue: 0,0:04:21.49,0:04:25.00,Default,,0000,0000,0000,,ぐっ! あ!
Dialogue: 0,0:04:25.00,0:04:28.00,Default,,0000,0000,0000,,ありがと ごめんね
Dialogue: 0,0:04:28.00,0:04:31.84,Default,,0000,0000,0000,,人は わかり合える
Dialogue: 0,0:04:28.00,0:04:31.84,Default,,0000,0000,0000,,人は一つになれる
Dialogue: 0,0:04:31.84,0:04:35.51,Default,,0000,0000,0000,,優しさは 自分のために あるのではありません
Dialogue: 0,0:04:35.51,0:04:39.01,Default,,0000,0000,0000,,優しさは 他人に施すからこそ輝く!
Dialogue: 0,0:04:39.01,0:04:42.52,Default,,0000,0000,0000,,ああ! つまりは愛なのです!
Dialogue: 0,0:04:42.52,0:04:44.52,Default,,0000,0000,0000,,ぐっ! ああ
Dialogue: 0,0:04:44.52,0:04:47.69,Default,,0000,0000,0000,,存分に感じてください
Dialogue: 0,0:04:44.52,0:04:47.69,Default,,0000,0000,0000,,あなたの愛を
Dialogue: 0,0:04:47.69,0:04:51.69,Default,,0000,0000,0000,,ルスベル君を救いたいと願った あなたの尊い在り方を
Dialogue: 0,0:04:56.86,0:05:02.80,Default,,0000,0000,0000,,ルスベル君の恐怖を
Dialogue: 0,0:04:56.86,0:05:02.80,Default,,0000,0000,0000,,優しいあなたが 一緒に感じる
Dialogue: 0,0:05:02.80,0:05:06.64,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:05:02.80,0:05:06.64,Default,,0000,0000,0000,,あなたの感じた ルスベル君の恐怖を
Dialogue: 0,0:05:06.64,0:05:09.81,Default,,0000,0000,0000,,ルスベル君が あなたを通して感じる
Dialogue: 0,0:05:09.81,0:05:12.65,Default,,0000,0000,0000,,目に映り込む すべてが怖い
Dialogue: 0,0:05:12.65,0:05:15.82,Default,,0000,0000,0000,,そのルスベル君が感じた 更なる恐怖を
Dialogue: 0,0:05:15.82,0:05:19.65,Default,,0000,0000,0000,,またしても あなたは すべて 受け止める
Dialogue: 0,0:05:19.65,0:05:26.33,Default,,0000,0000,0000,,喜びも 悲しみも 恐怖も
Dialogue: 0,0:05:19.65,0:05:26.33,Default,,0000,0000,0000,,首をつらされる苦しみも
Dialogue: 0,0:05:26.33,0:05:31.16,Default,,0000,0000,0000,,それこそ 死が愛を分かつまで
Dialogue: 0,0:05:31.16,0:05:33.67,Default,,0000,0000,0000,,どうやら 限界みたいですね
Dialogue: 0,0:05:33.67,0:05:38.17,Default,,0000,0000,0000,,では 次は ティーナちゃんに 力を お借りしましょう
Dialogue: 0,0:05:38.17,0:05:41.84,Default,,0000,0000,0000,,お二人は
Dialogue: 0,0:05:41.84,0:05:43.84,Default,,0000,0000,0000,,お疲れさまでした
Dialogue: 0,0:05:45.85,0:05:48.18,Default,,0000,0000,0000,,そして 歌のあとは ご歓談
Dialogue: 0,0:05:48.18,0:05:50.52,Default,,0000,0000,0000,,ナツキ様は その時間に向けて
Dialogue: 0,0:05:50.52,0:05:53.19,Default,,0000,0000,0000,,おやつなんて準備されるのが よいと思いません
Dialogue: 0,0:05:53.19,0:05:56.02,Default,,0000,0000,0000,,がっ! たっ
Dialogue: 0,0:05:53.19,0:05:56.02,Default,,0000,0000,0000,,だっ! ああ うっ
Dialogue: 0,0:05:56.02,0:05:59.86,Default,,0000,0000,0000,,なっ 何が
Dialogue: 0,0:05:56.02,0:05:59.86,Default,,0000,0000,0000,,もう! 「何が」じゃないわよ
Dialogue: 0,0:05:59.86,0:06:03.63,Default,,0000,0000,0000,,スバル いきなり だめじゃない
Dialogue: 0,0:05:59.86,0:06:03.63,Default,,0000,0000,0000,,そうなのよ 暴力の前に
Dialogue: 0,0:06:03.63,0:06:07.63,Default,,0000,0000,0000,,まず その不細工なウインクを やめろと注意すべきかしら
Dialogue: 0,0:06:07.63,0:06:10.47,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:06:07.63,0:06:10.47,Default,,0000,0000,0000,,そんなに不細工でしたか? 私!
Dialogue: 0,0:06:10.47,0:06:12.64,Default,,0000,0000,0000,,気持ち悪い
Dialogue: 0,0:06:10.47,0:06:12.64,Default,,0000,0000,0000,,あっ あ
Dialogue: 0,0:06:12.64,0:06:15.81,Default,,0000,0000,0000,,スバル 大丈夫?
Dialogue: 0,0:06:12.64,0:06:15.81,Default,,0000,0000,0000,,あっ ああ
Dialogue: 0,0:06:15.81,0:06:18.81,Default,,0000,0000,0000,,切り替えろ 切り替えろ!
Dialogue: 0,0:06:18.81,0:06:21.98,Default,,0000,0000,0000,,ぐずぐずしてる暇はない
Dialogue: 0,0:06:18.81,0:06:21.98,Default,,0000,0000,0000,,早くしないと
Dialogue: 0,0:06:21.98,0:06:24.65,Default,,0000,0000,0000,,でも 1人で行っても だめだ
Dialogue: 0,0:06:24.65,0:06:28.15,Default,,0000,0000,0000,,無策のままじゃ
Dialogue: 0,0:06:24.65,0:06:28.15,Default,,0000,0000,0000,,誰かの力がいる
Dialogue: 0,0:06:28.15,0:06:30.82,Default,,0000,0000,0000,,シリウスに勝てて 権能も効かない
Dialogue: 0,0:06:30.82,0:06:34.16,Default,,0000,0000,0000,,広場に 10分以内に来てくれる強キャラ
Dialogue: 0,0:06:34.16,0:06:36.16,Default,,0000,0000,0000,,ラインハルト!
Dialogue: 0,0:06:36.16,0:06:40.00,Default,,0000,0000,0000,,しつけえぞ!
Dialogue: 0,0:06:36.16,0:06:40.00,Default,,0000,0000,0000,,頼む 緊急事態なんだよ!
Dialogue: 0,0:06:40.00,0:06:43.67,Default,,0000,0000,0000,,ざけんな! 赤毛野郎に 嫌み言われんのは ごめんだ!
Dialogue: 0,0:06:43.67,0:06:46.84,Default,,0000,0000,0000,,とっとと うせろ!
Dialogue: 0,0:06:43.67,0:06:46.84,Default,,0000,0000,0000,,あ ちくしょう!
Dialogue: 0,0:06:46.84,0:06:49.84,Default,,0000,0000,0000,,ラチンス これは冗談じゃない
Dialogue: 0,0:06:49.84,0:06:53.15,Default,,0000,0000,0000,,あと5分もしないうちに やつが
Dialogue: 0,0:06:57.02,0:07:00.32,Default,,0000,0000,0000,,魔女教のやつらが 来るかもしれねえんだ!
Dialogue: 0,0:07:03.96,0:07:06.46,Default,,0000,0000,0000,,あっ ハッ ハァ
Dialogue: 0,0:07:06.46,0:07:10.13,Default,,0000,0000,0000,,てめえ そんな話を どこで
Dialogue: 0,0:07:10.13,0:07:14.63,Default,,0000,0000,0000,,あっ てめえは 確か 魔女教の怠惰を
Dialogue: 0,0:07:14.63,0:07:16.80,Default,,0000,0000,0000,,んっ ちくしょう
Dialogue: 0,0:07:14.63,0:07:19.47,Default,,0000,0000,0000,,これで 何もなきゃ 街なかで 魔法 ぶっ放すのは 都市法違反だ
Dialogue: 0,0:07:19.47,0:07:21.77,Default,,0000,0000,0000,,てめえも 頭 下げろよ!
Dialogue: 0,0:07:25.48,0:07:29.15,Default,,0000,0000,0000,,あれ 見て! きれい!
Dialogue: 0,0:07:25.48,0:07:29.15,Default,,0000,0000,0000,,これで
Dialogue: 0,0:07:29.15,0:07:33.15,Default,,0000,0000,0000,,とても きれいな 輝きでしたね ありがと
Dialogue: 0,0:07:29.15,0:07:33.15,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:07:33.15,0:07:36.32,Default,,0000,0000,0000,,はい! では 皆さん
Dialogue: 0,0:07:36.32,0:07:39.66,Default,,0000,0000,0000,,おはようございます!
Dialogue: 0,0:07:36.32,0:07:39.66,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:07:39.66,0:07:43.66,Default,,0000,0000,0000,,だめだ 見るな! おい ラチンス!
Dialogue: 0,0:07:43.66,0:07:47.83,Default,,0000,0000,0000,,はい 思ったよりも ずっと早く 静かになってもらえましたね
Dialogue: 0,0:07:47.83,0:07:50.67,Default,,0000,0000,0000,,きっと 私の前に 皆さんの気を引いてくれた
Dialogue: 0,0:07:50.67,0:07:56.01,Default,,0000,0000,0000,,お二人のおかげでしょうか
Dialogue: 0,0:07:50.67,0:07:56.01,Default,,0000,0000,0000,,ありがと 拍手!
Dialogue: 0,0:07:56.01,0:07:58.01,Default,,0000,0000,0000,,くっ くっ くっ
Dialogue: 0,0:07:58.01,0:08:01.61,Default,,0000,0000,0000,,うっ! くっ ぐっ! あっ
Dialogue: 0,0:08:01.61,0:08:06.12,Default,,0000,0000,0000,,はい! 皆さんが見てくださるまで 21秒かかりました
Dialogue: 0,0:08:06.12,0:08:08.96,Default,,0000,0000,0000,,ごめんね でも 喜ばしいです
Dialogue: 0,0:08:08.96,0:08:12.46,Default,,0000,0000,0000,,さて それじゃあ 自己紹介しませんと
Dialogue: 0,0:08:12.46,0:08:17.46,Default,,0000,0000,0000,,私は 魔女教大罪司教 憤怒担当
Dialogue: 0,0:08:17.46,0:08:20.97,Default,,0000,0000,0000,,シリウス・ロマネコンティ
Dialogue: 0,0:08:20.97,0:08:23.14,Default,,0000,0000,0000,,と申します
Dialogue: 0,0:08:23.14,0:08:27.81,Default,,0000,0000,0000,,お!
Dialogue: 0,0:08:23.14,0:08:27.81,Default,,0000,0000,0000,,うんうんうん ありがと
Dialogue: 0,0:08:27.81,0:08:31.31,Default,,0000,0000,0000,,皆さんの時間を頂いてしまって ごめんね うんうんうん
Dialogue: 0,0:08:31.31,0:08:35.65,Default,,0000,0000,0000,,でも すぐに終わりにしますから 安心していてくださいね
Dialogue: 0,0:08:35.65,0:08:37.82,Default,,0000,0000,0000,,そうかい
Dialogue: 0,0:08:35.65,0:08:37.82,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:08:37.82,0:08:39.99,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:08:37.82,0:08:39.99,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:37.82,0:08:42.59,Default,,0000,0000,0000,,それなら 僕も 手早く終わりにしたほうが よさそうだね
Dialogue: 0,0:08:45.16,0:08:47.16,Default,,0000,0000,0000,,到着が遅れて すまない
Dialogue: 0,0:08:47.16,0:08:49.50,Default,,0000,0000,0000,,近道を探すのに 手間取ってしまった
Dialogue: 0,0:08:49.50,0:08:52.16,Default,,0000,0000,0000,,僕が呼ばれた理由は わかった
Dialogue: 0,0:08:52.16,0:08:55.00,Default,,0000,0000,0000,,正しい判断だったね ラチンス
Dialogue: 0,0:08:55.00,0:08:58.34,Default,,0000,0000,0000,,それとも 君のほうかな? スバル
Dialogue: 0,0:08:55.00,0:08:58.34,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:58.34,0:09:01.77,Default,,0000,0000,0000,,ラッ ラインハルト!
Dialogue: 0,0:08:58.34,0:09:01.77,Default,,0000,0000,0000,,あっ うわっ!
Dialogue: 0,0:09:01.77,0:09:05.61,Default,,0000,0000,0000,,ああ 僕だよ
Dialogue: 0,0:09:01.77,0:09:05.61,Default,,0000,0000,0000,,大変な状況だったようだ
Dialogue: 0,0:09:05.61,0:09:09.45,Default,,0000,0000,0000,,あれは 大罪司教だね
Dialogue: 0,0:09:05.61,0:09:09.45,Default,,0000,0000,0000,,ああ あいつは
Dialogue: 0,0:09:09.45,0:09:12.62,Default,,0000,0000,0000,,あいつは 他人を洗脳する力の持ち主だ
Dialogue: 0,0:09:12.62,0:09:15.96,Default,,0000,0000,0000,,なるほど
Dialogue: 0,0:09:12.62,0:09:15.96,Default,,0000,0000,0000,,あっ もしかして
Dialogue: 0,0:09:15.96,0:09:20.29,Default,,0000,0000,0000,,赤毛のあなたは 有名な 剣聖さんではありませんか?
Dialogue: 0,0:09:20.29,0:09:23.46,Default,,0000,0000,0000,,ああ そうだ
Dialogue: 0,0:09:20.29,0:09:23.46,Default,,0000,0000,0000,,あいにく まだ その称号は
Dialogue: 0,0:09:23.46,0:09:26.30,Default,,0000,0000,0000,,僕には 過分なものだと わきまえているけれどね
Dialogue: 0,0:09:26.30,0:09:29.47,Default,,0000,0000,0000,,待て ラインハルト
Dialogue: 0,0:09:26.30,0:09:29.47,Default,,0000,0000,0000,,そいつと話し続けちゃ まずい
Dialogue: 0,0:09:29.47,0:09:32.64,Default,,0000,0000,0000,,そのようだね
Dialogue: 0,0:09:29.47,0:09:32.64,Default,,0000,0000,0000,,僕の呼ばれた本懐だ
Dialogue: 0,0:09:32.64,0:09:35.64,Default,,0000,0000,0000,,問題を片づける
Dialogue: 0,0:09:32.64,0:09:35.64,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:09:35.64,0:09:37.64,Default,,0000,0000,0000,,ああ なんて規格外!
Dialogue: 0,0:09:39.81,0:09:42.98,Default,,0000,0000,0000,,ラインハルト そいつは任せた!
Dialogue: 0,0:09:42.98,0:09:46.32,Default,,0000,0000,0000,,ああ なんて圧倒的!
Dialogue: 0,0:09:46.32,0:09:49.66,Default,,0000,0000,0000,,鎖か やっかいだな
Dialogue: 0,0:09:49.66,0:09:51.66,Default,,0000,0000,0000,,ウフフフフ!
Dialogue: 0,0:09:55.49,0:09:58.83,Default,,0000,0000,0000,,アハハ! すごすぎます!
Dialogue: 0,0:09:58.83,0:10:01.33,Default,,0000,0000,0000,,君の腕も立派なものだよ
Dialogue: 0,0:10:01.33,0:10:05.84,Default,,0000,0000,0000,,それだけに 悪事に使われることが 残念でならない
Dialogue: 0,0:10:01.33,0:10:05.84,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:10:08.17,0:10:11.68,Default,,0000,0000,0000,,行こう ここにいちゃいけない!
Dialogue: 0,0:10:08.17,0:10:11.68,Default,,0000,0000,0000,,でっ でも ティーナが!
Dialogue: 0,0:10:11.68,0:10:13.85,Default,,0000,0000,0000,,ここから出るのが先だ!
Dialogue: 0,0:10:13.85,0:10:18.85,Default,,0000,0000,0000,,殺せ! 殺せ! 殺せ!
Dialogue: 0,0:10:18.85,0:10:23.52,Default,,0000,0000,0000,,あ
Dialogue: 0,0:10:18.85,0:10:23.52,Default,,0000,0000,0000,,殺せ! 殺せ! 殺せ!
Dialogue: 0,0:10:23.52,0:10:27.36,Default,,0000,0000,0000,,殺せ! 殺せ!
Dialogue: 0,0:10:23.52,0:10:27.36,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:10:27.36,0:10:29.36,Default,,0000,0000,0000,,殺せ!
Dialogue: 0,0:10:29.36,0:10:34.87,Default,,0000,0000,0000,,一つになれること
Dialogue: 0,0:10:29.36,0:10:34.87,Default,,0000,0000,0000,,それこそが愛でしょう?
Dialogue: 0,0:10:34.87,0:10:36.87,Default,,0000,0000,0000,,でしたら これは紛れもなく
Dialogue: 0,0:10:36.87,0:10:40.54,Default,,0000,0000,0000,,愛が生み出した理想郷とは 思いませんか?
Dialogue: 0,0:10:40.54,0:10:42.71,Default,,0000,0000,0000,,最後に言い残す言葉は?
Dialogue: 0,0:10:42.71,0:10:47.21,Default,,0000,0000,0000,,ありがと ごめんね
Dialogue: 0,0:10:42.71,0:10:47.21,Default,,0000,0000,0000,,では 1つだけ ご忠告を
Dialogue: 0,0:10:47.21,0:10:50.88,Default,,0000,0000,0000,,他の大罪司教は 私のように おとなしくはないので
Dialogue: 0,0:10:50.88,0:10:54.89,Default,,0000,0000,0000,,遺言なんて聞こうとすると ひどい目に遭ってしまいますよ
Dialogue: 0,0:10:54.89,0:10:58.39,Default,,0000,0000,0000,,肝に銘じておくことにするよ
Dialogue: 0,0:10:54.89,0:10:58.39,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:10:58.39,0:11:02.33,Default,,0000,0000,0000,,なんか おかしい
Dialogue: 0,0:10:58.39,0:11:02.33,Default,,0000,0000,0000,,止めなきゃ まずい
Dialogue: 0,0:11:02.33,0:11:07.00,Default,,0000,0000,0000,,わかり合うこと 譲り合うこと 認め合うこと 話し合うこと
Dialogue: 0,0:11:07.00,0:11:11.50,Default,,0000,0000,0000,,そうして 一つになることこそが 愛のあるべき真実の形!
Dialogue: 0,0:11:11.50,0:11:16.51,Default,,0000,0000,0000,,ラインハルト!
Dialogue: 0,0:11:11.50,0:11:16.51,Default,,0000,0000,0000,,うっ! ぐっ うっ 殺せ!
Dialogue: 0,0:11:20.51,0:11:24.02,Default,,0000,0000,0000,,ああ 優しい世界
Dialogue: 0,0:11:26.02,0:11:28.02,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:11:32.02,0:11:34.33,Default,,0000,0000,0000,,ハッ そんな
Dialogue: 0,0:11:40.20,0:11:42.54,Default,,0000,0000,0000,,そして 歌のあとは ご歓談
Dialogue: 0,0:11:42.54,0:11:44.70,Default,,0000,0000,0000,,ナツキ様は その時間に向けて
Dialogue: 0,0:11:44.70,0:11:47.87,Default,,0000,0000,0000,,おやつなんて準備されるのが よいと思いませんか?
Dialogue: 0,0:11:47.87,0:11:51.88,Default,,0000,0000,0000,,痛た! 痛た!
Dialogue: 0,0:11:47.87,0:11:51.88,Default,,0000,0000,0000,,痛い! 痛いのよ スバル!
Dialogue: 0,0:11:51.88,0:11:54.88,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:51.88,0:11:54.88,Default,,0000,0000,0000,,どうなされたんです?
Dialogue: 0,0:11:54.88,0:11:57.55,Default,,0000,0000,0000,,いきなり 幼女様の手を破壊しようとして
Dialogue: 0,0:11:57.55,0:11:59.99,Default,,0000,0000,0000,,ああ かわいそうに 私が なめなめなめ なめて差し
Dialogue: 0,0:11:59.99,0:12:01.99,Default,,0000,0000,0000,,いらんお世話かしら!
Dialogue: 0,0:12:01.99,0:12:05.83,Default,,0000,0000,0000,,これで 3回目
Dialogue: 0,0:12:01.99,0:12:05.83,Default,,0000,0000,0000,,ラインハルトでも だめか
Dialogue: 0,0:12:05.83,0:12:10.00,Default,,0000,0000,0000,,スバル 大丈夫?
Dialogue: 0,0:12:05.83,0:12:10.00,Default,,0000,0000,0000,,あっ うん なんでもない
Dialogue: 0,0:12:10.00,0:12:13.33,Default,,0000,0000,0000,,あっ じゃあ エミリアたんは 歌を楽しんでてちょうだいな
Dialogue: 0,0:12:13.33,0:12:15.67,Default,,0000,0000,0000,,はい 楽しんでです!
Dialogue: 0,0:12:15.67,0:12:18.50,Default,,0000,0000,0000,,ベア子 お前は 俺と一緒に買い物班な
Dialogue: 0,0:12:18.50,0:12:22.34,Default,,0000,0000,0000,,仲よく いちゃいちゃしてこうぜ
Dialogue: 0,0:12:18.50,0:12:22.34,Default,,0000,0000,0000,,きゅ 急に 何を言いだして
Dialogue: 0,0:12:22.34,0:12:27.85,Default,,0000,0000,0000,,あっ ううん わかったのよ
Dialogue: 0,0:12:27.85,0:12:31.35,Default,,0000,0000,0000,,エミリアたん すぐに戻るから
Dialogue: 0,0:12:27.85,0:12:31.35,Default,,0000,0000,0000,,うん
Dialogue: 0,0:12:35.02,0:12:37.02,Default,,0000,0000,0000,,ふむ
Dialogue: 0,0:12:37.02,0:12:41.03,Default,,0000,0000,0000,,いいかげん 何があったか 説明してもらうかしら
Dialogue: 0,0:12:41.03,0:12:45.20,Default,,0000,0000,0000,,今から向かう広場に 魔女教が現れる
Dialogue: 0,0:12:45.20,0:12:47.20,Default,,0000,0000,0000,,魔女教
Dialogue: 0,0:12:47.20,0:12:51.37,Default,,0000,0000,0000,,そんな心配そうな顔 する必要ないのよ
Dialogue: 0,0:12:51.37,0:12:55.04,Default,,0000,0000,0000,,どこで何を知ったか 根拠なんて いらないかしら
Dialogue: 0,0:12:55.04,0:12:59.71,Default,,0000,0000,0000,,スバルが話してくれた
Dialogue: 0,0:12:55.04,0:12:59.71,Default,,0000,0000,0000,,それが ベティーの信じる根拠なのよ
Dialogue: 0,0:12:59.71,0:13:03.48,Default,,0000,0000,0000,,ベアトリス
Dialogue: 0,0:12:59.71,0:13:03.48,Default,,0000,0000,0000,,ほんと お前には助けられるよ
Dialogue: 0,0:13:03.48,0:13:07.65,Default,,0000,0000,0000,,フフン! 当然かしら
Dialogue: 0,0:13:03.48,0:13:07.65,Default,,0000,0000,0000,,話せることから話してみるのよ
Dialogue: 0,0:13:07.65,0:13:12.49,Default,,0000,0000,0000,,そうだな
Dialogue: 0,0:13:07.65,0:13:12.49,Default,,0000,0000,0000,,現れるのは 大罪司教の憤怒だ
Dialogue: 0,0:13:12.49,0:13:17.66,Default,,0000,0000,0000,,そいつの能力だが
Dialogue: 0,0:13:12.49,0:13:17.66,Default,,0000,0000,0000,,感情とか感覚の共有って感じだ
Dialogue: 0,0:13:17.66,0:13:20.67,Default,,0000,0000,0000,,早い話 危険を危険と思えなくなる
Dialogue: 0,0:13:20.67,0:13:23.00,Default,,0000,0000,0000,,それなら 感覚の共有は?
Dialogue: 0,0:13:23.00,0:13:26.67,Default,,0000,0000,0000,,そのまま
Dialogue: 0,0:13:23.00,0:13:26.67,Default,,0000,0000,0000,,相手が痛がれば こっちも痛い
Dialogue: 0,0:13:26.67,0:13:31.18,Default,,0000,0000,0000,,大罪司教の首をはねたら それを見ている連中の首も 吹っ飛ぶ
Dialogue: 0,0:13:31.18,0:13:34.85,Default,,0000,0000,0000,,うん
Dialogue: 0,0:13:31.18,0:13:34.85,Default,,0000,0000,0000,,お手上げすぎるだろ?
Dialogue: 0,0:13:34.85,0:13:37.18,Default,,0000,0000,0000,,だから お前の知恵と力を借りたいんだ
Dialogue: 0,0:13:37.18,0:13:41.52,Default,,0000,0000,0000,,一応 ラインハルトを呼んで共闘するって 鬼札も考えてるんだが
Dialogue: 0,0:13:41.52,0:13:44.69,Default,,0000,0000,0000,,それは無理かしら
Dialogue: 0,0:13:41.52,0:13:44.69,Default,,0000,0000,0000,,無理? なんで?
Dialogue: 0,0:13:44.69,0:13:47.19,Default,,0000,0000,0000,,あれの体質が原因なのよ
Dialogue: 0,0:13:47.19,0:13:49.70,Default,,0000,0000,0000,,ラインハルトと同じ戦場に立つと
Dialogue: 0,0:13:49.70,0:13:53.37,Default,,0000,0000,0000,,ベティーは ただの かわいい子に なってしまうかしら
Dialogue: 0,0:13:49.70,0:13:53.37,Default,,0000,0000,0000,,はっ?
Dialogue: 0,0:13:53.37,0:13:57.04,Default,,0000,0000,0000,,ラインハルトは この世界の異質さの頂点なのよ
Dialogue: 0,0:13:57.04,0:13:59.04,Default,,0000,0000,0000,,ただ存在するだけで
Dialogue: 0,0:13:59.04,0:14:02.14,Default,,0000,0000,0000,,周囲のマナは 盲目的に あれに従おうとする
Dialogue: 0,0:14:02.14,0:14:05.98,Default,,0000,0000,0000,,魔法使いも 精霊使いも 力を発揮できなくなるかしら
Dialogue: 0,0:14:05.98,0:14:08.48,Default,,0000,0000,0000,,そんなことが
Dialogue: 0,0:14:08.48,0:14:10.98,Default,,0000,0000,0000,,ベア子と俺だけで なんとかするしか
Dialogue: 0,0:14:10.98,0:14:14.49,Default,,0000,0000,0000,,スバル もしかしたら 1つ 対処法がなくはないのよ
Dialogue: 0,0:14:14.49,0:14:16.49,Default,,0000,0000,0000,,対処法? どんな?
Dialogue: 0,0:14:16.49,0:14:19.16,Default,,0000,0000,0000,,はっきり言えば シャマクの出番かしら
Dialogue: 0,0:14:19.16,0:14:21.66,Default,,0000,0000,0000,,あっ シャマクさん きた!
Dialogue: 0,0:14:21.66,0:14:24.50,Default,,0000,0000,0000,,シャマクの効果は 術の対象の意識を
Dialogue: 0,0:14:24.50,0:14:27.50,Default,,0000,0000,0000,,世界と 強制的に切り離すことなのよ
Dialogue: 0,0:14:27.50,0:14:33.01,Default,,0000,0000,0000,,つまり 敵の影響範囲にある人間を
Dialogue: 0,0:14:27.50,0:14:33.01,Default,,0000,0000,0000,,まとめて シャマクで取り込めば
Dialogue: 0,0:14:33.01,0:14:36.18,Default,,0000,0000,0000,,そうか! 確かに シャマクなら どんな問題でも
Dialogue: 0,0:14:36.18,0:14:39.51,Default,,0000,0000,0000,,その なみなみならない信用は 謎すぎるかしら
Dialogue: 0,0:14:39.51,0:14:43.35,Default,,0000,0000,0000,,待てよ! いくら ベア子でも シャマクの悪口は許さねえぞ
Dialogue: 0,0:14:43.35,0:14:47.35,Default,,0000,0000,0000,,本気で 何が スバルに そこまで言わせているのよ
Dialogue: 0,0:14:47.35,0:14:51.36,Default,,0000,0000,0000,,とにかく あの能力を 無効化できれば こっちのもんだ
Dialogue: 0,0:14:51.36,0:14:53.69,Default,,0000,0000,0000,,あとは
Dialogue: 0,0:14:51.36,0:14:53.69,Default,,0000,0000,0000,,その大罪司教を
Dialogue: 0,0:14:53.69,0:14:57.53,Default,,0000,0000,0000,,やっつけるだけかしら
Dialogue: 0,0:14:53.69,0:14:57.53,Default,,0000,0000,0000,,問題は そこだよな
Dialogue: 0,0:14:57.53,0:14:59.97,Default,,0000,0000,0000,,それなら 私の出番じゃないかしら?
Dialogue: 0,0:14:59.97,0:15:03.97,Default,,0000,0000,0000,,えっ エミリアたん? どうして
Dialogue: 0,0:15:03.97,0:15:07.14,Default,,0000,0000,0000,,様子が おかしいと思ったら やっぱり
Dialogue: 0,0:15:07.14,0:15:09.81,Default,,0000,0000,0000,,公園で待ってるよう 言っておいたはずなのよ
Dialogue: 0,0:15:09.81,0:15:12.48,Default,,0000,0000,0000,,いけない子かしら
Dialogue: 0,0:15:09.81,0:15:12.48,Default,,0000,0000,0000,,ごめんね
Dialogue: 0,0:15:12.48,0:15:16.48,Default,,0000,0000,0000,,私も待ってるつもりだったの
Dialogue: 0,0:15:12.48,0:15:16.48,Default,,0000,0000,0000,,でも プリシラに言われて
Dialogue: 0,0:15:16.48,0:15:18.48,Default,,0000,0000,0000,,あの赤い娘に?
Dialogue: 0,0:15:18.48,0:15:21.32,Default,,0000,0000,0000,,今 追いかけないと 後悔するかもって
Dialogue: 0,0:15:21.32,0:15:24.99,Default,,0000,0000,0000,,何もなかったら 私も戻るつもりだったけど
Dialogue: 0,0:15:24.99,0:15:28.66,Default,,0000,0000,0000,,魔女教が現れるんでしょう?
Dialogue: 0,0:15:24.99,0:15:28.66,Default,,0000,0000,0000,,ちゃんと聞こえてたんだから
Dialogue: 0,0:15:28.66,0:15:32.00,Default,,0000,0000,0000,,エミリアたん 気持ちは うれしい
Dialogue: 0,0:15:28.66,0:15:32.00,Default,,0000,0000,0000,,うれしいけど
Dialogue: 0,0:15:32.00,0:15:34.83,Default,,0000,0000,0000,,スバルが戻れって言っても 戻らないわ
Dialogue: 0,0:15:34.83,0:15:37.50,Default,,0000,0000,0000,,魔女教のことは 私も ひと事じゃないんだもの
Dialogue: 0,0:15:37.50,0:15:42.01,Default,,0000,0000,0000,,エミリア!
Dialogue: 0,0:15:37.50,0:15:42.01,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:37.50,0:15:42.01,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:15:42.01,0:15:44.51,Default,,0000,0000,0000,,怒ったふりをしてもだめよ
Dialogue: 0,0:15:44.51,0:15:48.68,Default,,0000,0000,0000,,私が怒られて困るのは 私が悪いことをしたときだけ
Dialogue: 0,0:15:48.68,0:15:53.35,Default,,0000,0000,0000,,聞き分けがないのは 私じゃなくて 今は スバルのほうだもの
Dialogue: 0,0:15:50.68,0:15:53.35,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:53.35,0:15:58.19,Default,,0000,0000,0000,,そうやって スバルが 私を 守ろうとしてくれてるの わかる
Dialogue: 0,0:15:58.19,0:16:02.63,Default,,0000,0000,0000,,でも それで スバルが傷つくのに 目をつむるのは 絶対に嫌
Dialogue: 0,0:16:02.63,0:16:05.63,Default,,0000,0000,0000,,スバルが戦うとき 私も戦う
Dialogue: 0,0:16:05.63,0:16:09.30,Default,,0000,0000,0000,,スバルが 誰かを守ろうとするなら 私も手伝う
Dialogue: 0,0:16:09.30,0:16:12.14,Default,,0000,0000,0000,,スバルが 私を守ってくれるみたいに
Dialogue: 0,0:16:12.14,0:16:14.81,Default,,0000,0000,0000,,私も スバルを守ってあげたいの
Dialogue: 0,0:16:14.81,0:16:19.65,Default,,0000,0000,0000,,だって スバル 今にも泣きそうな顔してる
Dialogue: 0,0:16:19.65,0:16:22.82,Default,,0000,0000,0000,,スバル もう 諦めたほうがいいのよ
Dialogue: 0,0:16:22.82,0:16:26.15,Default,,0000,0000,0000,,ベティーにも エミリアの気持ちが わかるかしら
Dialogue: 0,0:16:26.15,0:16:30.32,Default,,0000,0000,0000,,だから 説得したくないのよ
Dialogue: 0,0:16:26.15,0:16:30.32,Default,,0000,0000,0000,,フゥ
Dialogue: 0,0:16:30.32,0:16:33.16,Default,,0000,0000,0000,,魔女教は きっと 君を狙ってくる
Dialogue: 0,0:16:33.16,0:16:36.33,Default,,0000,0000,0000,,まず 何より 自分第一で行動してくれよ
Dialogue: 0,0:16:36.33,0:16:38.33,Default,,0000,0000,0000,,うん わかった
Dialogue: 0,0:16:38.33,0:16:41.33,Default,,0000,0000,0000,,捕まっても スバルが助けてくれる って 信じてるから
Dialogue: 0,0:16:41.33,0:16:44.00,Default,,0000,0000,0000,,縁起でもないこと 言わないでくれよ
Dialogue: 0,0:16:44.00,0:16:46.67,Default,,0000,0000,0000,,あっ あいつだ!
Dialogue: 0,0:16:44.00,0:16:46.67,Default,,0000,0000,0000,,あいつが 魔女教
Dialogue: 0,0:16:46.67,0:16:49.68,Default,,0000,0000,0000,,ウル・ヒューマ!
Dialogue: 0,0:16:49.68,0:16:53.01,Default,,0000,0000,0000,,エッ エミリアたん?
Dialogue: 0,0:16:49.68,0:16:53.01,Default,,0000,0000,0000,,先制攻撃してみたんだけど
Dialogue: 0,0:16:53.01,0:16:55.51,Default,,0000,0000,0000,,だめだった?
Dialogue: 0,0:16:53.01,0:16:55.51,Default,,0000,0000,0000,,グッジョブ! だけど
Dialogue: 0,0:16:55.51,0:16:59.69,Default,,0000,0000,0000,,思った以上だったから驚いて
Dialogue: 0,0:16:55.51,0:16:59.69,Default,,0000,0000,0000,,ベア子 やったと思うか?
Dialogue: 0,0:16:59.69,0:17:04.46,Default,,0000,0000,0000,,とりあえず 周りの連中には やらかしたと思われてるかしら
Dialogue: 0,0:17:01.62,0:17:04.46,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:17:04.46,0:17:07.79,Default,,0000,0000,0000,,あっ えっと 悪意があって こんなことしたわけじゃないんだ
Dialogue: 0,0:17:07.79,0:17:10.96,Default,,0000,0000,0000,,俺たちはだな
Dialogue: 0,0:17:07.79,0:17:10.96,Default,,0000,0000,0000,,だめよ スバル 後ろに下がっていて
Dialogue: 0,0:17:10.96,0:17:13.47,Default,,0000,0000,0000,,みんなの目 正気じゃない
Dialogue: 0,0:17:13.47,0:17:17.80,Default,,0000,0000,0000,,ベア子 シャマクの準備は?
Dialogue: 0,0:17:13.47,0:17:17.80,Default,,0000,0000,0000,,しくったのよ
Dialogue: 0,0:17:17.80,0:17:19.81,Default,,0000,0000,0000,,これは邪法かしら
Dialogue: 0,0:17:19.81,0:17:23.98,Default,,0000,0000,0000,,魔法より 呪いや呪術に近い 魂への干渉なのよ
Dialogue: 0,0:17:23.98,0:17:26.31,Default,,0000,0000,0000,,シャマクじゃ 太刀打ちできないかしら
Dialogue: 0,0:17:26.31,0:17:29.82,Default,,0000,0000,0000,,臭い 臭い 臭い 臭い
Dialogue: 0,0:17:26.31,0:17:29.82,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:17:29.82,0:17:33.49,Default,,0000,0000,0000,,臭い 臭い 臭い 臭い 臭い!
Dialogue: 0,0:17:33.49,0:17:36.99,Default,,0000,0000,0000,,臭う 臭う 女の臭い!
Dialogue: 0,0:17:36.99,0:17:42.33,Default,,0000,0000,0000,,薄汚くて いまいましい 私から
Dialogue: 0,0:17:36.99,0:17:42.33,Default,,0000,0000,0000,,あの人を奪う 半魔の悪臭
Dialogue: 0,0:17:42.33,0:17:46.00,Default,,0000,0000,0000,,あ 忌まわしい! 私から あの人を奪っただけでは
Dialogue: 0,0:17:46.00,0:17:49.33,Default,,0000,0000,0000,,まだ 飽き足らないのか?
Dialogue: 0,0:17:46.00,0:17:49.33,Default,,0000,0000,0000,,薄汚い半魔!
Dialogue: 0,0:17:49.33,0:17:51.34,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:17:49.33,0:17:51.34,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:17:51.34,0:17:55.84,Default,,0000,0000,0000,,私は 魔女教大罪司教 憤怒担当!
Dialogue: 0,0:17:51.34,0:17:55.84,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:17:55.84,0:17:59.68,Default,,0000,0000,0000,,シリウス・ロマネコンティ!!
Dialogue: 0,0:17:59.68,0:18:02.11,Default,,0000,0000,0000,,いまいましい くそ半魔!
Dialogue: 0,0:18:02.11,0:18:06.62,Default,,0000,0000,0000,,お前を焼き焦がして 燃えかすを 夫の墓前に ばらまいてやる!
Dialogue: 0,0:18:06.62,0:18:10.29,Default,,0000,0000,0000,,あいつ これまでと 全然 様子が違うじゃねえか
Dialogue: 0,0:18:10.29,0:18:13.46,Default,,0000,0000,0000,,うじばえみたいに 焼いても焼いても湧いてきて
Dialogue: 0,0:18:13.46,0:18:16.30,Default,,0000,0000,0000,,なんの恨みがあるんだ? ええ?
Dialogue: 0,0:18:16.30,0:18:18.96,Default,,0000,0000,0000,,私には 喪に服す自由もないと?
Dialogue: 0,0:18:18.96,0:18:21.30,Default,,0000,0000,0000,,どこまで どこまで!
Dialogue: 0,0:18:21.30,0:18:25.14,Default,,0000,0000,0000,,あなたが 何を言ってるのか 私には わからないわ
Dialogue: 0,0:18:25.14,0:18:28.31,Default,,0000,0000,0000,,あなたが 私に怒ってるなら 話を聞かせて
Dialogue: 0,0:18:28.31,0:18:32.31,Default,,0000,0000,0000,,いきなり仕掛けたのは こっちだから 怒るのは当然だもの
Dialogue: 0,0:18:32.31,0:18:35.81,Default,,0000,0000,0000,,でも 周りの人たちは関係ない
Dialogue: 0,0:18:32.31,0:18:35.81,Default,,0000,0000,0000,,解放してあげて
Dialogue: 0,0:18:35.81,0:18:38.65,Default,,0000,0000,0000,,上から目線で ねだってんじゃあない!
Dialogue: 0,0:18:38.65,0:18:43.49,Default,,0000,0000,0000,,怒るのが当然? なら 謝れよ!
Dialogue: 0,0:18:38.65,0:18:43.49,Default,,0000,0000,0000,,はいつくばって許しを乞え!
Dialogue: 0,0:18:43.49,0:18:46.49,Default,,0000,0000,0000,,その上で 尻から はらわたを焼いてやる!
Dialogue: 0,0:18:46.49,0:18:49.50,Default,,0000,0000,0000,,んっ あなた 話が通じない人ね
Dialogue: 0,0:18:49.50,0:18:52.30,Default,,0000,0000,0000,,それなら 私にも考えがあるんだからね!
Dialogue: 0,0:18:54.50,0:18:57.84,Default,,0000,0000,0000,,うん! こらしょ!
Dialogue: 0,0:18:54.50,0:18:57.84,Default,,0000,0000,0000,,どっこいしょ! やっ!
Dialogue: 0,0:18:57.84,0:19:00.11,Default,,0000,0000,0000,,チッ! くそ半魔!
Dialogue: 0,0:19:00.11,0:19:04.28,Default,,0000,0000,0000,,そんな悪口 何回も言わないで!
Dialogue: 0,0:19:04.28,0:19:06.28,Default,,0000,0000,0000,,ざまあ あっ!
Dialogue: 0,0:19:08.45,0:19:13.12,Default,,0000,0000,0000,,よいしょ! えい!
Dialogue: 0,0:19:08.45,0:19:13.12,Default,,0000,0000,0000,,てい! やっ! それ!
Dialogue: 0,0:19:13.12,0:19:16.52,Default,,0000,0000,0000,,ああ あ 煩わしい!
Dialogue: 0,0:19:13.12,0:19:16.52,Default,,0000,0000,0000,,うりゃ! うりゃりゃ! えい!
Dialogue: 0,0:19:19.63,0:19:22.29,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:19:19.63,0:19:22.29,Default,,0000,0000,0000,,やぁ!
Dialogue: 0,0:19:22.29,0:19:26.47,Default,,0000,0000,0000,,くそが! 半魔が! うじばえ!
Dialogue: 0,0:19:22.29,0:19:26.47,Default,,0000,0000,0000,,いらだたしい!
Dialogue: 0,0:19:26.47,0:19:28.63,Default,,0000,0000,0000,,んっ 押してる
Dialogue: 0,0:19:26.47,0:19:28.63,Default,,0000,0000,0000,,腹立たしい!
Dialogue: 0,0:19:28.63,0:19:31.80,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:28.63,0:19:31.80,Default,,0000,0000,0000,,くそ虫が!
Dialogue: 0,0:19:31.80,0:19:33.81,Default,,0000,0000,0000,,エミリア 長引かせてくれ!
Dialogue: 0,0:19:33.81,0:19:36.81,Default,,0000,0000,0000,,あんまり むちゃできないからね!
Dialogue: 0,0:19:33.81,0:19:36.81,Default,,0000,0000,0000,,ああ!
Dialogue: 0,0:19:36.81,0:19:38.81,Default,,0000,0000,0000,,ベア子
Dialogue: 0,0:19:36.81,0:19:38.81,Default,,0000,0000,0000,,よいしょ
Dialogue: 0,0:19:38.81,0:19:41.15,Default,,0000,0000,0000,,ムラク
Dialogue: 0,0:19:41.15,0:19:45.98,Default,,0000,0000,0000,,うお!
Dialogue: 0,0:19:41.15,0:19:45.98,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:19:45.98,0:19:50.82,Default,,0000,0000,0000,,舌 かむなよ ベア子!
Dialogue: 0,0:19:45.98,0:19:50.82,Default,,0000,0000,0000,,ふん!
Dialogue: 0,0:19:45.98,0:19:50.82,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:19:50.82,0:19:53.33,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:19:53.33,0:19:56.50,Default,,0000,0000,0000,,ルスベル 大丈夫か!?
Dialogue: 0,0:19:53.33,0:19:56.50,Default,,0000,0000,0000,,ん!
Dialogue: 0,0:19:56.50,0:20:00.00,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:56.50,0:20:00.00,Default,,0000,0000,0000,,ティーナ
Dialogue: 0,0:20:00.00,0:20:02.00,Default,,0000,0000,0000,,えい! やっ! ハッ!
Dialogue: 0,0:20:02.00,0:20:05.00,Default,,0000,0000,0000,,たぎる熱情こそ 心の震え!
Dialogue: 0,0:20:02.00,0:20:05.00,Default,,0000,0000,0000,,うっ! それ! フッ うっ!
Dialogue: 0,0:20:05.00,0:20:08.01,Default,,0000,0000,0000,,ああ ああ 憤怒!
Dialogue: 0,0:20:08.01,0:20:10.01,Default,,0000,0000,0000,,キャッ!
Dialogue: 0,0:20:10.01,0:20:13.51,Default,,0000,0000,0000,,男を誘う瞳
Dialogue: 0,0:20:10.01,0:20:13.51,Default,,0000,0000,0000,,男を誘う鈴の音の声
Dialogue: 0,0:20:13.51,0:20:16.01,Default,,0000,0000,0000,,男を誘う きらめく銀髪
Dialogue: 0,0:20:16.01,0:20:18.02,Default,,0000,0000,0000,,ああ 汚らわしい!
Dialogue: 0,0:20:18.02,0:20:23.36,Default,,0000,0000,0000,,そうまでして 私から
Dialogue: 0,0:20:18.02,0:20:23.36,Default,,0000,0000,0000,,あの人を奪うのか? 泥棒猫め!
Dialogue: 0,0:20:23.36,0:20:27.53,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:20:23.36,0:20:27.53,Default,,0000,0000,0000,,ちょっと 変なこと言わないで!
Dialogue: 0,0:20:27.53,0:20:30.53,Default,,0000,0000,0000,,この目も 声も 銀色の髪も
Dialogue: 0,0:20:30.53,0:20:33.03,Default,,0000,0000,0000,,私が大好きな人が 褒めてくれたもの!
Dialogue: 0,0:20:33.03,0:20:36.70,Default,,0000,0000,0000,,世界で いちばん かっこいい 女の人と おんなじなの!
Dialogue: 0,0:20:36.70,0:20:39.54,Default,,0000,0000,0000,,それを変なふうに言って 怒ったから!
Dialogue: 0,0:20:39.54,0:20:43.21,Default,,0000,0000,0000,,怒る? 怒るだと?
Dialogue: 0,0:20:39.54,0:20:43.21,Default,,0000,0000,0000,,冗談じゃない!
Dialogue: 0,0:20:43.21,0:20:47.55,Default,,0000,0000,0000,,それは 私のものだ!
Dialogue: 0,0:20:47.55,0:20:49.55,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:20:47.55,0:20:49.55,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:20:49.55,0:20:54.39,Default,,0000,0000,0000,,私が あの人から もらったものだ
Dialogue: 0,0:20:49.55,0:20:54.39,Default,,0000,0000,0000,,それを私から奪おうなんて
Dialogue: 0,0:20:54.39,0:20:58.06,Default,,0000,0000,0000,,やめろ! やめろ やめろ やめろ やめ うっ
Dialogue: 0,0:20:58.06,0:21:00.36,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:21:05.16,0:21:08.83,Default,,0000,0000,0000,,ん! うぅ
Dialogue: 0,0:21:05.16,0:21:08.83,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:21:08.83,0:21:11.00,Default,,0000,0000,0000,,ティーナ!
Dialogue: 0,0:21:08.83,0:21:11.00,Default,,0000,0000,0000,,えっ? くっ
Dialogue: 0,0:21:11.00,0:21:13.34,Default,,0000,0000,0000,,くっ!
Dialogue: 0,0:21:11.00,0:21:13.34,Default,,0000,0000,0000,,ん!
Dialogue: 0,0:21:13.34,0:21:17.84,Default,,0000,0000,0000,,その憤怒 お前が持つのは もったいない
Dialogue: 0,0:21:17.84,0:21:21.01,Default,,0000,0000,0000,,キャッ! あっ くっ
Dialogue: 0,0:21:21.01,0:21:24.52,Default,,0000,0000,0000,,あっ うっ
Dialogue: 0,0:21:21.01,0:21:24.52,Default,,0000,0000,0000,,エミリア!
Dialogue: 0,0:21:24.52,0:21:29.02,Default,,0000,0000,0000,,甘美な激情を虫が抱くな
Dialogue: 0,0:21:24.52,0:21:29.02,Default,,0000,0000,0000,,へどが出る
Dialogue: 0,0:21:29.02,0:21:32.52,Default,,0000,0000,0000,,ありがと ごめんね
Dialogue: 0,0:21:32.52,0:21:36.36,Default,,0000,0000,0000,,うっ エミリア!
Dialogue: 0,0:21:32.52,0:21:36.36,Default,,0000,0000,0000,,スバル だめなのよ
Dialogue: 0,0:21:36.36,0:21:39.56,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:21:36.36,0:21:39.56,Default,,0000,0000,0000,,間に合った
Dialogue: 0,0:21:36.36,0:21:39.56,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:47.87,0:21:52.04,Default,,0000,0000,0000,,お前は
Dialogue: 0,0:21:47.87,0:21:52.04,Default,,0000,0000,0000,,僕は 彼女を迎えに来た
Dialogue: 0,0:21:52.04,0:21:54.71,Default,,0000,0000,0000,,間に合って 本当によかったよ
Dialogue: 0,0:21:54.71,0:21:56.72,Default,,0000,0000,0000,,迎え?
Dialogue: 0,0:21:56.72,0:21:59.22,Default,,0000,0000,0000,,妻に迎える女性の手を取るのは
Dialogue: 0,0:21:59.22,0:22:03.66,Default,,0000,0000,0000,,男として 人として 当然のことじゃないかい?
Dialogue: 0,0:22:03.66,0:22:05.66,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:22:05.66,0:22:12.50,Default,,0000,0000,0000,,僕は 魔女教大罪司教 強欲担当
Dialogue: 0,0:22:05.66,0:22:12.50,Default,,0000,0000,0000,,レグルス・コルニアス
Dialogue: 0,0:22:12.50,0:22:15.50,Default,,0000,0000,0000,,約束どおり 彼女を
Dialogue: 0,0:22:15.50,0:22:19.30,Default,,0000,0000,0000,,僕の79番目の妻にする
