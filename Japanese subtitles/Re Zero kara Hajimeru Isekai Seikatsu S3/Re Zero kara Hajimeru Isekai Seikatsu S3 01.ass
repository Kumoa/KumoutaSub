Dialogue: 0,0:00:04.17,0:00:09.01,Default,,0000,0000,0000,,ハァハァ ハァハァ ハァハァハァ
Dialogue: 0,0:00:09.01,0:00:12.51,Default,,0000,0000,0000,,ハァハァ ハァハァハァ
Dialogue: 0,0:00:12.51,0:00:16.52,Default,,0000,0000,0000,,よっ! うっ! んっ ぐっ!
Dialogue: 0,0:00:16.52,0:00:20.69,Default,,0000,0000,0000,,とっ んっ とっ!
Dialogue: 0,0:00:20.69,0:00:24.86,Default,,0000,0000,0000,,んしょ! ハァハァ ハァハァ ハァハァ
Dialogue: 0,0:00:24.86,0:00:28.70,Default,,0000,0000,0000,,んっ フン!
Dialogue: 0,0:00:28.70,0:00:31.87,Default,,0000,0000,0000,,どりゃ!
Dialogue: 0,0:00:31.87,0:00:35.87,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:00:35.87,0:00:37.87,Default,,0000,0000,0000,,ダハハ
Dialogue: 0,0:00:37.87,0:00:43.54,Default,,0000,0000,0000,,ハァハァ ハァハァハァ フッフフ
Dialogue: 0,0:00:43.54,0:00:48.15,Default,,0000,0000,0000,,よっしゃ! クリアー!
Dialogue: 0,0:00:52.39,0:00:54.72,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:00:54.72,0:00:56.89,Default,,0000,0000,0000,,スバル
Dialogue: 0,0:00:54.72,0:00:56.89,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:56.89,0:00:59.56,Default,,0000,0000,0000,,お疲れさまだったかしら?
Dialogue: 0,0:00:59.56,0:01:04.33,Default,,0000,0000,0000,,ハァ おっ 助かる
Dialogue: 0,0:01:04.33,0:01:09.00,Default,,0000,0000,0000,,かぁ! ちょっと冷やしてあって 生き返るわ!
Dialogue: 0,0:01:09.00,0:01:12.17,Default,,0000,0000,0000,,礼なら ペトラに 直接 言ってやるといいのよ
Dialogue: 0,0:01:12.17,0:01:17.01,Default,,0000,0000,0000,,きっと あの娘は 飛んで喜ぶかしら
Dialogue: 0,0:01:12.17,0:01:17.01,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:01:17.01,0:01:20.35,Default,,0000,0000,0000,,俺とベア子の契約から もう 1年か
Dialogue: 0,0:01:20.35,0:01:22.68,Default,,0000,0000,0000,,時間 過ぎるの 早えし
Dialogue: 0,0:01:22.68,0:01:26.35,Default,,0000,0000,0000,,俺のベア子が 今日も かわいくて 感慨深いぜ
Dialogue: 0,0:01:26.35,0:01:30.36,Default,,0000,0000,0000,,フフーン! ベティーが かわいいのは 当然のことなのよ
Dialogue: 0,0:01:30.36,0:01:33.53,Default,,0000,0000,0000,,俺も この1年で すっかり たくましくなったしな
Dialogue: 0,0:01:33.53,0:01:37.03,Default,,0000,0000,0000,,ププー! かしら やられたのよ
Dialogue: 0,0:01:37.03,0:01:39.53,Default,,0000,0000,0000,,今の冗談は おもしろかったかしら
Dialogue: 0,0:01:39.53,0:01:42.20,Default,,0000,0000,0000,,いや 冗談のつもり なかったんだけどな!
Dialogue: 0,0:01:42.20,0:01:45.87,Default,,0000,0000,0000,,見ろよ! この秘密の訓練所!
Dialogue: 0,0:01:45.87,0:01:49.71,Default,,0000,0000,0000,,大人でも 余裕で音を上げる 鬼畜仕様のアトラクションを
Dialogue: 0,0:01:49.71,0:01:53.05,Default,,0000,0000,0000,,俺 パーフェクトに クリアできるようになったんだぜ?
Dialogue: 0,0:01:53.05,0:01:55.05,Default,,0000,0000,0000,,大げさすぎるのよ
Dialogue: 0,0:01:55.05,0:01:58.05,Default,,0000,0000,0000,,大体 秘密の訓練所なんて 言ってるのは
Dialogue: 0,0:01:58.05,0:02:00.82,Default,,0000,0000,0000,,スバルとガーフィールの2人だけかしら
Dialogue: 0,0:02:00.82,0:02:03.66,Default,,0000,0000,0000,,お 言ってくれたな!
Dialogue: 0,0:02:00.82,0:02:03.66,Default,,0000,0000,0000,,うわ! キャーなのよ!
Dialogue: 0,0:02:03.66,0:02:07.49,Default,,0000,0000,0000,,精霊虐待かしら!
Dialogue: 0,0:02:03.66,0:02:07.49,Default,,0000,0000,0000,,スバルは 極悪非道の契約者なのよ!
Dialogue: 0,0:02:07.49,0:02:10.50,Default,,0000,0000,0000,,スバル様! ベアトリスちゃん!
Dialogue: 0,0:02:07.49,0:02:10.50,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:10.50,0:02:13.17,Default,,0000,0000,0000,,お屋敷に お客様が来たの
Dialogue: 0,0:02:13.17,0:02:17.67,Default,,0000,0000,0000,,エミリア姉様が ご一緒してほしいって
Dialogue: 0,0:02:13.17,0:02:17.67,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:17.67,0:02:20.84,Default,,0000,0000,0000,,んっ 予定にない来客
Dialogue: 0,0:02:20.84,0:02:23.84,Default,,0000,0000,0000,,俺を呼ぶ かわいいエミリアたん
Dialogue: 0,0:02:23.84,0:02:25.85,Default,,0000,0000,0000,,事件の予感がしないか?
Dialogue: 0,0:02:25.85,0:02:29.35,Default,,0000,0000,0000,,面倒が舞い込むパターンに 違いないかしら
Dialogue: 0,0:02:29.35,0:02:32.69,Default,,0000,0000,0000,,お! お兄さんだ!
Dialogue: 0,0:02:32.69,0:02:34.69,Default,,0000,0000,0000,,元気してた?
Dialogue: 0,0:02:34.69,0:02:37.86,Default,,0000,0000,0000,,うおっ! うっ ミミ!
Dialogue: 0,0:02:34.69,0:02:37.86,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:02:37.86,0:02:40.69,Default,,0000,0000,0000,,久しぶりじゃねえか!
Dialogue: 0,0:02:37.86,0:02:40.69,Default,,0000,0000,0000,,元気してたか?
Dialogue: 0,0:02:40.69,0:02:42.70,Default,,0000,0000,0000,,ミミ 超元気!
Dialogue: 0,0:02:42.70,0:02:45.70,Default,,0000,0000,0000,,あと 背 伸びた!
Dialogue: 0,0:02:42.70,0:02:45.70,Default,,0000,0000,0000,,もはや 大人の女!
Dialogue: 0,0:02:45.70,0:02:50.20,Default,,0000,0000,0000,,出会い頭に 人の頭に飛びついてくるやつのどこが 大人の女!?
Dialogue: 0,0:02:50.20,0:02:53.54,Default,,0000,0000,0000,,けど まあ 遠い所 よく来てくれたな
Dialogue: 0,0:02:53.54,0:02:56.71,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:53.54,0:02:56.71,Default,,0000,0000,0000,,ところで ミミがいるってことは
Dialogue: 0,0:02:56.71,0:02:59.98,Default,,0000,0000,0000,,お兄さん 心配せんでもよろしい
Dialogue: 0,0:02:59.98,0:03:03.98,Default,,0000,0000,0000,,今日は ユリウス 一緒じゃないから
Dialogue: 0,0:03:14.33,0:03:18.13,Default,,0000,0000,0000,,やっと来たのね バルス
Dialogue: 0,0:03:14.33,0:03:18.13,Default,,0000,0000,0000,,ずいぶんと遅かったじゃない
Dialogue: 0,0:03:20.17,0:03:22.17,Default,,0000,0000,0000,,いやらしい
Dialogue: 0,0:03:20.17,0:03:22.17,Default,,0000,0000,0000,,お前のほうが いやらしいよ!
Dialogue: 0,0:03:22.17,0:03:25.34,Default,,0000,0000,0000,,ほのぼのしい光景以外の 何物でもねえだろ!
Dialogue: 0,0:03:22.17,0:03:25.34,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:03:25.34,0:03:27.67,Default,,0000,0000,0000,,そうやって なんでも 自分の主観で
Dialogue: 0,0:03:27.67,0:03:30.68,Default,,0000,0000,0000,,物事を判断する癖を やめなさい
Dialogue: 0,0:03:30.68,0:03:33.01,Default,,0000,0000,0000,,覚えておくといいわ バルス
Dialogue: 0,0:03:33.01,0:03:35.68,Default,,0000,0000,0000,,ラムの評価は ラムの主観が すべてよ
Dialogue: 0,0:03:35.68,0:03:39.69,Default,,0000,0000,0000,,今 前半と後半で 主張が 矛盾して なかったか!?
Dialogue: 0,0:03:35.68,0:03:39.69,Default,,0000,0000,0000,,あっ? んっ?
Dialogue: 0,0:03:39.69,0:03:42.02,Default,,0000,0000,0000,,よう 遅えじゃねえかよ 大将
Dialogue: 0,0:03:42.02,0:03:44.02,Default,,0000,0000,0000,,早く入ってくれや
Dialogue: 0,0:03:44.02,0:03:48.53,Default,,0000,0000,0000,,オットー兄ィとエミリア様の歓迎じゃ 掛け合い漫才にしかなってねえ
Dialogue: 0,0:03:48.53,0:03:51.36,Default,,0000,0000,0000,,それは それで しばらく見守っていたい演目
Dialogue: 0,0:03:51.36,0:03:53.87,Default,,0000,0000,0000,,ばかなこと 言ってないで さっさと入りなさい
Dialogue: 0,0:03:53.87,0:03:57.87,Default,,0000,0000,0000,,ギャッ! かっ たっ たっ! ハァ
Dialogue: 0,0:03:57.87,0:03:59.87,Default,,0000,0000,0000,,あっ んっ?
Dialogue: 0,0:03:59.87,0:04:02.14,Default,,0000,0000,0000,,こちらの方が?
Dialogue: 0,0:04:02.14,0:04:05.81,Default,,0000,0000,0000,,ええ そうよ
Dialogue: 0,0:04:02.14,0:04:05.81,Default,,0000,0000,0000,,お待たせして ごめんなさい
Dialogue: 0,0:04:05.81,0:04:09.65,Default,,0000,0000,0000,,私の騎士様 ナツキ・スバルです
Dialogue: 0,0:04:09.65,0:04:14.15,Default,,0000,0000,0000,,ハッ! 私の騎士様
Dialogue: 0,0:04:14.15,0:04:17.32,Default,,0000,0000,0000,,あっ どうかなさいました?
Dialogue: 0,0:04:17.32,0:04:19.99,Default,,0000,0000,0000,,ハッ! ちょっと うっかり トリップしちゃった
Dialogue: 0,0:04:19.99,0:04:23.30,Default,,0000,0000,0000,,ナハハハ! 大変 失礼しました
Dialogue: 0,0:04:26.00,0:04:31.50,Default,,0000,0000,0000,,ご紹介にあずかりました
Dialogue: 0,0:04:26.00,0:04:31.50,Default,,0000,0000,0000,,エミリア様の騎士 ナツキ・スバルです
Dialogue: 0,0:04:31.50,0:04:34.51,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:04:31.50,0:04:34.51,Default,,0000,0000,0000,,ご丁寧に ありがとうございます
Dialogue: 0,0:04:34.51,0:04:37.18,Default,,0000,0000,0000,,ぼっ んっ
Dialogue: 0,0:04:37.18,0:04:41.18,Default,,0000,0000,0000,,自分は アナスタシア・ホーシン様の 使者として参りました
Dialogue: 0,0:04:41.18,0:04:43.52,Default,,0000,0000,0000,,ヨシュア・ユークリウスと申します
Dialogue: 0,0:04:43.52,0:04:46.52,Default,,0000,0000,0000,,んっ? ユークリウス?
Dialogue: 0,0:04:46.52,0:04:49.52,Default,,0000,0000,0000,,あっ スバルも驚いたみたいね
Dialogue: 0,0:04:49.52,0:04:53.69,Default,,0000,0000,0000,,そうなの ヨシュアって ユリウスの弟さんなんですって
Dialogue: 0,0:04:53.69,0:04:58.20,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:04:53.69,0:04:58.20,Default,,0000,0000,0000,,ナツキ殿ですよね?
Dialogue: 0,0:04:53.69,0:04:58.20,Default,,0000,0000,0000,,兄から聞いています
Dialogue: 0,0:04:58.20,0:05:01.47,Default,,0000,0000,0000,,その 数々のうわさも かねがね
Dialogue: 0,0:05:01.47,0:05:04.64,Default,,0000,0000,0000,,なるほど ユリウスの弟か
Dialogue: 0,0:05:04.64,0:05:08.98,Default,,0000,0000,0000,,言われてみれば 嫌み じゃなく 鋭い目つきとか
Dialogue: 0,0:05:08.98,0:05:12.31,Default,,0000,0000,0000,,皮肉 じゃなく 優雅な口元とか
Dialogue: 0,0:05:12.31,0:05:15.65,Default,,0000,0000,0000,,悪魔
Dialogue: 0,0:05:12.31,0:05:15.65,Default,,0000,0000,0000,,麗しい髪の色とか同じだよな
Dialogue: 0,0:05:15.65,0:05:19.65,Default,,0000,0000,0000,,ちょくちょく 無理が見えるんで 余計な口は 閉じてくれませんかね?
Dialogue: 0,0:05:19.65,0:05:21.99,Default,,0000,0000,0000,,さて それじゃあ
Dialogue: 0,0:05:21.99,0:05:25.16,Default,,0000,0000,0000,,待たせて悪かったなってことで 話の続きを
Dialogue: 0,0:05:25.16,0:05:27.99,Default,,0000,0000,0000,,ちょ ちょっと待ってください!
Dialogue: 0,0:05:25.16,0:05:27.99,Default,,0000,0000,0000,,その女の子は?
Dialogue: 0,0:05:27.99,0:05:30.33,Default,,0000,0000,0000,,ベティーが どうかしたかしら?
Dialogue: 0,0:05:30.33,0:05:34.67,Default,,0000,0000,0000,,あれは ベア子!
Dialogue: 0,0:05:30.33,0:05:34.67,Default,,0000,0000,0000,,お兄さんと お姉さんの子ども!
Dialogue: 0,0:05:34.67,0:05:36.84,Default,,0000,0000,0000,,え!
Dialogue: 0,0:05:34.67,0:05:36.84,Default,,0000,0000,0000,,そうそう
Dialogue: 0,0:05:36.84,0:05:40.84,Default,,0000,0000,0000,,これは 俺とエミリアたんの かわいいベイビー ベアトリス
Dialogue: 0,0:05:36.84,0:05:40.84,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:40.84,0:05:44.18,Default,,0000,0000,0000,,違うでしょ
Dialogue: 0,0:05:40.84,0:05:44.18,Default,,0000,0000,0000,,ヨシュアが驚いてるじゃない
Dialogue: 0,0:05:44.18,0:05:48.68,Default,,0000,0000,0000,,私 スバルと チューはしたけど チューじゃ 赤ちゃんは できないんでしょ
Dialogue: 0,0:05:46.51,0:05:48.68,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:05:48.68,0:05:52.02,Default,,0000,0000,0000,,勉強したんだから
Dialogue: 0,0:05:48.68,0:05:52.02,Default,,0000,0000,0000,,あ ごめん エミリアたん
Dialogue: 0,0:05:52.02,0:05:54.69,Default,,0000,0000,0000,,なんか ものすごい赤裸々な勢いで 暴露されそうで
Dialogue: 0,0:05:54.69,0:05:58.02,Default,,0000,0000,0000,,恥ずかしいから やめて
Dialogue: 0,0:05:54.69,0:05:58.02,Default,,0000,0000,0000,,俺が悪かった
Dialogue: 0,0:05:58.02,0:06:03.46,Default,,0000,0000,0000,,えっと それで 実際のところ
Dialogue: 0,0:05:58.02,0:06:03.46,Default,,0000,0000,0000,,こちらの ベアトリス嬢の立場は
Dialogue: 0,0:06:03.46,0:06:07.30,Default,,0000,0000,0000,,ベアトリスは 俺と契約した かわいい大精霊
Dialogue: 0,0:06:07.30,0:06:10.14,Default,,0000,0000,0000,,大精霊
Dialogue: 0,0:06:10.14,0:06:12.14,Default,,0000,0000,0000,,よう お客人
Dialogue: 0,0:06:12.14,0:06:16.64,Default,,0000,0000,0000,,うちの大将が 精霊 連れてっと なんか 問題あんのかよ?
Dialogue: 0,0:06:16.64,0:06:19.65,Default,,0000,0000,0000,,いえ うわさは耳にしていましたが
Dialogue: 0,0:06:19.65,0:06:22.98,Default,,0000,0000,0000,,ナツキ殿が 本当に 精霊騎士であるとは
Dialogue: 0,0:06:22.98,0:06:27.32,Default,,0000,0000,0000,,ご存じかと思いますが 兄も精霊騎士
Dialogue: 0,0:06:27.32,0:06:30.32,Default,,0000,0000,0000,,この国随一の精霊騎士ですので
Dialogue: 0,0:06:30.32,0:06:33.99,Default,,0000,0000,0000,,ああ もちろん 知ってる
Dialogue: 0,0:06:30.32,0:06:33.99,Default,,0000,0000,0000,,あいつには世話に
Dialogue: 0,0:06:33.99,0:06:38.16,Default,,0000,0000,0000,,ぐっ 世話になった から
Dialogue: 0,0:06:38.16,0:06:41.17,Default,,0000,0000,0000,,そんなに 助けられたの 認めたくないんですかね?
Dialogue: 0,0:06:41.17,0:06:43.17,Default,,0000,0000,0000,,ベティーとスバル以外にも
Dialogue: 0,0:06:43.17,0:06:46.34,Default,,0000,0000,0000,,精霊使いの騎士がいるのは 知っているのよ
Dialogue: 0,0:06:46.34,0:06:49.34,Default,,0000,0000,0000,,なかなか 見どころのあるやつと 聞いていたかしら
Dialogue: 0,0:06:49.34,0:06:52.68,Default,,0000,0000,0000,,無論です!
Dialogue: 0,0:06:49.34,0:06:52.68,Default,,0000,0000,0000,,兄様は すごい方ですから
Dialogue: 0,0:06:52.68,0:06:57.52,Default,,0000,0000,0000,,弱冠22歳にして 王国騎士団の花形 近衛騎士団で
Dialogue: 0,0:06:57.52,0:06:59.69,Default,,0000,0000,0000,,実質的な2番手
Dialogue: 0,0:06:59.69,0:07:01.62,Default,,0000,0000,0000,,今は お役目を離れていますが
Dialogue: 0,0:07:01.62,0:07:06.13,Default,,0000,0000,0000,,アナスタシア様が即位された暁には 団長の座は確実です!
Dialogue: 0,0:07:06.13,0:07:08.80,Default,,0000,0000,0000,,今代の剣聖である ラインハルト様でも
Dialogue: 0,0:07:08.80,0:07:11.46,Default,,0000,0000,0000,,兄様の 騎士としての在り方には かなわない!
Dialogue: 0,0:07:11.46,0:07:14.13,Default,,0000,0000,0000,,まさしく 兄様は 真の騎士!
Dialogue: 0,0:07:14.13,0:07:16.97,Default,,0000,0000,0000,,おっ おう
Dialogue: 0,0:07:14.13,0:07:16.97,Default,,0000,0000,0000,,どん引きなのよ
Dialogue: 0,0:07:16.97,0:07:19.64,Default,,0000,0000,0000,,フフフ!
Dialogue: 0,0:07:16.97,0:07:21.81,Default,,0000,0000,0000,,ヨシュアって ほんとに すごく お兄さんのユリウスが好きなのね
Dialogue: 0,0:07:21.81,0:07:24.48,Default,,0000,0000,0000,,あっ! もっ 申し訳ありません
Dialogue: 0,0:07:24.48,0:07:27.15,Default,,0000,0000,0000,,家族のこととなると 自制が利かなくて
Dialogue: 0,0:07:27.15,0:07:30.15,Default,,0000,0000,0000,,いいから とっとと 本題に入れよ
Dialogue: 0,0:07:30.15,0:07:33.99,Default,,0000,0000,0000,,バームベームは 寝かせるほど うまい ってのも 限度があらあ
Dialogue: 0,0:07:33.99,0:07:35.99,Default,,0000,0000,0000,,バームベーム!?
Dialogue: 0,0:07:33.99,0:07:35.99,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:07:35.99,0:07:39.16,Default,,0000,0000,0000,,ミミも大好き! おいしい!
Dialogue: 0,0:07:35.99,0:07:39.16,Default,,0000,0000,0000,,おっ あっ
Dialogue: 0,0:07:39.16,0:07:41.99,Default,,0000,0000,0000,,一緒に食う?
Dialogue: 0,0:07:39.16,0:07:41.99,Default,,0000,0000,0000,,おっ ああ
Dialogue: 0,0:07:41.99,0:07:44.33,Default,,0000,0000,0000,,じゃあ 約束!
Dialogue: 0,0:07:44.33,0:07:48.67,Default,,0000,0000,0000,,失礼いたしました
Dialogue: 0,0:07:48.67,0:07:53.01,Default,,0000,0000,0000,,それでは 我が あるじである アナスタシア・ホーシン様からのお言葉を
Dialogue: 0,0:07:53.01,0:07:56.84,Default,,0000,0000,0000,,エミリア様に お伝えします
Dialogue: 0,0:07:56.84,0:07:59.18,Default,,0000,0000,0000,,アナスタシア様は エミリア様を
Dialogue: 0,0:07:59.18,0:08:02.78,Default,,0000,0000,0000,,水門都市プリステラへ ご招待したいと お考えです
Dialogue: 0,0:08:02.78,0:08:05.28,Default,,0000,0000,0000,,水門都市プリステラ
Dialogue: 0,0:08:05.28,0:08:07.79,Default,,0000,0000,0000,,一体 どのような ご用件なんでしょう?
Dialogue: 0,0:08:07.79,0:08:10.46,Default,,0000,0000,0000,,パーティーのお誘いだそうです
Dialogue: 0,0:08:10.46,0:08:12.63,Default,,0000,0000,0000,,アナスタシア様のご厚意で
Dialogue: 0,0:08:12.63,0:08:16.46,Default,,0000,0000,0000,,エミリア様の探し物を 見つけたとのことですよ
Dialogue: 0,0:08:16.46,0:08:19.47,Default,,0000,0000,0000,,私の探し物?
Dialogue: 0,0:08:19.47,0:08:22.13,Default,,0000,0000,0000,,はい プリステラの商人が
Dialogue: 0,0:08:22.13,0:08:25.47,Default,,0000,0000,0000,,エミリア様 ご所望の 魔晶石を所有しているそうです
Dialogue: 0,0:08:25.47,0:08:27.81,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:08:25.47,0:08:27.81,Default,,0000,0000,0000,,魔晶石?
Dialogue: 0,0:08:27.81,0:08:33.48,Default,,0000,0000,0000,,はい 大精霊様を呼び戻す触媒を
Dialogue: 0,0:08:27.81,0:08:33.48,Default,,0000,0000,0000,,探しておられるのですよね?
Dialogue: 0,0:08:33.48,0:08:35.78,Default,,0000,0000,0000,,ハッ あっ
Dialogue: 0,0:08:39.15,0:08:43.32,Default,,0000,0000,0000,,んじゃね ガーフ!
Dialogue: 0,0:08:39.15,0:08:43.32,Default,,0000,0000,0000,,プリプリで待ってるから!
Dialogue: 0,0:08:43.32,0:08:46.16,Default,,0000,0000,0000,,絶対 来ること!
Dialogue: 0,0:08:43.32,0:08:46.16,Default,,0000,0000,0000,,アハハハ
Dialogue: 0,0:08:46.16,0:08:49.16,Default,,0000,0000,0000,,ガーフィール すっかり 気に入られたみたいですね
Dialogue: 0,0:08:49.16,0:08:51.16,Default,,0000,0000,0000,,別に うれしかねえよ!
Dialogue: 0,0:08:51.16,0:08:53.67,Default,,0000,0000,0000,,案外 まんざらでも ないんじゃないですか?
Dialogue: 0,0:08:53.67,0:08:56.00,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:08:53.67,0:08:56.00,Default,,0000,0000,0000,,そんなことあるわけねえだろ!
Dialogue: 0,0:08:56.00,0:08:59.34,Default,,0000,0000,0000,,素直じゃないですね
Dialogue: 0,0:08:56.00,0:08:59.34,Default,,0000,0000,0000,,これが 素直な気持ちだ!
Dialogue: 0,0:08:59.34,0:09:03.28,Default,,0000,0000,0000,,ぶっちゃけ アナスタシアさんに 借りを作るのは怖いんだけど
Dialogue: 0,0:09:03.28,0:09:07.28,Default,,0000,0000,0000,,プリステラって どんな街なんだ?
Dialogue: 0,0:09:03.28,0:09:07.28,Default,,0000,0000,0000,,有名な所なの?
Dialogue: 0,0:09:07.28,0:09:10.78,Default,,0000,0000,0000,,プリステラは ルグニカの五大都市の1つで
Dialogue: 0,0:09:10.78,0:09:14.29,Default,,0000,0000,0000,,カララギ都市国家との 国境沿いにある街なの
Dialogue: 0,0:09:14.29,0:09:19.13,Default,,0000,0000,0000,,都市中に 水路が流れてて すごく きれいな街なんだって
Dialogue: 0,0:09:19.13,0:09:21.96,Default,,0000,0000,0000,,へぇ 水上都市ってやつか
Dialogue: 0,0:09:21.96,0:09:25.30,Default,,0000,0000,0000,,俺の知識だと ヴェネチアとかに近いのかな?
Dialogue: 0,0:09:25.30,0:09:27.63,Default,,0000,0000,0000,,ヴェネチアは知らないけど
Dialogue: 0,0:09:27.63,0:09:30.97,Default,,0000,0000,0000,,プリステラは 水上都市じゃなくて 水門都市
Dialogue: 0,0:09:30.97,0:09:33.47,Default,,0000,0000,0000,,水門都市?
Dialogue: 0,0:09:33.47,0:09:36.64,Default,,0000,0000,0000,,そう 湖の中にある街で
Dialogue: 0,0:09:36.64,0:09:39.48,Default,,0000,0000,0000,,雨が降ると 街じゅう 水浸しになっちゃうの
Dialogue: 0,0:09:39.48,0:09:43.32,Default,,0000,0000,0000,,だから 街の周りを高い塀で覆って
Dialogue: 0,0:09:43.32,0:09:46.99,Default,,0000,0000,0000,,水の量を調整する水門を いくつも置いてるんだって
Dialogue: 0,0:09:46.99,0:09:52.66,Default,,0000,0000,0000,,いきなり イメージが 水の都から
Dialogue: 0,0:09:46.99,0:09:52.66,Default,,0000,0000,0000,,水の監獄に変わっちゃうな
Dialogue: 0,0:09:52.66,0:09:56.33,Default,,0000,0000,0000,,そんな街に呼び出す あっちの狙いは なんだろう?
Dialogue: 0,0:09:56.33,0:10:00.50,Default,,0000,0000,0000,,ただ よくしてくれただけかもって 信じちゃうのは だめ?
Dialogue: 0,0:10:00.50,0:10:02.84,Default,,0000,0000,0000,,残念だけど 王選候補者は
Dialogue: 0,0:10:02.84,0:10:06.51,Default,,0000,0000,0000,,どいつも こいつも 癖があるからね
Dialogue: 0,0:10:02.84,0:10:06.51,Default,,0000,0000,0000,,うん
Dialogue: 0,0:10:06.51,0:10:09.51,Default,,0000,0000,0000,,でも
Dialogue: 0,0:10:09.51,0:10:14.85,Default,,0000,0000,0000,,パックとは 話したいことも
Dialogue: 0,0:10:09.51,0:10:14.85,Default,,0000,0000,0000,,聞きたいことも いっぱいあるの
Dialogue: 0,0:10:14.85,0:10:18.68,Default,,0000,0000,0000,,だから
Dialogue: 0,0:10:14.85,0:10:18.68,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:10:18.68,0:10:22.36,Default,,0000,0000,0000,,とっとと戻れよな 猫精霊
Dialogue: 0,0:10:22.36,0:10:26.86,Default,,0000,0000,0000,,俺も お前に 恨み言が山ほどあんだからさ
Dialogue: 0,0:10:26.86,0:10:29.36,Default,,0000,0000,0000,,あっ うん
Dialogue: 0,0:10:33.20,0:10:35.70,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:10:33.20,0:10:35.70,Default,,0000,0000,0000,,こんな大事なときに
Dialogue: 0,0:10:35.70,0:10:38.87,Default,,0000,0000,0000,,屋敷にいられなくて
Dialogue: 0,0:10:35.70,0:10:38.87,Default,,0000,0000,0000,,いえいえ
Dialogue: 0,0:10:38.87,0:10:44.04,Default,,0000,0000,0000,,私としては エミリア様の意思を
Dialogue: 0,0:10:38.87,0:10:44.04,Default,,0000,0000,0000,,尊重させていただきますよ!
Dialogue: 0,0:10:44.04,0:10:47.05,Default,,0000,0000,0000,,たとえ 西方貴族を集めた会合で
Dialogue: 0,0:10:47.05,0:10:50.72,Default,,0000,0000,0000,,大変 忙しい時期 だとしてもねえ
Dialogue: 0,0:10:47.05,0:10:50.72,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:10:50.72,0:10:53.39,Default,,0000,0000,0000,,ハァ 全く
Dialogue: 0,0:10:53.39,0:10:57.72,Default,,0000,0000,0000,,旦那様は 本当に 反省の色が うかがえない方ですわね
Dialogue: 0,0:10:57.72,0:11:02.66,Default,,0000,0000,0000,,おや 手厳しいね フレデリカ
Dialogue: 0,0:10:57.72,0:11:02.66,Default,,0000,0000,0000,,当然ですわ
Dialogue: 0,0:11:02.66,0:11:05.66,Default,,0000,0000,0000,,正直 エミリア様とスバル君だけを
Dialogue: 0,0:11:05.66,0:11:08.33,Default,,0000,0000,0000,,行かせるなら不安だけど
Dialogue: 0,0:11:08.33,0:11:12.17,Default,,0000,0000,0000,,ガーフィールとオットー君が 一緒なら 大丈夫でしょ
Dialogue: 0,0:11:12.17,0:11:16.34,Default,,0000,0000,0000,,オットー君なら 交渉で 下手なドジ 踏む心配もないし
Dialogue: 0,0:11:16.34,0:11:20.18,Default,,0000,0000,0000,,最悪 ガーフィールが 何もかも ぶち壊して 逃げてこられる
Dialogue: 0,0:11:20.18,0:11:23.52,Default,,0000,0000,0000,,それは それで すごく 問題になりそうだから
Dialogue: 0,0:11:23.52,0:11:26.19,Default,,0000,0000,0000,,私も 一生懸命 頑張るわね
Dialogue: 0,0:11:26.19,0:11:29.02,Default,,0000,0000,0000,,心配ご無用だよ エミリアたん
Dialogue: 0,0:11:29.02,0:11:32.36,Default,,0000,0000,0000,,相手が アナスタシアさんだろうと ユリウスだろうと
Dialogue: 0,0:11:32.36,0:11:35.86,Default,,0000,0000,0000,,話し合いを けむに巻かせれば 俺は 一級品だ
Dialogue: 0,0:11:35.86,0:11:39.70,Default,,0000,0000,0000,,もう それって 自慢することじゃないと思うの
Dialogue: 0,0:11:39.70,0:11:42.37,Default,,0000,0000,0000,,となると 屋敷に残るのは
Dialogue: 0,0:11:42.37,0:11:45.20,Default,,0000,0000,0000,,ラムということで かまわないかな?
Dialogue: 0,0:11:45.20,0:11:48.21,Default,,0000,0000,0000,,ええ ロズワール様のお心のままに
Dialogue: 0,0:11:48.21,0:11:50.38,Default,,0000,0000,0000,,話は まとまったようだ
Dialogue: 0,0:11:50.38,0:11:55.21,Default,,0000,0000,0000,,それじゃあ 4人のお守りは ベアトリス 君に任せたよ
Dialogue: 0,0:11:55.21,0:11:59.22,Default,,0000,0000,0000,,みゅっ! お前に 言われるまでもないかしら!
Dialogue: 0,0:12:02.82,0:12:05.32,Default,,0000,0000,0000,,僕はね
Dialogue: 0,0:12:05.32,0:12:10.00,Default,,0000,0000,0000,,これでも ちゃんと皆さんのことを 考えてるつもりなんですよ!
Dialogue: 0,0:12:10.00,0:12:14.50,Default,,0000,0000,0000,,なんか いよいよ お前も 完全に 内政官だな
Dialogue: 0,0:12:10.00,0:12:14.50,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:12:14.50,0:12:17.00,Default,,0000,0000,0000,,なんですか?
Dialogue: 0,0:12:14.50,0:12:17.00,Default,,0000,0000,0000,,その哀れむような目つき
Dialogue: 0,0:12:17.00,0:12:19.67,Default,,0000,0000,0000,,落ち着けって オットー兄ィ
Dialogue: 0,0:12:17.00,0:12:19.67,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:12:19.67,0:12:23.51,Default,,0000,0000,0000,,大将も あんまし からかい過ぎるもんじゃねえよ
Dialogue: 0,0:12:23.51,0:12:27.01,Default,,0000,0000,0000,,前に 1日 10オットーまでって 決めたっだろうが!
Dialogue: 0,0:12:27.01,0:12:31.32,Default,,0000,0000,0000,,1日 10オットーって それ なんの単位なんですかね!?
Dialogue: 0,0:12:46.03,0:12:48.03,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:12:48.03,0:12:51.04,Default,,0000,0000,0000,,お邪魔します
Dialogue: 0,0:12:58.54,0:13:00.55,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:13:07.15,0:13:10.49,Default,,0000,0000,0000,,レム
Dialogue: 0,0:13:10.49,0:13:13.66,Default,,0000,0000,0000,,どうやら しばらく会えなくなりそうだ
Dialogue: 0,0:13:13.66,0:13:17.66,Default,,0000,0000,0000,,けど 今日は 話すことが いっぱいあるぞ
Dialogue: 0,0:13:17.66,0:13:20.17,Default,,0000,0000,0000,,なんせ 招かれざる客が
Dialogue: 0,0:13:20.17,0:13:23.00,Default,,0000,0000,0000,,とんでもない問題を 持ち込んでくれたからな
Dialogue: 0,0:13:39.52,0:13:41.52,Default,,0000,0000,0000,,アナスタシア様に会う前に
Dialogue: 0,0:13:41.52,0:13:46.19,Default,,0000,0000,0000,,まず 現在の王選の状況について お話ししておきますね
Dialogue: 0,0:13:46.19,0:13:49.20,Default,,0000,0000,0000,,ええ
Dialogue: 0,0:13:46.19,0:13:49.20,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:13:49.20,0:13:54.70,Default,,0000,0000,0000,,当初 王選は クルシュ・カルステン公爵と
Dialogue: 0,0:13:49.20,0:13:54.70,Default,,0000,0000,0000,,アナスタシア・ホーシンが
Dialogue: 0,0:13:54.70,0:13:57.37,Default,,0000,0000,0000,,本命と対抗に見られていました
Dialogue: 0,0:13:57.37,0:14:00.81,Default,,0000,0000,0000,,エミリア様も含めた他の3人は
Dialogue: 0,0:14:00.81,0:14:05.31,Default,,0000,0000,0000,,言葉を選ばずに言えば 数合わせのような認識ですね
Dialogue: 0,0:14:05.31,0:14:07.98,Default,,0000,0000,0000,,うん それは否定できないと思う
Dialogue: 0,0:14:07.98,0:14:10.82,Default,,0000,0000,0000,,ですが 少なくとも この1年で
Dialogue: 0,0:14:10.82,0:14:13.82,Default,,0000,0000,0000,,市井の認識が変わりつつあるのは 事実です
Dialogue: 0,0:14:13.82,0:14:17.49,Default,,0000,0000,0000,,エミリア様は 有力だった2陣営と共に
Dialogue: 0,0:14:17.49,0:14:22.66,Default,,0000,0000,0000,,白鯨と大罪司教を討伐したという
Dialogue: 0,0:14:17.49,0:14:22.66,Default,,0000,0000,0000,,功績が大きい
Dialogue: 0,0:14:22.66,0:14:25.66,Default,,0000,0000,0000,,エミリア様以外の数合わせ組も
Dialogue: 0,0:14:25.66,0:14:30.00,Default,,0000,0000,0000,,特に プリシラ陣営の躍進は 目覚ましいものがあります
Dialogue: 0,0:14:30.00,0:14:33.67,Default,,0000,0000,0000,,亡くなった旦那さんの所領を 受け継いだあと
Dialogue: 0,0:14:33.67,0:14:38.51,Default,,0000,0000,0000,,情勢の不安に揺れる 周辺の有力者を 一気に 味方に付けました
Dialogue: 0,0:14:38.51,0:14:42.85,Default,,0000,0000,0000,,乗せれば 乗せるだけ踊る 当人の気質と美貌もあって
Dialogue: 0,0:14:42.85,0:14:47.35,Default,,0000,0000,0000,,太陽姫と慕われ 日に日に 勢いを増しています
Dialogue: 0,0:14:47.35,0:14:51.02,Default,,0000,0000,0000,,フェルト陣営も 当初の強みは騎士である
Dialogue: 0,0:14:51.02,0:14:54.53,Default,,0000,0000,0000,,剣聖 ラインハルト・ヴァン・アストレアのみでしたが
Dialogue: 0,0:14:54.53,0:14:57.03,Default,,0000,0000,0000,,フェルト様が目を付けたのは
Dialogue: 0,0:14:57.03,0:14:59.97,Default,,0000,0000,0000,,能力はあっても 性格に難があったり
Dialogue: 0,0:14:59.97,0:15:02.47,Default,,0000,0000,0000,,すねに傷のある者たちでした
Dialogue: 0,0:15:02.47,0:15:05.97,Default,,0000,0000,0000,,彼らを積極的に取り込み 柔軟な発想と視点で
Dialogue: 0,0:15:05.97,0:15:08.97,Default,,0000,0000,0000,,領地の大改革を始めたんです
Dialogue: 0,0:15:08.97,0:15:13.98,Default,,0000,0000,0000,,なので この1年 盤上から
Dialogue: 0,0:15:08.97,0:15:13.98,Default,,0000,0000,0000,,転がり落ちた候補者はいません
Dialogue: 0,0:15:13.98,0:15:16.98,Default,,0000,0000,0000,,ただ
Dialogue: 0,0:15:13.98,0:15:16.98,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:15:16.98,0:15:20.82,Default,,0000,0000,0000,,魔女教との戦いで 記憶をなくされた
Dialogue: 0,0:15:20.82,0:15:25.16,Default,,0000,0000,0000,,クルシュ・カルステン公爵だけは 芳しくありませんね
Dialogue: 0,0:15:25.16,0:15:28.66,Default,,0000,0000,0000,,そんな中 アナスタシア陣営だけは
Dialogue: 0,0:15:28.66,0:15:31.83,Default,,0000,0000,0000,,王選が始まる前も 始まってからも
Dialogue: 0,0:15:31.83,0:15:35.67,Default,,0000,0000,0000,,一度の失速もなく 安定した支持を持ってるんです
Dialogue: 0,0:15:35.67,0:15:39.67,Default,,0000,0000,0000,,アナスタシアさんの所は ホーシン商会って
Dialogue: 0,0:15:39.67,0:15:43.01,Default,,0000,0000,0000,,おっきな お店が 力になってるのよね
Dialogue: 0,0:15:39.67,0:15:43.01,Default,,0000,0000,0000,,はい
Dialogue: 0,0:15:43.01,0:15:46.01,Default,,0000,0000,0000,,彼女たちの武器は財力
Dialogue: 0,0:15:46.01,0:15:49.85,Default,,0000,0000,0000,,経済で ぶん殴るのは 最強の一手ってわけです
Dialogue: 0,0:15:49.85,0:15:52.52,Default,,0000,0000,0000,,そのアナスタシア陣営の招待
Dialogue: 0,0:15:52.52,0:15:55.02,Default,,0000,0000,0000,,あげくに 借りを作りそうな状況
Dialogue: 0,0:15:55.02,0:15:58.52,Default,,0000,0000,0000,,僕が どのくらい胃が痛いか わかってくれました?
Dialogue: 0,0:15:58.52,0:16:01.13,Default,,0000,0000,0000,,やっと すごく身に染みました
Dialogue: 0,0:16:01.13,0:16:03.46,Default,,0000,0000,0000,,勝手なことして ごめんなさい
Dialogue: 0,0:16:03.46,0:16:06.80,Default,,0000,0000,0000,,わかっていただければ とりあえず 大丈夫です
Dialogue: 0,0:16:06.80,0:16:10.47,Default,,0000,0000,0000,,なにも 1人で 悩みを抱える必要はありません
Dialogue: 0,0:16:10.47,0:16:14.64,Default,,0000,0000,0000,,この竜車と一緒ですよ
Dialogue: 0,0:16:10.47,0:16:14.64,Default,,0000,0000,0000,,竜車と一緒って?
Dialogue: 0,0:16:14.64,0:16:18.14,Default,,0000,0000,0000,,今 手綱を握っているのは ナツキさんです
Dialogue: 0,0:16:18.14,0:16:21.98,Default,,0000,0000,0000,,ナツキさんが サボらないように 見張っているのは ベアトリスちゃん
Dialogue: 0,0:16:21.98,0:16:25.48,Default,,0000,0000,0000,,周りの警戒をしているのは ガーフィールですし
Dialogue: 0,0:16:25.48,0:16:28.82,Default,,0000,0000,0000,,その 竜車の旅程を計画したのは 僕です
Dialogue: 0,0:16:28.82,0:16:33.66,Default,,0000,0000,0000,,そして エミリア様は その全員に お疲れさまと声を掛けて
Dialogue: 0,0:16:33.66,0:16:37.00,Default,,0000,0000,0000,,まあ えっちら おっちらと プリステラを目指しているわけで
Dialogue: 0,0:16:37.00,0:16:41.33,Default,,0000,0000,0000,,今のオットー君の言い回し なんだが すごく スバルみたいよ
Dialogue: 0,0:16:41.33,0:16:45.17,Default,,0000,0000,0000,,うえっ? 本当ですか? 嫌だな
Dialogue: 0,0:16:45.17,0:16:49.17,Default,,0000,0000,0000,,おい オットー! なんだよ? ずりい!
Dialogue: 0,0:16:49.17,0:16:52.18,Default,,0000,0000,0000,,なに 俺のエミリアたんと 盛り上がってんだ!
Dialogue: 0,0:16:52.18,0:16:54.35,Default,,0000,0000,0000,,ベア子 ちょっと 手綱 持ってろ!
Dialogue: 0,0:16:52.18,0:16:54.35,Default,,0000,0000,0000,,嫌! むっ 無理なのよ!
Dialogue: 0,0:16:54.35,0:16:56.68,Default,,0000,0000,0000,,うん!
Dialogue: 0,0:16:54.35,0:16:56.68,Default,,0000,0000,0000,,やめるかしら! スバル! スバル!
Dialogue: 0,0:16:56.68,0:16:59.69,Default,,0000,0000,0000,,あっ おい 大将 何してんだ!?
Dialogue: 0,0:16:59.69,0:17:02.96,Default,,0000,0000,0000,,大丈夫っかよ!
Dialogue: 0,0:16:59.69,0:17:02.96,Default,,0000,0000,0000,,ひぇ 待って
Dialogue: 0,0:17:02.96,0:17:06.96,Default,,0000,0000,0000,,うわっ! あ!
Dialogue: 0,0:17:02.96,0:17:06.96,Default,,0000,0000,0000,,あっ あっ あっ あっ あっ あっ!
Dialogue: 0,0:17:06.96,0:17:09.96,Default,,0000,0000,0000,,スーバールー!
Dialogue: 0,0:17:16.14,0:17:19.64,Default,,0000,0000,0000,,出入りだけで やけに厳重だな
Dialogue: 0,0:17:19.64,0:17:22.98,Default,,0000,0000,0000,,ますます 水の監獄っぽさが増す
Dialogue: 0,0:17:22.98,0:17:25.48,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:17:22.98,0:17:25.48,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:17:31.82,0:17:34.99,Default,,0000,0000,0000,,おお
Dialogue: 0,0:17:31.82,0:17:34.99,Default,,0000,0000,0000,,すごい
Dialogue: 0,0:17:34.99,0:17:38.66,Default,,0000,0000,0000,,確かに こりゃ 壮観だ
Dialogue: 0,0:17:38.66,0:17:43.33,Default,,0000,0000,0000,,もともと プリステラは 湖の上に建設された
Dialogue: 0,0:17:43.33,0:17:47.00,Default,,0000,0000,0000,,400年前の技術を結集した 都市なのよ
Dialogue: 0,0:17:47.00,0:17:49.00,Default,,0000,0000,0000,,おかしな造りだけど
Dialogue: 0,0:17:49.00,0:17:52.34,Default,,0000,0000,0000,,都市そのものが わなだった成り立ちを考えると
Dialogue: 0,0:17:52.34,0:17:55.34,Default,,0000,0000,0000,,街の中央に 水が 集まりやすくなっているのも
Dialogue: 0,0:17:55.34,0:17:57.51,Default,,0000,0000,0000,,当然の構造かしら
Dialogue: 0,0:17:57.51,0:18:01.95,Default,,0000,0000,0000,,街そのものが わなだったって すごく いわくありげ
Dialogue: 0,0:18:01.95,0:18:05.62,Default,,0000,0000,0000,,魔獣でも狙ってたのかよ?
Dialogue: 0,0:18:01.95,0:18:05.62,Default,,0000,0000,0000,,謎なのよ
Dialogue: 0,0:18:05.62,0:18:09.96,Default,,0000,0000,0000,,記録には なんのための わなだったかまでは 残ってないかしら
Dialogue: 0,0:18:09.96,0:18:13.46,Default,,0000,0000,0000,,しっかし これ ほんとに迷路みたいだな
Dialogue: 0,0:18:13.46,0:18:16.96,Default,,0000,0000,0000,,街の形は 水路に合わせて 造られてるから
Dialogue: 0,0:18:16.96,0:18:19.80,Default,,0000,0000,0000,,陸路は すごく 入り組んじゃってるみたい
Dialogue: 0,0:18:19.80,0:18:24.97,Default,,0000,0000,0000,,都市の中は 竜車よりも
Dialogue: 0,0:18:19.80,0:18:24.97,Default,,0000,0000,0000,,竜船が主流なんですよ
Dialogue: 0,0:18:24.97,0:18:31.14,Default,,0000,0000,0000,,グッ ウゥー!
Dialogue: 0,0:18:24.97,0:18:31.14,Default,,0000,0000,0000,,ガー!
Dialogue: 0,0:18:31.14,0:18:33.15,Default,,0000,0000,0000,,カー!
Dialogue: 0,0:18:36.82,0:18:39.65,Default,,0000,0000,0000,,水の羽衣亭
Dialogue: 0,0:18:39.65,0:18:43.49,Default,,0000,0000,0000,,なんか すごく不思議な形の建物ね
Dialogue: 0,0:18:43.49,0:18:46.66,Default,,0000,0000,0000,,これ 宿っていうか 旅館じゃねえか
Dialogue: 0,0:18:46.66,0:18:49.16,Default,,0000,0000,0000,,驚いてくれてるみたいやね
Dialogue: 0,0:18:49.16,0:18:53.67,Default,,0000,0000,0000,,そしたら うちも ここを選んだかいがあるわぁ
Dialogue: 0,0:18:53.67,0:18:56.67,Default,,0000,0000,0000,,アナスタシアさん
Dialogue: 0,0:18:53.67,0:18:56.67,Default,,0000,0000,0000,,はいな
Dialogue: 0,0:18:56.67,0:18:58.84,Default,,0000,0000,0000,,ようこそ プリステラへ
Dialogue: 0,0:18:58.84,0:19:01.94,Default,,0000,0000,0000,,来てくれて ありがとうな
Dialogue: 0,0:19:01.94,0:19:04.61,Default,,0000,0000,0000,,げっ!
Dialogue: 0,0:19:01.94,0:19:04.61,Default,,0000,0000,0000,,久しぶりね ユリウス
Dialogue: 0,0:19:04.61,0:19:07.61,Default,,0000,0000,0000,,お久しぶりです エミリア様
Dialogue: 0,0:19:07.61,0:19:09.62,Default,,0000,0000,0000,,顔を合わせるのは久しぶりだ
Dialogue: 0,0:19:09.62,0:19:13.29,Default,,0000,0000,0000,,壮健であっただろうか?
Dialogue: 0,0:19:09.62,0:19:13.29,Default,,0000,0000,0000,,ナツキ・スバル殿
Dialogue: 0,0:19:13.29,0:19:16.79,Default,,0000,0000,0000,,何が スバル殿だ
Dialogue: 0,0:19:13.29,0:19:16.79,Default,,0000,0000,0000,,しらじらしいんだよ!
Dialogue: 0,0:19:16.79,0:19:21.46,Default,,0000,0000,0000,,そう言われても 今の あなたには 相応の立場がある
Dialogue: 0,0:19:21.46,0:19:23.63,Default,,0000,0000,0000,,そのつもりで接したまでだが?
Dialogue: 0,0:19:23.63,0:19:25.96,Default,,0000,0000,0000,,「までだが?」じゃねえよ!
Dialogue: 0,0:19:25.96,0:19:28.63,Default,,0000,0000,0000,,気分が悪いし 皮肉は やめろ
Dialogue: 0,0:19:25.96,0:19:28.63,Default,,0000,0000,0000,,フフフ!
Dialogue: 0,0:19:28.63,0:19:31.80,Default,,0000,0000,0000,,なるほど
Dialogue: 0,0:19:28.63,0:19:31.80,Default,,0000,0000,0000,,どうやら 立場は変わっても
Dialogue: 0,0:19:31.80,0:19:34.47,Default,,0000,0000,0000,,その心根には 影響が薄いらしい
Dialogue: 0,0:19:31.80,0:19:34.47,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:34.47,0:19:36.48,Default,,0000,0000,0000,,え 皆さん
Dialogue: 0,0:19:36.48,0:19:39.48,Default,,0000,0000,0000,,旧交を温めるのも いいとは思うんですが
Dialogue: 0,0:19:39.48,0:19:43.32,Default,,0000,0000,0000,,あっ! あなたは
Dialogue: 0,0:19:39.48,0:19:43.32,Default,,0000,0000,0000,,あっ 僕は
Dialogue: 0,0:19:43.32,0:19:46.15,Default,,0000,0000,0000,,これは 大変 失礼いたしました
Dialogue: 0,0:19:43.32,0:19:46.15,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:46.15,0:19:49.99,Default,,0000,0000,0000,,まさか この場に あなた様のような高位の精霊が
Dialogue: 0,0:19:49.99,0:19:52.99,Default,,0000,0000,0000,,同席されているとは 思わなかったものですから
Dialogue: 0,0:19:52.99,0:19:56.66,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:19:52.99,0:19:56.66,Default,,0000,0000,0000,,ハァ 紹介しておいてやるぜ
Dialogue: 0,0:19:56.66,0:20:00.67,Default,,0000,0000,0000,,俺と契約した ロリ じゃなくて 精霊のベアトリスだ
Dialogue: 0,0:20:00.67,0:20:06.00,Default,,0000,0000,0000,,ベティーは スバルのパートナーだから
Dialogue: 0,0:20:00.67,0:20:06.00,Default,,0000,0000,0000,,この場にいるのは 当然かしら
Dialogue: 0,0:20:06.00,0:20:09.17,Default,,0000,0000,0000,,お前の連れている まだ 名もない準精霊たちとは
Dialogue: 0,0:20:09.17,0:20:12.68,Default,,0000,0000,0000,,格も位階も かわいさも 段違いなのよ
Dialogue: 0,0:20:12.68,0:20:15.68,Default,,0000,0000,0000,,それを しっかりと わきまえたうえで
Dialogue: 0,0:20:15.68,0:20:19.35,Default,,0000,0000,0000,,おいしい紅茶と お菓子を 所望するかしら
Dialogue: 0,0:20:19.35,0:20:22.69,Default,,0000,0000,0000,,最後まで 威厳を保てよ!
Dialogue: 0,0:20:19.35,0:20:22.69,Default,,0000,0000,0000,,フフフフ!
Dialogue: 0,0:20:22.69,0:20:24.69,Default,,0000,0000,0000,,あっ! ガーフ 来てた!
Dialogue: 0,0:20:24.69,0:20:27.69,Default,,0000,0000,0000,,お嬢 なんで 秘密にしてたかな!
Dialogue: 0,0:20:27.69,0:20:30.20,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:20:27.69,0:20:30.20,Default,,0000,0000,0000,,行こう! 宿の探検!
Dialogue: 0,0:20:30.20,0:20:33.37,Default,,0000,0000,0000,,ミミが案内したげる!
Dialogue: 0,0:20:30.20,0:20:33.37,Default,,0000,0000,0000,,おっ おい 待て こら!
Dialogue: 0,0:20:33.37,0:20:35.37,Default,,0000,0000,0000,,俺様 まだ 話が
Dialogue: 0,0:20:35.37,0:20:38.54,Default,,0000,0000,0000,,力 強っ!
Dialogue: 0,0:20:35.37,0:20:38.54,Default,,0000,0000,0000,,ほら 行こう! すぐ行こう!
Dialogue: 0,0:20:38.54,0:20:41.54,Default,,0000,0000,0000,,ハァ 俺たちも行くか
Dialogue: 0,0:20:41.54,0:20:44.88,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:20:41.54,0:20:44.88,Default,,0000,0000,0000,,かしこまって どうしたんだよ?
Dialogue: 0,0:20:44.88,0:20:49.72,Default,,0000,0000,0000,,いや いいんですけどね
Dialogue: 0,0:20:44.88,0:20:49.72,Default,,0000,0000,0000,,いいんですけどね
Dialogue: 0,0:20:49.72,0:20:53.39,Default,,0000,0000,0000,,なんか すごく不思議な雰囲気
Dialogue: 0,0:20:53.39,0:20:58.22,Default,,0000,0000,0000,,床に座っちゃうし 靴も脱いでるし
Dialogue: 0,0:20:58.22,0:21:01.33,Default,,0000,0000,0000,,これは たぶん 寝室も ベッドじゃなくて
Dialogue: 0,0:21:01.33,0:21:03.50,Default,,0000,0000,0000,,床に布団を敷くんだよな
Dialogue: 0,0:21:03.50,0:21:06.50,Default,,0000,0000,0000,,部屋着も 浴衣だったりするのかな?
Dialogue: 0,0:21:06.50,0:21:11.00,Default,,0000,0000,0000,,スバル すごく詳しいのね
Dialogue: 0,0:21:06.50,0:21:11.00,Default,,0000,0000,0000,,ほんまやね
Dialogue: 0,0:21:11.00,0:21:14.17,Default,,0000,0000,0000,,一体 どこで カララギ式について勉強したん?
Dialogue: 0,0:21:14.17,0:21:17.01,Default,,0000,0000,0000,,カララギ式って この宿のことか?
Dialogue: 0,0:21:17.01,0:21:22.01,Default,,0000,0000,0000,,そうやよ
Dialogue: 0,0:21:17.01,0:21:22.01,Default,,0000,0000,0000,,ワフー建築様式は カララギ伝来のもん
Dialogue: 0,0:21:22.01,0:21:24.02,Default,,0000,0000,0000,,ワフー建築
Dialogue: 0,0:21:24.02,0:21:26.69,Default,,0000,0000,0000,,そりゃ なんとも 聞き逃せねえ響きだ
Dialogue: 0,0:21:26.69,0:21:30.52,Default,,0000,0000,0000,,もともと プリステラは カララギ建国の雄である
Dialogue: 0,0:21:30.52,0:21:34.69,Default,,0000,0000,0000,,ホーシンが立ち上げに関わった 都市なんです
Dialogue: 0,0:21:30.52,0:21:34.69,Default,,0000,0000,0000,,ホーシン?
Dialogue: 0,0:21:34.69,0:21:39.03,Default,,0000,0000,0000,,荒れ地のホーシンとも呼ばれ 400年前の当時から
Dialogue: 0,0:21:39.03,0:21:41.20,Default,,0000,0000,0000,,とにかく 革新的な発想力と
Dialogue: 0,0:21:41.20,0:21:44.04,Default,,0000,0000,0000,,先進的な理念で知られた人物です
Dialogue: 0,0:21:44.04,0:21:47.04,Default,,0000,0000,0000,,荒れ地のホーシン
Dialogue: 0,0:21:47.04,0:21:50.71,Default,,0000,0000,0000,,その正体は 恐らく 俺と同じ 異世界
Dialogue: 0,0:21:50.71,0:21:53.41,Default,,0000,0000,0000,,日本から召喚された人間
Dialogue: 0,0:21:58.22,0:22:01.49,Default,,0000,0000,0000,,アナスタシア様 準備が整いました
Dialogue: 0,0:22:01.49,0:22:03.66,Default,,0000,0000,0000,,ありがとう ヨシュア
Dialogue: 0,0:22:03.66,0:22:06.66,Default,,0000,0000,0000,,そしたら お待ちかねの話に入ろか
Dialogue: 0,0:22:06.66,0:22:11.33,Default,,0000,0000,0000,,お探しの魔晶石 その所有者は
Dialogue: 0,0:22:11.33,0:22:14.67,Default,,0000,0000,0000,,この都市におる 大商会の跡取り息子やの
Dialogue: 0,0:22:14.67,0:22:20.34,Default,,0000,0000,0000,,ヨシュアには そのミューズ商会まで行く
Dialogue: 0,0:22:14.67,0:22:20.34,Default,,0000,0000,0000,,竜船を用意してもろたんよ
Dialogue: 0,0:22:20.34,0:22:23.01,Default,,0000,0000,0000,,ミューズ商会の跡取り息子
Dialogue: 0,0:22:23.01,0:22:26.85,Default,,0000,0000,0000,,そう
Dialogue: 0,0:22:23.01,0:22:26.85,Default,,0000,0000,0000,,本人の商才も大したもんやけど
Dialogue: 0,0:22:26.85,0:22:31.02,Default,,0000,0000,0000,,この街やと もっと別の名前で 有名な お人なんよ
Dialogue: 0,0:22:31.02,0:22:33.02,Default,,0000,0000,0000,,別の名前で?
Dialogue: 0,0:22:33.02,0:22:38.69,Default,,0000,0000,0000,,そう 歌姫に心を奪われた男
Dialogue: 0,0:22:38.69,0:22:41.89,Default,,0000,0000,0000,,転じて 歌姫狂い
Dialogue: 0,0:22:44.03,0:22:47.03,Default,,0000,0000,0000,,船で 水の上を渡るなんて初めて!
Dialogue: 0,0:22:47.03,0:22:49.53,Default,,0000,0000,0000,,なんか ドキドキしてきちゃった
Dialogue: 0,0:22:49.53,0:22:54.04,Default,,0000,0000,0000,,歌姫狂いって 絶対 変人だろ
Dialogue: 0,0:22:54.04,0:22:58.54,Default,,0000,0000,0000,,あれ? こっちと あっちで 水の流れ 違う?
Dialogue: 0,0:22:58.54,0:23:02.65,Default,,0000,0000,0000,,フフッ 驚いた?
Dialogue: 0,0:22:58.54,0:23:02.65,Default,,0000,0000,0000,,実は 私 知ってるの
Dialogue: 0,0:23:02.65,0:23:04.65,Default,,0000,0000,0000,,ほら 見て
Dialogue: 0,0:23:04.65,0:23:09.32,Default,,0000,0000,0000,,あれが 街の中の 水の流れを 制御してる制御塔なの
Dialogue: 0,0:23:09.32,0:23:13.66,Default,,0000,0000,0000,,塔全体が 複雑な仕組みの ミーティアになってて
Dialogue: 0,0:23:13.66,0:23:17.16,Default,,0000,0000,0000,,水の魔石の力で 水流を操ってるんですって
Dialogue: 0,0:23:17.16,0:23:19.33,Default,,0000,0000,0000,,ちなみに この都市では
Dialogue: 0,0:23:19.33,0:23:23.84,Default,,0000,0000,0000,,水を汚すと 大変な罰則があるので 気を付けてください
Dialogue: 0,0:23:23.84,0:23:28.34,Default,,0000,0000,0000,,さっきから おびえた顔で 水を眺めてるガーフィールは 特に
Dialogue: 0,0:23:28.34,0:23:31.01,Default,,0000,0000,0000,,別に 水が怖えってこたあねえよ!
Dialogue: 0,0:23:31.01,0:23:34.51,Default,,0000,0000,0000,,ただ ぬれ猫になんのが 嫌だってだけでよ!
Dialogue: 0,0:23:34.51,0:23:38.18,Default,,0000,0000,0000,,じゃあ 力いっぱい マント つかむの やめてもらえます?
Dialogue: 0,0:23:38.18,0:23:41.69,Default,,0000,0000,0000,,破れそうな音してるんで
Dialogue: 0,0:23:38.18,0:23:41.69,Default,,0000,0000,0000,,フフフ
Dialogue: 0,0:23:41.69,0:23:45.19,Default,,0000,0000,0000,,やれやれ
Dialogue: 0,0:23:41.69,0:23:45.19,Default,,0000,0000,0000,,みんな はしゃぎ過ぎなのよ
Dialogue: 0,0:23:45.19,0:23:48.53,Default,,0000,0000,0000,,もっと おとなしく 淑女なベティーを見習うといい
Dialogue: 0,0:23:48.53,0:23:50.86,Default,,0000,0000,0000,,スバル?
Dialogue: 0,0:23:50.86,0:23:54.03,Default,,0000,0000,0000,,やばい
Dialogue: 0,0:23:54.03,0:23:58.37,Default,,0000,0000,0000,,今 なんて言ったのかしら?
Dialogue: 0,0:23:54.03,0:23:58.37,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:23:58.37,0:24:00.97,Default,,0000,0000,0000,,んっ やばい
Dialogue: 0,0:24:00.97,0:24:04.31,Default,,0000,0000,0000,,うっ! 吐きそう
Dialogue: 0,0:24:00.97,0:24:04.31,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:24:04.31,0:24:06.65,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:24:06.65,0:24:08.65,Default,,0000,0000,0000,,小学校の臨海学校で
Dialogue: 0,0:24:08.65,0:24:11.98,Default,,0000,0000,0000,,フェリーに乗ったときの悪夢が 再来した
Dialogue: 0,0:24:11.98,0:24:16.32,Default,,0000,0000,0000,,やばい 世界 揺れてる
Dialogue: 0,0:24:11.98,0:24:16.32,Default,,0000,0000,0000,,今 なお 揺れ続けてる
Dialogue: 0,0:24:16.32,0:24:19.83,Default,,0000,0000,0000,,もう少し 風を浴びて おとなしくしてるかしら
Dialogue: 0,0:24:19.83,0:24:24.33,Default,,0000,0000,0000,,歌姫狂いのほうは あの3人に 任せておけばいいのよ
Dialogue: 0,0:24:24.33,0:24:28.00,Default,,0000,0000,0000,,あっ まさか 俺が 船酔いすると知ってて
Dialogue: 0,0:24:28.00,0:24:30.84,Default,,0000,0000,0000,,エミリアたんと分断するのが 狙いだったのか?
Dialogue: 0,0:24:30.84,0:24:32.84,Default,,0000,0000,0000,,へぼへぼのスバルが抜けて
Dialogue: 0,0:24:32.84,0:24:37.18,Default,,0000,0000,0000,,どうにかなるエミリアじゃないかしら
Dialogue: 0,0:24:32.84,0:24:37.18,Default,,0000,0000,0000,,ええい ちくしょう
Dialogue: 0,0:24:37.18,0:24:43.01,Default,,0000,0000,0000,,まだ ちょっと ふらふらするけど
Dialogue: 0,0:24:37.18,0:24:43.01,Default,,0000,0000,0000,,こんぐらいなら
Dialogue: 0,0:24:43.01,0:24:46.69,Default,,0000,0000,0000,,ベア子と 手をつなげば ほのぼのパワーで帳消しだ
Dialogue: 0,0:24:46.69,0:24:49.02,Default,,0000,0000,0000,,調子のいいことなのよ
Dialogue: 0,0:24:49.02,0:24:53.53,Default,,0000,0000,0000,,まあ 何かあっても ベティーが なんとかしてあげるかしら
Dialogue: 0,0:24:53.53,0:24:56.03,Default,,0000,0000,0000,,おう 頼りにしてるぜ!
Dialogue: 0,0:24:56.03,0:25:01.30,Default,,0000,0000,0000,,んじゃ エミリアたんが
Dialogue: 0,0:24:56.03,0:25:01.30,Default,,0000,0000,0000,,心細くて泣きだす前に合流だ!
Dialogue: 0,0:25:01.30,0:25:06.47,Default,,0000,0000,0000,,んで ミューズ商会
Dialogue: 0,0:25:06.47,0:25:09.64,Default,,0000,0000,0000,,陸路で行くと こっちで合ってんのか?
Dialogue: 0,0:25:09.64,0:25:11.64,Default,,0000,0000,0000,,そのはずなのよ
Dialogue: 0,0:25:11.64,0:25:14.81,Default,,0000,0000,0000,,つか ここ さっき 通らなかった?
Dialogue: 0,0:25:14.81,0:25:18.98,Default,,0000,0000,0000,,お前 ひょっとして
Dialogue: 0,0:25:18.98,0:25:23.32,Default,,0000,0000,0000,,道に迷ったのか?
Dialogue: 0,0:25:18.98,0:25:23.32,Default,,0000,0000,0000,,べっ
Dialogue: 0,0:25:18.98,0:25:23.32,Default,,0000,0000,0000,,別に迷ったわけじゃないかしら!
Dialogue: 0,0:25:23.32,0:25:25.99,Default,,0000,0000,0000,,でも もし スバルが不安なら
Dialogue: 0,0:25:25.99,0:25:29.66,Default,,0000,0000,0000,,念のため 誰かに道を尋ねるのもいいのよ?
Dialogue: 0,0:25:29.66,0:25:32.50,Default,,0000,0000,0000,,はいはい かわいい かわいい
Dialogue: 0,0:25:32.50,0:25:35.50,Default,,0000,0000,0000,,あっ ても 誰もいねえ
Dialogue: 0,0:25:35.50,0:25:40.17,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:25:45.84,0:25:52.52,Default,,0000,0000,0000,,「あてもなくさまよう」
Dialogue: 0,0:25:52.52,0:25:56.02,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:25:52.52,0:25:56.02,Default,,0000,0000,0000,,おお すげえ
Dialogue: 0,0:25:56.02,0:26:01.46,Default,,0000,0000,0000,,「金もない 未来もない」
Dialogue: 0,0:26:01.46,0:26:04.63,Default,,0000,0000,0000,,「夢もない 見栄だけはある」
Dialogue: 0,0:26:04.63,0:26:07.63,Default,,0000,0000,0000,,いや 待て なんだ? これ
Dialogue: 0,0:26:07.63,0:26:10.47,Default,,0000,0000,0000,,よくよく聴いたら ひでえ歌詞だな おい!
Dialogue: 0,0:26:10.47,0:26:12.64,Default,,0000,0000,0000,,ひゃあ!
Dialogue: 0,0:26:12.64,0:26:15.47,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:26:12.64,0:26:15.47,Default,,0000,0000,0000,,ありゃ
Dialogue: 0,0:26:15.47,0:26:17.98,Default,,0000,0000,0000,,やべえ! 空気 読めないことした
Dialogue: 0,0:26:17.98,0:26:21.65,Default,,0000,0000,0000,,スバルの ばか! なんて不粋かしら
Dialogue: 0,0:26:17.98,0:26:21.65,Default,,0000,0000,0000,,台なしなのよ!
Dialogue: 0,0:26:21.65,0:26:23.82,Default,,0000,0000,0000,,余計なことすんなよ!
Dialogue: 0,0:26:21.65,0:26:23.82,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:26:23.82,0:26:26.32,Default,,0000,0000,0000,,なんだ? お前!
Dialogue: 0,0:26:23.82,0:26:26.32,Default,,0000,0000,0000,,邪魔すんな!
Dialogue: 0,0:26:26.32,0:26:29.49,Default,,0000,0000,0000,,ばか野郎!
Dialogue: 0,0:26:26.32,0:26:29.49,Default,,0000,0000,0000,,あたっ! うっ うっ
Dialogue: 0,0:26:29.49,0:26:31.99,Default,,0000,0000,0000,,うわ! あ!
Dialogue: 0,0:26:35.16,0:26:39.00,Default,,0000,0000,0000,,んっ ああ ひでえ目に遭った
Dialogue: 0,0:26:39.00,0:26:42.33,Default,,0000,0000,0000,,正直 1年ぶりに 死を覚悟した
Dialogue: 0,0:26:42.33,0:26:46.00,Default,,0000,0000,0000,,知らんのよ 治癒魔法は かけてあげないかしら
Dialogue: 0,0:26:46.00,0:26:48.34,Default,,0000,0000,0000,,エミリアにでも頼むといいのよ
Dialogue: 0,0:26:48.34,0:26:51.01,Default,,0000,0000,0000,,でも お前 エミリアたんに 回復 せがんだら
Dialogue: 0,0:26:51.01,0:26:54.18,Default,,0000,0000,0000,,不機嫌になるじゃん
Dialogue: 0,0:26:51.01,0:26:54.18,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:26:54.18,0:26:57.18,Default,,0000,0000,0000,,あっと 悪い
Dialogue: 0,0:26:54.18,0:26:57.18,Default,,0000,0000,0000,,歌を邪魔するつもりは
Dialogue: 0,0:26:57.18,0:26:59.95,Default,,0000,0000,0000,,ひらめきました!
Dialogue: 0,0:26:57.18,0:26:59.95,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:26:57.18,0:26:59.95,Default,,0000,0000,0000,,はっ?
Dialogue: 0,0:26:59.95,0:27:03.46,Default,,0000,0000,0000,,聴いてください!
Dialogue: 0,0:26:59.95,0:27:03.46,Default,,0000,0000,0000,,「デュワワ、恋の年の差」!
Dialogue: 0,0:27:06.12,0:27:09.13,Default,,0000,0000,0000,,「ねえ 見えてる感じてる」
Dialogue: 0,0:27:09.13,0:27:12.30,Default,,0000,0000,0000,,「あなたと私の恋の年の差」
Dialogue: 0,0:27:12.30,0:27:15.47,Default,,0000,0000,0000,,「周りは変だと云うけれど」
Dialogue: 0,0:27:15.47,0:27:18.97,Default,,0000,0000,0000,,「私は そんなの気にしてないわ」
Dialogue: 0,0:27:18.97,0:27:22.64,Default,,0000,0000,0000,,「ねえ 待ってて お願い 待っててて」
Dialogue: 0,0:27:22.64,0:27:26.64,Default,,0000,0000,0000,,「あと少し もう少し」
Dialogue: 0,0:27:26.64,0:27:29.48,Default,,0000,0000,0000,,「背伸びをすれば届くぐらい」
Dialogue: 0,0:27:29.48,0:27:31.98,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:27:29.48,0:27:31.98,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:27:31.98,0:27:34.65,Default,,0000,0000,0000,,「私と あなたの恋の距離」
Dialogue: 0,0:27:34.65,0:27:39.49,Default,,0000,0000,0000,,「あまくとろける恋の距離」「ちぢまる二人の恋の距離」
Dialogue: 0,0:27:39.49,0:27:44.33,Default,,0000,0000,0000,,「静かに燃える愛となり」 「やがて二人にコウノトリ」
Dialogue: 0,0:27:44.33,0:27:47.00,Default,,0000,0000,0000,,「きっと2人に子を送り」
Dialogue: 0,0:27:47.00,0:27:50.60,Default,,0000,0000,0000,,「未来は明るい恋物語っ!」
Dialogue: 0,0:27:54.01,0:27:56.01,Default,,0000,0000,0000,,え!
Dialogue: 0,0:27:56.01,0:27:58.01,Default,,0000,0000,0000,,ちょ ちょっと待つかしら
Dialogue: 0,0:27:56.01,0:27:58.01,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:27:58.01,0:28:00.95,Default,,0000,0000,0000,,なんで スバルは 急に 歌に交じってるのよ!
Dialogue: 0,0:28:00.95,0:28:05.12,Default,,0000,0000,0000,,それを お前が 当たり前みたいに 受け入れてるのも おかしいかしら?
Dialogue: 0,0:28:05.12,0:28:07.79,Default,,0000,0000,0000,,おいおい 何 言ってんだ? ベア子
Dialogue: 0,0:28:07.79,0:28:10.12,Default,,0000,0000,0000,,歌は 国境を超えるんだぜ?
Dialogue: 0,0:28:10.12,0:28:14.96,Default,,0000,0000,0000,,いい話ですね!
Dialogue: 0,0:28:10.12,0:28:14.96,Default,,0000,0000,0000,,このリリアナ 感動に胸が震えます!
Dialogue: 0,0:28:14.96,0:28:17.46,Default,,0000,0000,0000,,震えるほどありませんが
Dialogue: 0,0:28:14.96,0:28:17.46,Default,,0000,0000,0000,,うんうん
Dialogue: 0,0:28:17.46,0:28:21.80,Default,,0000,0000,0000,,ベティーが間違ってるみたいな 雰囲気は 納得がいかないのよ!
Dialogue: 0,0:28:21.80,0:28:25.30,Default,,0000,0000,0000,,おっと 自己紹介が遅れました
Dialogue: 0,0:28:25.30,0:28:28.81,Default,,0000,0000,0000,,私 このリュリーレと 歌声だけで身を立てる
Dialogue: 0,0:28:28.81,0:28:30.81,Default,,0000,0000,0000,,吟遊詩人をやってます
Dialogue: 0,0:28:30.81,0:28:35.98,Default,,0000,0000,0000,,リリアナと申します
Dialogue: 0,0:28:30.81,0:28:35.98,Default,,0000,0000,0000,,以後 お見知り置きょ
Dialogue: 0,0:28:35.98,0:28:38.98,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:28:35.98,0:28:38.98,Default,,0000,0000,0000,,かんだかしら?
Dialogue: 0,0:28:38.98,0:28:43.15,Default,,0000,0000,0000,,失礼 盛大に かみました
Dialogue: 0,0:28:43.15,0:28:47.16,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:28:43.15,0:28:47.16,Default,,0000,0000,0000,,ひょっとして この娘
Dialogue: 0,0:28:47.16,0:28:49.16,Default,,0000,0000,0000,,なあ ひょっとして あんたが
Dialogue: 0,0:28:49.16,0:28:52.83,Default,,0000,0000,0000,,ちまたで有名な 歌姫ってやつなのか?
Dialogue: 0,0:28:52.83,0:28:55.17,Default,,0000,0000,0000,,えっと えっと
Dialogue: 0,0:28:52.83,0:28:57.67,Default,,0000,0000,0000,,その呼ばれ方は ちょっと 恥ずいのですが
Dialogue: 0,0:28:55.17,0:28:57.67,Default,,0000,0000,0000,,はい
Dialogue: 0,0:28:57.67,0:29:03.44,Default,,0000,0000,0000,,なら 歌姫狂いがいるっていう
Dialogue: 0,0:28:57.67,0:29:03.44,Default,,0000,0000,0000,,ミューズ商会って知ってるよな?
Dialogue: 0,0:29:03.44,0:29:06.61,Default,,0000,0000,0000,,案内するのは かまいませんが
Dialogue: 0,0:29:06.61,0:29:10.78,Default,,0000,0000,0000,,歌姫の歌を聴いたんですから 出すもん 出してくださいよ
Dialogue: 0,0:29:10.78,0:29:14.12,Default,,0000,0000,0000,,歌姫って呼ばれるのは 恥ずいんじゃなかったのかよ?
Dialogue: 0,0:29:14.12,0:29:16.62,Default,,0000,0000,0000,,それは それ これは これです
Dialogue: 0,0:29:16.62,0:29:20.46,Default,,0000,0000,0000,,お客さん まさか ただ聴きしよう ってんじゃないでしょうね?
Dialogue: 0,0:29:20.46,0:29:23.13,Default,,0000,0000,0000,,わかったよ いくら欲しいんだ?
Dialogue: 0,0:29:23.13,0:29:26.13,Default,,0000,0000,0000,,それは お客さんの心の赴くまま!
Dialogue: 0,0:29:26.13,0:29:29.13,Default,,0000,0000,0000,,ありったけ下さい!
Dialogue: 0,0:29:26.13,0:29:29.13,Default,,0000,0000,0000,,無理やり 赴かせんじゃねえ!
Dialogue: 0,0:29:29.13,0:29:33.64,Default,,0000,0000,0000,,ああ なんたる言いぐさ!
Dialogue: 0,0:29:29.13,0:29:33.64,Default,,0000,0000,0000,,あっ ひらめきました!
Dialogue: 0,0:29:33.64,0:29:36.81,Default,,0000,0000,0000,,聴いてください
Dialogue: 0,0:29:33.64,0:29:36.81,Default,,0000,0000,0000,,「荒波高波世間の波」
Dialogue: 0,0:29:36.81,0:29:38.81,Default,,0000,0000,0000,,もういいよ!
Dialogue: 0,0:29:36.81,0:29:38.81,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:29:38.81,0:29:42.31,Default,,0000,0000,0000,,などと話してるうちに 到着しました!
Dialogue: 0,0:29:42.31,0:29:46.99,Default,,0000,0000,0000,,お ここが
Dialogue: 0,0:29:42.31,0:29:46.99,Default,,0000,0000,0000,,はい! それでは聴いてください!
Dialogue: 0,0:29:46.99,0:29:50.49,Default,,0000,0000,0000,,本日 最後の曲です 「人生パヤパヤ」!
Dialogue: 0,0:29:50.49,0:29:52.82,Default,,0000,0000,0000,,しかし すげえな お前
Dialogue: 0,0:29:52.82,0:29:55.49,Default,,0000,0000,0000,,言動だけで ここまで 俺を どん引きさせたのは
Dialogue: 0,0:29:55.49,0:29:57.66,Default,,0000,0000,0000,,ペテルギウス以来かもしれねえ
Dialogue: 0,0:29:57.66,0:30:00.17,Default,,0000,0000,0000,,ほほう 誰かは存じませんが
Dialogue: 0,0:30:00.17,0:30:03.84,Default,,0000,0000,0000,,なかなか 見どころがありますね ペテルギウスさん
Dialogue: 0,0:30:03.84,0:30:06.34,Default,,0000,0000,0000,,もし どこかで会う機会があれば
Dialogue: 0,0:30:06.34,0:30:09.34,Default,,0000,0000,0000,,終生の好敵手に なったかもしれません!
Dialogue: 0,0:30:09.34,0:30:11.68,Default,,0000,0000,0000,,魔女教大罪司教だぞ?
Dialogue: 0,0:30:11.68,0:30:14.51,Default,,0000,0000,0000,,えっ!?
Dialogue: 0,0:30:14.51,0:30:16.68,Default,,0000,0000,0000,,あっ ちょちょちょ
Dialogue: 0,0:30:14.51,0:30:16.68,Default,,0000,0000,0000,,待ってください!
Dialogue: 0,0:30:16.68,0:30:19.68,Default,,0000,0000,0000,,あなた ひょっとして
Dialogue: 0,0:30:19.68,0:30:22.19,Default,,0000,0000,0000,,幼女使いの ナツキ・スバル様ですか!?
Dialogue: 0,0:30:22.19,0:30:25.69,Default,,0000,0000,0000,,いや その二つ名には 物申したいけど!
Dialogue: 0,0:30:25.69,0:30:29.03,Default,,0000,0000,0000,,クルシュ・カルステン公爵が主導した 三大魔獣
Dialogue: 0,0:30:29.03,0:30:32.70,Default,,0000,0000,0000,,白鯨の討伐において なみなみならぬ助力をし
Dialogue: 0,0:30:32.70,0:30:36.70,Default,,0000,0000,0000,,剣鬼ヴィルヘルムをして 恩人と言わせた 歴史の介添え人!
Dialogue: 0,0:30:36.70,0:30:40.71,Default,,0000,0000,0000,,そして 世界を震かんさせた 魔女教大罪司教 怠惰を
Dialogue: 0,0:30:40.71,0:30:45.54,Default,,0000,0000,0000,,カルステン公爵と ホーシン商会 アナスタシア嬢の 力を借りながら撃破し
Dialogue: 0,0:30:45.54,0:30:50.38,Default,,0000,0000,0000,,更には 三大魔獣 大兎をも討伐した英雄!
Dialogue: 0,0:30:50.38,0:30:53.05,Default,,0000,0000,0000,,はわわ! 目の前に
Dialogue: 0,0:30:53.05,0:30:56.39,Default,,0000,0000,0000,,目の前に 伝説がいるでごじゃりまする!
Dialogue: 0,0:30:56.39,0:30:58.39,Default,,0000,0000,0000,,へへ!
Dialogue: 0,0:30:56.39,0:30:58.39,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:30:58.39,0:31:01.33,Default,,0000,0000,0000,,リリアナ嬢ちゃん どうかしたか?
Dialogue: 0,0:31:01.33,0:31:04.16,Default,,0000,0000,0000,,この2人は?
Dialogue: 0,0:31:01.33,0:31:04.16,Default,,0000,0000,0000,,あ 俺たちは
Dialogue: 0,0:31:04.16,0:31:08.83,Default,,0000,0000,0000,,今 中で 商談中のエミリア様の従者だ
Dialogue: 0,0:31:04.16,0:31:08.83,Default,,0000,0000,0000,,ハッ! ということは
Dialogue: 0,0:31:08.83,0:31:12.84,Default,,0000,0000,0000,,その商談の便宜を図れば 幼女使い ナツキ・スバル様が
Dialogue: 0,0:31:12.84,0:31:15.67,Default,,0000,0000,0000,,お話を聞かせてくださったり するんですか?
Dialogue: 0,0:31:15.67,0:31:18.18,Default,,0000,0000,0000,,だから その呼び方は やめろって
Dialogue: 0,0:31:18.18,0:31:20.35,Default,,0000,0000,0000,,あと 話って なんだよ?
Dialogue: 0,0:31:20.35,0:31:22.68,Default,,0000,0000,0000,,そりゃ もう いろいろですよ! いろいろ!
Dialogue: 0,0:31:22.68,0:31:26.02,Default,,0000,0000,0000,,伝え聞いてる うわさが どのくらい事実なのか
Dialogue: 0,0:31:26.02,0:31:29.02,Default,,0000,0000,0000,,知りたい 聞きたい 歌いたい!
Dialogue: 0,0:31:26.02,0:31:29.02,Default,,0000,0000,0000,,ですし
Dialogue: 0,0:31:29.02,0:31:33.86,Default,,0000,0000,0000,,そこから 後世に語り継ぐような 英雄譚が歌えるかもしれません!
Dialogue: 0,0:31:33.86,0:31:35.86,Default,,0000,0000,0000,,さあ 行きましょう!
Dialogue: 0,0:31:33.86,0:31:35.86,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:31:35.86,0:31:40.53,Default,,0000,0000,0000,,義理と人情 はかりにかけたら ぶっ壊すのが リリアナ・マスカレードです!
Dialogue: 0,0:31:40.53,0:31:43.20,Default,,0000,0000,0000,,ぶっ壊すって 何するつもりなのよ?
Dialogue: 0,0:31:43.20,0:31:47.54,Default,,0000,0000,0000,,キリタカさんってば 私に ぞっこんで はちゃめちゃ甘いお人なので
Dialogue: 0,0:31:47.54,0:31:52.38,Default,,0000,0000,0000,,きっと 私から言えば 商談も ボロボロ ガッタガタに進むって寸法です
Dialogue: 0,0:31:52.38,0:31:55.88,Default,,0000,0000,0000,,いや それ 明らかに スムーズに進んだ擬音じゃねえだろ
Dialogue: 0,0:31:55.88,0:31:59.22,Default,,0000,0000,0000,,いいから いいから!
Dialogue: 0,0:31:55.88,0:31:59.22,Default,,0000,0000,0000,,心配ご無用 お任せあれ!
Dialogue: 0,0:31:59.22,0:32:03.49,Default,,0000,0000,0000,,あっ? あっ おい ちょっと!
Dialogue: 0,0:31:59.22,0:32:03.49,Default,,0000,0000,0000,,待てって!
Dialogue: 0,0:32:03.49,0:32:05.99,Default,,0000,0000,0000,,お願いします
Dialogue: 0,0:32:05.99,0:32:08.49,Default,,0000,0000,0000,,どうか その魔晶石を譲ってください
Dialogue: 0,0:32:08.49,0:32:10.50,Default,,0000,0000,0000,,フゥ
Dialogue: 0,0:32:10.50,0:32:12.50,Default,,0000,0000,0000,,だから! おい!
Dialogue: 0,0:32:10.50,0:32:12.50,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:32:12.50,0:32:17.34,Default,,0000,0000,0000,,落ち着け! おい 待てって!
Dialogue: 0,0:32:12.50,0:32:17.34,Default,,0000,0000,0000,,ここは 何とぞ 私に!
Dialogue: 0,0:32:17.34,0:32:21.17,Default,,0000,0000,0000,,リッ リリアナ? どうした?
Dialogue: 0,0:32:17.34,0:32:21.17,Default,,0000,0000,0000,,だから 今 大切な話を
Dialogue: 0,0:32:21.17,0:32:24.51,Default,,0000,0000,0000,,うぅ うぅっ!
Dialogue: 0,0:32:21.17,0:32:24.51,Default,,0000,0000,0000,,このリリアナを 女にしてください!
Dialogue: 0,0:32:24.51,0:32:26.84,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:32:24.51,0:32:26.84,Default,,0000,0000,0000,,スバル?
Dialogue: 0,0:32:26.84,0:32:30.35,Default,,0000,0000,0000,,やっ やあ エミリアたん 奇遇だね
Dialogue: 0,0:32:30.35,0:32:33.52,Default,,0000,0000,0000,,奇遇も何も あんなに うるさくして
Dialogue: 0,0:32:33.52,0:32:36.85,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:32:33.52,0:32:36.85,Default,,0000,0000,0000,,あれ? キリタカさん?
Dialogue: 0,0:32:36.85,0:32:38.86,Default,,0000,0000,0000,,るな
Dialogue: 0,0:32:36.85,0:32:38.86,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:32:38.86,0:32:40.86,Default,,0000,0000,0000,,ぼっ
Dialogue: 0,0:32:38.86,0:32:40.86,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:32:38.86,0:32:40.86,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:32:40.86,0:32:43.70,Default,,0000,0000,0000,,ぼっ 僕の
Dialogue: 0,0:32:40.86,0:32:43.70,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:32:43.70,0:32:46.40,Default,,0000,0000,0000,,リリアナに触るな!
Dialogue: 0,0:32:49.70,0:32:52.04,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:32:52.04,0:32:55.21,Default,,0000,0000,0000,,なんで 歌姫狂いと言われてる人の 目の前で
Dialogue: 0,0:32:55.21,0:32:58.04,Default,,0000,0000,0000,,当の歌姫と べたべたするんですかね?
Dialogue: 0,0:32:58.04,0:33:00.31,Default,,0000,0000,0000,,べたべたしてたわけじゃねえよ!
Dialogue: 0,0:33:00.31,0:33:02.65,Default,,0000,0000,0000,,じゃれ合ってるように 見えたっけどな
Dialogue: 0,0:33:02.65,0:33:04.65,Default,,0000,0000,0000,,じゃれ合ってもねえ!
Dialogue: 0,0:33:04.65,0:33:08.32,Default,,0000,0000,0000,,おかげで まとまりかけてた話が ぶち壊しですよ!
Dialogue: 0,0:33:08.32,0:33:11.32,Default,,0000,0000,0000,,スバルだって 悪気があったわけじゃ ないんだから
Dialogue: 0,0:33:11.32,0:33:13.99,Default,,0000,0000,0000,,エミリアたん
Dialogue: 0,0:33:11.32,0:33:13.99,Default,,0000,0000,0000,,もっと 言ってやって!
Dialogue: 0,0:33:13.99,0:33:18.33,Default,,0000,0000,0000,,スバルは ちゃんと反省して
Dialogue: 0,0:33:13.99,0:33:18.33,Default,,0000,0000,0000,,あっ はい すみませんでした
Dialogue: 0,0:33:18.33,0:33:21.33,Default,,0000,0000,0000,,フフッ しかたないんだから
Dialogue: 0,0:33:21.33,0:33:23.50,Default,,0000,0000,0000,,キャッ! ごめんなさい!
Dialogue: 0,0:33:23.50,0:33:27.17,Default,,0000,0000,0000,,気にしなくていい
Dialogue: 0,0:33:23.50,0:33:27.17,Default,,0000,0000,0000,,僕も不注意だった
Dialogue: 0,0:33:27.17,0:33:30.34,Default,,0000,0000,0000,,一瞬 見とれてしまったせいだね
Dialogue: 0,0:33:30.34,0:33:32.51,Default,,0000,0000,0000,,えっと
Dialogue: 0,0:33:32.51,0:33:36.18,Default,,0000,0000,0000,,君の きれいな銀色の髪にね
Dialogue: 0,0:33:32.51,0:33:36.18,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:33:36.18,0:33:39.35,Default,,0000,0000,0000,,おっと ストップ! そこまでだ
Dialogue: 0,0:33:39.35,0:33:43.02,Default,,0000,0000,0000,,お言葉に甘えて 今回は お互いの不注意ってことで
Dialogue: 0,0:33:43.02,0:33:45.19,Default,,0000,0000,0000,,今日のところは 失礼させてくれ
Dialogue: 0,0:33:45.19,0:33:48.36,Default,,0000,0000,0000,,ちょっと スバル そんな誠意のない言い方
Dialogue: 0,0:33:48.36,0:33:50.36,Default,,0000,0000,0000,,いいから ねっ?
Dialogue: 0,0:33:50.36,0:33:53.03,Default,,0000,0000,0000,,お互いの出会いに感謝だ
Dialogue: 0,0:33:53.03,0:33:57.70,Default,,0000,0000,0000,,水の都の粋な計らいってやつだな
Dialogue: 0,0:33:53.03,0:33:57.70,Default,,0000,0000,0000,,ご丁寧に どうも
Dialogue: 0,0:33:57.70,0:33:59.87,Default,,0000,0000,0000,,そうだね 今のところ
Dialogue: 0,0:33:59.87,0:34:02.97,Default,,0000,0000,0000,,僕が君たちに固執する理由は薄い
Dialogue: 0,0:33:59.87,0:34:02.97,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:34:02.97,0:34:07.98,Default,,0000,0000,0000,,また機会があれば 勝手に
Dialogue: 0,0:34:02.97,0:34:07.98,Default,,0000,0000,0000,,運命が 僕らを巡り合わせるさ
Dialogue: 0,0:34:07.98,0:34:13.48,Default,,0000,0000,0000,,同感だ それじゃあ 運命が導く
Dialogue: 0,0:34:07.98,0:34:13.48,Default,,0000,0000,0000,,あしたの再会を願って
Dialogue: 0,0:34:16.15,0:34:19.49,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:34:16.15,0:34:19.49,Default,,0000,0000,0000,,んっ どうしたの? エミリアたん
Dialogue: 0,0:34:19.49,0:34:21.99,Default,,0000,0000,0000,,ううん 今の人
Dialogue: 0,0:34:21.99,0:34:25.00,Default,,0000,0000,0000,,どこかで会ったような気がして
Dialogue: 0,0:34:25.00,0:34:27.00,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:34:30.17,0:34:33.67,Default,,0000,0000,0000,,ともかく 歌姫狂いとの交渉に関しては
Dialogue: 0,0:34:33.67,0:34:36.67,Default,,0000,0000,0000,,あした 改めて 方針を練り直しましょう
Dialogue: 0,0:34:36.67,0:34:40.51,Default,,0000,0000,0000,,僕は 所用があるので ここで いったん 抜けます
Dialogue: 0,0:34:40.51,0:34:44.68,Default,,0000,0000,0000,,用事?
Dialogue: 0,0:34:40.51,0:34:44.68,Default,,0000,0000,0000,,ええ
Dialogue: 0,0:34:40.51,0:34:44.68,Default,,0000,0000,0000,,せっかく プリステラまで来ましたし
Dialogue: 0,0:34:44.68,0:34:48.52,Default,,0000,0000,0000,,この機会に 挨拶回りを
Dialogue: 0,0:34:48.52,0:34:50.69,Default,,0000,0000,0000,,仕事熱心なやっちゃな
Dialogue: 0,0:34:50.69,0:34:56.36,Default,,0000,0000,0000,,なんだ? 宿のっほうから 誰かが
Dialogue: 0,0:34:50.69,0:34:56.36,Default,,0000,0000,0000,,怒ってやがるにおいがすんぜ
Dialogue: 0,0:34:56.36,0:34:58.36,Default,,0000,0000,0000,,何度も言わせんな!
Dialogue: 0,0:34:58.36,0:35:02.30,Default,,0000,0000,0000,,なめた口 利いてないで とっとと ご主人様を連れてこい!
Dialogue: 0,0:35:02.30,0:35:04.80,Default,,0000,0000,0000,,あなたのような 粗暴な方の前には
Dialogue: 0,0:35:04.80,0:35:07.81,Default,,0000,0000,0000,,主人どころか 兄様だって呼べませんよ
Dialogue: 0,0:35:07.81,0:35:10.14,Default,,0000,0000,0000,,お引き取りください
Dialogue: 0,0:35:07.81,0:35:10.14,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:35:10.14,0:35:14.15,Default,,0000,0000,0000,,話のわかんねえ がきだな おい
Dialogue: 0,0:35:10.14,0:35:14.15,Default,,0000,0000,0000,,ぶっちめるぞ てめえ!
Dialogue: 0,0:35:14.15,0:35:16.15,Default,,0000,0000,0000,,そこまでよ!
Dialogue: 0,0:35:14.15,0:35:16.15,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:35:16.15,0:35:19.32,Default,,0000,0000,0000,,エミリア様! もう お戻りで?
Dialogue: 0,0:35:19.32,0:35:22.99,Default,,0000,0000,0000,,何があったの?
Dialogue: 0,0:35:19.32,0:35:22.99,Default,,0000,0000,0000,,落ち着いて ちゃんと話し合って
Dialogue: 0,0:35:22.99,0:35:25.16,Default,,0000,0000,0000,,どうしたも こうしたもねえ!
Dialogue: 0,0:35:25.16,0:35:28.99,Default,,0000,0000,0000,,この がきが 中に入れねえって ほざきやがったんだ!
Dialogue: 0,0:35:28.99,0:35:33.10,Default,,0000,0000,0000,,って お前 どっかで見た顔だと思ったら
Dialogue: 0,0:35:36.67,0:35:39.50,Default,,0000,0000,0000,,チンじゃねえか!
Dialogue: 0,0:35:36.67,0:35:39.50,Default,,0000,0000,0000,,誰が チンだ!
Dialogue: 0,0:35:39.50,0:35:42.51,Default,,0000,0000,0000,,俺には ラチンスって名前があんだよ!
Dialogue: 0,0:35:42.51,0:35:47.01,Default,,0000,0000,0000,,ラチンス? やっぱ チンじゃねえか
Dialogue: 0,0:35:42.51,0:35:47.01,Default,,0000,0000,0000,,うっ うっ! うっせえ!
Dialogue: 0,0:35:47.01,0:35:49.01,Default,,0000,0000,0000,,知り合いなの? スバル
Dialogue: 0,0:35:49.01,0:35:51.85,Default,,0000,0000,0000,,懐かしの 王都の知り合いだよ
Dialogue: 0,0:35:51.85,0:35:56.02,Default,,0000,0000,0000,,仲間と一緒に 俺の身ぐるみを 剥がそうとしてきたんだ
Dialogue: 0,0:35:56.02,0:35:59.96,Default,,0000,0000,0000,,ベティーの聞くかぎりだと くずとしか 思えないかしら
Dialogue: 0,0:35:56.02,0:35:59.96,Default,,0000,0000,0000,,ぬあっ!
Dialogue: 0,0:35:59.96,0:36:01.96,Default,,0000,0000,0000,,誰が くずだ てめえ!
Dialogue: 0,0:36:01.96,0:36:06.46,Default,,0000,0000,0000,,とりあえず 俺様に任せろ!
Dialogue: 0,0:36:01.96,0:36:06.46,Default,,0000,0000,0000,,こんな野郎は
Dialogue: 0,0:36:06.46,0:36:09.13,Default,,0000,0000,0000,,ハッ! くっ!
Dialogue: 0,0:36:06.46,0:36:09.13,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:36:09.13,0:36:13.97,Default,,0000,0000,0000,,ラチンス!
Dialogue: 0,0:36:09.13,0:36:13.97,Default,,0000,0000,0000,,戻ってこないと思ったら
Dialogue: 0,0:36:13.97,0:36:16.97,Default,,0000,0000,0000,,何を騒がしくしてるんだい?
Dialogue: 0,0:36:16.97,0:36:19.48,Default,,0000,0000,0000,,うぅ ぐっ! うっ!
Dialogue: 0,0:36:19.48,0:36:22.31,Default,,0000,0000,0000,,ぐっ! あっ
Dialogue: 0,0:36:22.31,0:36:26.82,Default,,0000,0000,0000,,ラインハルト!
Dialogue: 0,0:36:22.31,0:36:26.82,Default,,0000,0000,0000,,やあ 久しいね スバル
Dialogue: 0,0:36:26.82,0:36:30.82,Default,,0000,0000,0000,,うわさは聞いているよ
Dialogue: 0,0:36:26.82,0:36:30.82,Default,,0000,0000,0000,,元気そうで何よりだ
Dialogue: 0,0:36:30.82,0:36:33.82,Default,,0000,0000,0000,,時に スバル 1年ぶりの再会で
Dialogue: 0,0:36:33.82,0:36:36.33,Default,,0000,0000,0000,,いろいろと 話したいことはあるんだけど
Dialogue: 0,0:36:36.33,0:36:41.17,Default,,0000,0000,0000,,まず 彼を止めてもらえるかな?
Dialogue: 0,0:36:36.33,0:36:41.17,Default,,0000,0000,0000,,君の友人だろう?
Dialogue: 0,0:36:41.17,0:36:43.33,Default,,0000,0000,0000,,おっ 落ち着け ガーフィール!
Dialogue: 0,0:36:43.33,0:36:47.84,Default,,0000,0000,0000,,こいつは ラインハルト 俺の 友達だ
Dialogue: 0,0:36:47.84,0:36:49.84,Default,,0000,0000,0000,,心配いらない
Dialogue: 0,0:36:49.84,0:36:54.51,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:36:49.84,0:36:54.51,Default,,0000,0000,0000,,聞いてのとおり ラインハルト・ヴァン・アストレアだ
Dialogue: 0,0:36:54.51,0:36:58.18,Default,,0000,0000,0000,,君の名前を聞かせてもらえると ありがたい
Dialogue: 0,0:36:58.18,0:37:01.29,Default,,0000,0000,0000,,チッ! ガーフィール・ティンゼルだ
Dialogue: 0,0:37:01.29,0:37:06.29,Default,,0000,0000,0000,,そうか 君が エミリア様の盾か
Dialogue: 0,0:37:01.29,0:37:06.29,Default,,0000,0000,0000,,会えて うれしいよ
Dialogue: 0,0:37:06.29,0:37:08.63,Default,,0000,0000,0000,,うっ ああ?
Dialogue: 0,0:37:08.63,0:37:12.13,Default,,0000,0000,0000,,気に障ったなら すまない
Dialogue: 0,0:37:12.13,0:37:15.30,Default,,0000,0000,0000,,以後 気を付けるよ
Dialogue: 0,0:37:12.13,0:37:15.30,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:37:15.30,0:37:18.30,Default,,0000,0000,0000,,ラインハルト うちの子が ごめんなさい
Dialogue: 0,0:37:18.30,0:37:20.30,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:37:18.30,0:37:20.30,Default,,0000,0000,0000,,なんともなかった?
Dialogue: 0,0:37:20.30,0:37:23.31,Default,,0000,0000,0000,,エミリア様 ご無沙汰しております
Dialogue: 0,0:37:23.31,0:37:25.81,Default,,0000,0000,0000,,幸い 彼の狙いが正確だったおかげで
Dialogue: 0,0:37:25.81,0:37:28.48,Default,,0000,0000,0000,,問題なく 止めることができました
Dialogue: 0,0:37:28.48,0:37:30.82,Default,,0000,0000,0000,,フェルトちゃんのこと 聞いてるわよ
Dialogue: 0,0:37:30.82,0:37:33.48,Default,,0000,0000,0000,,すごく 活躍してるんですってね!
Dialogue: 0,0:37:33.48,0:37:37.66,Default,,0000,0000,0000,,華々しい エミリア様の ご活躍に比べれば まだまだです
Dialogue: 0,0:37:37.66,0:37:40.83,Default,,0000,0000,0000,,スバル 白鯨の話
Dialogue: 0,0:37:40.83,0:37:43.33,Default,,0000,0000,0000,,あとで 詳しく聞かせてもらって かまわないかい?
Dialogue: 0,0:37:43.33,0:37:47.33,Default,,0000,0000,0000,,僕にとっても あの魔獣は 無関係ではないんだ
Dialogue: 0,0:37:47.33,0:37:51.34,Default,,0000,0000,0000,,おう いいぜ けど その前に
Dialogue: 0,0:37:51.34,0:37:54.34,Default,,0000,0000,0000,,お前 ラチンスと知り合いなのか?
Dialogue: 0,0:37:54.34,0:37:58.34,Default,,0000,0000,0000,,ああ 彼は 今 フェルト様の下で働いていてね
Dialogue: 0,0:37:58.34,0:38:02.11,Default,,0000,0000,0000,,ラチンス あとは 僕が話をしておくから
Dialogue: 0,0:38:02.11,0:38:06.62,Default,,0000,0000,0000,,フェルト様に そろそろ 宿に戻るよう お伝えしてくれ
Dialogue: 0,0:38:02.11,0:38:06.62,Default,,0000,0000,0000,,へいへい
Dialogue: 0,0:38:06.62,0:38:09.95,Default,,0000,0000,0000,,何かあれば 合図を打ち上げるように
Dialogue: 0,0:38:09.95,0:38:13.12,Default,,0000,0000,0000,,5秒で駆けつける
Dialogue: 0,0:38:09.95,0:38:13.12,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:38:13.12,0:38:16.03,Default,,0000,0000,0000,,冗談に聞こえねえのが おっかねえよ
Dialogue: 0,0:38:25.64,0:38:29.14,Default,,0000,0000,0000,,さっきのことが よっぽど こたえてるみたいだな
Dialogue: 0,0:38:29.14,0:38:31.31,Default,,0000,0000,0000,,たまには いい薬なのよ
Dialogue: 0,0:38:31.31,0:38:34.15,Default,,0000,0000,0000,,自分より上がいると 知っておくのは
Dialogue: 0,0:38:34.15,0:38:36.85,Default,,0000,0000,0000,,ガーフィールにとっても いい機会かしら
Dialogue: 0,0:38:38.82,0:38:41.99,Default,,0000,0000,0000,,それでは アナスタシア様が いらっしゃるまで
Dialogue: 0,0:38:41.99,0:38:43.99,Default,,0000,0000,0000,,こちらで お待ちください
Dialogue: 0,0:38:43.99,0:38:47.16,Default,,0000,0000,0000,,失礼いたします
Dialogue: 0,0:38:47.16,0:38:51.33,Default,,0000,0000,0000,,んっ? あっ スバルきゅん!
Dialogue: 0,0:38:47.16,0:38:51.33,Default,,0000,0000,0000,,お久しぶりです
Dialogue: 0,0:38:51.33,0:38:55.83,Default,,0000,0000,0000,,フェリス! クルシュさんも
Dialogue: 0,0:38:55.83,0:38:57.84,Default,,0000,0000,0000,,ヴィルヘルムさん!
Dialogue: 0,0:38:57.84,0:39:02.27,Default,,0000,0000,0000,,お久しぶりです!
Dialogue: 0,0:38:57.84,0:39:02.27,Default,,0000,0000,0000,,おじい様
Dialogue: 0,0:39:02.27,0:39:05.11,Default,,0000,0000,0000,,ラインハルトか
Dialogue: 0,0:39:05.11,0:39:07.78,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:39:07.78,0:39:13.45,Default,,0000,0000,0000,,それにしても クルシュさんたちまで
Dialogue: 0,0:39:07.78,0:39:13.45,Default,,0000,0000,0000,,呼ばれてるのは驚きだった
Dialogue: 0,0:39:13.45,0:39:17.46,Default,,0000,0000,0000,,私たちも 皆さんが おそろいとは思いませんでした
Dialogue: 0,0:39:17.46,0:39:19.62,Default,,0000,0000,0000,,うれしい偶然ですね
Dialogue: 0,0:39:19.62,0:39:24.46,Default,,0000,0000,0000,,ラインハルトとヴィルヘルムさんが 家族だったなんて 驚いちゃった
Dialogue: 0,0:39:24.46,0:39:29.13,Default,,0000,0000,0000,,でも 2人とも 目を合わせないわね
Dialogue: 0,0:39:29.13,0:39:33.80,Default,,0000,0000,0000,,ところで アナスタシアさんは なんで みんなに声を掛けたんですか?
Dialogue: 0,0:39:33.80,0:39:37.14,Default,,0000,0000,0000,,うたぐり深いんやから
Dialogue: 0,0:39:33.80,0:39:37.14,Default,,0000,0000,0000,,うちは ほんとに
Dialogue: 0,0:39:37.14,0:39:40.64,Default,,0000,0000,0000,,ちょっと お話ししたいなって 思っただけやよ
Dialogue: 0,0:39:40.64,0:39:44.65,Default,,0000,0000,0000,,だから お話の通じん人らには 声 掛けんかったし
Dialogue: 0,0:39:44.65,0:39:47.15,Default,,0000,0000,0000,,お話が通じない?
Dialogue: 0,0:39:47.15,0:39:51.16,Default,,0000,0000,0000,,では プリシラ様には 声を掛けて いらっしゃらないのですか?
Dialogue: 0,0:39:51.16,0:39:54.16,Default,,0000,0000,0000,,あそこは 完全に独自路線なのと
Dialogue: 0,0:39:54.16,0:39:57.83,Default,,0000,0000,0000,,呼び出す口実が 全然 見つからんかったんよ
Dialogue: 0,0:39:57.83,0:40:01.17,Default,,0000,0000,0000,,フェルトさんとは ちょっと 仲よくなってたしな
Dialogue: 0,0:40:01.17,0:40:05.17,Default,,0000,0000,0000,,口実って
Dialogue: 0,0:40:01.17,0:40:05.17,Default,,0000,0000,0000,,どうせ 来てもらうんなら
Dialogue: 0,0:40:05.17,0:40:08.34,Default,,0000,0000,0000,,喜んでもらえる お土産を 用意したいやん?
Dialogue: 0,0:40:08.34,0:40:13.18,Default,,0000,0000,0000,,じゃあ クルシュさんたちの それっていうのは
Dialogue: 0,0:40:13.18,0:40:17.01,Default,,0000,0000,0000,,私たちが プリステラに足を運んだのは
Dialogue: 0,0:40:17.01,0:40:20.52,Default,,0000,0000,0000,,アナスタシア様から 大罪司教 暴食の件で
Dialogue: 0,0:40:20.52,0:40:23.19,Default,,0000,0000,0000,,お話を伺えると聞いたからです
Dialogue: 0,0:40:23.19,0:40:25.52,Default,,0000,0000,0000,,ハッ! んっ
Dialogue: 0,0:40:25.52,0:40:29.19,Default,,0000,0000,0000,,別に ナツキ君に 意地悪したわけとちゃうよ
Dialogue: 0,0:40:29.19,0:40:32.70,Default,,0000,0000,0000,,ただ この話は ナツキ君より
Dialogue: 0,0:40:32.70,0:40:37.54,Default,,0000,0000,0000,,クルシュさんのほうが 高く買ってくれるってだけ
Dialogue: 0,0:40:37.54,0:40:42.71,Default,,0000,0000,0000,,商人の考え方だな
Dialogue: 0,0:40:37.54,0:40:42.71,Default,,0000,0000,0000,,ムカつくけど 理解はできる
Dialogue: 0,0:40:42.71,0:40:46.54,Default,,0000,0000,0000,,大人になったものだね 君も
Dialogue: 0,0:40:42.71,0:40:46.54,Default,,0000,0000,0000,,チッ! うるせえ
Dialogue: 0,0:40:46.54,0:40:49.55,Default,,0000,0000,0000,,ギリギリ こらえてる俺を 刺激するな
Dialogue: 0,0:40:49.55,0:40:51.55,Default,,0000,0000,0000,,そんな怖い顔せんでも
Dialogue: 0,0:40:51.55,0:40:54.89,Default,,0000,0000,0000,,ナツキ君にだけ ないしょにしたりせんよ
Dialogue: 0,0:40:54.89,0:40:57.22,Default,,0000,0000,0000,,クルシュさんからの希望もあったしね
Dialogue: 0,0:40:57.22,0:41:01.33,Default,,0000,0000,0000,,ほんま お人よしなんやから
Dialogue: 0,0:40:57.22,0:41:01.33,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:41:01.33,0:41:04.33,Default,,0000,0000,0000,,もちろん 私の記憶のことですから
Dialogue: 0,0:41:04.33,0:41:08.00,Default,,0000,0000,0000,,暴食との決着は 私自身でつけたい
Dialogue: 0,0:41:08.00,0:41:10.33,Default,,0000,0000,0000,,ですが スバル様にとって
Dialogue: 0,0:41:10.33,0:41:13.34,Default,,0000,0000,0000,,レムさんのことが 悲願であることも わかっています
Dialogue: 0,0:41:13.34,0:41:15.84,Default,,0000,0000,0000,,クルシュさん
Dialogue: 0,0:41:13.34,0:41:15.84,Default,,0000,0000,0000,,それに
Dialogue: 0,0:41:15.84,0:41:19.68,Default,,0000,0000,0000,,志を一緒にする方は 多いほうがいいと思います
Dialogue: 0,0:41:19.68,0:41:24.35,Default,,0000,0000,0000,,誰の剣が 最初に届くかは 恨みっこなしですが
Dialogue: 0,0:41:24.35,0:41:27.02,Default,,0000,0000,0000,,ほんとに ありがとう
Dialogue: 0,0:41:27.02,0:41:30.02,Default,,0000,0000,0000,,俺は きっと その期待に応えてみせるよ
Dialogue: 0,0:41:30.02,0:41:32.69,Default,,0000,0000,0000,,きっと 必ず
Dialogue: 0,0:41:32.69,0:41:36.36,Default,,0000,0000,0000,,それでも きっと 私たちのほうが先ですよ?
Dialogue: 0,0:41:36.36,0:41:38.53,Default,,0000,0000,0000,,なんだ!
Dialogue: 0,0:41:38.53,0:41:40.87,Default,,0000,0000,0000,,ひとそろいしてんじゃねえか!
Dialogue: 0,0:41:40.87,0:41:44.54,Default,,0000,0000,0000,,1年ぶりだってのに 意外と変わらねえもんだな
Dialogue: 0,0:41:44.54,0:41:48.87,Default,,0000,0000,0000,,まあ そりゃあ 私も おんなじか
Dialogue: 0,0:41:44.54,0:41:48.87,Default,,0000,0000,0000,,フェルト様!
Dialogue: 0,0:41:48.87,0:41:52.38,Default,,0000,0000,0000,,ちゃんと 外向きのお召し物を ご用意したはずですが
Dialogue: 0,0:41:52.38,0:41:54.38,Default,,0000,0000,0000,,それは どうされたのです?
Dialogue: 0,0:41:54.38,0:41:58.05,Default,,0000,0000,0000,,ハン! 誰が てめえの趣味に つきあうかよ
Dialogue: 0,0:41:58.05,0:42:03.49,Default,,0000,0000,0000,,観光なんてのは方便で
Dialogue: 0,0:41:58.05,0:42:03.49,Default,,0000,0000,0000,,私は替えの服を探してただけだ
Dialogue: 0,0:42:03.49,0:42:07.09,Default,,0000,0000,0000,,本当に あなたという方は
Dialogue: 0,0:42:03.49,0:42:07.09,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:42:09.33,0:42:13.00,Default,,0000,0000,0000,,本日は お招きいただき ありがとうございます
Dialogue: 0,0:42:13.00,0:42:16.17,Default,,0000,0000,0000,,お互いに 王選候補者同士
Dialogue: 0,0:42:16.17,0:42:19.34,Default,,0000,0000,0000,,有意義な話し合いに いたしましょう
Dialogue: 0,0:42:19.34,0:42:22.17,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:42:19.34,0:42:22.17,Default,,0000,0000,0000,,そら 行儀 終わり!
Dialogue: 0,0:42:22.17,0:42:24.51,Default,,0000,0000,0000,,私も交ぜてくれ!
Dialogue: 0,0:42:24.51,0:42:28.18,Default,,0000,0000,0000,,にしても 変な街だし 妙な建物だよな?
Dialogue: 0,0:42:28.18,0:42:31.35,Default,,0000,0000,0000,,あちこち もの珍しくて 疲れちまったよ
Dialogue: 0,0:42:31.35,0:42:33.85,Default,,0000,0000,0000,,フェルトさんには かなわんなぁ
Dialogue: 0,0:42:33.85,0:42:37.19,Default,,0000,0000,0000,,せやけど もの珍しいって 思ってもらえたんなら
Dialogue: 0,0:42:37.19,0:42:39.69,Default,,0000,0000,0000,,うちも うれしいわ
Dialogue: 0,0:42:39.69,0:42:43.19,Default,,0000,0000,0000,,この旅館には 他にも いろいろあるんよ
Dialogue: 0,0:42:43.19,0:42:45.70,Default,,0000,0000,0000,,あ! あ
Dialogue: 0,0:42:45.70,0:42:47.87,Default,,0000,0000,0000,,ほぐれるわ!
Dialogue: 0,0:42:47.87,0:42:51.37,Default,,0000,0000,0000,,大将
Dialogue: 0,0:42:47.87,0:42:51.37,Default,,0000,0000,0000,,あっ? どうした?
Dialogue: 0,0:42:51.37,0:42:56.07,Default,,0000,0000,0000,,悪いんだが ちっとばかし 外出して かまわねえか?
Dialogue: 0,0:42:59.04,0:43:03.15,Default,,0000,0000,0000,,ガーフィール 心配しなくても お前は強いよ
Dialogue: 0,0:43:03.15,0:43:05.82,Default,,0000,0000,0000,,でも 最強じゃねえ
Dialogue: 0,0:43:05.82,0:43:10.82,Default,,0000,0000,0000,,それだけじゃ 不十分なんだよ
Dialogue: 0,0:43:05.82,0:43:10.82,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:43:10.82,0:43:15.33,Default,,0000,0000,0000,,まあ 一晩あれば 立ち直れるだろ
Dialogue: 0,0:43:15.33,0:43:19.00,Default,,0000,0000,0000,,チラッ チラリ
Dialogue: 0,0:43:19.00,0:43:23.33,Default,,0000,0000,0000,,ススススススススススス
Dialogue: 0,0:43:23.33,0:43:28.01,Default,,0000,0000,0000,,ソソッ ハッ 似合う かしら?
Dialogue: 0,0:43:28.01,0:43:30.34,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:43:28.01,0:43:30.34,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:43:28.01,0:43:30.34,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:43:30.34,0:43:34.35,Default,,0000,0000,0000,,ベッ ベア子!
Dialogue: 0,0:43:30.34,0:43:34.35,Default,,0000,0000,0000,,なんだ? その格好は!
Dialogue: 0,0:43:34.35,0:43:36.35,Default,,0000,0000,0000,,フフン! 今のベティーは
Dialogue: 0,0:43:36.35,0:43:39.52,Default,,0000,0000,0000,,いつものベティーとは 一味 違っているのよ
Dialogue: 0,0:43:39.52,0:43:42.19,Default,,0000,0000,0000,,すげえ! 浴衣まであんのか!
Dialogue: 0,0:43:42.19,0:43:45.69,Default,,0000,0000,0000,,ベア子 プリティー! ベア子 ラブリー!
Dialogue: 0,0:43:45.69,0:43:48.19,Default,,0000,0000,0000,,はしゃぎ過ぎよ スバル
Dialogue: 0,0:43:45.69,0:43:48.19,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:43:48.19,0:43:51.60,Default,,0000,0000,0000,,エミリアたん!
Dialogue: 0,0:43:55.03,0:43:57.03,Default,,0000,0000,0000,,ハフン!
Dialogue: 0,0:43:57.03,0:43:59.04,Default,,0000,0000,0000,,んっ? スバル
Dialogue: 0,0:43:59.04,0:44:02.47,Default,,0000,0000,0000,,なんだか 鼻息が荒いみたいだけど 熱でもあるの?
Dialogue: 0,0:44:02.47,0:44:04.98,Default,,0000,0000,0000,,あっ 恋の微熱が ちょっと
Dialogue: 0,0:44:02.47,0:44:04.98,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:44:04.98,0:44:09.15,Default,,0000,0000,0000,,おい 風呂で聞いたぜ?
Dialogue: 0,0:44:04.98,0:44:09.15,Default,,0000,0000,0000,,なんか うちのポンコツ騎士が
Dialogue: 0,0:44:09.15,0:44:12.15,Default,,0000,0000,0000,,そっちの金髪の兄ちゃん いじめたんだってな?
Dialogue: 0,0:44:12.15,0:44:16.15,Default,,0000,0000,0000,,フェルト様 彼とは 少し 行き違いがあっただけです
Dialogue: 0,0:44:16.15,0:44:19.99,Default,,0000,0000,0000,,実際は あの年齢で 末恐ろしい実力者でしたよ
Dialogue: 0,0:44:19.99,0:44:24.33,Default,,0000,0000,0000,,その 無自覚な上から目線 ほんと 説得力ねえな
Dialogue: 0,0:44:24.33,0:44:26.33,Default,,0000,0000,0000,,時に フェルト様
Dialogue: 0,0:44:26.33,0:44:28.33,Default,,0000,0000,0000,,そのお召し物ですが
Dialogue: 0,0:44:28.33,0:44:31.84,Default,,0000,0000,0000,,とても よく お似合いですね
Dialogue: 0,0:44:28.33,0:44:31.84,Default,,0000,0000,0000,,うっぜえ
Dialogue: 0,0:44:31.84,0:44:33.84,Default,,0000,0000,0000,,しっかし フェルト
Dialogue: 0,0:44:33.84,0:44:37.51,Default,,0000,0000,0000,,すがすがしいほど ラインハルトのこと 雑に扱うよな
Dialogue: 0,0:44:37.51,0:44:40.51,Default,,0000,0000,0000,,うちは もともと 下心スタートだったし
Dialogue: 0,0:44:40.51,0:44:43.68,Default,,0000,0000,0000,,そういう意味では フェリスとクルシュさんとこが
Dialogue: 0,0:44:43.68,0:44:46.35,Default,,0000,0000,0000,,いちばん理想的な関係だよな
Dialogue: 0,0:44:46.35,0:44:51.02,Default,,0000,0000,0000,,フフッ そう言われてしまうと てれくさいものがありますね
Dialogue: 0,0:44:51.02,0:44:54.19,Default,,0000,0000,0000,,ねっ? フェリス
Dialogue: 0,0:44:51.02,0:44:54.19,Default,,0000,0000,0000,,まあ フェリちゃんも
Dialogue: 0,0:44:54.19,0:44:57.36,Default,,0000,0000,0000,,バリバリ クルシュ様に 下心ありますけどね
Dialogue: 0,0:44:57.36,0:44:59.96,Default,,0000,0000,0000,,なっ!
Dialogue: 0,0:44:57.36,0:44:59.96,Default,,0000,0000,0000,,フフッ!
Dialogue: 0,0:44:59.96,0:45:04.47,Default,,0000,0000,0000,,よし そろそろ 飯にしようか
Dialogue: 0,0:44:59.96,0:45:04.47,Default,,0000,0000,0000,,スッ スバル様!
Dialogue: 0,0:45:04.47,0:45:06.97,Default,,0000,0000,0000,,こんな空気にしたまま 逃げないでください!
Dialogue: 0,0:45:06.97,0:45:11.28,Default,,0000,0000,0000,,心配しにゃくても 冗談に 決まってるじゃないですか!
Dialogue: 0,0:45:14.31,0:45:18.82,Default,,0000,0000,0000,,あっ くっ!
Dialogue: 0,0:45:18.82,0:45:23.65,Default,,0000,0000,0000,,私の姿が なぜ 見えているのか あなたには わかっているでしょ?
Dialogue: 0,0:45:23.65,0:45:27.83,Default,,0000,0000,0000,,うるせえ! 黙りやがれ!
Dialogue: 0,0:45:27.83,0:45:30.16,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:45:30.16,0:45:33.83,Default,,0000,0000,0000,,ぐっ!
Dialogue: 0,0:45:33.83,0:45:36.67,Default,,0000,0000,0000,,あなたが 私に殺されなかったのは
Dialogue: 0,0:45:36.67,0:45:39.34,Default,,0000,0000,0000,,ほんの少し 運がよかっただけ
Dialogue: 0,0:45:39.34,0:45:44.34,Default,,0000,0000,0000,,あなたが 私を殺せたのは ただの偶然
Dialogue: 0,0:45:44.34,0:45:46.34,Default,,0000,0000,0000,,うるっせえ!!
Dialogue: 0,0:45:46.34,0:45:49.01,Default,,0000,0000,0000,,だって あなたは弱いんだもの
Dialogue: 0,0:45:49.01,0:45:52.35,Default,,0000,0000,0000,,ただの意気地なしの弱虫なのに
Dialogue: 0,0:45:52.35,0:45:55.52,Default,,0000,0000,0000,,私を殺した
Dialogue: 0,0:45:55.52,0:45:57.52,Default,,0000,0000,0000,,ぐっ!
Dialogue: 0,0:45:59.52,0:46:02.96,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:45:59.52,0:46:02.96,Default,,0000,0000,0000,,あっ ガーフ いた!
Dialogue: 0,0:46:02.96,0:46:05.96,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:46:02.96,0:46:05.96,Default,,0000,0000,0000,,どこ行くの?
Dialogue: 0,0:46:05.96,0:46:09.47,Default,,0000,0000,0000,,ミミも行く! ヘヘッ!
Dialogue: 0,0:46:09.47,0:46:11.47,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:46:09.47,0:46:11.47,Default,,0000,0000,0000,,むむっ?
Dialogue: 0,0:46:11.47,0:46:13.64,Default,,0000,0000,0000,,ガーフ 変な顔してる!
Dialogue: 0,0:46:11.47,0:46:13.64,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:46:13.64,0:46:16.31,Default,,0000,0000,0000,,なんか おもしろそうなことあった?
Dialogue: 0,0:46:16.31,0:46:19.64,Default,,0000,0000,0000,,これが 景気のいい面に見えっかよ!
Dialogue: 0,0:46:19.64,0:46:22.48,Default,,0000,0000,0000,,話したくねえし 話す義理もねえよ!
Dialogue: 0,0:46:22.48,0:46:25.65,Default,,0000,0000,0000,,ギリとか ニンジョウとか むつかしいこと 言ってると
Dialogue: 0,0:46:25.65,0:46:28.49,Default,,0000,0000,0000,,ヨシュアみたくならん?
Dialogue: 0,0:46:25.65,0:46:28.49,Default,,0000,0000,0000,,あっ? んっ
Dialogue: 0,0:46:28.49,0:46:31.66,Default,,0000,0000,0000,,もっと てけとうでいいと ミミは思います
Dialogue: 0,0:46:31.66,0:46:36.99,Default,,0000,0000,0000,,あほみたいに笑ったほうが
Dialogue: 0,0:46:31.66,0:46:36.99,Default,,0000,0000,0000,,ガーフ かっこいい!
Dialogue: 0,0:46:36.99,0:46:39.00,Default,,0000,0000,0000,,あっ んっ
Dialogue: 0,0:46:39.00,0:46:42.33,Default,,0000,0000,0000,,あほみたいって なんだ!? こら!
Dialogue: 0,0:46:39.00,0:46:42.33,Default,,0000,0000,0000,,キャー!
Dialogue: 0,0:46:42.33,0:46:45.67,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:46:45.67,0:46:48.17,Default,,0000,0000,0000,,ヘヘヘヘ
Dialogue: 0,0:46:45.67,0:46:48.17,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:46:48.17,0:46:53.18,Default,,0000,0000,0000,,あっ ガーフ 見てみ 見てみ!
Dialogue: 0,0:46:48.17,0:46:53.18,Default,,0000,0000,0000,,夕焼けが めっちゃ きれい!
Dialogue: 0,0:46:53.18,0:46:56.18,Default,,0000,0000,0000,,超赤い!
Dialogue: 0,0:46:56.18,0:47:00.12,Default,,0000,0000,0000,,てめえ ちっとは落ち着けや!
Dialogue: 0,0:46:56.18,0:47:00.12,Default,,0000,0000,0000,,うん 無理!
Dialogue: 0,0:47:00.12,0:47:02.12,Default,,0000,0000,0000,,即答かよ! ハァ
Dialogue: 0,0:47:02.12,0:47:05.79,Default,,0000,0000,0000,,「フンフンフーン フフンフフーン」
Dialogue: 0,0:47:05.79,0:47:08.29,Default,,0000,0000,0000,,「フッフフフ フンフーン」
Dialogue: 0,0:47:08.29,0:47:12.96,Default,,0000,0000,0000,,フフッ!
Dialogue: 0,0:47:08.29,0:47:12.96,Default,,0000,0000,0000,,まあ ぐだぐだ 考えってても しかたねえか
Dialogue: 0,0:47:12.96,0:47:15.97,Default,,0000,0000,0000,,どした?
Dialogue: 0,0:47:12.96,0:47:15.97,Default,,0000,0000,0000,,なんでもねえ
Dialogue: 0,0:47:15.97,0:47:19.47,Default,,0000,0000,0000,,いきなり 最強には なれっこねえってこった
Dialogue: 0,0:47:19.47,0:47:23.14,Default,,0000,0000,0000,,俺様 まだ 登ってる真っ最中だ!
Dialogue: 0,0:47:23.14,0:47:27.98,Default,,0000,0000,0000,,お!
Dialogue: 0,0:47:23.14,0:47:27.98,Default,,0000,0000,0000,,この長い長い 最強への坂をな!
Dialogue: 0,0:47:27.98,0:47:31.32,Default,,0000,0000,0000,,ヘッ! なかっなか わかってんじゃねえかよ!
Dialogue: 0,0:47:31.32,0:47:37.49,Default,,0000,0000,0000,,そうさ!
Dialogue: 0,0:47:31.32,0:47:37.49,Default,,0000,0000,0000,,それが 最強への道だ!
Dialogue: 0,0:47:37.49,0:47:41.66,Default,,0000,0000,0000,,あっ ガーフ! あれ!
Dialogue: 0,0:47:37.49,0:47:41.66,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:47:45.16,0:47:48.00,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:47:48.00,0:47:50.00,Default,,0000,0000,0000,,くっ! ハァ
Dialogue: 0,0:47:50.00,0:47:52.50,Default,,0000,0000,0000,,あらよっと
Dialogue: 0,0:47:50.00,0:47:52.50,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:47:56.01,0:47:59.94,Default,,0000,0000,0000,,んっ とまあ こんなもんよ!
Dialogue: 0,0:47:59.94,0:48:03.45,Default,,0000,0000,0000,,すご! かっちょいい!
Dialogue: 0,0:48:03.45,0:48:05.45,Default,,0000,0000,0000,,おっ お兄さん
Dialogue: 0,0:48:03.45,0:48:05.45,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:48:05.45,0:48:08.45,Default,,0000,0000,0000,,うわ!
Dialogue: 0,0:48:05.45,0:48:08.45,Default,,0000,0000,0000,,ありがとうございました!
Dialogue: 0,0:48:08.45,0:48:10.62,Default,,0000,0000,0000,,気にっすんじゃねえよ
Dialogue: 0,0:48:10.62,0:48:13.62,Default,,0000,0000,0000,,お兄さん お名前は なんというんですか?
Dialogue: 0,0:48:13.62,0:48:16.13,Default,,0000,0000,0000,,名乗るほどの者じゃあねえよ
Dialogue: 0,0:48:16.13,0:48:20.13,Default,,0000,0000,0000,,それでも あえて 名乗るなら 俺様は虎!
Dialogue: 0,0:48:20.13,0:48:23.63,Default,,0000,0000,0000,,人呼んで ゴージャスタイガー!
Dialogue: 0,0:48:23.63,0:48:26.80,Default,,0000,0000,0000,,うわ!
Dialogue: 0,0:48:23.63,0:48:26.80,Default,,0000,0000,0000,,ゴージャスタイガー
Dialogue: 0,0:48:26.80,0:48:29.14,Default,,0000,0000,0000,,ゴージャスタイガー!
Dialogue: 0,0:48:29.14,0:48:31.81,Default,,0000,0000,0000,,すげえ! かっこいい!
Dialogue: 0,0:48:31.81,0:48:34.98,Default,,0000,0000,0000,,お! ゴージャス!
Dialogue: 0,0:48:34.98,0:48:37.48,Default,,0000,0000,0000,,これって このまま食べられるの?
Dialogue: 0,0:48:37.48,0:48:40.98,Default,,0000,0000,0000,,見たことないやろ?
Dialogue: 0,0:48:37.48,0:48:40.98,Default,,0000,0000,0000,,こればっかりは
Dialogue: 0,0:48:40.98,0:48:45.82,Default,,0000,0000,0000,,ティグラシー大河の近くやないと 経験できん料理やろね
Dialogue: 0,0:48:45.82,0:48:49.99,Default,,0000,0000,0000,,これは こうするのが正解
Dialogue: 0,0:48:45.82,0:48:49.99,Default,,0000,0000,0000,,あん!
Dialogue: 0,0:48:49.99,0:48:53.83,Default,,0000,0000,0000,,うん うまい!
Dialogue: 0,0:48:49.99,0:48:53.83,Default,,0000,0000,0000,,懐かしのお刺身!
Dialogue: 0,0:48:49.99,0:48:53.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:48:53.83,0:48:57.33,Default,,0000,0000,0000,,最高! アナスタシアさん 最高!
Dialogue: 0,0:48:53.83,0:48:57.33,Default,,0000,0000,0000,,ウフフフフフ!
Dialogue: 0,0:48:57.33,0:49:00.77,Default,,0000,0000,0000,,おっ おいしいの?
Dialogue: 0,0:48:57.33,0:49:00.77,Default,,0000,0000,0000,,絶品だよ!
Dialogue: 0,0:49:00.77,0:49:03.61,Default,,0000,0000,0000,,新鮮だからかな?
Dialogue: 0,0:49:00.77,0:49:03.61,Default,,0000,0000,0000,,めちゃめちゃ うまい!
Dialogue: 0,0:49:03.61,0:49:07.95,Default,,0000,0000,0000,,うううううう
Dialogue: 0,0:49:03.61,0:49:07.95,Default,,0000,0000,0000,,んっ? どうした? ベア子
Dialogue: 0,0:49:07.95,0:49:11.45,Default,,0000,0000,0000,,こっ この緑の塊は毒かしら?
Dialogue: 0,0:49:11.45,0:49:14.95,Default,,0000,0000,0000,,はっ 鼻が ツーンとして
Dialogue: 0,0:49:14.95,0:49:17.45,Default,,0000,0000,0000,,クルシュ様も どうですか?
Dialogue: 0,0:49:17.45,0:49:20.79,Default,,0000,0000,0000,,そのとき 俺様は言ったのさ!
Dialogue: 0,0:49:20.79,0:49:25.30,Default,,0000,0000,0000,,てめえらの悪事は お見通しだぜ 三下どもが! ってな
Dialogue: 0,0:49:25.30,0:49:27.80,Default,,0000,0000,0000,,かっちょいい! しびれる!
Dialogue: 0,0:49:27.80,0:49:30.47,Default,,0000,0000,0000,,すごい!
Dialogue: 0,0:49:30.47,0:49:33.97,Default,,0000,0000,0000,,よう お前んち こっちでいいのか?
Dialogue: 0,0:49:30.47,0:49:33.97,Default,,0000,0000,0000,,うん
Dialogue: 0,0:49:33.97,0:49:38.64,Default,,0000,0000,0000,,それっにしても チビどもだけで ずいっぶん 遠出したじゃねえか
Dialogue: 0,0:49:38.64,0:49:42.48,Default,,0000,0000,0000,,お姉ちゃん 怒ってるかな?
Dialogue: 0,0:49:38.64,0:49:42.48,Default,,0000,0000,0000,,ないしょで出てきたから
Dialogue: 0,0:49:42.48,0:49:47.15,Default,,0000,0000,0000,,あ 姉貴が おっかねえってのは 俺様にも わかっかんな
Dialogue: 0,0:49:47.15,0:49:51.82,Default,,0000,0000,0000,,よし 俺様に任せとけや!
Dialogue: 0,0:49:47.15,0:49:51.82,Default,,0000,0000,0000,,あっ ほんと? ゴージャスタイガー
Dialogue: 0,0:49:51.82,0:49:54.16,Default,,0000,0000,0000,,あっ フレド!
Dialogue: 0,0:49:51.82,0:49:54.16,Default,,0000,0000,0000,,おっ お姉ちゃん!
Dialogue: 0,0:49:54.16,0:49:56.16,Default,,0000,0000,0000,,何してんの!
Dialogue: 0,0:49:54.16,0:49:56.16,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:49:56.16,0:49:59.33,Default,,0000,0000,0000,,どれだけ うちに心配かけたら 気が済むのよ!
Dialogue: 0,0:49:59.33,0:50:02.83,Default,,0000,0000,0000,,まあまあ 姉ちゃん こいつにも 悪気はねえんだ
Dialogue: 0,0:50:02.83,0:50:05.34,Default,,0000,0000,0000,,ここは 大目に
Dialogue: 0,0:50:02.83,0:50:05.34,Default,,0000,0000,0000,,お姉ちゃん
Dialogue: 0,0:50:05.34,0:50:08.34,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:50:05.34,0:50:08.34,Default,,0000,0000,0000,,フレドは いたの?
Dialogue: 0,0:50:08.34,0:50:10.34,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:50:10.34,0:50:13.51,Default,,0000,0000,0000,,うちの子が お世話になったみたいで
Dialogue: 0,0:50:13.51,0:50:15.85,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:50:15.85,0:50:18.35,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:50:26.69,0:50:30.39,Default,,0000,0000,0000,,ハッ ハァ ああ
Dialogue: 0,0:50:34.20,0:50:36.20,Default,,0000,0000,0000,,母さん?
Dialogue: 0,0:50:39.54,0:50:44.21,Default,,0000,0000,0000,,んっ もう 食べられないのよ
Dialogue: 0,0:50:39.54,0:50:44.21,Default,,0000,0000,0000,,うん!
Dialogue: 0,0:50:44.21,0:50:49.91,Default,,0000,0000,0000,,けど このツーンは
Dialogue: 0,0:50:44.21,0:50:49.91,Default,,0000,0000,0000,,意外と癖になるかしら
Dialogue: 0,0:50:53.55,0:50:55.55,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:50:57.89,0:51:00.32,Default,,0000,0000,0000,,驚かせてしまいましたかな?
Dialogue: 0,0:51:00.32,0:51:03.16,Default,,0000,0000,0000,,いえ
Dialogue: 0,0:51:00.32,0:51:03.16,Default,,0000,0000,0000,,ちょっと 見とれてただけです
Dialogue: 0,0:51:03.16,0:51:06.33,Default,,0000,0000,0000,,剣鬼と和風庭園が似合いすぎて
Dialogue: 0,0:51:06.33,0:51:09.00,Default,,0000,0000,0000,,月夜が映える人 好きなんで
Dialogue: 0,0:51:09.00,0:51:11.84,Default,,0000,0000,0000,,そのような言葉 私ではなく
Dialogue: 0,0:51:11.84,0:51:16.01,Default,,0000,0000,0000,,女性に ささやくべきでしょう
Dialogue: 0,0:51:11.84,0:51:16.01,Default,,0000,0000,0000,,損な お方だ
Dialogue: 0,0:51:16.01,0:51:19.34,Default,,0000,0000,0000,,目下のところ いちばん 心をくすぐりたい子には
Dialogue: 0,0:51:19.34,0:51:22.51,Default,,0000,0000,0000,,この手の言い回しが 全く通用しないんですよ
Dialogue: 0,0:51:22.51,0:51:26.18,Default,,0000,0000,0000,,その もどかしさも また 恋の楽しみですよ
Dialogue: 0,0:51:26.18,0:51:29.85,Default,,0000,0000,0000,,久しぶりに のろけ話の雰囲気ですね?
Dialogue: 0,0:51:29.85,0:51:32.69,Default,,0000,0000,0000,,聞きますかな?
Dialogue: 0,0:51:29.85,0:51:32.69,Default,,0000,0000,0000,,ぜひに
Dialogue: 0,0:51:32.69,0:51:35.09,Default,,0000,0000,0000,,では
Dialogue: 0,0:51:37.03,0:51:43.70,Default,,0000,0000,0000,,かつての私は 今以上に口下手で
Dialogue: 0,0:51:37.03,0:51:43.70,Default,,0000,0000,0000,,言葉の足らない男でした
Dialogue: 0,0:51:43.70,0:51:49.04,Default,,0000,0000,0000,,剣を振ることが
Dialogue: 0,0:51:43.70,0:51:49.04,Default,,0000,0000,0000,,私のすべてでした
Dialogue: 0,0:51:49.04,0:51:55.05,Default,,0000,0000,0000,,剣を振るまでに思ったことも
Dialogue: 0,0:51:49.04,0:51:55.05,Default,,0000,0000,0000,,剣を振ることで思えたことも
Dialogue: 0,0:51:55.05,0:51:58.05,Default,,0000,0000,0000,,私を形づくる すべてでした
Dialogue: 0,0:51:58.05,0:52:02.99,Default,,0000,0000,0000,,妻は 私に そんな当たり前のことを 気付かせてくれた
Dialogue: 0,0:52:02.99,0:52:07.16,Default,,0000,0000,0000,,それからは 剣を握るたびに 妻を思い出す
Dialogue: 0,0:52:07.16,0:52:10.16,Default,,0000,0000,0000,,それは 今でも?
Dialogue: 0,0:52:10.16,0:52:16.00,Default,,0000,0000,0000,,私と妻をつないでくれたのは
Dialogue: 0,0:52:10.16,0:52:16.00,Default,,0000,0000,0000,,今も昔も剣でした
Dialogue: 0,0:52:16.00,0:52:22.51,Default,,0000,0000,0000,,剣を握るかぎり
Dialogue: 0,0:52:16.00,0:52:22.51,Default,,0000,0000,0000,,私は 妻を思い続けるでしょう
Dialogue: 0,0:52:22.51,0:52:26.68,Default,,0000,0000,0000,,奥さんは 先代の剣聖だったんですよね
Dialogue: 0,0:52:26.68,0:52:32.68,Default,,0000,0000,0000,,平時の妻は 花をめでるのを好む
Dialogue: 0,0:52:26.68,0:52:32.68,Default,,0000,0000,0000,,普通の女性でした
Dialogue: 0,0:52:32.68,0:52:36.02,Default,,0000,0000,0000,,歴史に名を残す英雄たちが
Dialogue: 0,0:52:36.02,0:52:39.86,Default,,0000,0000,0000,,常日頃から 英雄で あり続けたわけではありません
Dialogue: 0,0:52:39.86,0:52:43.36,Default,,0000,0000,0000,,そして それは スバル殿も同じです
Dialogue: 0,0:52:39.86,0:52:43.36,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:52:43.36,0:52:48.20,Default,,0000,0000,0000,,あなたの名前も 今は あなたが 思う以上に広がっている
Dialogue: 0,0:52:48.20,0:52:52.70,Default,,0000,0000,0000,,そんなこと
Dialogue: 0,0:52:48.20,0:52:52.70,Default,,0000,0000,0000,,私は確信しております
Dialogue: 0,0:52:52.70,0:52:55.54,Default,,0000,0000,0000,,スバル殿は 1人で 成しえないことを
Dialogue: 0,0:52:55.54,0:53:00.14,Default,,0000,0000,0000,,1人では 成しえない誰かを集めて 成し遂げてしまう人物なのだと
Dialogue: 0,0:53:00.14,0:53:02.81,Default,,0000,0000,0000,,俺は ちっぽけで どうしようもない
Dialogue: 0,0:53:02.81,0:53:05.48,Default,,0000,0000,0000,,ろくでなしですよ
Dialogue: 0,0:53:02.81,0:53:05.48,Default,,0000,0000,0000,,ええ
Dialogue: 0,0:53:05.48,0:53:08.65,Default,,0000,0000,0000,,ちっぽけで どうしようもない ろくでなしの あなたが
Dialogue: 0,0:53:08.65,0:53:12.16,Default,,0000,0000,0000,,私は好きなのです
Dialogue: 0,0:53:12.16,0:53:16.33,Default,,0000,0000,0000,,少々 しゃべり過ぎましたかな
Dialogue: 0,0:53:16.33,0:53:21.50,Default,,0000,0000,0000,,しかし スバル殿と話していると
Dialogue: 0,0:53:16.33,0:53:21.50,Default,,0000,0000,0000,,いつも思ってしまう
Dialogue: 0,0:53:21.50,0:53:25.67,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:53:21.50,0:53:25.67,Default,,0000,0000,0000,,どうして 私は 自分の孫と
Dialogue: 0,0:53:25.67,0:53:30.67,Default,,0000,0000,0000,,こうして 言葉を交わすことが できずにいるのだろうかと
Dialogue: 0,0:53:30.67,0:53:33.84,Default,,0000,0000,0000,,ラインハルトとは 仲よくできないんですか?
Dialogue: 0,0:53:33.84,0:53:37.18,Default,,0000,0000,0000,,家族ですよね?
Dialogue: 0,0:53:33.84,0:53:37.18,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:53:37.18,0:53:39.68,Default,,0000,0000,0000,,私には 己の人生の中で
Dialogue: 0,0:53:39.68,0:53:43.19,Default,,0000,0000,0000,,決して 言い訳のできない後悔が 3つある
Dialogue: 0,0:53:46.02,0:53:48.36,Default,,0000,0000,0000,,そのうちの1つが
Dialogue: 0,0:53:48.36,0:53:52.16,Default,,0000,0000,0000,,今の私と孫との間にある 溝の原因です
Dialogue: 0,0:53:54.86,0:53:59.54,Default,,0000,0000,0000,,度し難いほど 許し難いほどに愚かでした
Dialogue: 0,0:53:59.54,0:54:02.47,Default,,0000,0000,0000,,妻の敵討ちを理由に
Dialogue: 0,0:54:02.47,0:54:05.98,Default,,0000,0000,0000,,私は その後悔から目を背けてきた
Dialogue: 0,0:54:05.98,0:54:08.65,Default,,0000,0000,0000,,そして 敵討ちを果たした今
Dialogue: 0,0:54:08.65,0:54:12.48,Default,,0000,0000,0000,,本当なら 歩み寄るべきだと わかってはいるのです
Dialogue: 0,0:54:12.48,0:54:15.82,Default,,0000,0000,0000,,でも 勇気がない
Dialogue: 0,0:54:15.82,0:54:18.52,Default,,0000,0000,0000,,お恥ずかしいかぎりです
Dialogue: 0,0:54:24.66,0:54:30.83,Default,,0000,0000,0000,,ラインハルト 白鯨のときのことを
Dialogue: 0,0:54:24.66,0:54:30.83,Default,,0000,0000,0000,,聞きたいって言ってましたよ
Dialogue: 0,0:54:30.83,0:54:35.17,Default,,0000,0000,0000,,白鯨のことが 2人の気まずい仲に 関係あるかは知りません
Dialogue: 0,0:54:35.17,0:54:39.18,Default,,0000,0000,0000,,でも ラインハルトは ヴィルヘルムさんが 10年以上かけて
Dialogue: 0,0:54:39.18,0:54:42.01,Default,,0000,0000,0000,,おばあちゃんの敵を 取ったんだって知ってる
Dialogue: 0,0:54:42.01,0:54:45.35,Default,,0000,0000,0000,,その話を聞きたがってる
Dialogue: 0,0:54:45.35,0:54:49.35,Default,,0000,0000,0000,,きっと あいつも期待してますよ
Dialogue: 0,0:54:49.35,0:54:51.66,Default,,0000,0000,0000,,ヴィルヘルムさんが話してくれるのを
Dialogue: 0,0:54:54.69,0:54:57.03,Default,,0000,0000,0000,,全く
Dialogue: 0,0:54:57.03,0:55:01.03,Default,,0000,0000,0000,,スバル殿には かないませんな
Dialogue: 0,0:55:11.64,0:55:16.65,Default,,0000,0000,0000,,1 2 3 4 5 6 7 8
Dialogue: 0,0:55:16.65,0:55:22.32,Default,,0000,0000,0000,,1 2 3 4 5 6 7 8
Dialogue: 0,0:55:22.32,0:55:25.32,Default,,0000,0000,0000,,さあ 両手を上げて
Dialogue: 0,0:55:25.32,0:55:27.66,Default,,0000,0000,0000,,ビクトリー!
Dialogue: 0,0:55:27.66,0:55:31.49,Default,,0000,0000,0000,,スバル なんだか 今朝は すごく ご機嫌ね
Dialogue: 0,0:55:31.49,0:55:34.33,Default,,0000,0000,0000,,昨日は 寝る前に ちょっと いいことがあってさ
Dialogue: 0,0:55:34.33,0:55:36.50,Default,,0000,0000,0000,,そうなんだ よかった
Dialogue: 0,0:55:36.50,0:55:40.67,Default,,0000,0000,0000,,スバル ちょっと 悩んでたみたいだから
Dialogue: 0,0:55:36.50,0:55:40.67,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:55:40.67,0:55:44.17,Default,,0000,0000,0000,,スバルと違って あっちは ひどいありさまなのよ
Dialogue: 0,0:55:44.17,0:55:47.51,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:55:44.17,0:55:47.51,Default,,0000,0000,0000,,うっ うっ オエー!
Dialogue: 0,0:55:47.51,0:55:49.68,Default,,0000,0000,0000,,オットーは 二日酔いか?
Dialogue: 0,0:55:49.68,0:55:53.02,Default,,0000,0000,0000,,ええ せっかく プリステラまで来たんですから
Dialogue: 0,0:55:53.02,0:55:55.52,Default,,0000,0000,0000,,昨夜は いろんな人と会って 顔つなぎを
Dialogue: 0,0:55:55.52,0:55:57.52,Default,,0000,0000,0000,,オエッ!
Dialogue: 0,0:55:55.52,0:55:57.52,Default,,0000,0000,0000,,危ねえ!
Dialogue: 0,0:55:57.52,0:56:00.29,Default,,0000,0000,0000,,そういえば ガーフィールが見当たりませんね
Dialogue: 0,0:56:00.29,0:56:05.63,Default,,0000,0000,0000,,んっ あいつは 今
Dialogue: 0,0:56:00.29,0:56:05.63,Default,,0000,0000,0000,,ちょっと ナイーブな状態なんだ
Dialogue: 0,0:56:05.63,0:56:09.47,Default,,0000,0000,0000,,見かけたら優しくしてやってくれ
Dialogue: 0,0:56:05.63,0:56:09.47,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:56:09.47,0:56:13.14,Default,,0000,0000,0000,,それで オットー君 今日は どんな予定なの?
Dialogue: 0,0:56:13.14,0:56:15.14,Default,,0000,0000,0000,,リリアナを 人質にして
Dialogue: 0,0:56:15.14,0:56:18.48,Default,,0000,0000,0000,,魔晶石と交換するって作戦で いくんだっけ?
Dialogue: 0,0:56:18.48,0:56:21.14,Default,,0000,0000,0000,,とりあえず ナツキさんは 居残りで お願いします
Dialogue: 0,0:56:21.14,0:56:23.48,Default,,0000,0000,0000,,反論は 受け付けません!
Dialogue: 0,0:56:23.48,0:56:25.82,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:56:23.48,0:56:25.82,Default,,0000,0000,0000,,よう そろってんな
Dialogue: 0,0:56:25.82,0:56:28.32,Default,,0000,0000,0000,,ずいぶん 朝が早えじゃんか
Dialogue: 0,0:56:28.32,0:56:32.16,Default,,0000,0000,0000,,あれ? この緑色の兄ちゃん 昨日は いなかったよな?
Dialogue: 0,0:56:32.16,0:56:34.32,Default,,0000,0000,0000,,うちの内政官だ
Dialogue: 0,0:56:34.32,0:56:37.16,Default,,0000,0000,0000,,まあ お前らにとっての チンみたいな存在だな
Dialogue: 0,0:56:37.16,0:56:41.16,Default,,0000,0000,0000,,そういえば フェルトちゃん ラインハルトとは 一緒じゃないのね
Dialogue: 0,0:56:41.16,0:56:45.17,Default,,0000,0000,0000,,がきじゃねえんだから くっつかれてもうぜえだけだっての!
Dialogue: 0,0:56:45.17,0:56:49.34,Default,,0000,0000,0000,,それに これは 私も認めたくねえけど あいつ
Dialogue: 0,0:56:49.34,0:56:51.51,Default,,0000,0000,0000,,私が呼んだら 1秒で来るぞ
Dialogue: 0,0:56:51.51,0:56:54.68,Default,,0000,0000,0000,,フェルト様 お呼びですか?
Dialogue: 0,0:56:51.51,0:56:54.68,Default,,0000,0000,0000,,呼んでねえよ!
Dialogue: 0,0:56:54.68,0:56:57.01,Default,,0000,0000,0000,,エミリア様 おはようございます
Dialogue: 0,0:56:57.01,0:56:59.85,Default,,0000,0000,0000,,スバルも おはよう いい朝だね
Dialogue: 0,0:56:59.85,0:57:03.95,Default,,0000,0000,0000,,フフフフ フェルトちゃんとラインハルト すごく仲よし
Dialogue: 0,0:57:03.95,0:57:08.79,Default,,0000,0000,0000,,そだね 仲よし ごちそうさまシナリオだね
Dialogue: 0,0:57:03.95,0:57:08.79,Default,,0000,0000,0000,,ぐっ
Dialogue: 0,0:57:08.79,0:57:11.80,Default,,0000,0000,0000,,んだ?
Dialogue: 0,0:57:08.79,0:57:11.80,Default,,0000,0000,0000,,その 死ぬほど不愉快な言葉は!
Dialogue: 0,0:57:11.80,0:57:14.30,Default,,0000,0000,0000,,気に入らねえ!
Dialogue: 0,0:57:22.97,0:57:25.14,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:57:25.14,0:57:27.31,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:57:25.14,0:57:27.31,Default,,0000,0000,0000,,おはようさん
Dialogue: 0,0:57:27.31,0:57:30.98,Default,,0000,0000,0000,,なんや おそろいで 仲よしなんやね
Dialogue: 0,0:57:30.98,0:57:32.98,Default,,0000,0000,0000,,アナスタシア様
Dialogue: 0,0:57:30.98,0:57:32.98,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:57:32.98,0:57:35.82,Default,,0000,0000,0000,,今朝は ますます お美しい
Dialogue: 0,0:57:35.82,0:57:39.66,Default,,0000,0000,0000,,エッヘヘヘ! うちの隠し玉やで
Dialogue: 0,0:57:39.66,0:57:43.33,Default,,0000,0000,0000,,あれ? リカードとミミたちとは 一緒やなかったん?
Dialogue: 0,0:57:43.33,0:57:47.83,Default,,0000,0000,0000,,リカードは戻っていません
Dialogue: 0,0:57:43.33,0:57:47.83,Default,,0000,0000,0000,,それと ミミなのですが
Dialogue: 0,0:57:47.83,0:57:50.67,Default,,0000,0000,0000,,どうやら ガーフィールに ついて回っているようで
Dialogue: 0,0:57:50.67,0:57:53.50,Default,,0000,0000,0000,,昨夜から 宿に戻っていないと知って
Dialogue: 0,0:57:53.50,0:57:57.17,Default,,0000,0000,0000,,ヘータローとティビーが 慌てて 街に飛び出していきました
Dialogue: 0,0:57:57.17,0:58:01.44,Default,,0000,0000,0000,,ミミのことやと ヘータローは 周りが見えんくなるからね
Dialogue: 0,0:58:01.44,0:58:04.61,Default,,0000,0000,0000,,でも ティビーがいるなら大丈夫
Dialogue: 0,0:58:01.44,0:58:04.61,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:58:04.61,0:58:07.95,Default,,0000,0000,0000,,その代わり ヨシュアに お願いしたいことがあるんやけど
Dialogue: 0,0:58:07.95,0:58:09.95,Default,,0000,0000,0000,,なっ なんでしょうか?
Dialogue: 0,0:58:09.95,0:58:15.46,Default,,0000,0000,0000,,ヘータローたちの代わりに 大正門に
Dialogue: 0,0:58:09.95,0:58:15.46,Default,,0000,0000,0000,,手紙を届けに行ってほしいんよ
Dialogue: 0,0:58:15.46,0:58:18.13,Default,,0000,0000,0000,,大事な大事な手紙やからね
Dialogue: 0,0:58:18.13,0:58:20.96,Default,,0000,0000,0000,,あっ それって まさか 暴食の?
Dialogue: 0,0:58:20.96,0:58:24.13,Default,,0000,0000,0000,,頼んだぞ ヨシュア
Dialogue: 0,0:58:20.96,0:58:24.13,Default,,0000,0000,0000,,お前が 俺の希望だ!
Dialogue: 0,0:58:24.13,0:58:27.97,Default,,0000,0000,0000,,なんで あなたに頼まれる必要が
Dialogue: 0,0:58:27.97,0:58:29.97,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:58:29.97,0:58:34.31,Default,,0000,0000,0000,,遅くなりました
Dialogue: 0,0:58:29.97,0:58:34.31,Default,,0000,0000,0000,,私たちが最後のようですね
Dialogue: 0,0:58:34.31,0:58:37.15,Default,,0000,0000,0000,,これで 今朝は ひとそろいみたいやね
Dialogue: 0,0:58:37.15,0:58:39.55,Default,,0000,0000,0000,,そしたら 運び込んでくれる?
Dialogue: 0,0:58:45.32,0:58:47.32,Default,,0000,0000,0000,,こっ これは!
Dialogue: 0,0:58:47.32,0:58:49.33,Default,,0000,0000,0000,,今日の朝食は
Dialogue: 0,0:58:49.33,0:58:54.50,Default,,0000,0000,0000,,カララギの国民的な伝統料理
Dialogue: 0,0:58:49.33,0:58:54.50,Default,,0000,0000,0000,,ダイスキヤキや!
Dialogue: 0,0:58:54.50,0:58:57.50,Default,,0000,0000,0000,,おっ お好み焼きだと!?
Dialogue: 0,0:59:01.10,0:59:03.61,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:59:03.61,0:59:06.44,Default,,0000,0000,0000,,スバル 見て!
Dialogue: 0,0:59:03.61,0:59:06.44,Default,,0000,0000,0000,,きれいに ひっくり返せたの
Dialogue: 0,0:59:06.44,0:59:08.61,Default,,0000,0000,0000,,自信作だわ! 食べて!
Dialogue: 0,0:59:08.61,0:59:11.28,Default,,0000,0000,0000,,まあまあ うまく出来たかしら
Dialogue: 0,0:59:11.28,0:59:14.12,Default,,0000,0000,0000,,スバル せっかくだから ベティーが焼いてあげた
Dialogue: 0,0:59:14.12,0:59:18.12,Default,,0000,0000,0000,,このダイスキヤキ 食べさせてあげてもいいのよ
Dialogue: 0,0:59:18.12,0:59:20.12,Default,,0000,0000,0000,,ベアトリスちゃん
Dialogue: 0,0:59:20.12,0:59:22.13,Default,,0000,0000,0000,,いくらなんでも ソース かけすぎ!
Dialogue: 0,0:59:22.13,0:59:25.46,Default,,0000,0000,0000,,エミリア様も!
Dialogue: 0,0:59:22.13,0:59:25.46,Default,,0000,0000,0000,,生焼けは おなか壊しますから!
Dialogue: 0,0:59:25.46,0:59:30.27,Default,,0000,0000,0000,,まずは 2人とも 自分で 味見してから 人に薦めようか
Dialogue: 0,0:59:32.64,0:59:34.80,Default,,0000,0000,0000,,フェルト様 次が焼けました
Dialogue: 0,0:59:34.80,0:59:38.64,Default,,0000,0000,0000,,お 上手 上手
Dialogue: 0,0:59:34.80,0:59:38.64,Default,,0000,0000,0000,,その調子で ガンガン 焼けよ
Dialogue: 0,0:59:38.64,0:59:40.64,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:59:40.64,0:59:44.98,Default,,0000,0000,0000,,んっ ああ あっ ハァ
Dialogue: 0,0:59:44.98,0:59:48.15,Default,,0000,0000,0000,,なんか 見ちゃいけないものを 見た気分だな
Dialogue: 0,0:59:48.15,0:59:51.65,Default,,0000,0000,0000,,プリステラ市民の皆さん おはようございます
Dialogue: 0,0:59:51.65,0:59:55.16,Default,,0000,0000,0000,,気持ちのいい朝ですね
Dialogue: 0,0:59:51.65,0:59:55.16,Default,,0000,0000,0000,,おっ? なんだ? こりゃ
Dialogue: 0,0:59:55.16,0:59:57.66,Default,,0000,0000,0000,,この街の 毎朝のお約束
Dialogue: 0,0:59:57.66,1:00:00.83,Default,,0000,0000,0000,,都市庁舎にある ミーティアを使った放送なんよ
Dialogue: 0,1:00:00.83,1:00:03.33,Default,,0000,0000,0000,,ミーティアの放送
Dialogue: 0,1:00:03.33,1:00:08.34,Default,,0000,0000,0000,,毎日 放送があるのですか?
Dialogue: 0,1:00:03.33,1:00:08.34,Default,,0000,0000,0000,,それは なんのために?
Dialogue: 0,1:00:08.34,1:00:11.01,Default,,0000,0000,0000,,有事の際の備えと聞いています
Dialogue: 0,1:00:11.01,1:00:14.01,Default,,0000,0000,0000,,この都市は構造上 緊急時の避難経路が
Dialogue: 0,1:00:14.01,1:00:17.68,Default,,0000,0000,0000,,限られていますので
Dialogue: 0,1:00:14.01,1:00:17.68,Default,,0000,0000,0000,,ふん にゃるほどね
Dialogue: 0,1:00:17.68,1:00:20.35,Default,,0000,0000,0000,,ちなみに この放送の提案者も
Dialogue: 0,1:00:20.35,1:00:22.69,Default,,0000,0000,0000,,ミーティアの提供も キリタカさんだそうです
Dialogue: 0,1:00:22.69,1:00:26.02,Default,,0000,0000,0000,,リリアナ・マスカレードの出番で
Dialogue: 0,1:00:22.69,1:00:26.02,Default,,0000,0000,0000,,あ これ 本人だわ
Dialogue: 0,1:00:26.02,1:00:29.19,Default,,0000,0000,0000,,皆さん どもです!
Dialogue: 0,1:00:26.02,1:00:29.19,Default,,0000,0000,0000,,リリアナですよ!
Dialogue: 0,1:00:29.19,1:00:33.36,Default,,0000,0000,0000,,精いっぱい 歌って奏でて 楽しませたい所存ですので
Dialogue: 0,1:00:33.36,1:00:38.03,Default,,0000,0000,0000,,この 短い ひとときを 皆さんも ぜひぜひ 楽しんでいただいて
Dialogue: 0,1:00:38.03,1:00:41.37,Default,,0000,0000,0000,,応援よろです!
Dialogue: 0,1:00:41.37,1:00:46.04,Default,,0000,0000,0000,,では 歌います 聴いてください
Dialogue: 0,1:00:41.37,1:00:46.04,Default,,0000,0000,0000,,「剣鬼恋歌 第二幕」
Dialogue: 0,1:00:46.04,1:00:48.04,Default,,0000,0000,0000,,んっ ばっ!
Dialogue: 0,1:00:51.55,1:01:00.99,Default,,0000,0000,0000,,「街のはずれの
Dialogue: 0,1:00:51.55,1:01:00.99,Default,,0000,0000,0000,,人気のない片隅へ」
Dialogue: 0,1:01:00.99,1:01:10.60,Default,,0000,0000,0000,,「剣鬼は向かう 孤独を手に携え」
Dialogue: 0,1:01:13.67,1:01:16.51,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:01:16.51,1:01:19.01,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:01:19.01,1:01:23.35,Default,,0000,0000,0000,,ラインハルト
Dialogue: 0,1:01:19.01,1:01:23.35,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:01:23.35,1:01:27.52,Default,,0000,0000,0000,,その だな
Dialogue: 0,1:01:23.35,1:01:27.52,Default,,0000,0000,0000,,はい なんでしょうか?
Dialogue: 0,1:01:27.52,1:01:30.85,Default,,0000,0000,0000,,うまく焼けそうにない
Dialogue: 0,1:01:30.85,1:01:35.02,Default,,0000,0000,0000,,コツがあれば 教えてもらえないだろうか?
Dialogue: 0,1:01:35.02,1:01:37.03,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:01:39.53,1:01:42.63,Default,,0000,0000,0000,,はい わかりました おじい様
Dialogue: 0,1:01:52.38,1:01:54.38,Default,,0000,0000,0000,,そりゃ ないぜ
Dialogue: 0,1:01:52.38,1:01:54.38,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:01:54.38,1:01:58.55,Default,,0000,0000,0000,,今更 都合がよすぎるんじゃねえか
Dialogue: 0,1:01:58.55,1:02:00.82,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,1:02:00.82,1:02:03.02,Default,,0000,0000,0000,,おやじ殿
Dialogue: 0,1:02:00.82,1:02:03.02,Default,,0000,0000,0000,,くっ
Dialogue: 0,1:02:08.49,1:02:12.50,Default,,0000,0000,0000,,あんた 誰だよ?
Dialogue: 0,1:02:08.49,1:02:12.50,Default,,0000,0000,0000,,ああん?
Dialogue: 0,1:02:12.50,1:02:18.67,Default,,0000,0000,0000,,ずいぶんと 敵意満々な
Dialogue: 0,1:02:12.50,1:02:18.67,Default,,0000,0000,0000,,目つきしてくれてんな がき
Dialogue: 0,1:02:18.67,1:02:21.00,Default,,0000,0000,0000,,ハァ
Dialogue: 0,1:02:21.00,1:02:24.01,Default,,0000,0000,0000,,おい! 剣聖でも ユークリウスでもいい
Dialogue: 0,1:02:24.01,1:02:27.34,Default,,0000,0000,0000,,この無礼な がき ぶった斬れ
Dialogue: 0,1:02:27.34,1:02:29.35,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:02:27.34,1:02:29.35,Default,,0000,0000,0000,,お言葉ですが
Dialogue: 0,1:02:27.34,1:02:29.35,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:02:29.35,1:02:34.52,Default,,0000,0000,0000,,現在 私も ラインハルトも 特務により
Dialogue: 0,1:02:29.35,1:02:34.52,Default,,0000,0000,0000,,本来の役目を離れております
Dialogue: 0,1:02:34.52,1:02:36.69,Default,,0000,0000,0000,,たとえ 副団長といえど
Dialogue: 0,1:02:36.69,1:02:39.69,Default,,0000,0000,0000,,我々への命令権を お持ちではないはず
Dialogue: 0,1:02:39.69,1:02:42.02,Default,,0000,0000,0000,,お お 怖い 怖い
Dialogue: 0,1:02:42.02,1:02:45.53,Default,,0000,0000,0000,,冗談に決まってんだろうが
Dialogue: 0,1:02:42.02,1:02:45.53,Default,,0000,0000,0000,,熱くなんなよ
Dialogue: 0,1:02:45.53,1:02:48.70,Default,,0000,0000,0000,,いくら 俺が お飾りの副団長っていっても
Dialogue: 0,1:02:48.70,1:02:51.20,Default,,0000,0000,0000,,そんぐらいの団則は わきまえてらあ
Dialogue: 0,1:02:51.20,1:02:55.37,Default,,0000,0000,0000,,お飾りの副団長?
Dialogue: 0,1:02:51.20,1:02:55.37,Default,,0000,0000,0000,,そうだよ お飾りだ
Dialogue: 0,1:02:55.37,1:03:00.31,Default,,0000,0000,0000,,お飾りで 嫌われ者の ルグニカ王国 近衛騎士団 副団長
Dialogue: 0,1:03:00.31,1:03:03.65,Default,,0000,0000,0000,,無駄飯食らい ハインケルってのは 俺のことさ
Dialogue: 0,1:03:03.65,1:03:07.48,Default,,0000,0000,0000,,無駄飯食らいも 嫌われ者も 開き直ってんじゃねえよ
Dialogue: 0,1:03:07.48,1:03:09.49,Default,,0000,0000,0000,,落ち着きたまえ スバル
Dialogue: 0,1:03:09.49,1:03:11.82,Default,,0000,0000,0000,,副団長の空気に 飲まれてはいけない
Dialogue: 0,1:03:11.82,1:03:16.33,Default,,0000,0000,0000,,ハッ! さすがは最優
Dialogue: 0,1:03:11.82,1:03:16.33,Default,,0000,0000,0000,,お行儀のいい言葉選びだ
Dialogue: 0,1:03:16.33,1:03:19.83,Default,,0000,0000,0000,,ハインケル!
Dialogue: 0,1:03:19.83,1:03:21.83,Default,,0000,0000,0000,,ハインケル
Dialogue: 0,1:03:21.83,1:03:24.33,Default,,0000,0000,0000,,1回 呼べば わかりますよ
Dialogue: 0,1:03:24.33,1:03:27.50,Default,,0000,0000,0000,,まだ 耳が遠くなるような 年じゃありません
Dialogue: 0,1:03:27.50,1:03:31.84,Default,,0000,0000,0000,,それより 薄情じゃねえですか
Dialogue: 0,1:03:27.50,1:03:31.84,Default,,0000,0000,0000,,白鯨討伐のお祝い
Dialogue: 0,1:03:31.84,1:03:36.01,Default,,0000,0000,0000,,俺からも 述べさせて もらいたかったってのに ハハハハ
Dialogue: 0,1:03:36.01,1:03:38.51,Default,,0000,0000,0000,,なあ? おやじ殿
Dialogue: 0,1:03:38.51,1:03:41.02,Default,,0000,0000,0000,,ハインケル 私は
Dialogue: 0,1:03:41.02,1:03:45.69,Default,,0000,0000,0000,,ラインハルト! お前も そうだろ?
Dialogue: 0,1:03:41.02,1:03:45.69,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:03:45.69,1:03:49.86,Default,,0000,0000,0000,,お前も おやじ殿のおかげで 肩の荷が下りただろ?
Dialogue: 0,1:03:49.86,1:03:53.70,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,1:03:49.86,1:03:53.70,Default,,0000,0000,0000,,なんせ お前が死なせた
Dialogue: 0,1:03:53.70,1:03:57.37,Default,,0000,0000,0000,,先代様の敵討ちを していただいたんだからな
Dialogue: 0,1:03:57.37,1:03:59.37,Default,,0000,0000,0000,,やめろ ハインケル!
Dialogue: 0,1:03:59.37,1:04:04.47,Default,,0000,0000,0000,,お前は
Dialogue: 0,1:03:59.37,1:04:04.47,Default,,0000,0000,0000,,お前というやつは どこまで
Dialogue: 0,1:04:04.47,1:04:08.14,Default,,0000,0000,0000,,今更 きれい事なんて やめてくれよ おやじ殿
Dialogue: 0,1:04:08.14,1:04:11.48,Default,,0000,0000,0000,,あんたにだけは 俺を非難する資格はねえ
Dialogue: 0,1:04:11.48,1:04:15.48,Default,,0000,0000,0000,,先代を殺したと 最初に ラインハルトをなじったのは
Dialogue: 0,1:04:15.48,1:04:18.32,Default,,0000,0000,0000,,他でもない あんたなんだからな
Dialogue: 0,1:04:18.32,1:04:20.32,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:04:20.32,1:04:23.83,Default,,0000,0000,0000,,ハン!
Dialogue: 0,1:04:20.32,1:04:23.83,Default,,0000,0000,0000,,都合が悪くなれば だんまりか
Dialogue: 0,1:04:23.83,1:04:26.16,Default,,0000,0000,0000,,それじゃ 仲直りだってできるはずがねえ
Dialogue: 0,1:04:26.16,1:04:31.50,Default,,0000,0000,0000,,そんな都合がいいこと
Dialogue: 0,1:04:26.16,1:04:31.50,Default,,0000,0000,0000,,テレシア・ヴァン・アストレアが許すかよ
Dialogue: 0,1:04:31.50,1:04:34.50,Default,,0000,0000,0000,,ハインケル・ヴァン・アストレア
Dialogue: 0,1:04:34.50,1:04:37.17,Default,,0000,0000,0000,,チッ ヴァンを付けるな がき!
Dialogue: 0,1:04:37.17,1:04:41.68,Default,,0000,0000,0000,,その剣名は もらってねえ
Dialogue: 0,1:04:37.17,1:04:41.68,Default,,0000,0000,0000,,ハインケル・アストレアだ
Dialogue: 0,1:04:41.68,1:04:46.68,Default,,0000,0000,0000,,それで あなたは 何をしに ここに来たの?
Dialogue: 0,1:04:44.01,1:04:46.68,Default,,0000,0000,0000,,エミリア
Dialogue: 0,1:04:46.68,1:04:50.02,Default,,0000,0000,0000,,これは これは
Dialogue: 0,1:04:46.68,1:04:50.02,Default,,0000,0000,0000,,あなたが エミリア様で
Dialogue: 0,1:04:50.02,1:04:53.36,Default,,0000,0000,0000,,なんでも 勝ち目のない戦いに 担ぎ出された
Dialogue: 0,1:04:53.36,1:04:55.52,Default,,0000,0000,0000,,半魔のお姫様だとか
Dialogue: 0,1:04:53.36,1:04:55.52,Default,,0000,0000,0000,,ぐっ!
Dialogue: 0,1:04:55.52,1:05:00.30,Default,,0000,0000,0000,,あなたが 私を どう思っているか 今は その話はしていないわ
Dialogue: 0,1:05:00.30,1:05:02.80,Default,,0000,0000,0000,,私が聞きたいのは 1つだけ
Dialogue: 0,1:05:02.80,1:05:05.13,Default,,0000,0000,0000,,あなたは 何をしに ここに来たの?
Dialogue: 0,1:05:05.13,1:05:09.14,Default,,0000,0000,0000,,んっ チッ!
Dialogue: 0,1:05:05.13,1:05:09.14,Default,,0000,0000,0000,,聞いてた話と違うじゃねえかよ
Dialogue: 0,1:05:09.14,1:05:13.48,Default,,0000,0000,0000,,ちゃんと答えて
Dialogue: 0,1:05:09.14,1:05:13.48,Default,,0000,0000,0000,,うん
Dialogue: 0,1:05:13.48,1:05:16.31,Default,,0000,0000,0000,,自信満々に 乗り込んできたわりには
Dialogue: 0,1:05:16.31,1:05:18.98,Default,,0000,0000,0000,,ずいぶん かっこ悪いな おい
Dialogue: 0,1:05:18.98,1:05:22.99,Default,,0000,0000,0000,,どんな おもしろい話が聞けるんかって 楽しみにしとったのに
Dialogue: 0,1:05:22.99,1:05:26.49,Default,,0000,0000,0000,,無粋な殿方には お帰りいただきたいものですね
Dialogue: 0,1:05:26.49,1:05:29.16,Default,,0000,0000,0000,,お気は済みましたか? 副団長
Dialogue: 0,1:05:26.49,1:05:29.16,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:05:29.16,1:05:31.16,Default,,0000,0000,0000,,他に要件がないのであれば
Dialogue: 0,1:05:31.16,1:05:34.50,Default,,0000,0000,0000,,この場は辞していただくのが お互いのためかと存じます
Dialogue: 0,1:05:34.50,1:05:36.50,Default,,0000,0000,0000,,うっ くっ
Dialogue: 0,1:05:36.50,1:05:40.84,Default,,0000,0000,0000,,その必要はないぞ 凡骨
Dialogue: 0,1:05:36.50,1:05:40.84,Default,,0000,0000,0000,,遅いじゃねえか
Dialogue: 0,1:05:40.84,1:05:44.84,Default,,0000,0000,0000,,いつまでも来ねえから 肝を冷やしたぜ プリシラ嬢
Dialogue: 0,1:05:44.84,1:05:47.68,Default,,0000,0000,0000,,さえずるな
Dialogue: 0,1:05:44.84,1:05:47.68,Default,,0000,0000,0000,,ぐっ
Dialogue: 0,1:05:47.68,1:05:49.68,Default,,0000,0000,0000,,久しい顔ぶれよな
Dialogue: 0,1:05:47.68,1:05:49.68,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:05:49.68,1:05:52.01,Default,,0000,0000,0000,,ずいぶんと なれ合っていたと見えるが
Dialogue: 0,1:05:52.01,1:05:55.52,Default,,0000,0000,0000,,プリシラ そいつを連れてきたのは お前なのか?
Dialogue: 0,1:05:59.36,1:06:02.29,Default,,0000,0000,0000,,誰じゃ? 貴様は
Dialogue: 0,1:05:59.36,1:06:02.29,Default,,0000,0000,0000,,覚えてないのかよ!
Dialogue: 0,1:06:02.29,1:06:05.46,Default,,0000,0000,0000,,姫さんよ いくらなんでも それは ひどくね?
Dialogue: 0,1:06:05.46,1:06:10.13,Default,,0000,0000,0000,,城で 所信表明したとき 大勢の前で 大恥 さらしたやつが いたじゃん?
Dialogue: 0,1:06:10.13,1:06:12.30,Default,,0000,0000,0000,,あれが そこの兄弟だよ
Dialogue: 0,1:06:10.13,1:06:12.30,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:06:12.30,1:06:15.14,Default,,0000,0000,0000,,姫さんも さんざん 腹 抱えて 笑ってたじゃねえか
Dialogue: 0,1:06:15.14,1:06:19.14,Default,,0000,0000,0000,,記憶にない そも わらわが腹を抱えて笑うような
Dialogue: 0,1:06:19.14,1:06:21.31,Default,,0000,0000,0000,,品のないことがあるものか
Dialogue: 0,1:06:21.31,1:06:23.48,Default,,0000,0000,0000,,勝手なことを言うでない アル
Dialogue: 0,1:06:23.48,1:06:26.48,Default,,0000,0000,0000,,だってよ 兄弟
Dialogue: 0,1:06:23.48,1:06:26.48,Default,,0000,0000,0000,,悪いが 力不足だった
Dialogue: 0,1:06:26.48,1:06:30.32,Default,,0000,0000,0000,,お前 もうちょっと 1年間で 発言力 増やしておけよ!
Dialogue: 0,1:06:30.32,1:06:33.16,Default,,0000,0000,0000,,また 頑張って 一から 好感度 上げてくれや
Dialogue: 0,1:06:33.16,1:06:36.99,Default,,0000,0000,0000,,んっ ハァ
Dialogue: 0,1:06:33.16,1:06:36.99,Default,,0000,0000,0000,,それで 質問の答えは?
Dialogue: 0,1:06:36.99,1:06:41.00,Default,,0000,0000,0000,,この凡骨を連れ出したのが わらわかどうかか?
Dialogue: 0,1:06:41.00,1:06:44.50,Default,,0000,0000,0000,,ならば その考えは正しい
Dialogue: 0,1:06:41.00,1:06:44.50,Default,,0000,0000,0000,,そのとおりよ
Dialogue: 0,1:06:44.50,1:06:47.67,Default,,0000,0000,0000,,これは わらわが呼びつけ この場に連れ出した
Dialogue: 0,1:06:47.67,1:06:49.67,Default,,0000,0000,0000,,なっ! なんのために?
Dialogue: 0,1:06:49.67,1:06:52.34,Default,,0000,0000,0000,,強いて言えば
Dialogue: 0,1:06:52.34,1:06:56.18,Default,,0000,0000,0000,,それが おもしろそうだと 思ったからじゃ
Dialogue: 0,1:06:52.34,1:06:56.18,Default,,0000,0000,0000,,なっ!
Dialogue: 0,1:06:56.18,1:07:00.62,Default,,0000,0000,0000,,ゆがんだ家族模様とそれを不細工に取り合わせる無粋
Dialogue: 0,1:07:00.62,1:07:05.29,Default,,0000,0000,0000,,そんな醜悪な演目を 平然と 舞わせるわけにはいくまい
Dialogue: 0,1:07:05.29,1:07:09.46,Default,,0000,0000,0000,,故に 台本を書き換えた
Dialogue: 0,1:07:05.29,1:07:09.46,Default,,0000,0000,0000,,見ものであったろう?
Dialogue: 0,1:07:09.46,1:07:12.13,Default,,0000,0000,0000,,プリシラ!
Dialogue: 0,1:07:09.46,1:07:12.13,Default,,0000,0000,0000,,やめろ 兄弟
Dialogue: 0,1:07:12.13,1:07:14.46,Default,,0000,0000,0000,,ここで 俺らが やり合っても 益がねえ
Dialogue: 0,1:07:14.46,1:07:16.47,Default,,0000,0000,0000,,ふざけるな!
Dialogue: 0,1:07:16.47,1:07:20.80,Default,,0000,0000,0000,,だったら 心は いくらでも 傷つけていいっていうのかよ
Dialogue: 0,1:07:20.80,1:07:22.81,Default,,0000,0000,0000,,スバル
Dialogue: 0,1:07:25.98,1:07:29.48,Default,,0000,0000,0000,,あっ んっ
Dialogue: 0,1:07:29.48,1:07:33.82,Default,,0000,0000,0000,,うち あんた様にだけは 今日のこと 伝えんかったはずやけど?
Dialogue: 0,1:07:33.82,1:07:37.99,Default,,0000,0000,0000,,女ぎつね 何事も 誰ぞの耳に入れば
Dialogue: 0,1:07:37.99,1:07:40.99,Default,,0000,0000,0000,,涙滴のように 染み出すことは避けられん
Dialogue: 0,1:07:40.99,1:07:44.49,Default,,0000,0000,0000,,てか そのおっさん ラインハルトのおやじだろ?
Dialogue: 0,1:07:44.49,1:07:48.16,Default,,0000,0000,0000,,ほう
Dialogue: 0,1:07:44.49,1:07:48.16,Default,,0000,0000,0000,,たかだか 貧民街の小娘風情が
Dialogue: 0,1:07:48.16,1:07:50.83,Default,,0000,0000,0000,,わらわに何事か意見すると?
Dialogue: 0,1:07:50.83,1:07:53.84,Default,,0000,0000,0000,,ひと事ってわけには いけねえかんな
Dialogue: 0,1:07:53.84,1:07:58.01,Default,,0000,0000,0000,,なんせ アストレア家の家督は ラインハルトのもんじゃねえ
Dialogue: 0,1:07:58.01,1:08:02.95,Default,,0000,0000,0000,,私らの生命線ってやつは そのおっさんが 握ってやがんだからよ
Dialogue: 0,1:08:02.95,1:08:06.62,Default,,0000,0000,0000,,フッ
Dialogue: 0,1:08:02.95,1:08:06.62,Default,,0000,0000,0000,,やっと そこに頭が追いついたか
Dialogue: 0,1:08:06.62,1:08:11.12,Default,,0000,0000,0000,,つまり そういうこった
Dialogue: 0,1:08:06.62,1:08:11.12,Default,,0000,0000,0000,,アストレア家の家督は 俺が握ってる
Dialogue: 0,1:08:11.12,1:08:14.46,Default,,0000,0000,0000,,俺は それを ラインハルトへ譲ったつもりも
Dialogue: 0,1:08:14.46,1:08:17.46,Default,,0000,0000,0000,,譲るつもりも 毛頭ねえ
Dialogue: 0,1:08:14.46,1:08:17.46,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:08:19.46,1:08:22.80,Default,,0000,0000,0000,,あっ フェルト様 僕は
Dialogue: 0,1:08:22.80,1:08:27.47,Default,,0000,0000,0000,,ラインハルト 黙って 堂々とした面してろ
Dialogue: 0,1:08:27.47,1:08:30.14,Default,,0000,0000,0000,,はい
Dialogue: 0,1:08:30.14,1:08:33.81,Default,,0000,0000,0000,,なんて言ったところで お前の危機感は正解だぜ
Dialogue: 0,1:08:33.81,1:08:36.48,Default,,0000,0000,0000,,ラインハルトのご主人様よ
Dialogue: 0,1:08:36.48,1:08:41.32,Default,,0000,0000,0000,,アストレア家は 俺のもんだ
Dialogue: 0,1:08:36.48,1:08:41.32,Default,,0000,0000,0000,,そして 俺は お前を支持しない
Dialogue: 0,1:08:41.32,1:08:44.32,Default,,0000,0000,0000,,俺が支持するのは
Dialogue: 0,1:08:41.32,1:08:44.32,Default,,0000,0000,0000,,これ 凡骨
Dialogue: 0,1:08:44.32,1:08:48.82,Default,,0000,0000,0000,,ああ? なんだ? プリシラ嬢
Dialogue: 0,1:08:44.32,1:08:48.82,Default,,0000,0000,0000,,今 俺は 大事な話を
Dialogue: 0,1:08:48.82,1:08:52.33,Default,,0000,0000,0000,,うるさい
Dialogue: 0,1:08:48.82,1:08:52.33,Default,,0000,0000,0000,,うっ あっ
Dialogue: 0,1:08:52.33,1:08:54.33,Default,,0000,0000,0000,,なっ!
Dialogue: 0,1:08:58.00,1:09:01.60,Default,,0000,0000,0000,,姫さん かんしゃくは そこまでだ
Dialogue: 0,1:08:58.00,1:09:01.60,Default,,0000,0000,0000,,うぅ かっ
Dialogue: 0,1:09:01.60,1:09:06.44,Default,,0000,0000,0000,,ったく 勘弁してくれや
Dialogue: 0,1:09:01.60,1:09:06.44,Default,,0000,0000,0000,,陽剣まで抜かれちゃ 心臓に
Dialogue: 0,1:09:06.44,1:09:08.44,Default,,0000,0000,0000,,ぶんどき! うっ
Dialogue: 0,1:09:08.44,1:09:13.28,Default,,0000,0000,0000,,シュルト そこな凡骨を運び出せ
Dialogue: 0,1:09:08.44,1:09:13.28,Default,,0000,0000,0000,,介抱してやるがいい
Dialogue: 0,1:09:13.28,1:09:15.78,Default,,0000,0000,0000,,はいであります プリシラ様!
Dialogue: 0,1:09:15.78,1:09:19.29,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:09:15.78,1:09:19.29,Default,,0000,0000,0000,,失礼するであります ハインケル様
Dialogue: 0,1:09:19.29,1:09:21.96,Default,,0000,0000,0000,,よいしょ よいしょ
Dialogue: 0,1:09:21.96,1:09:25.29,Default,,0000,0000,0000,,シュルトちゃんは いつでも けなげだね
Dialogue: 0,1:09:25.29,1:09:28.63,Default,,0000,0000,0000,,で さっきのおっさんの話は 本気か?
Dialogue: 0,1:09:28.63,1:09:31.63,Default,,0000,0000,0000,,私ら追い出して 領主に戻んのかよ?
Dialogue: 0,1:09:31.63,1:09:34.64,Default,,0000,0000,0000,,仮に そうだと言えば 貴様は どうする?
Dialogue: 0,1:09:34.64,1:09:37.64,Default,,0000,0000,0000,,泣き寝入りして 素直に引き下がるのか?
Dialogue: 0,1:09:37.64,1:09:40.48,Default,,0000,0000,0000,,ハッ! 笑わせんじゃねえよ
Dialogue: 0,1:09:40.48,1:09:44.65,Default,,0000,0000,0000,,私は 誰に言われようが 泣き寝入りだけは 絶対しねえ
Dialogue: 0,1:09:44.65,1:09:48.98,Default,,0000,0000,0000,,あの おっさんから こいつに家督を譲らせてやる
Dialogue: 0,1:09:48.98,1:09:53.99,Default,,0000,0000,0000,,それでよい いずれ きたる
Dialogue: 0,1:09:48.98,1:09:53.99,Default,,0000,0000,0000,,わらわの勝利は約束されている
Dialogue: 0,1:09:53.99,1:09:57.99,Default,,0000,0000,0000,,ならば 道筋には 波乱と遊興を求める
Dialogue: 0,1:09:57.99,1:10:00.00,Default,,0000,0000,0000,,わらわを沸かせよ
Dialogue: 0,1:10:00.00,1:10:03.50,Default,,0000,0000,0000,,それが 貴様ら 端役の役割じゃ
Dialogue: 0,1:10:03.50,1:10:07.34,Default,,0000,0000,0000,,そのおごり 泣いて後悔させてやるよ
Dialogue: 0,1:10:07.34,1:10:09.34,Default,,0000,0000,0000,,フッ
Dialogue: 0,1:10:09.34,1:10:12.51,Default,,0000,0000,0000,,んっ! くそ 頭 冷やせ
Dialogue: 0,1:10:12.51,1:10:15.51,Default,,0000,0000,0000,,結局 カッカしてたの 俺だけじゃねえか
Dialogue: 0,1:10:15.51,1:10:18.01,Default,,0000,0000,0000,,そう 床に当たるものではないよ
Dialogue: 0,1:10:18.01,1:10:20.52,Default,,0000,0000,0000,,宿の者を困らせることになる
Dialogue: 0,1:10:20.52,1:10:23.52,Default,,0000,0000,0000,,俺は 1人で ただ勝手に キレてただけだ
Dialogue: 0,1:10:23.52,1:10:28.02,Default,,0000,0000,0000,,みんなが冷静だったのに情けねえ
Dialogue: 0,1:10:23.52,1:10:28.02,Default,,0000,0000,0000,,そんなことはない
Dialogue: 0,1:10:28.02,1:10:30.53,Default,,0000,0000,0000,,君が 短慮な振る舞いを見せたから
Dialogue: 0,1:10:30.53,1:10:33.03,Default,,0000,0000,0000,,周りが かえって 冷静になることができた
Dialogue: 0,1:10:33.03,1:10:36.03,Default,,0000,0000,0000,,あっ?
Dialogue: 0,1:10:33.03,1:10:36.03,Default,,0000,0000,0000,,君の軽率さが役に立つこともある
Dialogue: 0,1:10:36.03,1:10:39.87,Default,,0000,0000,0000,,お前 ほんとは 俺のこと 褒めるつもりとかねえだろ?
Dialogue: 0,1:10:39.87,1:10:42.20,Default,,0000,0000,0000,,確かに 騎士らしさを求めるなら
Dialogue: 0,1:10:42.20,1:10:45.04,Default,,0000,0000,0000,,君の行いは 褒められたものではない
Dialogue: 0,1:10:45.04,1:10:47.14,Default,,0000,0000,0000,,だが
Dialogue: 0,1:10:45.04,1:10:47.14,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:10:50.21,1:10:52.38,Default,,0000,0000,0000,,なんのつもりだよ
Dialogue: 0,1:10:52.38,1:10:55.55,Default,,0000,0000,0000,,見てのとおりだ 君に感謝を
Dialogue: 0,1:10:55.55,1:11:00.16,Default,,0000,0000,0000,,私に代わり あの場で 義憤をあらわにしてくれた君に 感謝したい
Dialogue: 0,1:11:00.16,1:11:02.32,Default,,0000,0000,0000,,うっ んっ!
Dialogue: 0,1:11:02.32,1:11:05.66,Default,,0000,0000,0000,,代わりに怒ってくれて ありがとうってか ふざけんな!
Dialogue: 0,1:11:05.66,1:11:08.83,Default,,0000,0000,0000,,なんで 俺が お前の代わりに 怒ったことになんだよ!
Dialogue: 0,1:11:08.83,1:11:11.50,Default,,0000,0000,0000,,俺が怒ったのは 俺が ムカついたからだ
Dialogue: 0,1:11:11.50,1:11:16.34,Default,,0000,0000,0000,,お前も ムカついてたんなら 怒ればよかったじゃねえか!
Dialogue: 0,1:11:16.34,1:11:21.84,Default,,0000,0000,0000,,フッ 仮にも 直属の上司に
Dialogue: 0,1:11:16.34,1:11:21.84,Default,,0000,0000,0000,,そのような無礼は働けまいよ
Dialogue: 0,1:11:21.84,1:11:24.35,Default,,0000,0000,0000,,窮屈な考え方しやがって
Dialogue: 0,1:11:24.35,1:11:29.18,Default,,0000,0000,0000,,騎士らしくって 思い詰めてる間に 心まで よろい 着ちまってんのか?
Dialogue: 0,1:11:29.18,1:11:32.02,Default,,0000,0000,0000,,心まで よろいをか
Dialogue: 0,1:11:32.02,1:11:35.19,Default,,0000,0000,0000,,フッ 全く 耳が痛いよ
Dialogue: 0,1:11:35.19,1:11:38.03,Default,,0000,0000,0000,,あの ひげ面だけどよ
Dialogue: 0,1:11:38.03,1:11:42.87,Default,,0000,0000,0000,,まさか 剣聖の父親だってことを かさに 着てやがるんじゃねえだろうな?
Dialogue: 0,1:11:42.87,1:11:45.03,Default,,0000,0000,0000,,それもなくはない
Dialogue: 0,1:11:45.03,1:11:50.21,Default,,0000,0000,0000,,だが 最大の理由は
Dialogue: 0,1:11:45.03,1:11:50.21,Default,,0000,0000,0000,,副団長ではなく ラインハルトにある
Dialogue: 0,1:11:50.21,1:11:53.21,Default,,0000,0000,0000,,アストレア家と 言うべきかもしれないが
Dialogue: 0,1:11:53.21,1:11:58.88,Default,,0000,0000,0000,,あの方は ヴィルヘルム様のご子息にして
Dialogue: 0,1:11:53.21,1:11:58.88,Default,,0000,0000,0000,,アストレア家の現当主だ
Dialogue: 0,1:11:58.88,1:12:01.15,Default,,0000,0000,0000,,そんな人物を冷遇し
Dialogue: 0,1:12:01.15,1:12:04.32,Default,,0000,0000,0000,,王国に はん意を持たれれば どうなる?
Dialogue: 0,1:12:01.15,1:12:04.32,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:12:04.32,1:12:07.82,Default,,0000,0000,0000,,ハインケルが 王国に反抗する気になったら
Dialogue: 0,1:12:07.82,1:12:10.99,Default,,0000,0000,0000,,剣聖一家が 敵に回りかねないってか?
Dialogue: 0,1:12:10.99,1:12:15.16,Default,,0000,0000,0000,,それは つまり 王国が ラインハルトも ヴィルヘルムさんも
Dialogue: 0,1:12:15.16,1:12:17.33,Default,,0000,0000,0000,,信じてないってことじゃねえか!
Dialogue: 0,1:12:17.33,1:12:19.67,Default,,0000,0000,0000,,15年前 王族の1人が
Dialogue: 0,1:12:19.67,1:12:23.84,Default,,0000,0000,0000,,何者かに誘拐される事件があった
Dialogue: 0,1:12:19.67,1:12:23.84,Default,,0000,0000,0000,,それが どうした?
Dialogue: 0,1:12:23.84,1:12:27.68,Default,,0000,0000,0000,,当時 ヴィルヘルム様は 近衛騎士団の団長で
Dialogue: 0,1:12:27.68,1:12:31.35,Default,,0000,0000,0000,,その さらわれた王族の 捜索の責任者でもあった
Dialogue: 0,1:12:31.35,1:12:35.35,Default,,0000,0000,0000,,先代の剣聖様を加えた 白鯨討伐は
Dialogue: 0,1:12:35.35,1:12:40.86,Default,,0000,0000,0000,,ヴィルヘルム様が捜索のために 王都を
Dialogue: 0,1:12:35.35,1:12:40.86,Default,,0000,0000,0000,,離れている間に行われたんだ
Dialogue: 0,1:12:40.86,1:12:44.36,Default,,0000,0000,0000,,事件のせいで 奥さんの死に目に会えなかった
Dialogue: 0,1:12:44.36,1:12:47.20,Default,,0000,0000,0000,,だから あの人が逆恨みしてるってか?
Dialogue: 0,1:12:47.20,1:12:50.03,Default,,0000,0000,0000,,あの人が そんな人じゃないって
Dialogue: 0,1:12:50.03,1:12:53.04,Default,,0000,0000,0000,,どうして みんな わからねえんだよ!
Dialogue: 0,1:12:53.04,1:12:55.20,Default,,0000,0000,0000,,すまない このような話を
Dialogue: 0,1:12:55.20,1:12:58.37,Default,,0000,0000,0000,,心の準備もなしに 聞かせるべきではなかった
Dialogue: 0,1:12:58.37,1:13:01.81,Default,,0000,0000,0000,,お前が ラインハルトを心配してるのも わかるよ
Dialogue: 0,1:13:01.81,1:13:06.32,Default,,0000,0000,0000,,だから カッとなって当然だし それが おかしいとも思わねえ
Dialogue: 0,1:13:06.32,1:13:08.48,Default,,0000,0000,0000,,さっきも言ったろ
Dialogue: 0,1:13:08.48,1:13:11.15,Default,,0000,0000,0000,,お行儀がいいばっかりの 騎士らしさに
Dialogue: 0,1:13:11.15,1:13:14.16,Default,,0000,0000,0000,,別に こだわり続ける必要なんか ねえだろうが
Dialogue: 0,1:13:14.16,1:13:16.16,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:13:16.16,1:13:20.16,Default,,0000,0000,0000,,よろい 脱いで ユーリになってみるのも悪くない
Dialogue: 0,1:13:20.16,1:13:25.00,Default,,0000,0000,0000,,あれぐらい 融通 利かしたほうが うまく回ることも あるかもしれないぜ
Dialogue: 0,1:13:25.00,1:13:28.30,Default,,0000,0000,0000,,ユーリか
Dialogue: 0,1:13:31.34,1:13:35.51,Default,,0000,0000,0000,,なんとも懐かしい名前を 引っ張り出してきたものだ
Dialogue: 0,1:13:35.51,1:13:39.85,Default,,0000,0000,0000,,ユーリとして見上げる空は 浴びる風は
Dialogue: 0,1:13:39.85,1:13:42.52,Default,,0000,0000,0000,,こんな気分だったか
Dialogue: 0,1:13:39.85,1:13:42.52,Default,,0000,0000,0000,,あっ?
Dialogue: 0,1:13:42.52,1:13:48.02,Default,,0000,0000,0000,,思えば あのときも
Dialogue: 0,1:13:42.52,1:13:48.02,Default,,0000,0000,0000,,空の色は ふだんと違って見えた
Dialogue: 0,1:13:48.02,1:13:50.69,Default,,0000,0000,0000,,ハァ わっけわかんねえ
Dialogue: 0,1:13:50.69,1:13:53.36,Default,,0000,0000,0000,,気取るな きざ野郎 フン!
Dialogue: 0,1:13:53.36,1:13:55.36,Default,,0000,0000,0000,,フッ
Dialogue: 0,1:13:55.36,1:13:58.03,Default,,0000,0000,0000,,ねえ スバル
Dialogue: 0,1:13:58.03,1:14:02.30,Default,,0000,0000,0000,,庭で ユリウスと すごく 仲よさそうに 何を話してたの?
Dialogue: 0,1:14:02.30,1:14:05.97,Default,,0000,0000,0000,,あいつと仲よくってのが すごく間違ってるけど
Dialogue: 0,1:14:05.97,1:14:07.98,Default,,0000,0000,0000,,なんの話だったと思う?
Dialogue: 0,1:14:07.98,1:14:11.48,Default,,0000,0000,0000,,うん
Dialogue: 0,1:14:07.98,1:14:11.48,Default,,0000,0000,0000,,「今度 どこに遊びに行く?」とか?
Dialogue: 0,1:14:11.48,1:14:16.15,Default,,0000,0000,0000,,学校の友達!?
Dialogue: 0,1:14:11.48,1:14:16.15,Default,,0000,0000,0000,,お互い 敵情視察ってなもんだよ
Dialogue: 0,1:14:16.15,1:14:19.15,Default,,0000,0000,0000,,あとは ちょっとした 世間話とかしたぐらい
Dialogue: 0,1:14:19.15,1:14:21.32,Default,,0000,0000,0000,,それって 友達なんじゃないの?
Dialogue: 0,1:14:21.32,1:14:25.33,Default,,0000,0000,0000,,まあ 友達じゃないよ
Dialogue: 0,1:14:21.32,1:14:25.33,Default,,0000,0000,0000,,それだけは間違いない
Dialogue: 0,1:14:25.33,1:14:27.83,Default,,0000,0000,0000,,意地っ張り
Dialogue: 0,1:14:25.33,1:14:27.83,Default,,0000,0000,0000,,全くかしら
Dialogue: 0,1:14:27.83,1:14:30.00,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,1:14:30.00,1:14:34.00,Default,,0000,0000,0000,,なんだか すごく にぎやかね!
Dialogue: 0,1:14:30.00,1:14:34.00,Default,,0000,0000,0000,,そのようなのよ
Dialogue: 0,1:14:34.00,1:14:37.67,Default,,0000,0000,0000,,昨日と違って やけに騒がしく やってるかしら
Dialogue: 0,1:14:45.68,1:14:49.69,Default,,0000,0000,0000,,あっ?
Dialogue: 0,1:14:49.69,1:14:51.85,Default,,0000,0000,0000,,プリシラ!?
Dialogue: 0,1:14:51.85,1:14:54.36,Default,,0000,0000,0000,,んっ とても よい踊りでした!
Dialogue: 0,1:14:54.36,1:14:58.69,Default,,0000,0000,0000,,私 尋常でない足さばきに 思わず 目玉が飛び出すかと!
Dialogue: 0,1:14:58.69,1:15:02.97,Default,,0000,0000,0000,,貴様こそ なかなかに わらわを 興じさせる歌と演奏じゃ
Dialogue: 0,1:15:02.97,1:15:05.80,Default,,0000,0000,0000,,詩人の芸事で これほど興が乗ったのは
Dialogue: 0,1:15:05.80,1:15:08.64,Default,,0000,0000,0000,,久方ぶりよ 大義であった
Dialogue: 0,1:15:08.64,1:15:11.31,Default,,0000,0000,0000,,んっ? おや? おや? おやや?
Dialogue: 0,1:15:11.31,1:15:13.98,Default,,0000,0000,0000,,そこにいるのは ナツキ様とエミリア様!
Dialogue: 0,1:15:13.98,1:15:16.98,Default,,0000,0000,0000,,それに幼女様では?
Dialogue: 0,1:15:13.98,1:15:16.98,Default,,0000,0000,0000,,アハハ
Dialogue: 0,1:15:16.98,1:15:21.48,Default,,0000,0000,0000,,昨日は 慌ただしくなって 約束もできなかったけど
Dialogue: 0,1:15:21.48,1:15:24.49,Default,,0000,0000,0000,,今日も ここにいてくれて助かった
Dialogue: 0,1:15:24.49,1:15:26.99,Default,,0000,0000,0000,,んっ?
Dialogue: 0,1:15:24.49,1:15:26.99,Default,,0000,0000,0000,,なんじゃ? 貴様
Dialogue: 0,1:15:26.99,1:15:29.16,Default,,0000,0000,0000,,わらわを じろじろと見つめおって
Dialogue: 0,1:15:29.16,1:15:31.83,Default,,0000,0000,0000,,不敬であろう
Dialogue: 0,1:15:29.16,1:15:31.83,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,1:15:31.83,1:15:35.50,Default,,0000,0000,0000,,でも プリシラが踊ってたのが すごく意外で
Dialogue: 0,1:15:31.83,1:15:35.50,Default,,0000,0000,0000,,うんうん
Dialogue: 0,1:15:35.50,1:15:39.00,Default,,0000,0000,0000,,わらわとて 興が乗らねば 舞は踊らぬ
Dialogue: 0,1:15:39.00,1:15:43.34,Default,,0000,0000,0000,,それをさせるだけの価値が この芸者の歌にはあったのでな
Dialogue: 0,1:15:43.34,1:15:46.84,Default,,0000,0000,0000,,マジか!
Dialogue: 0,1:15:43.34,1:15:46.84,Default,,0000,0000,0000,,お前も リリアナ べた褒め勢かよ
Dialogue: 0,1:15:46.84,1:15:51.51,Default,,0000,0000,0000,,ヘヘヘヘヘ! それだけ 私の歌が すごいってことですか?
Dialogue: 0,1:15:51.51,1:15:53.68,Default,,0000,0000,0000,,もう もう てれりこ!
Dialogue: 0,1:15:53.68,1:15:56.18,Default,,0000,0000,0000,,貴様の歌には その価値があった
Dialogue: 0,1:15:56.18,1:16:00.46,Default,,0000,0000,0000,,どうじゃ? わらわのそばで うため 歌女として仕える気はないか?
Dialogue: 0,1:16:00.46,1:16:02.79,Default,,0000,0000,0000,,どもども ありがとうございます!
Dialogue: 0,1:16:02.79,1:16:06.63,Default,,0000,0000,0000,,なんとも 光栄な評価 私も鼻が高々ですとも!
Dialogue: 0,1:16:06.63,1:16:08.63,Default,,0000,0000,0000,,がっ! がっ!
Dialogue: 0,1:16:06.63,1:16:08.63,Default,,0000,0000,0000,,んっ
Dialogue: 0,1:16:06.63,1:16:08.63,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:16:08.63,1:16:11.80,Default,,0000,0000,0000,,お断りさせていただきます
Dialogue: 0,1:16:08.63,1:16:11.80,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:16:11.80,1:16:15.14,Default,,0000,0000,0000,,ほう
Dialogue: 0,1:16:11.80,1:16:15.14,Default,,0000,0000,0000,,なぜ わらわの誘いを断る?
Dialogue: 0,1:16:15.14,1:16:18.31,Default,,0000,0000,0000,,私は リリアナ 吟遊詩人です
Dialogue: 0,1:16:18.31,1:16:22.64,Default,,0000,0000,0000,,いずれは 風に流れて 再び 流浪する旅人の身
Dialogue: 0,1:16:22.64,1:16:25.48,Default,,0000,0000,0000,,土地に縛られず 人に縛られず
Dialogue: 0,1:16:25.48,1:16:29.15,Default,,0000,0000,0000,,それが なりわいであると 生き方を決めております
Dialogue: 0,1:16:29.15,1:16:32.49,Default,,0000,0000,0000,,故に わらわの誘いには乗らぬと
Dialogue: 0,1:16:32.49,1:16:36.16,Default,,0000,0000,0000,,母も その母も そのまた更に母も
Dialogue: 0,1:16:36.16,1:16:38.33,Default,,0000,0000,0000,,私の一族は そうしてきました
Dialogue: 0,1:16:38.33,1:16:41.16,Default,,0000,0000,0000,,私たちは 形あるものを残せず
Dialogue: 0,1:16:41.16,1:16:44.50,Default,,0000,0000,0000,,歌のみを 人の心に残して生きる一族
Dialogue: 0,1:16:44.50,1:16:46.84,Default,,0000,0000,0000,,風を囲うことができないように
Dialogue: 0,1:16:46.84,1:16:50.84,Default,,0000,0000,0000,,歌を遮ることは 何者にもできません
Dialogue: 0,1:16:55.18,1:16:57.35,Default,,0000,0000,0000,,あっ プリシラ
Dialogue: 0,1:16:55.18,1:16:57.35,Default,,0000,0000,0000,,フッ よい
Dialogue: 0,1:16:57.35,1:16:59.35,Default,,0000,0000,0000,,その信義 見事である
Dialogue: 0,1:16:59.35,1:17:02.12,Default,,0000,0000,0000,,許せ
Dialogue: 0,1:16:59.35,1:17:02.12,Default,,0000,0000,0000,,無粋は わらわのほうであった
Dialogue: 0,1:17:02.12,1:17:04.29,Default,,0000,0000,0000,,いいえ そんなことは
Dialogue: 0,1:17:04.29,1:17:06.96,Default,,0000,0000,0000,,私のほうこそ 申し訳ないですよ!
Dialogue: 0,1:17:06.96,1:17:09.96,Default,,0000,0000,0000,,なんじゃ? 凡夫
Dialogue: 0,1:17:06.96,1:17:09.96,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:17:09.96,1:17:11.96,Default,,0000,0000,0000,,いや 驚いてんだよ
Dialogue: 0,1:17:11.96,1:17:14.46,Default,,0000,0000,0000,,俺は てっきり 誘いを断った リリアナを
Dialogue: 0,1:17:14.46,1:17:17.13,Default,,0000,0000,0000,,真っ二つにするもんだと ビビってたのに
Dialogue: 0,1:17:17.13,1:17:19.47,Default,,0000,0000,0000,,私も ちょっと 意外だったかも
Dialogue: 0,1:17:19.47,1:17:21.97,Default,,0000,0000,0000,,プリシラって 欲しいものは なんでも 手元に
Dialogue: 0,1:17:21.97,1:17:25.31,Default,,0000,0000,0000,,置いておきたがる人なのかなって 思ってたから
Dialogue: 0,1:17:21.97,1:17:25.31,Default,,0000,0000,0000,,うんうん
Dialogue: 0,1:17:25.31,1:17:28.98,Default,,0000,0000,0000,,この世のは すべて わらわのものよ
Dialogue: 0,1:17:28.98,1:17:32.98,Default,,0000,0000,0000,,ならば 美しいもの 気高いもの
Dialogue: 0,1:17:32.98,1:17:37.65,Default,,0000,0000,0000,,価値ある すべてを 手元に置いて 鑑賞する必要なぞない
Dialogue: 0,1:17:37.65,1:17:40.82,Default,,0000,0000,0000,,この世の すべてが わらわの庭なれば
Dialogue: 0,1:17:40.82,1:17:44.83,Default,,0000,0000,0000,,さえずる小鳥が どこで歌うかなど 問題ではない
Dialogue: 0,1:17:44.83,1:17:46.83,Default,,0000,0000,0000,,はえ
Dialogue: 0,1:17:44.83,1:17:46.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:17:46.83,1:17:51.17,Default,,0000,0000,0000,,さあ さあ さあ ここは ひとつ 皆々様も落ち着かれた頃合いで
Dialogue: 0,1:17:51.17,1:17:55.00,Default,,0000,0000,0000,,親睦を兼ねて 私が 1曲 ご披露いたしましょうか!
Dialogue: 0,1:17:55.00,1:17:57.34,Default,,0000,0000,0000,,そして 歌のあとは ご歓談
Dialogue: 0,1:17:57.34,1:18:00.28,Default,,0000,0000,0000,,ナツキ様は その時間に向けて
Dialogue: 0,1:18:00.28,1:18:04.95,Default,,0000,0000,0000,,おやつなんて準備されるのが よいと思いませんか?
Dialogue: 0,1:18:04.95,1:18:06.95,Default,,0000,0000,0000,,そして 歌のあとは ご歓談
Dialogue: 0,1:18:06.95,1:18:11.79,Default,,0000,0000,0000,,ナツキ様は その時間に向けて おやつなんて準備されるのが
Dialogue: 0,1:18:08.95,1:18:11.79,Default,,0000,0000,0000,,よいと思いませんか?
Dialogue: 0,1:18:11.79,1:18:16.09,Default,,0000,0000,0000,,何これ? はいって言わないと 進まないタイプの茶番選択肢?
Dialogue: 0,1:18:18.96,1:18:21.96,Default,,0000,0000,0000,,俺って へたれてるよな 本当に
Dialogue: 0,1:18:21.96,1:18:25.30,Default,,0000,0000,0000,,おっと 悪い
Dialogue: 0,1:18:21.96,1:18:25.30,Default,,0000,0000,0000,,おいおい 兄ちゃん
Dialogue: 0,1:18:25.30,1:18:28.97,Default,,0000,0000,0000,,それが謝る態度か?
Dialogue: 0,1:18:25.30,1:18:28.97,Default,,0000,0000,0000,,もっと 誠意ってもんが
Dialogue: 0,1:18:28.97,1:18:30.97,Default,,0000,0000,0000,,うげっ!
Dialogue: 0,1:18:28.97,1:18:30.97,Default,,0000,0000,0000,,なんだ チンか
Dialogue: 0,1:18:30.97,1:18:32.97,Default,,0000,0000,0000,,だから チンじゃねえっての!
Dialogue: 0,1:18:32.97,1:18:34.98,Default,,0000,0000,0000,,なんで てめえが こんな所いんだよ!
Dialogue: 0,1:18:34.98,1:18:36.98,Default,,0000,0000,0000,,そう冷たくすんなって
Dialogue: 0,1:18:36.98,1:18:39.31,Default,,0000,0000,0000,,命のやり取りをした仲じゃねえか
Dialogue: 0,1:18:39.31,1:18:42.15,Default,,0000,0000,0000,,そんな覚えねえよ!
Dialogue: 0,1:18:39.31,1:18:42.15,Default,,0000,0000,0000,,寄ってくんじゃねえ!
Dialogue: 0,1:18:39.31,1:18:42.15,Default,,0000,0000,0000,,ヘッヘヘ
Dialogue: 0,1:18:42.15,1:18:44.32,Default,,0000,0000,0000,,まあ 聞いてくれよ 実はよ
Dialogue: 0,1:18:44.32,1:18:47.99,Default,,0000,0000,0000,,しつけえんだよ! 大体 てめえは なれなれし過ぎんだ!
Dialogue: 0,1:18:47.99,1:18:51.33,Default,,0000,0000,0000,,ご歓談中の皆様 お急ぎの方々!
Dialogue: 0,1:18:51.33,1:18:54.33,Default,,0000,0000,0000,,んっ? なんだ?
Dialogue: 0,1:18:51.33,1:18:54.33,Default,,0000,0000,0000,,何かしら?
Dialogue: 0,1:18:54.33,1:18:57.17,Default,,0000,0000,0000,,ごめんね お騒がせしております
Dialogue: 0,1:18:57.17,1:19:01.94,Default,,0000,0000,0000,,ほんのひととき こうして 皆様の時間を 拝借させてください!
Dialogue: 0,1:19:01.94,1:19:04.27,Default,,0000,0000,0000,,ありがと ごめんね
Dialogue: 0,1:19:04.27,1:19:08.44,Default,,0000,0000,0000,,私は 魔女教大罪司教 憤怒担当
Dialogue: 0,1:19:08.44,1:19:11.95,Default,,0000,0000,0000,,シリウス・ロマネコンティと申します
Dialogue: 0,1:19:11.95,1:19:13.95,Default,,0000,0000,0000,,うっ!
Dialogue: 0,1:19:11.95,1:19:13.95,Default,,0000,0000,0000,,えっ あっ?
Dialogue: 0,1:19:13.95,1:19:17.79,Default,,0000,0000,0000,,今 なんて言った?
Dialogue: 0,1:19:13.95,1:19:17.79,Default,,0000,0000,0000,,冗談だろ 魔女教なんて
Dialogue: 0,1:19:17.79,1:19:23.29,Default,,0000,0000,0000,,おい 聞こえたかよ?
Dialogue: 0,1:19:17.79,1:19:23.29,Default,,0000,0000,0000,,ああ 冗談にしちゃ笑えねえ
Dialogue: 0,1:19:23.29,1:19:25.79,Default,,0000,0000,0000,,うっ!
Dialogue: 0,1:19:23.29,1:19:25.79,Default,,0000,0000,0000,,はい そこまで
Dialogue: 0,1:19:25.79,1:19:29.80,Default,,0000,0000,0000,,皆さんが静かになるまで 35秒かかりました
Dialogue: 0,1:19:29.80,1:19:33.47,Default,,0000,0000,0000,,でも 静かになってくれて ありがと ごめんね
Dialogue: 0,1:19:33.47,1:19:36.47,Default,,0000,0000,0000,,私は とても喜ばしいです!
Dialogue: 0,1:19:36.47,1:19:40.48,Default,,0000,0000,0000,,それと そこの あなたと あなた
Dialogue: 0,1:19:40.48,1:19:42.48,Default,,0000,0000,0000,,そして そちらのお兄さんたち
Dialogue: 0,1:19:42.48,1:19:45.31,Default,,0000,0000,0000,,ごめんね そんなに怒らないで
Dialogue: 0,1:19:45.31,1:19:48.15,Default,,0000,0000,0000,,皆さんの 大切な時間を頂くことを
Dialogue: 0,1:19:48.15,1:19:52.49,Default,,0000,0000,0000,,私は とても申し訳ないと 心から思っています!
Dialogue: 0,1:19:52.49,1:19:54.49,Default,,0000,0000,0000,,だから ごめんね ありがと
Dialogue: 0,1:19:56.49,1:19:59.16,Default,,0000,0000,0000,,はい ありがと
Dialogue: 0,1:19:56.49,1:19:59.16,Default,,0000,0000,0000,,どうやら 皆さん
Dialogue: 0,1:19:59.16,1:20:01.66,Default,,0000,0000,0000,,少し 落ち着いて くださったようですね
Dialogue: 0,1:20:01.66,1:20:03.67,Default,,0000,0000,0000,,不安は わかります
Dialogue: 0,1:20:03.67,1:20:07.34,Default,,0000,0000,0000,,ただ 今日は どうしても 確かめたいことがあって
Dialogue: 0,1:20:07.34,1:20:10.84,Default,,0000,0000,0000,,こうして 皆さんのお時間を 頂戴しているだけなんです
Dialogue: 0,1:20:10.84,1:20:13.34,Default,,0000,0000,0000,,確かめたいこと?
Dialogue: 0,1:20:13.34,1:20:16.18,Default,,0000,0000,0000,,ごめんね
Dialogue: 0,1:20:13.34,1:20:16.18,Default,,0000,0000,0000,,ざわざわしないでください
Dialogue: 0,1:20:16.18,1:20:18.35,Default,,0000,0000,0000,,何かあれば どうか 話して
Dialogue: 0,1:20:18.35,1:20:22.85,Default,,0000,0000,0000,,私 皆さんのためなら わりと なんでも お話ししますよ
Dialogue: 0,1:20:22.85,1:20:26.52,Default,,0000,0000,0000,,お言葉に甘えて 質問させてもらっていいか?
Dialogue: 0,1:20:26.52,1:20:30.36,Default,,0000,0000,0000,,ええ! どうぞ どうぞ!
Dialogue: 0,1:20:26.52,1:20:30.36,Default,,0000,0000,0000,,そこの あなた! ありがと!
Dialogue: 0,1:20:30.36,1:20:32.69,Default,,0000,0000,0000,,なんの用だか知らないが
Dialogue: 0,1:20:32.69,1:20:36.20,Default,,0000,0000,0000,,俺は 女の子を待たしてんだよ
Dialogue: 0,1:20:32.69,1:20:36.20,Default,,0000,0000,0000,,それも 4人
Dialogue: 0,1:20:36.20,1:20:40.70,Default,,0000,0000,0000,,だから なるたけ早く 用事を済まして 解放してもらいたいんだが
Dialogue: 0,1:20:40.70,1:20:43.87,Default,,0000,0000,0000,,あら! それは大変 ごめんね
Dialogue: 0,1:20:43.87,1:20:46.71,Default,,0000,0000,0000,,でも 隅に置けませんね お兄さん
Dialogue: 0,1:20:46.71,1:20:50.21,Default,,0000,0000,0000,,4人も女の子を待たせてるなんて いけない人
Dialogue: 0,1:20:50.21,1:20:53.55,Default,,0000,0000,0000,,でも ありがと
Dialogue: 0,1:20:50.21,1:20:53.55,Default,,0000,0000,0000,,ごめんね 急がなきゃ
Dialogue: 0,1:20:53.55,1:20:55.88,Default,,0000,0000,0000,,いや いいんだ 落ち着いて
Dialogue: 0,1:20:55.88,1:20:58.89,Default,,0000,0000,0000,,穏便に話を進めてくれたほうが ありがたいし
Dialogue: 0,1:20:58.89,1:21:01.66,Default,,0000,0000,0000,,気を使わせて ごめんね
Dialogue: 0,1:20:58.89,1:21:01.66,Default,,0000,0000,0000,,ありがと
Dialogue: 0,1:21:01.66,1:21:04.49,Default,,0000,0000,0000,,では 本題に入りましょう!
Dialogue: 0,1:21:04.49,1:21:08.00,Default,,0000,0000,0000,,私が こうして ここへ現れた その理由を
Dialogue: 0,1:21:08.00,1:21:12.50,Default,,0000,0000,0000,,プッ! 俺たちに確かめたいことが あるって言ってたよな?
Dialogue: 0,1:21:12.50,1:21:16.84,Default,,0000,0000,0000,,何を確かめたいんだ?
Dialogue: 0,1:21:12.50,1:21:16.84,Default,,0000,0000,0000,,そうよ 早く聞かせて!
Dialogue: 0,1:21:16.84,1:21:20.01,Default,,0000,0000,0000,,早くしないと 仕事に遅れちまうってんだよ!
Dialogue: 0,1:21:20.01,1:21:23.18,Default,,0000,0000,0000,,ごめんね ごめんね!
Dialogue: 0,1:21:23.18,1:21:27.52,Default,,0000,0000,0000,,本当に ごめんね!
Dialogue: 0,1:21:23.18,1:21:27.52,Default,,0000,0000,0000,,すぐに話を終わらせますから
Dialogue: 0,1:21:27.52,1:21:33.02,Default,,0000,0000,0000,,あのですね 私が確かめたいこと
Dialogue: 0,1:21:27.52,1:21:33.02,Default,,0000,0000,0000,,それは ズバリ
Dialogue: 0,1:21:33.02,1:21:36.19,Default,,0000,0000,0000,,愛についてなんです
Dialogue: 0,1:21:36.19,1:21:39.36,Default,,0000,0000,0000,,うわ 恥ずかしい!
Dialogue: 0,1:21:39.36,1:21:42.70,Default,,0000,0000,0000,,私の 愛の確認作業に
Dialogue: 0,1:21:42.70,1:21:45.70,Default,,0000,0000,0000,,どうか おつきあい いただけないでしょうか?
Dialogue: 0,1:21:45.70,1:21:48.70,Default,,0000,0000,0000,,いいぞ!
Dialogue: 0,1:21:45.70,1:21:48.70,Default,,0000,0000,0000,,うんうんうん
Dialogue: 0,1:21:45.70,1:21:48.70,Default,,0000,0000,0000,,もちろんだ!
Dialogue: 0,1:21:48.70,1:21:52.71,Default,,0000,0000,0000,,本当ですか!?
Dialogue: 0,1:21:48.70,1:21:52.71,Default,,0000,0000,0000,,ありがと ありがと ごめんね
Dialogue: 0,1:21:52.71,1:21:57.55,Default,,0000,0000,0000,,やっぱり 世界は優しい
Dialogue: 0,1:21:52.71,1:21:57.55,Default,,0000,0000,0000,,優しさと愛に満ち足りている
Dialogue: 0,1:21:57.55,1:22:01.82,Default,,0000,0000,0000,,それを実感するたび 私は感謝をしたくなるんです
Dialogue: 0,1:22:01.82,1:22:04.82,Default,,0000,0000,0000,,許し合うこと 譲り合うことができる
Dialogue: 0,1:22:04.82,1:22:10.33,Default,,0000,0000,0000,,だから 私は 「ありがとう」
Dialogue: 0,1:22:04.82,1:22:10.33,Default,,0000,0000,0000,,「ごめんさい」を重ねるんです
Dialogue: 0,1:22:18.00,1:22:20.00,Default,,0000,0000,0000,,ほら こっちに おいで
Dialogue: 0,1:22:20.00,1:22:23.51,Default,,0000,0000,0000,,ずっと待たせてしまって ごめんね
Dialogue: 0,1:22:23.51,1:22:26.84,Default,,0000,0000,0000,,うぅ
Dialogue: 0,1:22:23.51,1:22:26.84,Default,,0000,0000,0000,,窮屈で ごめんね
Dialogue: 0,1:22:26.84,1:22:30.51,Default,,0000,0000,0000,,でも 男の子だから そんなに泣いちゃいけませんよ
Dialogue: 0,1:22:30.51,1:22:34.52,Default,,0000,0000,0000,,ないしょにしてあげたいけど お漏らしまでしてしまって
Dialogue: 0,1:22:34.52,1:22:37.35,Default,,0000,0000,0000,,みんなに知られて 恥ずかしいですよ!
Dialogue: 0,1:22:37.35,1:22:39.69,Default,,0000,0000,0000,,そうだ! 恥ずかしいぞ!
Dialogue: 0,1:22:39.69,1:22:44.03,Default,,0000,0000,0000,,男の子だろ 泣くな 泣くな!
Dialogue: 0,1:22:39.69,1:22:44.03,Default,,0000,0000,0000,,男が泣いていいときは
Dialogue: 0,1:22:44.03,1:22:48.20,Default,,0000,0000,0000,,人生で 3回しかないんだからな!
Dialogue: 0,1:22:48.20,1:22:52.20,Default,,0000,0000,0000,,確かに 今は 萎縮してしまっていますが
Dialogue: 0,1:22:52.20,1:22:55.70,Default,,0000,0000,0000,,この子は とても勇気のある子なんです
Dialogue: 0,1:22:55.70,1:22:58.87,Default,,0000,0000,0000,,彼の名前は ルスベル・カラード君
Dialogue: 0,1:22:58.87,1:23:03.48,Default,,0000,0000,0000,,このプリステラで暮らしている まだ 9歳の男の子です
Dialogue: 0,1:23:03.48,1:23:06.31,Default,,0000,0000,0000,,うわ 将来有望ですね
Dialogue: 0,1:23:06.31,1:23:09.15,Default,,0000,0000,0000,,そんな ルスベル君には 幼なじみがいて
Dialogue: 0,1:23:09.15,1:23:13.15,Default,,0000,0000,0000,,金髪の巻き毛が かわいい ティーナちゃんっていうんです
Dialogue: 0,1:23:13.15,1:23:17.83,Default,,0000,0000,0000,,2人は お互いを大切に思い合っている 理想的な関係で
Dialogue: 0,1:23:17.83,1:23:22.83,Default,,0000,0000,0000,,ここへ来るのも どっちがいいか 私は とても悩んだんですよ
Dialogue: 0,1:23:22.83,1:23:25.83,Default,,0000,0000,0000,,最初は ティーナちゃんかなと 思ったんですが
Dialogue: 0,1:23:25.83,1:23:30.01,Default,,0000,0000,0000,,あんまり ルスベル君が 一生懸命 お願いしてくれたので
Dialogue: 0,1:23:30.01,1:23:33.34,Default,,0000,0000,0000,,私は 心を打たれてしまって
Dialogue: 0,1:23:33.34,1:23:36.51,Default,,0000,0000,0000,,だから ここは ルスベル君の心意気を買って
Dialogue: 0,1:23:36.51,1:23:38.85,Default,,0000,0000,0000,,彼に 協力してもらうことにしました!
Dialogue: 0,1:23:41.52,1:23:44.19,Default,,0000,0000,0000,,ルスベル 泣くな! お前は 最高だ!
Dialogue: 0,1:23:44.19,1:23:47.02,Default,,0000,0000,0000,,男を見せたんなら そのまま貫け!
Dialogue: 0,1:23:47.02,1:23:49.36,Default,,0000,0000,0000,,あんた きっと いい男になるわ!
Dialogue: 0,1:23:49.36,1:23:53.86,Default,,0000,0000,0000,,ルスベル プリステラの誇りだ!
Dialogue: 0,1:23:53.86,1:23:58.70,Default,,0000,0000,0000,,ああ ああ ありがと ありがと
Dialogue: 0,1:23:58.70,1:24:03.47,Default,,0000,0000,0000,,ああ! やっぱり すばらしい!
Dialogue: 0,1:23:58.70,1:24:03.47,Default,,0000,0000,0000,,みんな わかってくれた
Dialogue: 0,1:24:03.47,1:24:08.31,Default,,0000,0000,0000,,だって 彼の在り方には 愛があるから!
Dialogue: 0,1:24:08.31,1:24:12.81,Default,,0000,0000,0000,,シリウス ありがとう!
Dialogue: 0,1:24:12.81,1:24:16.02,Default,,0000,0000,0000,,ありがとう ありがとう
Dialogue: 0,1:24:19.65,1:24:22.32,Default,,0000,0000,0000,,互いを知らないから溝が生まれる
Dialogue: 0,1:24:22.32,1:24:26.16,Default,,0000,0000,0000,,互いの思いを分かち合えないから 対立は生じる
Dialogue: 0,1:24:26.16,1:24:30.00,Default,,0000,0000,0000,,互いが違うと諦めるから 絆は生まれない
Dialogue: 0,1:24:30.00,1:24:33.84,Default,,0000,0000,0000,,今 皆さんの心は? どうですか?
Dialogue: 0,1:24:33.84,1:24:37.67,Default,,0000,0000,0000,,そんなことはねえ!
Dialogue: 0,1:24:33.84,1:24:37.67,Default,,0000,0000,0000,,ああ 俺たちは誰1人 諦めない!
Dialogue: 0,1:24:37.67,1:24:39.67,Default,,0000,0000,0000,,心は一つだ!
Dialogue: 0,1:24:39.67,1:24:42.01,Default,,0000,0000,0000,,ありがとう! ありがとう!
Dialogue: 0,1:24:42.01,1:24:45.51,Default,,0000,0000,0000,,今 皆さんは 幸せに思ってくれていますか?
Dialogue: 0,1:24:45.51,1:24:48.85,Default,,0000,0000,0000,,当たり前だ!
Dialogue: 0,1:24:45.51,1:24:48.85,Default,,0000,0000,0000,,こんな気持ちは初めてだよ!
Dialogue: 0,1:24:48.85,1:24:53.02,Default,,0000,0000,0000,,ありがとう ルスベル!
Dialogue: 0,1:24:48.85,1:24:53.02,Default,,0000,0000,0000,,シリウスも ありがとう!
Dialogue: 0,1:25:00.96,1:25:03.63,Default,,0000,0000,0000,,ん! んん!
Dialogue: 0,1:25:00.96,1:25:03.63,Default,,0000,0000,0000,,うぅ
Dialogue: 0,1:25:03.63,1:25:06.97,Default,,0000,0000,0000,,ぐっ あっ うっ ぐっ
Dialogue: 0,1:25:06.97,1:25:10.97,Default,,0000,0000,0000,,たっ だぐ
Dialogue: 0,1:25:06.97,1:25:10.97,Default,,0000,0000,0000,,だぐげで だぐげ
Dialogue: 0,1:25:10.97,1:25:15.48,Default,,0000,0000,0000,,あなたの勇気をたたえます ルスベル君
Dialogue: 0,1:25:15.48,1:25:20.82,Default,,0000,0000,0000,,やっぱり あった!
Dialogue: 0,1:25:15.48,1:25:20.82,Default,,0000,0000,0000,,愛は あったのです!
Dialogue: 0,1:25:20.82,1:25:27.49,Default,,0000,0000,0000,,今 このとき 皆の心が
Dialogue: 0,1:25:20.82,1:25:27.49,Default,,0000,0000,0000,,一つになっているように!
Dialogue: 0,1:25:27.49,1:25:32.49,Default,,0000,0000,0000,,万雷の拍手を!
Dialogue: 0,1:25:35.66,1:25:38.00,Default,,0000,0000,0000,,ん!!
Dialogue: 0,1:25:38.00,1:25:42.00,Default,,0000,0000,0000,,ああ 優しい世界!
Dialogue: 0,1:25:52.18,1:25:55.02,Default,,0000,0000,0000,,そして 歌のあとは ご歓談
Dialogue: 0,1:25:55.02,1:25:57.35,Default,,0000,0000,0000,,ナツキ様は その時間に向けて
Dialogue: 0,1:25:57.35,1:26:00.96,Default,,0000,0000,0000,,おやつなんて準備されるのが よいと思いませんか?
Dialogue: 0,1:26:00.96,1:26:03.79,Default,,0000,0000,0000,,あっ
Dialogue: 0,1:26:03.79,1:26:08.30,Default,,0000,0000,0000,,あれれ? どうされました?
Dialogue: 0,1:26:03.79,1:26:08.30,Default,,0000,0000,0000,,無視? 無視ですか?
Dialogue: 0,1:26:08.30,1:26:13.30,Default,,0000,0000,0000,,おい! おい! お
Dialogue: 0,1:26:08.30,1:26:13.30,Default,,0000,0000,0000,,気持ち悪い
Dialogue: 0,1:26:13.30,1:26:15.64,Default,,0000,0000,0000,,おっ
Dialogue: 0,1:26:13.30,1:26:15.64,Default,,0000,0000,0000,,スバル? 急に どうしたの?
Dialogue: 0,1:26:15.64,1:26:20.81,Default,,0000,0000,0000,,ちょ 何事かしら! スバル? スバル!
Dialogue: 0,1:26:15.64,1:26:20.81,Default,,0000,0000,0000,,うっ うぅ 気持ち悪い
Dialogue: 0,1:26:20.81,1:26:23.65,Default,,0000,0000,0000,,ハァハァハァ 気持ち悪い
Dialogue: 0,1:26:23.65,1:26:25.98,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,1:26:25.98,1:26:28.58,Default,,0000,0000,0000,,気持ち悪い
