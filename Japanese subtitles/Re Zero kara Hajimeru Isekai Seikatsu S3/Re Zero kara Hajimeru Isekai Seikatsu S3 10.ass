Dialogue: 0,0:00:02.00,0:00:04.67,Default,,0000,0000,0000,,ヒッ ヒッヒッヒッヒッ!
Dialogue: 0,0:00:02.00,0:00:04.67,Default,,0000,0000,0000,,しっ 色欲!
Dialogue: 0,0:00:04.67,0:00:06.67,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:00:06.67,0:00:10.18,Default,,0000,0000,0000,,おっ? あ やっぱり
Dialogue: 0,0:00:10.18,0:00:13.35,Default,,0000,0000,0000,,私の血に 負けちまいやがりましたか
Dialogue: 0,0:00:13.35,0:00:16.85,Default,,0000,0000,0000,,そこそこ 高貴な血だったろうに
Dialogue: 0,0:00:13.35,0:00:16.85,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:00:16.85,0:00:19.35,Default,,0000,0000,0000,,黙れ! クルシュ様に何をした!?
Dialogue: 0,0:00:19.35,0:00:24.02,Default,,0000,0000,0000,,どうすれば治せる?
Dialogue: 0,0:00:19.35,0:00:24.02,Default,,0000,0000,0000,,あ もう うっさいな!
Dialogue: 0,0:00:24.02,0:00:27.19,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:00:27.19,0:00:29.20,Default,,0000,0000,0000,,あっ あっ
Dialogue: 0,0:00:27.19,0:00:31.36,Default,,0000,0000,0000,,ほら 刺したら どうです?
Dialogue: 0,0:00:29.20,0:00:31.36,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:00:31.36,0:00:36.20,Default,,0000,0000,0000,,どうしました?
Dialogue: 0,0:00:31.36,0:00:36.20,Default,,0000,0000,0000,,憎いんじゃねえんですか?
Dialogue: 0,0:00:36.20,0:00:40.37,Default,,0000,0000,0000,,復しゅうしたいんじゃ ねえんですか!?
Dialogue: 0,0:00:40.37,0:00:44.38,Default,,0000,0000,0000,,くっ はぁ!
Dialogue: 0,0:00:44.38,0:00:48.21,Default,,0000,0000,0000,,かはっ! ハハハハハ
Dialogue: 0,0:00:48.21,0:00:52.89,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:00:48.21,0:00:52.89,Default,,0000,0000,0000,,うっ うっ うっ ハァ
Dialogue: 0,0:00:52.89,0:00:56.22,Default,,0000,0000,0000,,なっ なんで?
Dialogue: 0,0:00:56.22,0:00:59.06,Default,,0000,0000,0000,,いっ 痛い
Dialogue: 0,0:00:56.22,0:00:59.06,Default,,0000,0000,0000,,あっ あっ
Dialogue: 0,0:00:59.06,0:01:04.33,Default,,0000,0000,0000,,痛いです どうして こんな
Dialogue: 0,0:01:04.33,0:01:08.00,Default,,0000,0000,0000,,あっ あんたが刺せって
Dialogue: 0,0:01:04.33,0:01:08.00,Default,,0000,0000,0000,,うっ うっ
Dialogue: 0,0:01:08.00,0:01:10.00,Default,,0000,0000,0000,,許せない
Dialogue: 0,0:01:08.00,0:01:10.00,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:01:10.00,0:01:14.01,Default,,0000,0000,0000,,あんなに 私と愛し合ったくせに!
Dialogue: 0,0:01:14.01,0:01:18.34,Default,,0000,0000,0000,,うっ 私とクルシュ様は そんな安っぽい関係じゃない!
Dialogue: 0,0:01:18.34,0:01:21.01,Default,,0000,0000,0000,,ああ そうなんですか?
Dialogue: 0,0:01:21.01,0:01:25.52,Default,,0000,0000,0000,,そいつは 演出をしくじりましたね
Dialogue: 0,0:01:25.52,0:01:28.19,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:01:25.52,0:01:28.19,Default,,0000,0000,0000,,ハッ! うっ! ぐはっ! うっ
Dialogue: 0,0:01:28.19,0:01:33.36,Default,,0000,0000,0000,,さてさて どんな命乞いを?
Dialogue: 0,0:01:28.19,0:01:33.36,Default,,0000,0000,0000,,んっ うっ くっ
Dialogue: 0,0:01:33.36,0:01:38.03,Default,,0000,0000,0000,,うっ どうしたら クルシュ様を
Dialogue: 0,0:01:38.03,0:01:42.20,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:01:38.03,0:01:42.20,Default,,0000,0000,0000,,龍の血に負けた体の治し方?
Dialogue: 0,0:01:42.20,0:01:45.71,Default,,0000,0000,0000,,そんなの 私が知りてえぐらいですよ
Dialogue: 0,0:01:45.71,0:01:48.04,Default,,0000,0000,0000,,うぅ うっ
Dialogue: 0,0:01:48.04,0:01:50.71,Default,,0000,0000,0000,,そこまでやね
Dialogue: 0,0:01:48.04,0:01:50.71,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:01:50.71,0:01:53.05,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:01:53.05,0:01:55.88,Default,,0000,0000,0000,,やっぱり 無理やったやろ?
Dialogue: 0,0:01:53.05,0:01:55.88,Default,,0000,0000,0000,,フェリスさん
Dialogue: 0,0:01:55.88,0:01:58.72,Default,,0000,0000,0000,,この手合いは しゃべったりせんわ
Dialogue: 0,0:01:58.72,0:02:03.99,Default,,0000,0000,0000,,仲間の顔だってのに
Dialogue: 0,0:01:58.72,0:02:03.99,Default,,0000,0000,0000,,容赦ねえじゃねえですか
Dialogue: 0,0:02:03.99,0:02:08.33,Default,,0000,0000,0000,,あの演説 聞いたら 絶対 ここに来る思とったわ
Dialogue: 0,0:02:08.33,0:02:10.83,Default,,0000,0000,0000,,あんたら 性格 最悪やもん
Dialogue: 0,0:02:10.83,0:02:13.83,Default,,0000,0000,0000,,てめえ 何者なんです?
Dialogue: 0,0:02:13.83,0:02:16.17,Default,,0000,0000,0000,,アナスタシア・ホーシン
Dialogue: 0,0:02:16.17,0:02:19.67,Default,,0000,0000,0000,,今は この都市の代表代理 ってとこやね
Dialogue: 0,0:02:19.67,0:02:21.67,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:21.67,0:02:25.51,Default,,0000,0000,0000,,んっ? うわっ!
Dialogue: 0,0:02:25.51,0:02:28.35,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:02:28.35,0:02:31.02,Default,,0000,0000,0000,,来るのは わかってたって 言うたやろ
Dialogue: 0,0:02:31.02,0:02:33.02,Default,,0000,0000,0000,,楽しませてくれるじゃ
Dialogue: 0,0:02:33.02,0:02:36.36,Default,,0000,0000,0000,,そしたら 歓迎の準備もせん商人なんて
Dialogue: 0,0:02:36.36,0:02:39.36,Default,,0000,0000,0000,,この世に 1人もおらんよ
Dialogue: 0,0:02:39.36,0:02:41.36,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:02:44.86,0:02:49.20,Default,,0000,0000,0000,,げふっ! 上等じゃねえですか!
Dialogue: 0,0:02:49.20,0:02:54.87,Default,,0000,0000,0000,,早く戻って 抱き締めて
Dialogue: 0,0:02:49.20,0:02:54.87,Default,,0000,0000,0000,,私以外 何も愛せねえように
Dialogue: 0,0:02:54.87,0:02:58.04,Default,,0000,0000,0000,,戻れねえよ
Dialogue: 0,0:02:54.87,0:02:58.04,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:02:58.04,0:02:59.98,Default,,0000,0000,0000,,私の美意識は
Dialogue: 0,0:02:59.98,0:03:05.15,Default,,0000,0000,0000,,自分の醜さを隠したがるやつに
Dialogue: 0,0:02:59.98,0:03:05.15,Default,,0000,0000,0000,,容赦しねえんですが?
Dialogue: 0,0:03:05.15,0:03:11.16,Default,,0000,0000,0000,,安心しろや 俺の美意識も
Dialogue: 0,0:03:05.15,0:03:11.16,Default,,0000,0000,0000,,てめえに容赦する気はねえ
Dialogue: 0,0:03:11.16,0:03:14.49,Default,,0000,0000,0000,,今日の俺は 機嫌が悪いんだ
Dialogue: 0,0:03:14.49,0:03:19.50,Default,,0000,0000,0000,,俺が死ぬ前に とっとと帰れや
Dialogue: 0,0:03:14.49,0:03:19.50,Default,,0000,0000,0000,,軟体生物!
Dialogue: 0,0:05:04.47,0:05:06.47,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:05:06.47,0:05:09.48,Default,,0000,0000,0000,,フッ あっ
Dialogue: 0,0:05:09.48,0:05:12.98,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:05:09.48,0:05:12.98,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:05:12.98,0:05:17.78,Default,,0000,0000,0000,,いいかげん気付けよ!
Dialogue: 0,0:05:12.98,0:05:17.78,Default,,0000,0000,0000,,威力の問題じゃないってさ!
Dialogue: 0,0:05:20.32,0:05:24.99,Default,,0000,0000,0000,,殴り続けてれば勝てるなんて 子どもの発想だよ
Dialogue: 0,0:05:24.99,0:05:30.00,Default,,0000,0000,0000,,君が ばかなのか それとも
Dialogue: 0,0:05:24.99,0:05:30.00,Default,,0000,0000,0000,,僕を ばかにしてるのかな?
Dialogue: 0,0:05:30.00,0:05:33.17,Default,,0000,0000,0000,,なら 別の手段に つきあってもらうよ
Dialogue: 0,0:05:33.17,0:05:35.17,Default,,0000,0000,0000,,んっ? あっ!
Dialogue: 0,0:05:35.17,0:05:37.50,Default,,0000,0000,0000,,いっ!
Dialogue: 0,0:05:37.50,0:05:42.18,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:05:37.50,0:05:42.18,Default,,0000,0000,0000,,まずは 第1弾だ!
Dialogue: 0,0:05:37.50,0:05:42.18,Default,,0000,0000,0000,,作戦Iだったかな?
Dialogue: 0,0:05:42.18,0:05:46.68,Default,,0000,0000,0000,,お前 ふざけるなよ!
Dialogue: 0,0:05:42.18,0:05:46.68,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:05:46.68,0:05:48.68,Default,,0000,0000,0000,,エミリアたん お願い!
Dialogue: 0,0:05:50.85,0:05:52.85,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:06:00.29,0:06:02.30,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:06:05.30,0:06:07.30,Default,,0000,0000,0000,,うぅ いっ!
Dialogue: 0,0:06:07.30,0:06:10.30,Default,,0000,0000,0000,,アルヒューマ!
Dialogue: 0,0:06:10.30,0:06:12.31,Default,,0000,0000,0000,,なっ!
Dialogue: 0,0:06:19.65,0:06:24.15,Default,,0000,0000,0000,,よっしゃ!
Dialogue: 0,0:06:19.65,0:06:24.15,Default,,0000,0000,0000,,池ポチャ 略して 作戦I 成功!
Dialogue: 0,0:06:24.15,0:06:26.15,Default,,0000,0000,0000,,これで やっつけられたらいいんだけど
Dialogue: 0,0:06:26.15,0:06:29.99,Default,,0000,0000,0000,,危ない!
Dialogue: 0,0:06:26.15,0:06:29.99,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:06:29.99,0:06:31.99,Default,,0000,0000,0000,,え! おっ!
Dialogue: 0,0:06:29.99,0:06:31.99,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:06:37.00,0:06:39.50,Default,,0000,0000,0000,,ラインハルト!
Dialogue: 0,0:06:37.00,0:06:39.50,Default,,0000,0000,0000,,さて
Dialogue: 0,0:06:39.50,0:06:43.00,Default,,0000,0000,0000,,これで いちばん面倒なやつは 片づいたよ!
Dialogue: 0,0:06:43.00,0:06:49.18,Default,,0000,0000,0000,,うっ 君 ほんとに
Dialogue: 0,0:06:43.00,0:06:49.18,Default,,0000,0000,0000,,人の話を聞かない女だな!
Dialogue: 0,0:06:49.18,0:06:51.68,Default,,0000,0000,0000,,何をしても 無意味なんだよ!
Dialogue: 0,0:06:51.68,0:06:55.52,Default,,0000,0000,0000,,僕は 完璧な 完成された人間だ!
Dialogue: 0,0:06:55.52,0:06:58.85,Default,,0000,0000,0000,,満たされた僕に これ以上も これ以下もない!
Dialogue: 0,0:06:58.85,0:07:02.29,Default,,0000,0000,0000,,満たされてるなんて あなた 大うそつきだわ!
Dialogue: 0,0:07:02.29,0:07:06.13,Default,,0000,0000,0000,,あなたの言ってることは 欲しい 欲しい もっと欲しいって
Dialogue: 0,0:07:06.13,0:07:08.96,Default,,0000,0000,0000,,すごく 身勝手なことばっかりだもの!
Dialogue: 0,0:07:08.96,0:07:11.80,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:07:08.96,0:07:11.80,Default,,0000,0000,0000,,満たされてるなら
Dialogue: 0,0:07:11.80,0:07:14.63,Default,,0000,0000,0000,,奥さんたちを もっと大事にして!
Dialogue: 0,0:07:14.63,0:07:18.47,Default,,0000,0000,0000,,あんなふうに縛りつけて それで諦めさせて
Dialogue: 0,0:07:18.47,0:07:21.81,Default,,0000,0000,0000,,それから それから
Dialogue: 0,0:07:21.81,0:07:24.81,Default,,0000,0000,0000,,あっ わかった
Dialogue: 0,0:07:24.81,0:07:27.48,Default,,0000,0000,0000,,私 あなたのこと
Dialogue: 0,0:07:27.48,0:07:30.32,Default,,0000,0000,0000,,大っ嫌いだわ!
Dialogue: 0,0:07:30.32,0:07:34.82,Default,,0000,0000,0000,,お前!
Dialogue: 0,0:07:34.82,0:07:36.82,Default,,0000,0000,0000,,エミリアたん よく言った!
Dialogue: 0,0:07:36.82,0:07:39.49,Default,,0000,0000,0000,,よく言ったけど いったん 下がろう!
Dialogue: 0,0:07:36.82,0:07:39.49,Default,,0000,0000,0000,,でも
Dialogue: 0,0:07:39.49,0:07:43.00,Default,,0000,0000,0000,,あいつの 無敵のからくりが 解けないうちは倒せない!
Dialogue: 0,0:07:43.00,0:07:47.83,Default,,0000,0000,0000,,俺たちが やらなきゃいけないことを 間違えちゃだめだ!
Dialogue: 0,0:07:45.00,0:07:47.83,Default,,0000,0000,0000,,あっ んっ
Dialogue: 0,0:07:47.83,0:07:50.00,Default,,0000,0000,0000,,んっ? えっ!
Dialogue: 0,0:07:50.00,0:07:53.01,Default,,0000,0000,0000,,あっ? うっ え!
Dialogue: 0,0:07:53.01,0:07:56.01,Default,,0000,0000,0000,,ねっ ねえ スバル
Dialogue: 0,0:07:56.01,0:08:01.28,Default,,0000,0000,0000,,私 すごく
Dialogue: 0,0:07:56.01,0:08:01.28,Default,,0000,0000,0000,,嫌な予感がするんだけど
Dialogue: 0,0:08:01.28,0:08:06.29,Default,,0000,0000,0000,,気が合うね 俺もだ
Dialogue: 0,0:08:06.29,0:08:08.49,Default,,0000,0000,0000,,あっ ああ
Dialogue: 0,0:08:06.29,0:08:08.49,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:08:12.12,0:08:16.33,Default,,0000,0000,0000,,そら! よけれるものなら よけてごらんよ
Dialogue: 0,0:08:19.97,0:08:21.97,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:08:24.14,0:08:27.34,Default,,0000,0000,0000,,逃げろ 逃げろ 逃げろ 逃げろ 逃げろ!
Dialogue: 0,0:08:31.31,0:08:33.65,Default,,0000,0000,0000,,フフッ んっ?
Dialogue: 0,0:08:33.65,0:08:37.32,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:08:33.65,0:08:37.32,Default,,0000,0000,0000,,え!
Dialogue: 0,0:08:37.32,0:08:40.32,Default,,0000,0000,0000,,うわ!
Dialogue: 0,0:08:37.32,0:08:40.32,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:08:40.32,0:08:43.16,Default,,0000,0000,0000,,うわ! おっ! お!
Dialogue: 0,0:08:43.16,0:08:45.99,Default,,0000,0000,0000,,エミリアたん すげえ! 賢い! かわいい!
Dialogue: 0,0:08:45.99,0:08:49.16,Default,,0000,0000,0000,,ばかなこと言ってないの!
Dialogue: 0,0:08:45.99,0:08:49.16,Default,,0000,0000,0000,,制御が難しいから 手を
Dialogue: 0,0:08:49.16,0:08:52.50,Default,,0000,0000,0000,,たまにさ いるんだよね
Dialogue: 0,0:08:49.16,0:08:52.50,Default,,0000,0000,0000,,あっ ハッ!
Dialogue: 0,0:08:52.50,0:08:58.34,Default,,0000,0000,0000,,君らみたいな 自分を
Dialogue: 0,0:08:52.50,0:08:58.34,Default,,0000,0000,0000,,特別と勘違いしてるやつらがさ
Dialogue: 0,0:08:58.34,0:09:00.34,Default,,0000,0000,0000,,気持ち悪っ!
Dialogue: 0,0:09:02.94,0:09:06.95,Default,,0000,0000,0000,,スバル 微精霊の子を 1人付けるから 頑張れる?
Dialogue: 0,0:09:06.95,0:09:11.12,Default,,0000,0000,0000,,任せて! これでも がきのころは 氷上のプリンセスって
Dialogue: 0,0:09:11.12,0:09:13.12,Default,,0000,0000,0000,,ええ? あ!
Dialogue: 0,0:09:16.96,0:09:19.13,Default,,0000,0000,0000,,えい!
Dialogue: 0,0:09:19.13,0:09:21.13,Default,,0000,0000,0000,,やぁ!
Dialogue: 0,0:09:21.13,0:09:23.63,Default,,0000,0000,0000,,うぅ やぁ!
Dialogue: 0,0:09:29.30,0:09:31.64,Default,,0000,0000,0000,,ひたすら 急所を
Dialogue: 0,0:09:31.64,0:09:35.98,Default,,0000,0000,0000,,慎みってものがない女だな 君は!
Dialogue: 0,0:09:31.64,0:09:35.98,Default,,0000,0000,0000,,花嫁に不適格だ!
Dialogue: 0,0:09:35.98,0:09:38.98,Default,,0000,0000,0000,,言ったでしょ!
Dialogue: 0,0:09:35.98,0:09:38.98,Default,,0000,0000,0000,,あなたの花嫁にはならない!
Dialogue: 0,0:09:38.98,0:09:41.48,Default,,0000,0000,0000,,私 きっと 笑えなくなるもの!
Dialogue: 0,0:09:41.48,0:09:44.15,Default,,0000,0000,0000,,エミリアたん!
Dialogue: 0,0:09:41.48,0:09:44.15,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:09:44.15,0:09:46.15,Default,,0000,0000,0000,,ハッ くっ!
Dialogue: 0,0:09:46.15,0:09:50.66,Default,,0000,0000,0000,,ぐぅ! フン!
Dialogue: 0,0:09:50.66,0:09:54.33,Default,,0000,0000,0000,,エミリア!
Dialogue: 0,0:09:50.66,0:09:54.33,Default,,0000,0000,0000,,あっ! くっ
Dialogue: 0,0:09:54.33,0:09:57.66,Default,,0000,0000,0000,,うぅっ!
Dialogue: 0,0:09:57.66,0:09:59.67,Default,,0000,0000,0000,,チッ! んっ?
Dialogue: 0,0:09:59.67,0:10:03.57,Default,,0000,0000,0000,,んな! ははい!
Dialogue: 0,0:10:07.67,0:10:11.34,Default,,0000,0000,0000,,ありがと スバル
Dialogue: 0,0:10:07.67,0:10:11.34,Default,,0000,0000,0000,,大丈夫! 役得!
Dialogue: 0,0:10:11.34,0:10:16.68,Default,,0000,0000,0000,,それより 作戦KとK2
Dialogue: 0,0:10:11.34,0:10:16.68,Default,,0000,0000,0000,,急所と金的も だめか
Dialogue: 0,0:10:16.68,0:10:18.85,Default,,0000,0000,0000,,あいつの弱点 どこだよ?
Dialogue: 0,0:10:18.85,0:10:22.36,Default,,0000,0000,0000,,そんなものはないって いいかげん 気付けよ!
Dialogue: 0,0:10:22.36,0:10:25.02,Default,,0000,0000,0000,,浮気女と間男が!
Dialogue: 0,0:10:25.02,0:10:27.69,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:10:25.02,0:10:27.69,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:10:27.69,0:10:32.20,Default,,0000,0000,0000,,あっ あっ あっ あっ
Dialogue: 0,0:10:27.69,0:10:32.20,Default,,0000,0000,0000,,あっ あっ あ! あ!!
Dialogue: 0,0:10:32.20,0:10:34.87,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:10:34.87,0:10:37.37,Default,,0000,0000,0000,,ラインハルト!
Dialogue: 0,0:10:34.87,0:10:37.37,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:10:37.37,0:10:39.71,Default,,0000,0000,0000,,んっ? うぅ!
Dialogue: 0,0:10:39.71,0:10:43.11,Default,,0000,0000,0000,,んっ? チッ!
Dialogue: 0,0:10:45.04,0:10:47.88,Default,,0000,0000,0000,,無事だったか!
Dialogue: 0,0:10:45.04,0:10:47.88,Default,,0000,0000,0000,,待たせて すまない
Dialogue: 0,0:10:47.88,0:10:51.18,Default,,0000,0000,0000,,どこまでも ばかげてるな 君!
Dialogue: 0,0:10:47.88,0:10:51.18,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:10:47.88,0:10:51.18,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:10:58.22,0:11:00.16,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:11:00.16,0:11:02.66,Default,,0000,0000,0000,,げっ! 作戦J!
Dialogue: 0,0:11:04.66,0:11:06.87,Default,,0000,0000,0000,,んっ? ばかが!
Dialogue: 0,0:11:10.50,0:11:13.51,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:11:13.51,0:11:15.84,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:11:13.51,0:11:15.84,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:11:13.51,0:11:15.84,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:11:15.84,0:11:19.55,Default,,0000,0000,0000,,なっ! お前!
Dialogue: 0,0:11:15.84,0:11:19.55,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:11:22.85,0:11:25.35,Default,,0000,0000,0000,,自爆作戦でも だめか
Dialogue: 0,0:11:25.35,0:11:30.19,Default,,0000,0000,0000,,うぅ くそ! 考え方が悪い?
Dialogue: 0,0:11:25.35,0:11:30.19,Default,,0000,0000,0000,,発想が間違ってるか?
Dialogue: 0,0:11:30.19,0:11:34.69,Default,,0000,0000,0000,,エミリアたん なんでもいい
Dialogue: 0,0:11:30.19,0:11:34.69,Default,,0000,0000,0000,,ヒントが欲しい
Dialogue: 0,0:11:34.69,0:11:37.36,Default,,0000,0000,0000,,あいつに捕まってる間 どんなことがあった?
Dialogue: 0,0:11:37.36,0:11:40.37,Default,,0000,0000,0000,,あっ どんなこと
Dialogue: 0,0:11:40.37,0:11:44.04,Default,,0000,0000,0000,,まず ショジョ?
Dialogue: 0,0:11:40.37,0:11:44.04,Default,,0000,0000,0000,,それかどうか聞かれて
Dialogue: 0,0:11:44.04,0:11:46.04,Default,,0000,0000,0000,,あいつ ぶっ殺す
Dialogue: 0,0:11:46.04,0:11:48.54,Default,,0000,0000,0000,,奥さんたちを番号で呼んでて
Dialogue: 0,0:11:48.54,0:11:51.38,Default,,0000,0000,0000,,それを 悪い王様みたいって言ったら
Dialogue: 0,0:11:51.38,0:11:56.55,Default,,0000,0000,0000,,あの子は 小さな王様
Dialogue: 0,0:11:51.38,0:11:56.55,Default,,0000,0000,0000,,ううん 小さな王って
Dialogue: 0,0:11:56.55,0:11:59.99,Default,,0000,0000,0000,,小さな王
Dialogue: 0,0:11:59.99,0:12:02.82,Default,,0000,0000,0000,,ハッ! 星の名前だ
Dialogue: 0,0:12:02.82,0:12:06.83,Default,,0000,0000,0000,,シリウス カペラ アルファルド ペテルギウス
Dialogue: 0,0:12:06.83,0:12:09.83,Default,,0000,0000,0000,,全部 俺が知ってる星の名前なんだ
Dialogue: 0,0:12:09.83,0:12:13.33,Default,,0000,0000,0000,,レグルスは ラテン語で 小さな王
Dialogue: 0,0:12:13.33,0:12:15.67,Default,,0000,0000,0000,,くっ!
Dialogue: 0,0:12:13.33,0:12:15.67,Default,,0000,0000,0000,,でも 別名があって
Dialogue: 0,0:12:15.67,0:12:18.34,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:12:15.67,0:12:18.34,Default,,0000,0000,0000,,スバル?
Dialogue: 0,0:12:18.34,0:12:20.34,Default,,0000,0000,0000,,エミリア
Dialogue: 0,0:12:18.34,0:12:20.34,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:12:20.34,0:12:23.34,Default,,0000,0000,0000,,聖堂で あいつに 首 つかまれてたよな
Dialogue: 0,0:12:23.34,0:12:26.35,Default,,0000,0000,0000,,そのときなんだけど あいつの手は熱かったか?
Dialogue: 0,0:12:26.35,0:12:30.02,Default,,0000,0000,0000,,それとも冷たかったか?
Dialogue: 0,0:12:26.35,0:12:30.02,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:30.02,0:12:34.02,Default,,0000,0000,0000,,何も感じなかった
Dialogue: 0,0:12:30.02,0:12:34.02,Default,,0000,0000,0000,,熱くも 冷たくも
Dialogue: 0,0:12:34.02,0:12:38.52,Default,,0000,0000,0000,,まるで なんにもないものに 触られてたみたいに
Dialogue: 0,0:12:38.52,0:12:41.53,Default,,0000,0000,0000,,なんにもないもの
Dialogue: 0,0:12:41.53,0:12:44.53,Default,,0000,0000,0000,,んっ! ラインハルト!
Dialogue: 0,0:12:44.53,0:12:48.53,Default,,0000,0000,0000,,そいつの心臓が動いてるか 確かめてくれ!
Dialogue: 0,0:12:51.37,0:12:54.21,Default,,0000,0000,0000,,わざわざ こうして 足を運んでいただいて
Dialogue: 0,0:12:54.21,0:12:56.71,Default,,0000,0000,0000,,ごめんね ありがと
Dialogue: 0,0:12:56.71,0:13:00.15,Default,,0000,0000,0000,,あれが 憤怒の大罪司教
Dialogue: 0,0:13:00.15,0:13:02.15,Default,,0000,0000,0000,,驚かせて ごめんね
Dialogue: 0,0:13:02.15,0:13:05.32,Default,,0000,0000,0000,,今夜は 街のあちこちが真っ暗でしょう?
Dialogue: 0,0:13:05.32,0:13:09.16,Default,,0000,0000,0000,,なので ちょっぴり背伸びして 明るくしてみたんです
Dialogue: 0,0:13:09.16,0:13:11.16,Default,,0000,0000,0000,,なっ なんだ なんだ!
Dialogue: 0,0:13:11.16,0:13:13.83,Default,,0000,0000,0000,,意外と 話せるお人じゃありませんか!
Dialogue: 0,0:13:13.83,0:13:16.83,Default,,0000,0000,0000,,私 誤解してたかもしれませんよ!
Dialogue: 0,0:13:16.83,0:13:21.33,Default,,0000,0000,0000,,まあ! うれしいことを 言ってくださいますね お嬢さん
Dialogue: 0,0:13:21.33,0:13:25.84,Default,,0000,0000,0000,,人と人とは わかり合える
Dialogue: 0,0:13:21.33,0:13:25.84,Default,,0000,0000,0000,,互いに 手を結び合えば!
Dialogue: 0,0:13:25.84,0:13:30.01,Default,,0000,0000,0000,,そうでしょう?
Dialogue: 0,0:13:25.84,0:13:30.01,Default,,0000,0000,0000,,そう! まさしく!
Dialogue: 0,0:13:30.01,0:13:34.51,Default,,0000,0000,0000,,やっぱり それって 愛ですよね?
Dialogue: 0,0:13:34.51,0:13:38.52,Default,,0000,0000,0000,,ええ そうです!
Dialogue: 0,0:13:34.51,0:13:38.52,Default,,0000,0000,0000,,愛です! 愛なのです!
Dialogue: 0,0:13:38.52,0:13:44.02,Default,,0000,0000,0000,,うっ こっ これは もはや
Dialogue: 0,0:13:38.52,0:13:44.02,Default,,0000,0000,0000,,聖女の風格!
Dialogue: 0,0:13:44.02,0:13:47.69,Default,,0000,0000,0000,,プリシラ様! いかがでしょう?
Dialogue: 0,0:13:44.02,0:13:47.69,Default,,0000,0000,0000,,話し合ってみては
Dialogue: 0,0:13:47.69,0:13:50.20,Default,,0000,0000,0000,,そうすれば こう 斬り合ったりする必要は
Dialogue: 0,0:13:50.20,0:13:53.53,Default,,0000,0000,0000,,よもや ここまで効果てきめんとはな
Dialogue: 0,0:13:53.53,0:13:56.70,Default,,0000,0000,0000,,感受性が強いのも考えものか
Dialogue: 0,0:13:56.70,0:14:00.31,Default,,0000,0000,0000,,ハハッ あっ プリシラ様!
Dialogue: 0,0:14:00.31,0:14:03.31,Default,,0000,0000,0000,,んっ んん んっ んっ
Dialogue: 0,0:14:00.31,0:14:03.31,Default,,0000,0000,0000,,んっ! ん! うっ うぅ
Dialogue: 0,0:14:03.31,0:14:05.81,Default,,0000,0000,0000,,んまあ!
Dialogue: 0,0:14:03.31,0:14:05.81,Default,,0000,0000,0000,,んっ うぅ! んっ
Dialogue: 0,0:14:05.81,0:14:07.81,Default,,0000,0000,0000,,うぅっ! ん!
Dialogue: 0,0:14:07.81,0:14:10.65,Default,,0000,0000,0000,,あっ あっ あっ ハァ
Dialogue: 0,0:14:10.65,0:14:14.15,Default,,0000,0000,0000,,あっ ああ あっ
Dialogue: 0,0:14:14.15,0:14:18.49,Default,,0000,0000,0000,,ハッ! プッ プリシラ様!
Dialogue: 0,0:14:14.15,0:14:18.49,Default,,0000,0000,0000,,今のは なんばしよっとですか!
Dialogue: 0,0:14:18.49,0:14:22.33,Default,,0000,0000,0000,,あげなことされたら もう お嫁に行けねえだ!
Dialogue: 0,0:14:22.33,0:14:26.00,Default,,0000,0000,0000,,口吸いを許したのは わらわとて同じであろう
Dialogue: 0,0:14:26.00,0:14:28.00,Default,,0000,0000,0000,,正気に戻る きっかけと
Dialogue: 0,0:14:28.00,0:14:32.00,Default,,0000,0000,0000,,それ以上の快楽が あったじゃろうが
Dialogue: 0,0:14:28.00,0:14:32.00,Default,,0000,0000,0000,,ふぇ?
Dialogue: 0,0:14:32.00,0:14:36.68,Default,,0000,0000,0000,,まあまあ! お二人は 愛し合っているのですね!
Dialogue: 0,0:14:36.68,0:14:39.51,Default,,0000,0000,0000,,そうです
Dialogue: 0,0:14:36.68,0:14:39.51,Default,,0000,0000,0000,,愛とは つながりを持って
Dialogue: 0,0:14:39.51,0:14:42.68,Default,,0000,0000,0000,,茶番は やめよ 聞くに堪えん
Dialogue: 0,0:14:42.68,0:14:44.68,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:14:44.68,0:14:50.36,Default,,0000,0000,0000,,あっ あれ? あれ? あれ?
Dialogue: 0,0:14:44.68,0:14:50.36,Default,,0000,0000,0000,,さっきまでの親近感は どこへ?
Dialogue: 0,0:14:50.36,0:14:54.36,Default,,0000,0000,0000,,なんて なんて ひどいことを
Dialogue: 0,0:14:54.36,0:14:58.70,Default,,0000,0000,0000,,彼女は 私と同じ 愛の道を歩み始めていたのに
Dialogue: 0,0:14:58.70,0:15:02.13,Default,,0000,0000,0000,,周りを見てください!
Dialogue: 0,0:14:58.70,0:15:02.13,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:15:02.13,0:15:04.30,Default,,0000,0000,0000,,あっ あの人たちは
Dialogue: 0,0:15:04.30,0:15:07.64,Default,,0000,0000,0000,,集められた 街の住人であろうよ
Dialogue: 0,0:15:07.64,0:15:10.48,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:15:07.64,0:15:10.48,Default,,0000,0000,0000,,ご覧なさい この光景を!
Dialogue: 0,0:15:10.48,0:15:14.15,Default,,0000,0000,0000,,誰一人 和を乱すことなく 整然と息をそろえて
Dialogue: 0,0:15:14.15,0:15:18.98,Default,,0000,0000,0000,,これこそ 本物の愛の証明では ありませんか!
Dialogue: 0,0:15:18.98,0:15:21.82,Default,,0000,0000,0000,,さあ! あなたたちも知りなさい!
Dialogue: 0,0:15:21.82,0:15:26.99,Default,,0000,0000,0000,,愛に包まれ
Dialogue: 0,0:15:21.82,0:15:26.99,Default,,0000,0000,0000,,1つになることの喜びを!
Dialogue: 0,0:15:26.99,0:15:28.99,Default,,0000,0000,0000,,うわ!
Dialogue: 0,0:15:33.17,0:15:35.33,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:15:33.17,0:15:35.33,Default,,0000,0000,0000,,うわ!
Dialogue: 0,0:15:35.33,0:15:37.34,Default,,0000,0000,0000,,え!
Dialogue: 0,0:15:37.34,0:15:41.34,Default,,0000,0000,0000,,貴様の賛同者たちは 命を危うくしてまで
Dialogue: 0,0:15:41.34,0:15:45.51,Default,,0000,0000,0000,,愛の証明に つきあうつもりは ないようじゃな
Dialogue: 0,0:15:45.51,0:15:47.68,Default,,0000,0000,0000,,あれらを正気に戻せ
Dialogue: 0,0:15:47.68,0:15:50.85,Default,,0000,0000,0000,,うため それが歌女である 貴様の役目じゃ
Dialogue: 0,0:15:50.85,0:15:53.69,Default,,0000,0000,0000,,やれなくば 死ぬるのみ!
Dialogue: 0,0:15:50.85,0:15:53.69,Default,,0000,0000,0000,,うぅ あっ ああ
Dialogue: 0,0:15:53.69,0:15:57.69,Default,,0000,0000,0000,,貴様の喉に 全員の命が懸かると思え
Dialogue: 0,0:15:57.69,0:16:00.46,Default,,0000,0000,0000,,誉れであろう?
Dialogue: 0,0:15:57.69,0:16:00.46,Default,,0000,0000,0000,,うわ!
Dialogue: 0,0:16:00.46,0:16:05.30,Default,,0000,0000,0000,,あなた 初めて お見かけする人種ですね
Dialogue: 0,0:16:05.30,0:16:08.13,Default,,0000,0000,0000,,そう そうそう!
Dialogue: 0,0:16:08.13,0:16:13.31,Default,,0000,0000,0000,,あなたと わかり合うことこそが
Dialogue: 0,0:16:08.13,0:16:13.31,Default,,0000,0000,0000,,こたびの私への試練なのでは?
Dialogue: 0,0:16:13.31,0:16:18.48,Default,,0000,0000,0000,,改めて
Dialogue: 0,0:16:13.31,0:16:18.48,Default,,0000,0000,0000,,私は 魔女教大罪司教 憤怒担当
Dialogue: 0,0:16:18.48,0:16:20.81,Default,,0000,0000,0000,,シリウス・ロマネコンティ
Dialogue: 0,0:16:20.81,0:16:23.65,Default,,0000,0000,0000,,普遍の愛で あなたを包みましょう
Dialogue: 0,0:16:23.65,0:16:28.15,Default,,0000,0000,0000,,この試練を乗り越えたとき 私は
Dialogue: 0,0:16:28.15,0:16:32.16,Default,,0000,0000,0000,,あの人の愛に焼かれるでしょう!
Dialogue: 0,0:16:32.16,0:16:36.00,Default,,0000,0000,0000,,んっ わらわの気は長くない
Dialogue: 0,0:16:32.16,0:16:36.00,Default,,0000,0000,0000,,急げよ 歌女
Dialogue: 0,0:16:36.00,0:16:38.50,Default,,0000,0000,0000,,うひぇ! あっ プリシラ様!
Dialogue: 0,0:16:38.50,0:16:41.83,Default,,0000,0000,0000,,フフフ!
Dialogue: 0,0:16:41.83,0:16:45.67,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:16:45.67,0:16:48.17,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:16:45.67,0:16:48.17,Default,,0000,0000,0000,,ンフッ!
Dialogue: 0,0:16:48.17,0:16:52.51,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:16:48.17,0:16:52.51,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:16:48.17,0:16:52.51,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:16:52.51,0:16:54.68,Default,,0000,0000,0000,,どっせい!
Dialogue: 0,0:16:54.68,0:16:59.52,Default,,0000,0000,0000,,ちくせう!
Dialogue: 0,0:16:54.68,0:16:59.52,Default,,0000,0000,0000,,やったりますよ リリアナ・マスカレード!
Dialogue: 0,0:16:59.52,0:17:02.82,Default,,0000,0000,0000,,一世一代の大舞台たい!
Dialogue: 0,0:17:05.29,0:17:07.96,Default,,0000,0000,0000,,ウフッ!
Dialogue: 0,0:17:05.29,0:17:07.96,Default,,0000,0000,0000,,フッ! んっ!
Dialogue: 0,0:17:07.96,0:17:10.96,Default,,0000,0000,0000,,フッ! んっ
Dialogue: 0,0:17:07.96,0:17:10.96,Default,,0000,0000,0000,,あら あら あら!
Dialogue: 0,0:17:10.96,0:17:13.47,Default,,0000,0000,0000,,まあ まあ まあ!
Dialogue: 0,0:17:13.47,0:17:17.64,Default,,0000,0000,0000,,こんなに かたくなな方は 初めてですよ
Dialogue: 0,0:17:17.64,0:17:20.97,Default,,0000,0000,0000,,あなたの心を こんなにも固く閉ざしたのは
Dialogue: 0,0:17:20.97,0:17:23.81,Default,,0000,0000,0000,,一体 何が原因なのでしょう?
Dialogue: 0,0:17:23.81,0:17:28.15,Default,,0000,0000,0000,,貴様に わらわの胸の内を 明かすなど 不可能よ
Dialogue: 0,0:17:28.15,0:17:32.65,Default,,0000,0000,0000,,できはしないと 私が諦めてしまえば 世界は闇!
Dialogue: 0,0:17:32.65,0:17:35.32,Default,,0000,0000,0000,,私は あなたを救いたいのです!
Dialogue: 0,0:17:35.32,0:17:37.49,Default,,0000,0000,0000,,弱みを見せないことが
Dialogue: 0,0:17:37.49,0:17:40.99,Default,,0000,0000,0000,,強くあることだと 思い違いしていませんか?
Dialogue: 0,0:17:40.99,0:17:44.50,Default,,0000,0000,0000,,他者と つながり合い 寄り添うことで
Dialogue: 0,0:17:44.50,0:17:46.83,Default,,0000,0000,0000,,初めて見える頂もあるのです!
Dialogue: 0,0:17:46.83,0:17:51.67,Default,,0000,0000,0000,,フン! よくも まあ 臆面もなく ペラペラと妄想を
Dialogue: 0,0:17:51.67,0:17:55.34,Default,,0000,0000,0000,,では こんな趣向は いかが?
Dialogue: 0,0:17:51.67,0:17:55.34,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:17:55.34,0:17:59.01,Default,,0000,0000,0000,,フッ 「アイリスと茨の王」 フフフ!
Dialogue: 0,0:17:59.01,0:18:01.01,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:18:04.78,0:18:07.95,Default,,0000,0000,0000,,そいつの心臓が動いてるか 確かめてくれ!
Dialogue: 0,0:18:07.95,0:18:09.96,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:18:09.96,0:18:12.79,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:09.96,0:18:12.79,Default,,0000,0000,0000,,よそ見とは いただけないね
Dialogue: 0,0:18:12.79,0:18:14.79,Default,,0000,0000,0000,,んっ? うっ!
Dialogue: 0,0:18:14.79,0:18:18.13,Default,,0000,0000,0000,,勘違いするなよ 剣聖
Dialogue: 0,0:18:14.79,0:18:18.13,Default,,0000,0000,0000,,んっ? うっ!
Dialogue: 0,0:18:18.13,0:18:23.30,Default,,0000,0000,0000,,遊んでやってたのは
Dialogue: 0,0:18:18.13,0:18:23.30,Default,,0000,0000,0000,,僕の心の広さと余裕のおかげだ
Dialogue: 0,0:18:23.30,0:18:26.97,Default,,0000,0000,0000,,でも 優しい僕にだって 限度があるんだからさ!
Dialogue: 0,0:18:26.97,0:18:28.97,Default,,0000,0000,0000,,どうやら
Dialogue: 0,0:18:26.97,0:18:28.97,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:18:28.97,0:18:31.64,Default,,0000,0000,0000,,スバルの推測は 正しかったらしい
Dialogue: 0,0:18:31.64,0:18:34.15,Default,,0000,0000,0000,,なっ んっ?
Dialogue: 0,0:18:34.15,0:18:36.48,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:18:36.48,0:18:42.49,Default,,0000,0000,0000,,空に落ちる気分を
Dialogue: 0,0:18:36.48,0:18:42.49,Default,,0000,0000,0000,,味わったことはあるかな!?
Dialogue: 0,0:18:42.49,0:18:45.16,Default,,0000,0000,0000,,あっ ラインハルト!
Dialogue: 0,0:18:42.49,0:18:45.16,Default,,0000,0000,0000,,スバル あっ
Dialogue: 0,0:18:45.16,0:18:47.16,Default,,0000,0000,0000,,君の推測で正しい
Dialogue: 0,0:18:47.16,0:18:50.50,Default,,0000,0000,0000,,彼の心臓は 動いていない ハッ
Dialogue: 0,0:18:50.50,0:18:54.10,Default,,0000,0000,0000,,すまない
Dialogue: 0,0:18:50.50,0:18:54.10,Default,,0000,0000,0000,,少し 戻るのに手間取る
Dialogue: 0,0:18:56.50,0:18:59.00,Default,,0000,0000,0000,,よくやってくれたぜ ラインハルト
Dialogue: 0,0:18:59.00,0:19:02.61,Default,,0000,0000,0000,,スバル 次は 私たちの番!
Dialogue: 0,0:18:59.00,0:19:02.61,Default,,0000,0000,0000,,どう戦うの?
Dialogue: 0,0:19:02.61,0:19:07.01,Default,,0000,0000,0000,,エミリアたん 耳 貸して
Dialogue: 0,0:19:02.61,0:19:07.01,Default,,0000,0000,0000,,ちゃんと返してね
Dialogue: 0,0:19:10.12,0:19:12.78,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:10.12,0:19:12.78,Default,,0000,0000,0000,,うん
Dialogue: 0,0:19:12.78,0:19:15.79,Default,,0000,0000,0000,,ハッ うん
Dialogue: 0,0:19:15.79,0:19:18.96,Default,,0000,0000,0000,,今度こそ 命乞いの相談かな?
Dialogue: 0,0:19:15.79,0:19:18.96,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:18.96,0:19:20.96,Default,,0000,0000,0000,,あのさ 今更 僕が
Dialogue: 0,0:19:20.96,0:19:23.30,Default,,0000,0000,0000,,あのさ
Dialogue: 0,0:19:20.96,0:19:23.30,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:19:23.30,0:19:28.80,Default,,0000,0000,0000,,気付いてるか? お前
Dialogue: 0,0:19:23.30,0:19:28.80,Default,,0000,0000,0000,,今 確実に詰められてるんだぜ?
Dialogue: 0,0:19:28.80,0:19:31.64,Default,,0000,0000,0000,,はっ?
Dialogue: 0,0:19:28.80,0:19:31.64,Default,,0000,0000,0000,,聞かせてやるよ
Dialogue: 0,0:19:31.64,0:19:36.64,Default,,0000,0000,0000,,お前には聞く権利がある
Dialogue: 0,0:19:31.64,0:19:36.64,Default,,0000,0000,0000,,ほら 好きだろ? 権利
Dialogue: 0,0:19:36.64,0:19:40.15,Default,,0000,0000,0000,,僕に聞く権利?
Dialogue: 0,0:19:36.64,0:19:40.15,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:19:40.15,0:19:43.48,Default,,0000,0000,0000,,なんせ 自分が どうやって 負けるのか
Dialogue: 0,0:19:43.48,0:19:47.15,Default,,0000,0000,0000,,知らないで負けたら 悔しくって 死んじまうだろ?
Dialogue: 0,0:19:47.15,0:19:50.32,Default,,0000,0000,0000,,くっ お前
Dialogue: 0,0:19:50.32,0:19:53.83,Default,,0000,0000,0000,,勝つよ
Dialogue: 0,0:19:50.32,0:19:53.83,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:19:50.32,0:19:53.83,Default,,0000,0000,0000,,あいつに ほえ面かかせてね
Dialogue: 0,0:19:53.83,0:19:57.33,Default,,0000,0000,0000,,そのあと もっかい お姫様だっこさせて
Dialogue: 0,0:19:57.33,0:20:00.50,Default,,0000,0000,0000,,んっ! フッ ばか
Dialogue: 0,0:20:00.50,0:20:03.67,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:20:03.67,0:20:05.87,Default,,0000,0000,0000,,ウルヒューマン!
Dialogue: 0,0:20:12.68,0:20:17.18,Default,,0000,0000,0000,,負かすとか 大口 たたいておいて また これ?
Dialogue: 0,0:20:17.18,0:20:22.85,Default,,0000,0000,0000,,永遠に攻撃してれば
Dialogue: 0,0:20:17.18,0:20:22.85,Default,,0000,0000,0000,,僕が根負けするとでも!?
Dialogue: 0,0:20:22.85,0:20:25.69,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:20:22.85,0:20:25.69,Default,,0000,0000,0000,,レグルス!
Dialogue: 0,0:20:22.85,0:20:25.69,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:20:25.69,0:20:29.53,Default,,0000,0000,0000,,俺は お前の権能の正体を知ってるぞ!
Dialogue: 0,0:20:29.53,0:20:33.37,Default,,0000,0000,0000,,おもしろいこと言うじゃないか
Dialogue: 0,0:20:33.37,0:20:38.04,Default,,0000,0000,0000,,君なんかが 僕を理解したとか言いだすわけ?
Dialogue: 0,0:20:38.04,0:20:43.88,Default,,0000,0000,0000,,んっ? 待て
Dialogue: 0,0:20:38.04,0:20:43.88,Default,,0000,0000,0000,,君 79番は どこへやった?
Dialogue: 0,0:20:43.88,0:20:46.88,Default,,0000,0000,0000,,答えなよ 79番だ!
Dialogue: 0,0:20:46.88,0:20:49.21,Default,,0000,0000,0000,,さっきまで 君が持っていこうとして
Dialogue: 0,0:20:49.21,0:20:53.55,Default,,0000,0000,0000,,うわっ! 本気で 奥さん 番号で呼んでる事実に どん引きだわ!
Dialogue: 0,0:20:53.55,0:20:59.06,Default,,0000,0000,0000,,つうか 答えると思う?
Dialogue: 0,0:20:53.55,0:20:59.06,Default,,0000,0000,0000,,なんで? 頭 お気楽とんぼなの?
Dialogue: 0,0:20:59.06,0:21:02.66,Default,,0000,0000,0000,,それとも 必死で 話題 そらしてんの?
Dialogue: 0,0:21:02.66,0:21:06.50,Default,,0000,0000,0000,,んっ いいさ 言ってみなよ
Dialogue: 0,0:21:06.50,0:21:11.84,Default,,0000,0000,0000,,いや 君みたいな人間の言葉
Dialogue: 0,0:21:06.50,0:21:11.84,Default,,0000,0000,0000,,信じる価値はないけどさ
Dialogue: 0,0:21:11.84,0:21:14.51,Default,,0000,0000,0000,,僕は 慈悲深いんだ
Dialogue: 0,0:21:14.51,0:21:16.84,Default,,0000,0000,0000,,慈悲深いね
Dialogue: 0,0:21:16.84,0:21:22.01,Default,,0000,0000,0000,,どうした? 話さないの?
Dialogue: 0,0:21:16.84,0:21:22.01,Default,,0000,0000,0000,,それとも話せないのかな?
Dialogue: 0,0:21:22.01,0:21:24.35,Default,,0000,0000,0000,,その場しのぎの うそっぱちだっていうのなら
Dialogue: 0,0:21:24.35,0:21:27.69,Default,,0000,0000,0000,,いいや 答えてやるよ レグルス
Dialogue: 0,0:21:27.69,0:21:32.86,Default,,0000,0000,0000,,お前の権能の正体 それは
Dialogue: 0,0:21:32.86,0:21:36.53,Default,,0000,0000,0000,,ゲームプレイ中のスタートボタンってやつだ!
Dialogue: 0,0:21:36.53,0:21:39.20,Default,,0000,0000,0000,,はっ?
Dialogue: 0,0:21:39.20,0:21:43.04,Default,,0000,0000,0000,,肉体の時間を止める 獅子の心臓
Dialogue: 0,0:21:43.04,0:21:46.37,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:21:43.04,0:21:46.37,Default,,0000,0000,0000,,そう言いかえてもいいぜ
Dialogue: 0,0:21:46.37,0:21:48.54,Default,,0000,0000,0000,,答え合わせは
Dialogue: 0,0:21:48.54,0:21:52.04,Default,,0000,0000,0000,,ああ その顔を見りゃ
Dialogue: 0,0:21:52.04,0:21:54.05,Default,,0000,0000,0000,,十分だな
Dialogue: 0,0:23:25.84,0:23:29.34,Default,,0000,0000,0000,,「アイリスと茨の王」?
Dialogue: 0,0:23:29.34,0:23:34.85,Default,,0000,0000,0000,,それとも 「ティレオスの薔薇騎士」?
Dialogue: 0,0:23:29.34,0:23:34.85,Default,,0000,0000,0000,,「マグリッツァの断頭台」?
Dialogue: 0,0:23:34.85,0:23:39.52,Default,,0000,0000,0000,,んっ 死ぬがよい
Dialogue: 0,0:23:39.52,0:23:42.35,Default,,0000,0000,0000,,プリシラ様!
Dialogue: 0,0:23:42.35,0:23:44.56,Default,,0000,0000,0000,,ウフッ
Dialogue: 0,0:23:42.35,0:23:44.56,Default,,0000,0000,0000,,フッ!
