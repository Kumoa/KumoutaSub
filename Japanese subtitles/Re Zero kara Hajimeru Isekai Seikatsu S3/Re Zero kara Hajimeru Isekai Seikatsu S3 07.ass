Dialogue: 0,0:00:15.35,0:00:17.35,Default,,0000,0000,0000,,おっと 反応あったな
Dialogue: 0,0:00:17.35,0:00:19.85,Default,,0000,0000,0000,,って 誰も映ってねえじゃねえか
Dialogue: 0,0:00:19.85,0:00:22.52,Default,,0000,0000,0000,,聞いてた話と違ってんな
Dialogue: 0,0:00:19.85,0:00:22.52,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:22.52,0:00:24.52,Default,,0000,0000,0000,,アル? アルよね?
Dialogue: 0,0:00:24.52,0:00:28.19,Default,,0000,0000,0000,,おいおい マジかよ
Dialogue: 0,0:00:24.52,0:00:28.19,Default,,0000,0000,0000,,このパターンは想定してねえぞ
Dialogue: 0,0:00:28.19,0:00:32.70,Default,,0000,0000,0000,,ああ 奇遇だな 嬢ちゃん
Dialogue: 0,0:00:28.19,0:00:32.70,Default,,0000,0000,0000,,ええ すごく偶然
Dialogue: 0,0:00:32.70,0:00:36.87,Default,,0000,0000,0000,,ハッ! そうだ! アル スバルに伝えてほしいことがあるの
Dialogue: 0,0:00:36.87,0:00:40.04,Default,,0000,0000,0000,,おっ おう 嬢ちゃんが無事って 兄弟に伝えて
Dialogue: 0,0:00:40.04,0:00:44.38,Default,,0000,0000,0000,,三番街の制御塔には レグルスって大罪司教がいるわ
Dialogue: 0,0:00:44.38,0:00:48.55,Default,,0000,0000,0000,,それから 一番街の制御塔には 色欲の大罪司教がいるみたい
Dialogue: 0,0:00:48.55,0:00:50.55,Default,,0000,0000,0000,,あっ あっ
Dialogue: 0,0:00:50.55,0:00:53.22,Default,,0000,0000,0000,,他の塔も 調べられたらよかったんだけど
Dialogue: 0,0:00:53.22,0:00:56.06,Default,,0000,0000,0000,,シリウスが どこにいるかは わからないの
Dialogue: 0,0:00:56.06,0:00:58.56,Default,,0000,0000,0000,,でも 放送のこともあるから
Dialogue: 0,0:00:58.56,0:01:01.83,Default,,0000,0000,0000,,ベアトリスのことは ちゃんと守ってあげてねって
Dialogue: 0,0:01:01.83,0:01:05.00,Default,,0000,0000,0000,,えっと それから
Dialogue: 0,0:01:01.83,0:01:05.00,Default,,0000,0000,0000,,待てよ
Dialogue: 0,0:01:01.83,0:01:05.00,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:01:05.00,0:01:08.33,Default,,0000,0000,0000,,嬢ちゃんが タフで ハイパーポジティブなのは わかったよ
Dialogue: 0,0:01:08.33,0:01:10.84,Default,,0000,0000,0000,,けど もっと 他にあんだろ
Dialogue: 0,0:01:10.84,0:01:14.84,Default,,0000,0000,0000,,あっ 一生懸命 考えたけど だめだった?
Dialogue: 0,0:01:14.84,0:01:18.18,Default,,0000,0000,0000,,違えよ!
Dialogue: 0,0:01:14.84,0:01:18.18,Default,,0000,0000,0000,,捕らわれのお姫様なんだぜ?
Dialogue: 0,0:01:18.18,0:01:20.51,Default,,0000,0000,0000,,そんなに強くなくていいだろ!
Dialogue: 0,0:01:20.51,0:01:23.52,Default,,0000,0000,0000,,兄弟に
Dialogue: 0,0:01:20.51,0:01:23.52,Default,,0000,0000,0000,,ナツキ・スバルに助けを求めたって
Dialogue: 0,0:01:23.52,0:01:25.85,Default,,0000,0000,0000,,ごめんね アル 心配かけて
Dialogue: 0,0:01:25.85,0:01:28.02,Default,,0000,0000,0000,,ううん ありがとう
Dialogue: 0,0:01:28.02,0:01:31.36,Default,,0000,0000,0000,,でも 大丈夫だから
Dialogue: 0,0:01:28.02,0:01:31.36,Default,,0000,0000,0000,,大丈夫って
Dialogue: 0,0:01:31.36,0:01:34.36,Default,,0000,0000,0000,,私 強がってるわけじゃないの
Dialogue: 0,0:01:34.36,0:01:38.03,Default,,0000,0000,0000,,それに こんなこと 言ったら 変かもしれないけど
Dialogue: 0,0:01:38.03,0:01:41.37,Default,,0000,0000,0000,,スバルが 私を助けてくれることは 疑ってないの
Dialogue: 0,0:01:41.37,0:01:45.71,Default,,0000,0000,0000,,だから 助けに来てくれたスバルが 危なくないように
Dialogue: 0,0:01:45.71,0:01:49.71,Default,,0000,0000,0000,,私がしておけること 全部 しておきたいのよ
Dialogue: 0,0:01:45.71,0:01:49.71,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:01:49.71,0:01:51.71,Default,,0000,0000,0000,,アル お願い
Dialogue: 0,0:01:51.71,0:01:54.55,Default,,0000,0000,0000,,プリシラには あとで 勝手な お願いしたこと
Dialogue: 0,0:01:54.55,0:01:57.22,Default,,0000,0000,0000,,私から謝るから
Dialogue: 0,0:01:57.22,0:02:00.15,Default,,0000,0000,0000,,ハァ わかった
Dialogue: 0,0:02:00.15,0:02:03.66,Default,,0000,0000,0000,,さっきの話 兄弟たちに ちゃんと伝えてやる
Dialogue: 0,0:02:03.66,0:02:07.33,Default,,0000,0000,0000,,あとは 白馬の王子様が なんとかするだろうよ
Dialogue: 0,0:02:07.33,0:02:11.33,Default,,0000,0000,0000,,王子様じゃなくて スバルが なんとかしてくれると 思うんだけど
Dialogue: 0,0:02:11.33,0:02:14.17,Default,,0000,0000,0000,,ああ そうだな!
Dialogue: 0,0:02:11.33,0:02:14.17,Default,,0000,0000,0000,,俺が悪かったよ!
Dialogue: 0,0:02:14.17,0:02:18.51,Default,,0000,0000,0000,,ほんとに おとなしくしてろよ?
Dialogue: 0,0:02:14.17,0:02:18.51,Default,,0000,0000,0000,,冗句じゃねえぞ
Dialogue: 0,0:02:18.51,0:02:22.01,Default,,0000,0000,0000,,うん わかった
Dialogue: 0,0:02:18.51,0:02:22.01,Default,,0000,0000,0000,,アルも 気を付けて お願いね
Dialogue: 0,0:02:22.01,0:02:24.51,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:02:24.51,0:02:26.85,Default,,0000,0000,0000,,よかった
Dialogue: 0,0:02:26.85,0:02:31.02,Default,,0000,0000,0000,,これで スバルたちに ちゃんと伝わってくれるわね
Dialogue: 0,0:02:31.02,0:02:36.52,Default,,0000,0000,0000,,あれ? なんで 私
Dialogue: 0,0:02:31.02,0:02:36.52,Default,,0000,0000,0000,,こんなに自信満々なんだろ?
Dialogue: 0,0:04:08.82,0:04:12.32,Default,,0000,0000,0000,,アナスタシアさん この使い方って わかるか?
Dialogue: 0,0:04:12.32,0:04:15.49,Default,,0000,0000,0000,,うん 難しないよ
Dialogue: 0,0:04:12.32,0:04:15.49,Default,,0000,0000,0000,,よし
Dialogue: 0,0:04:15.49,0:04:17.59,Default,,0000,0000,0000,,精が出るな 兄弟
Dialogue: 0,0:04:15.49,0:04:17.59,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:04:20.16,0:04:23.50,Default,,0000,0000,0000,,アル
Dialogue: 0,0:04:20.16,0:04:23.50,Default,,0000,0000,0000,,ずいぶんと 早い お戻りやったんやね
Dialogue: 0,0:04:23.50,0:04:26.83,Default,,0000,0000,0000,,俺だって 好きで戻ったわけじゃねえよ
Dialogue: 0,0:04:26.83,0:04:31.00,Default,,0000,0000,0000,,兄弟に伝言があってな
Dialogue: 0,0:04:26.83,0:04:31.00,Default,,0000,0000,0000,,伝言? 誰から?
Dialogue: 0,0:04:31.00,0:04:35.84,Default,,0000,0000,0000,,結婚前の花嫁は さらってくれる 白馬の王子様を待ってるとよ
Dialogue: 0,0:04:35.84,0:04:40.18,Default,,0000,0000,0000,,やけるね 兄弟
Dialogue: 0,0:04:35.84,0:04:40.18,Default,,0000,0000,0000,,あっ エッ エミリアの!?
Dialogue: 0,0:04:40.18,0:04:43.68,Default,,0000,0000,0000,,てのが 嬢ちゃんから聞いた話だ
Dialogue: 0,0:04:43.68,0:04:46.19,Default,,0000,0000,0000,,あと ベアトリスは大事にしろってよ
Dialogue: 0,0:04:46.19,0:04:49.86,Default,,0000,0000,0000,,最後の部分 含めて だいぶ重要な話だな
Dialogue: 0,0:04:49.86,0:04:52.03,Default,,0000,0000,0000,,すげえ助かるじゃねえか
Dialogue: 0,0:04:52.03,0:04:54.03,Default,,0000,0000,0000,,大将!
Dialogue: 0,0:04:52.03,0:04:54.03,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:04:56.03,0:04:58.03,Default,,0000,0000,0000,,うっ んっ
Dialogue: 0,0:04:58.03,0:05:00.30,Default,,0000,0000,0000,,ガーフィール
Dialogue: 0,0:04:58.03,0:05:00.30,Default,,0000,0000,0000,,大将!
Dialogue: 0,0:04:58.03,0:05:00.30,Default,,0000,0000,0000,,とっとっ
Dialogue: 0,0:05:00.30,0:05:02.97,Default,,0000,0000,0000,,無事だったか!
Dialogue: 0,0:05:00.30,0:05:02.97,Default,,0000,0000,0000,,お前 すげえ いきなりで
Dialogue: 0,0:05:02.97,0:05:05.14,Default,,0000,0000,0000,,そりゃあ 俺のせりふっだろうが!
Dialogue: 0,0:05:05.14,0:05:08.98,Default,,0000,0000,0000,,大将こそ やべえって 俺は 俺は
Dialogue: 0,0:05:08.98,0:05:11.98,Default,,0000,0000,0000,,おいおい まさか 泣いてんのか? お前
Dialogue: 0,0:05:11.98,0:05:13.98,Default,,0000,0000,0000,,泣いちゃあいねえよ!
Dialogue: 0,0:05:13.98,0:05:19.82,Default,,0000,0000,0000,,ただ 大将も オットー兄ィも
Dialogue: 0,0:05:13.98,0:05:19.82,Default,,0000,0000,0000,,エミリア様も ベアトリスも みんなよ
Dialogue: 0,0:05:19.82,0:05:24.49,Default,,0000,0000,0000,,心配かけて悪かった
Dialogue: 0,0:05:19.82,0:05:24.49,Default,,0000,0000,0000,,このとおり 俺は無事だ
Dialogue: 0,0:05:24.49,0:05:26.99,Default,,0000,0000,0000,,一部 黒くなったりしたが
Dialogue: 0,0:05:26.99,0:05:31.00,Default,,0000,0000,0000,,あっ? 黒く?
Dialogue: 0,0:05:26.99,0:05:31.00,Default,,0000,0000,0000,,ひとまず 聞き流しとけ
Dialogue: 0,0:05:31.00,0:05:34.83,Default,,0000,0000,0000,,それで ナツキ君は エミリアさんの伝言を信じるん?
Dialogue: 0,0:05:34.83,0:05:37.00,Default,,0000,0000,0000,,信じる
Dialogue: 0,0:05:37.00,0:05:41.01,Default,,0000,0000,0000,,最後のベアトリスの心配が めっちゃ本人っぽかった
Dialogue: 0,0:05:41.01,0:05:43.34,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:05:41.01,0:05:43.34,Default,,0000,0000,0000,,フン
Dialogue: 0,0:05:43.34,0:05:45.35,Default,,0000,0000,0000,,こんな状況で
Dialogue: 0,0:05:45.35,0:05:49.52,Default,,0000,0000,0000,,それでも 自分の精いっぱいを やってくれてる
Dialogue: 0,0:05:49.52,0:05:52.35,Default,,0000,0000,0000,,俺は エミリアの そんなとこを信じたい
Dialogue: 0,0:05:52.35,0:05:55.69,Default,,0000,0000,0000,,ああ まあ 頑張り過ぎて 無鉄砲になってないと
Dialogue: 0,0:05:55.69,0:05:59.53,Default,,0000,0000,0000,,ありがたいんだけど
Dialogue: 0,0:05:55.69,0:05:59.53,Default,,0000,0000,0000,,そいつは 俺も同感だ
Dialogue: 0,0:05:59.53,0:06:03.63,Default,,0000,0000,0000,,敵中で 元気すぎると思うぜ あの お嬢ちゃん
Dialogue: 0,0:06:08.63,0:06:12.64,Default,,0000,0000,0000,,驚きました
Dialogue: 0,0:06:08.63,0:06:12.64,Default,,0000,0000,0000,,ひゃっ! あっ んっ フッ
Dialogue: 0,0:06:12.64,0:06:14.64,Default,,0000,0000,0000,,まさか 戻ってくるなんて
Dialogue: 0,0:06:14.64,0:06:17.64,Default,,0000,0000,0000,,ご丁寧に 身代わりまで残していたのに
Dialogue: 0,0:06:17.64,0:06:20.98,Default,,0000,0000,0000,,えっ 身代わり? ちょっと 何 言ってるのか わかんない
Dialogue: 0,0:06:20.98,0:06:23.82,Default,,0000,0000,0000,,私 ずっと 疲れて ここで休んで
Dialogue: 0,0:06:23.82,0:06:26.65,Default,,0000,0000,0000,,冷たい! あっ 冷たくない!
Dialogue: 0,0:06:26.65,0:06:28.99,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:06:28.99,0:06:32.83,Default,,0000,0000,0000,,どうして そのまま 逃げてしまわなかったのですか?
Dialogue: 0,0:06:32.83,0:06:34.99,Default,,0000,0000,0000,,だから 私 逃げてなんて
Dialogue: 0,0:06:34.99,0:06:37.00,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:34.99,0:06:37.00,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:06:39.00,0:06:42.67,Default,,0000,0000,0000,,もしかして あなたは 私に逃げてほしかったの?
Dialogue: 0,0:06:42.67,0:06:46.51,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:06:42.67,0:06:46.51,Default,,0000,0000,0000,,でも そんなことしたら
Dialogue: 0,0:06:46.51,0:06:50.18,Default,,0000,0000,0000,,あなたと奥さんたちも大変なのに どうして?
Dialogue: 0,0:06:50.18,0:06:53.18,Default,,0000,0000,0000,,結局 なんの意味もなかった
Dialogue: 0,0:06:53.18,0:06:57.52,Default,,0000,0000,0000,,人生の最後に 少しだけ勇気を出したつもりが
Dialogue: 0,0:06:57.52,0:07:01.45,Default,,0000,0000,0000,,なんの意味も
Dialogue: 0,0:06:57.52,0:07:01.45,Default,,0000,0000,0000,,あなた
Dialogue: 0,0:07:01.45,0:07:05.29,Default,,0000,0000,0000,,それで ここは なんの集まりで
Dialogue: 0,0:07:05.29,0:07:07.96,Default,,0000,0000,0000,,その でっけえミーティアは なんに使うんだ?
Dialogue: 0,0:07:07.96,0:07:12.30,Default,,0000,0000,0000,,集まりは 魔女教から 都市を取り戻し隊本部
Dialogue: 0,0:07:12.30,0:07:16.14,Default,,0000,0000,0000,,ミーティアは 街じゅうに 声を届ける放送アイテムで
Dialogue: 0,0:07:16.14,0:07:18.64,Default,,0000,0000,0000,,この状況を変える切り札だ
Dialogue: 0,0:07:18.64,0:07:21.14,Default,,0000,0000,0000,,なんか思いついたのかよ? 大将
Dialogue: 0,0:07:21.14,0:07:23.48,Default,,0000,0000,0000,,ちょっとした方法をな
Dialogue: 0,0:07:23.48,0:07:27.98,Default,,0000,0000,0000,,知ってのとおり 今 街は 憤怒の権能の影響で
Dialogue: 0,0:07:27.98,0:07:30.15,Default,,0000,0000,0000,,爆発寸前の火薬庫状態だろ?
Dialogue: 0,0:07:30.15,0:07:34.15,Default,,0000,0000,0000,,んっ 間違いねえよ
Dialogue: 0,0:07:34.15,0:07:38.49,Default,,0000,0000,0000,,大将 捜して 俺も あちっこち見回ったが
Dialogue: 0,0:07:38.49,0:07:41.99,Default,,0000,0000,0000,,魔女教の放送と 今の都市の状況
Dialogue: 0,0:07:41.99,0:07:44.33,Default,,0000,0000,0000,,不安しかないやろね
Dialogue: 0,0:07:44.33,0:07:49.00,Default,,0000,0000,0000,,それが 人と一緒におると膨れ上がる
Dialogue: 0,0:07:49.00,0:07:51.67,Default,,0000,0000,0000,,だからこそ 憤怒の力は悪質だ
Dialogue: 0,0:07:51.67,0:07:56.68,Default,,0000,0000,0000,,孤独を深め 心をすり減らし
Dialogue: 0,0:07:51.67,0:07:56.68,Default,,0000,0000,0000,,命さえも脅かす
Dialogue: 0,0:07:56.68,0:07:58.85,Default,,0000,0000,0000,,到底 許せるものではない
Dialogue: 0,0:07:58.85,0:08:02.95,Default,,0000,0000,0000,,ナツキ君が何をしたいんか うちも 大体 わかったわ
Dialogue: 0,0:08:02.95,0:08:06.79,Default,,0000,0000,0000,,まあ ミーティアの無事まで確かめたら わかるわな
Dialogue: 0,0:08:06.79,0:08:11.12,Default,,0000,0000,0000,,大将 一体 何しでかすっつもりなんだよ?
Dialogue: 0,0:08:11.12,0:08:14.46,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:11.12,0:08:14.46,Default,,0000,0000,0000,,シリウスの憤怒の権能が
Dialogue: 0,0:08:14.46,0:08:17.63,Default,,0000,0000,0000,,街の人たちの不安な気持ちを 増幅させてる
Dialogue: 0,0:08:17.63,0:08:21.30,Default,,0000,0000,0000,,そのきっかけは 色欲の性格悪い放送だ
Dialogue: 0,0:08:21.30,0:08:25.47,Default,,0000,0000,0000,,だったら
Dialogue: 0,0:08:21.30,0:08:25.47,Default,,0000,0000,0000,,魔女教が不安をあおったように
Dialogue: 0,0:08:25.47,0:08:28.47,Default,,0000,0000,0000,,我々で 人々の希望を よみがえらせればいい
Dialogue: 0,0:08:28.47,0:08:32.31,Default,,0000,0000,0000,,うん そうすれば その希望が広がって
Dialogue: 0,0:08:32.31,0:08:34.98,Default,,0000,0000,0000,,同じように 街じゅうを 覆い尽くすはずなんだ
Dialogue: 0,0:08:34.98,0:08:38.15,Default,,0000,0000,0000,,あっ そっ そうか!
Dialogue: 0,0:08:38.15,0:08:42.82,Default,,0000,0000,0000,,それなら うつむいた連中も へっこんだままでいなくて よくなる!
Dialogue: 0,0:08:42.82,0:08:45.99,Default,,0000,0000,0000,,やろうぜ! 時間が もったいねえ 今すぐにでも
Dialogue: 0,0:08:45.99,0:08:50.66,Default,,0000,0000,0000,,待った そんな簡単な お話やないの
Dialogue: 0,0:08:45.99,0:08:50.66,Default,,0000,0000,0000,,なんでっだよ!
Dialogue: 0,0:08:50.66,0:08:54.33,Default,,0000,0000,0000,,放送を聞いた魔女教が どう動くと思うん?
Dialogue: 0,0:08:54.33,0:08:57.17,Default,,0000,0000,0000,,今度は 水門を 閉じたりせんかもしれんよ
Dialogue: 0,0:08:57.17,0:09:00.11,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:08:57.17,0:09:00.11,Default,,0000,0000,0000,,俺も それが怖い
Dialogue: 0,0:09:00.11,0:09:02.61,Default,,0000,0000,0000,,ただ その話にも 1個 疑問がある
Dialogue: 0,0:09:02.61,0:09:05.28,Default,,0000,0000,0000,,開いた水門だ
Dialogue: 0,0:09:02.61,0:09:05.28,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:09:05.28,0:09:08.95,Default,,0000,0000,0000,,そうか あれは 一番街の水門だった
Dialogue: 0,0:09:08.95,0:09:11.78,Default,,0000,0000,0000,,エミリア様の話が正しければ
Dialogue: 0,0:09:11.78,0:09:16.12,Default,,0000,0000,0000,,あのとき 色欲は 制御塔に いなかったはずだろ?
Dialogue: 0,0:09:16.12,0:09:18.12,Default,,0000,0000,0000,,タイミングだって おかしい
Dialogue: 0,0:09:18.12,0:09:21.63,Default,,0000,0000,0000,,なんだって 俺たちが逃げる手助け みたいに 水が流れて
Dialogue: 0,0:09:21.63,0:09:24.30,Default,,0000,0000,0000,,門は すぐに閉じたんだ?
Dialogue: 0,0:09:24.30,0:09:28.30,Default,,0000,0000,0000,,魔女教のやつらが やることは 確かに 支離滅裂だが
Dialogue: 0,0:09:28.30,0:09:31.47,Default,,0000,0000,0000,,ルールは あるはずだ
Dialogue: 0,0:09:31.47,0:09:35.81,Default,,0000,0000,0000,,それに やつらは ミーティアを壊さずに 放置していった
Dialogue: 0,0:09:35.81,0:09:39.15,Default,,0000,0000,0000,,壊す時間は 十分にあったのにだ
Dialogue: 0,0:09:39.15,0:09:43.48,Default,,0000,0000,0000,,つまり うちらが使うことは 織り込み済みやって言うん?
Dialogue: 0,0:09:43.48,0:09:47.15,Default,,0000,0000,0000,,そんなことして なんの得が
Dialogue: 0,0:09:43.48,0:09:47.15,Default,,0000,0000,0000,,理由なんかねえのさ
Dialogue: 0,0:09:47.15,0:09:49.99,Default,,0000,0000,0000,,チッ!
Dialogue: 0,0:09:49.99,0:09:53.83,Default,,0000,0000,0000,,連中は こっちのやることなんて なんとも思っちゃいねえよ
Dialogue: 0,0:09:53.83,0:09:58.66,Default,,0000,0000,0000,,負けたことがねえし 負けるなんてことは 考えたこともねえんだ
Dialogue: 0,0:09:58.66,0:10:03.00,Default,,0000,0000,0000,,竜が 足元の ありの作戦なんか 気にしねえだろ?
Dialogue: 0,0:10:03.00,0:10:05.84,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:10:03.00,0:10:05.84,Default,,0000,0000,0000,,ナツキ君
Dialogue: 0,0:10:03.00,0:10:05.84,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:10:05.84,0:10:08.84,Default,,0000,0000,0000,,放送案 乗ってもええよ
Dialogue: 0,0:10:08.84,0:10:11.18,Default,,0000,0000,0000,,アナスタシアさん
Dialogue: 0,0:10:11.18,0:10:16.18,Default,,0000,0000,0000,,あとは 誰が やるかや
Dialogue: 0,0:10:11.18,0:10:16.18,Default,,0000,0000,0000,,誰がって
Dialogue: 0,0:10:16.18,0:10:19.19,Default,,0000,0000,0000,,そりゃ ここは アナスタシアさんの出番だろ
Dialogue: 0,0:10:19.19,0:10:22.19,Default,,0000,0000,0000,,王選候補者で知名度もある
Dialogue: 0,0:10:22.19,0:10:25.02,Default,,0000,0000,0000,,アナスタシアさんの口から 戦おうって意思表明すれば
Dialogue: 0,0:10:25.02,0:10:28.86,Default,,0000,0000,0000,,うちの言葉に期待するんは 難しいと思う
Dialogue: 0,0:10:25.02,0:10:28.86,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:10:28.86,0:10:31.86,Default,,0000,0000,0000,,知名度の話だけでいいんなら
Dialogue: 0,0:10:31.86,0:10:36.70,Default,,0000,0000,0000,,それで うまくいくんなら うちも喜んで なんでも話したる
Dialogue: 0,0:10:36.70,0:10:38.87,Default,,0000,0000,0000,,けど うちの名前に
Dialogue: 0,0:10:38.87,0:10:41.71,Default,,0000,0000,0000,,魔女教の不安を追っ払う力はない
Dialogue: 0,0:10:41.71,0:10:46.38,Default,,0000,0000,0000,,無名の誰かよりは期待できる ぐらいが せいぜいやね
Dialogue: 0,0:10:46.38,0:10:50.05,Default,,0000,0000,0000,,力不足を認めるみたいで しゃくなんやけど
Dialogue: 0,0:10:50.05,0:10:53.55,Default,,0000,0000,0000,,あっ んっ それでも
Dialogue: 0,0:10:50.05,0:10:53.55,Default,,0000,0000,0000,,ナツキ君も わかってるやろ?
Dialogue: 0,0:10:53.55,0:10:57.22,Default,,0000,0000,0000,,必要なんは 不安に支配された人たちの心が
Dialogue: 0,0:10:57.22,0:11:00.66,Default,,0000,0000,0000,,一気に沸き立つ そんな希望
Dialogue: 0,0:10:57.22,0:11:00.66,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:11:00.66,0:11:05.66,Default,,0000,0000,0000,,口先で だまくらかしたらええ って話なら やれんことはない
Dialogue: 0,0:11:05.66,0:11:09.34,Default,,0000,0000,0000,,けど ナツキ君が やりたいんは それと違うやろ?
Dialogue: 0,0:11:09.34,0:11:12.51,Default,,0000,0000,0000,,身を切るって判断を 嫌やって否定した
Dialogue: 0,0:11:12.51,0:11:16.01,Default,,0000,0000,0000,,ナツキ君の考えとは
Dialogue: 0,0:11:12.51,0:11:16.01,Default,,0000,0000,0000,,それは
Dialogue: 0,0:11:16.01,0:11:18.01,Default,,0000,0000,0000,,あっ なら クルシュさんなら どうだ?
Dialogue: 0,0:11:18.01,0:11:24.02,Default,,0000,0000,0000,,王選の場でも 白鯨のときでも
Dialogue: 0,0:11:18.01,0:11:24.02,Default,,0000,0000,0000,,クルシュさんの言葉には力があった!
Dialogue: 0,0:11:24.02,0:11:28.69,Default,,0000,0000,0000,,せやね でも 今のクルシュさんを引っ張り出して
Dialogue: 0,0:11:28.69,0:11:31.36,Default,,0000,0000,0000,,ミーティアの前に立たせるなんて 不可能や
Dialogue: 0,0:11:31.36,0:11:34.69,Default,,0000,0000,0000,,んっ あっ
Dialogue: 0,0:11:34.69,0:11:38.20,Default,,0000,0000,0000,,なら ユリウスは どうだ?
Dialogue: 0,0:11:34.69,0:11:38.20,Default,,0000,0000,0000,,お前なら その資格が
Dialogue: 0,0:11:38.20,0:11:42.70,Default,,0000,0000,0000,,すまない
Dialogue: 0,0:11:38.20,0:11:42.70,Default,,0000,0000,0000,,君の期待に 私では応えられない
Dialogue: 0,0:11:42.70,0:11:44.70,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:42.70,0:11:44.70,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:11:44.70,0:11:47.21,Default,,0000,0000,0000,,ユリウスは うちの自慢の騎士
Dialogue: 0,0:11:47.21,0:11:52.21,Default,,0000,0000,0000,,でも ユリウスの武勲が どこまで 魔女教相手に通じるん?
Dialogue: 0,0:11:52.21,0:11:57.05,Default,,0000,0000,0000,,知名度と口のうまさを含めたら うちのほうが勝算あるくらい
Dialogue: 0,0:11:57.05,0:12:01.15,Default,,0000,0000,0000,,それなら 残る可能性は ヴィルヘルムさんとリカードか
Dialogue: 0,0:12:01.15,0:12:03.82,Default,,0000,0000,0000,,いや プリシラとリリアナを連れてくれば ワンチャン
Dialogue: 0,0:12:03.82,0:12:05.83,Default,,0000,0000,0000,,あのよ
Dialogue: 0,0:12:03.82,0:12:05.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:05.83,0:12:08.49,Default,,0000,0000,0000,,それって 大将が やるんじゃあ いけねえのか?
Dialogue: 0,0:12:08.49,0:12:11.83,Default,,0000,0000,0000,,はっ? うっ んっ
Dialogue: 0,0:12:11.83,0:12:15.00,Default,,0000,0000,0000,,大将しかいねえ 大将なんだよ
Dialogue: 0,0:12:11.83,0:12:15.00,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:15.00,0:12:17.00,Default,,0000,0000,0000,,だって そうだろ?
Dialogue: 0,0:12:17.00,0:12:20.34,Default,,0000,0000,0000,,魔女教の大罪司教を 倒したなんて肩書
Dialogue: 0,0:12:20.34,0:12:23.18,Default,,0000,0000,0000,,他の誰も持っちゃいねえんだ!
Dialogue: 0,0:12:23.18,0:12:25.85,Default,,0000,0000,0000,,それが 今 この街で いちばん
Dialogue: 0,0:12:25.85,0:12:30.35,Default,,0000,0000,0000,,いちばん でけえ意味がある!
Dialogue: 0,0:12:25.85,0:12:30.35,Default,,0000,0000,0000,,ガーフィール
Dialogue: 0,0:12:30.35,0:12:32.69,Default,,0000,0000,0000,,魔女教に占拠された街に
Dialogue: 0,0:12:32.69,0:12:35.52,Default,,0000,0000,0000,,これ以上 ふさわしい誰かが いるもんかよ!
Dialogue: 0,0:12:35.52,0:12:40.86,Default,,0000,0000,0000,,いるなら そいつは 剣聖ラインハルトか
Dialogue: 0,0:12:35.52,0:12:40.86,Default,,0000,0000,0000,,ナツキ・スバル以外に誰もいねえ!
Dialogue: 0,0:12:40.86,0:12:45.53,Default,,0000,0000,0000,,大将! あんただけなんだよ!
Dialogue: 0,0:12:40.86,0:12:45.53,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:12:45.53,0:12:48.03,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:12:45.53,0:12:48.03,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:12:48.03,0:12:50.04,Default,,0000,0000,0000,,うちも同意見や
Dialogue: 0,0:12:50.04,0:12:53.37,Default,,0000,0000,0000,,誰かに やらせるんなら ナツキ君しかおらんて
Dialogue: 0,0:12:53.37,0:12:56.04,Default,,0000,0000,0000,,アナスタシアさんまで
Dialogue: 0,0:12:56.04,0:12:58.71,Default,,0000,0000,0000,,お前まで 本気か?
Dialogue: 0,0:12:56.04,0:12:58.71,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:12:58.71,0:13:01.48,Default,,0000,0000,0000,,覚えているかな? スバル
Dialogue: 0,0:13:01.48,0:13:03.48,Default,,0000,0000,0000,,君が 王選の場で
Dialogue: 0,0:13:03.48,0:13:06.99,Default,,0000,0000,0000,,大勢の騎士たちの前で たんかを切ったことを
Dialogue: 0,0:13:06.99,0:13:11.49,Default,,0000,0000,0000,,その後 私が 君を 練兵場で打ち倒したことを
Dialogue: 0,0:13:11.49,0:13:16.00,Default,,0000,0000,0000,,生涯 3本指に入る 大反省と屈辱の瞬間だぜ?
Dialogue: 0,0:13:16.00,0:13:19.00,Default,,0000,0000,0000,,忘れようたって 忘れられるもんかよ
Dialogue: 0,0:13:19.00,0:13:21.83,Default,,0000,0000,0000,,私も よく覚えているとも
Dialogue: 0,0:13:21.83,0:13:26.51,Default,,0000,0000,0000,,君の根拠のない宣言も 騎士を呪った醜態も
Dialogue: 0,0:13:26.51,0:13:29.34,Default,,0000,0000,0000,,その後に 白鯨との戦いに加わり
Dialogue: 0,0:13:29.34,0:13:32.85,Default,,0000,0000,0000,,ついには 怠惰の討伐をも 成し遂げたことも
Dialogue: 0,0:13:32.85,0:13:36.85,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:13:32.85,0:13:36.85,Default,,0000,0000,0000,,この都市にいる誰かの声が
Dialogue: 0,0:13:36.85,0:13:40.19,Default,,0000,0000,0000,,不安に震える人々の 一助となるなら
Dialogue: 0,0:13:40.19,0:13:43.36,Default,,0000,0000,0000,,それは 君こそが ふさわしいと 私は考える
Dialogue: 0,0:13:43.36,0:13:47.03,Default,,0000,0000,0000,,君の求めに応じる者は ガーフィールをはじめとして
Dialogue: 0,0:13:47.03,0:13:51.20,Default,,0000,0000,0000,,大勢いるだろうが その中に私もいる
Dialogue: 0,0:13:51.20,0:13:53.87,Default,,0000,0000,0000,,あっ んっ
Dialogue: 0,0:13:51.20,0:13:53.87,Default,,0000,0000,0000,,フフッ
Dialogue: 0,0:13:53.87,0:13:55.87,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:53.87,0:13:55.87,Default,,0000,0000,0000,,うん
Dialogue: 0,0:13:55.87,0:13:59.97,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:13:55.87,0:13:59.97,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:13:59.97,0:14:02.31,Default,,0000,0000,0000,,とんだ過大評価だろ
Dialogue: 0,0:14:02.31,0:14:05.48,Default,,0000,0000,0000,,迷うなら やめちまえよ 兄弟
Dialogue: 0,0:14:02.31,0:14:05.48,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:14:05.48,0:14:08.98,Default,,0000,0000,0000,,ここにいるやつが そんな大層な男かよ
Dialogue: 0,0:14:08.98,0:14:12.99,Default,,0000,0000,0000,,んっ! うるっせえよ!
Dialogue: 0,0:14:08.98,0:14:12.99,Default,,0000,0000,0000,,てめえが大将を語んな!
Dialogue: 0,0:14:12.99,0:14:17.66,Default,,0000,0000,0000,,何もかも背負って それで どうにかなるんなら 大したもんだ
Dialogue: 0,0:14:17.66,0:14:22.33,Default,,0000,0000,0000,,けど 大多数の凡人は そんな役目なんて 背負えねえんだよ
Dialogue: 0,0:14:22.33,0:14:26.17,Default,,0000,0000,0000,,俺は もちろん 兄弟だって そうさ
Dialogue: 0,0:14:26.17,0:14:29.50,Default,,0000,0000,0000,,なのに なんで そんなに 背負わされなきゃならねえ
Dialogue: 0,0:14:29.50,0:14:32.50,Default,,0000,0000,0000,,かわいそうだろうが
Dialogue: 0,0:14:32.50,0:14:34.51,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:14:34.51,0:14:38.84,Default,,0000,0000,0000,,なあ 兄弟 兄弟にとって いちばん大事なのは
Dialogue: 0,0:14:38.84,0:14:40.85,Default,,0000,0000,0000,,あの嬢ちゃんじゃねえのかよ?
Dialogue: 0,0:14:38.84,0:14:40.85,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:14:40.85,0:14:43.85,Default,,0000,0000,0000,,俺は 姫さんのために行動する
Dialogue: 0,0:14:43.85,0:14:48.19,Default,,0000,0000,0000,,だから 他のやつらのことは 全部 後回しにするつもりだ
Dialogue: 0,0:14:48.19,0:14:51.52,Default,,0000,0000,0000,,アル
Dialogue: 0,0:14:48.19,0:14:51.52,Default,,0000,0000,0000,,兄弟も そうしろよ
Dialogue: 0,0:14:51.52,0:14:55.53,Default,,0000,0000,0000,,嬢ちゃん
Dialogue: 0,0:14:51.52,0:14:55.53,Default,,0000,0000,0000,,エミリアだけ助けて 尽くせばいい
Dialogue: 0,0:14:55.53,0:14:59.87,Default,,0000,0000,0000,,魔女教のやつらなんざ 通り魔みてえなもんだよ
Dialogue: 0,0:14:59.87,0:15:02.64,Default,,0000,0000,0000,,関わるだけ損をするのさ
Dialogue: 0,0:15:15.81,0:15:18.98,Default,,0000,0000,0000,,赤信号の交差点に 子どもが飛び出したら
Dialogue: 0,0:15:18.98,0:15:22.66,Default,,0000,0000,0000,,理由を考える前に 手を引いて 歩道に連れ戻すよな
Dialogue: 0,0:15:22.66,0:15:25.82,Default,,0000,0000,0000,,たぶん そんな感じなんだよ
Dialogue: 0,0:15:25.82,0:15:29.83,Default,,0000,0000,0000,,あっ もし やるなら 兄弟
Dialogue: 0,0:15:29.83,0:15:33.83,Default,,0000,0000,0000,,兄弟が これから背負うのは 英雄幻想だ
Dialogue: 0,0:15:33.83,0:15:36.34,Default,,0000,0000,0000,,英雄幻想
Dialogue: 0,0:15:36.34,0:15:39.67,Default,,0000,0000,0000,,負けちゃいけねえ 勝たなきゃならねえ
Dialogue: 0,0:15:39.67,0:15:44.84,Default,,0000,0000,0000,,希望を担い 期待を背負い
Dialogue: 0,0:15:39.67,0:15:44.84,Default,,0000,0000,0000,,未来を示して戦うんだ
Dialogue: 0,0:15:44.84,0:15:48.01,Default,,0000,0000,0000,,ここで決断したら そうならなきゃいけねえ
Dialogue: 0,0:15:48.01,0:15:51.35,Default,,0000,0000,0000,,負けちゃいけねえのは いつだって そうだろ
Dialogue: 0,0:15:51.35,0:15:54.52,Default,,0000,0000,0000,,重みが違え 兄弟の負けは
Dialogue: 0,0:15:54.52,0:15:57.52,Default,,0000,0000,0000,,兄弟の負けだけじゃ済まなくなる
Dialogue: 0,0:15:54.52,0:15:57.52,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:16:19.31,0:16:24.82,Default,,0000,0000,0000,,ありがとう スバル
Dialogue: 0,0:16:19.31,0:16:24.82,Default,,0000,0000,0000,,私を助けてくれて
Dialogue: 0,0:16:31.66,0:16:36.36,Default,,0000,0000,0000,,スバル! スバル!
Dialogue: 0,0:16:31.66,0:16:36.36,Default,,0000,0000,0000,,スバル! スバル!
Dialogue: 0,0:16:38.33,0:16:43.34,Default,,0000,0000,0000,,なんだ
Dialogue: 0,0:16:38.33,0:16:43.34,Default,,0000,0000,0000,,じゃあ いつもと変わらねえな
Dialogue: 0,0:16:43.34,0:16:46.84,Default,,0000,0000,0000,,そんな顔すんなよ ガーフィール
Dialogue: 0,0:16:43.34,0:16:46.84,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:16:46.84,0:16:49.01,Default,,0000,0000,0000,,大将
Dialogue: 0,0:16:49.01,0:16:51.68,Default,,0000,0000,0000,,ああ 大将 大将だ!
Dialogue: 0,0:16:51.68,0:16:54.01,Default,,0000,0000,0000,,やっぱり 大将は大将だ!
Dialogue: 0,0:16:54.01,0:16:56.35,Default,,0000,0000,0000,,訳わかんねえよ
Dialogue: 0,0:16:56.35,0:16:58.52,Default,,0000,0000,0000,,アナスタシアさん やるよ
Dialogue: 0,0:16:58.52,0:17:02.79,Default,,0000,0000,0000,,俺の声で どうにかできるなら 俺がやる
Dialogue: 0,0:17:02.79,0:17:07.13,Default,,0000,0000,0000,,ええんやね? いっぺん 希望になるんを選んだら
Dialogue: 0,0:17:07.13,0:17:09.46,Default,,0000,0000,0000,,俺のやることは変わらない
Dialogue: 0,0:17:09.46,0:17:12.30,Default,,0000,0000,0000,,英雄 いいじゃねえか
Dialogue: 0,0:17:12.30,0:17:15.63,Default,,0000,0000,0000,,ああ いや 正直 てれくさいにも程があるけど
Dialogue: 0,0:17:15.63,0:17:20.47,Default,,0000,0000,0000,,ヒーロー やることだけなら もう 1年前から決めてたんだ
Dialogue: 0,0:17:20.47,0:17:23.31,Default,,0000,0000,0000,,そうしないと 見られてる子に恥ずかしいし
Dialogue: 0,0:17:23.31,0:17:25.98,Default,,0000,0000,0000,,見てる子の背中に 追いつけねえから
Dialogue: 0,0:17:25.98,0:17:28.48,Default,,0000,0000,0000,,さよか したら ええよ
Dialogue: 0,0:17:28.48,0:17:31.65,Default,,0000,0000,0000,,男の子は かっこつけやもんね
Dialogue: 0,0:17:31.65,0:17:34.65,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:17:34.65,0:17:37.16,Default,,0000,0000,0000,,とちっても笑うなよ
Dialogue: 0,0:17:37.16,0:17:39.83,Default,,0000,0000,0000,,ため息もつくな
Dialogue: 0,0:17:37.16,0:17:39.83,Default,,0000,0000,0000,,できれば聞くな!
Dialogue: 0,0:17:39.83,0:17:43.66,Default,,0000,0000,0000,,笑いなどしない
Dialogue: 0,0:17:39.83,0:17:43.66,Default,,0000,0000,0000,,ため息もつかない
Dialogue: 0,0:17:43.66,0:17:48.17,Default,,0000,0000,0000,,最後まで 姿勢を正して 傾聴しよう
Dialogue: 0,0:17:45.66,0:17:48.17,Default,,0000,0000,0000,,けっ!
Dialogue: 0,0:17:48.17,0:17:51.17,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:17:48.17,0:17:51.17,Default,,0000,0000,0000,,心配してくれて ありがとよ アル
Dialogue: 0,0:17:51.17,0:17:53.57,Default,,0000,0000,0000,,おかげで覚悟が決まった
Dialogue: 0,0:17:56.01,0:17:58.01,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:12.79,0:18:15.13,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:15.13,0:18:18.80,Default,,0000,0000,0000,,いっそ あなたが戻らないまま
Dialogue: 0,0:18:18.80,0:18:21.80,Default,,0000,0000,0000,,旦那様の怒りに のまれてしまえばよかった
Dialogue: 0,0:18:21.80,0:18:25.64,Default,,0000,0000,0000,,これでは 何も変わらない時間が 続くだけで
Dialogue: 0,0:18:25.64,0:18:29.48,Default,,0000,0000,0000,,だったら 一度 立てたんなら また 頑張りましょう
Dialogue: 0,0:18:29.48,0:18:32.08,Default,,0000,0000,0000,,私 まだ 1回も諦めてなんてない
Dialogue: 0,0:18:34.15,0:18:37.98,Default,,0000,0000,0000,,もう 無理です もう 無理です
Dialogue: 0,0:18:37.98,0:18:41.15,Default,,0000,0000,0000,,あっ んっ?
Dialogue: 0,0:18:41.15,0:18:45.82,Default,,0000,0000,0000,,あなたが諦めないと そう おっしゃるのは ご自由にしてください
Dialogue: 0,0:18:45.82,0:18:49.16,Default,,0000,0000,0000,,ですが もう 私の魔が差すことはありません
Dialogue: 0,0:18:49.16,0:18:52.33,Default,,0000,0000,0000,,他の妻たちも同じでしょう
Dialogue: 0,0:18:49.16,0:18:52.33,Default,,0000,0000,0000,,そんな
Dialogue: 0,0:18:52.33,0:18:57.34,Default,,0000,0000,0000,,私は 小さな村で暮らす
Dialogue: 0,0:18:52.33,0:18:57.34,Default,,0000,0000,0000,,ただの娘でした
Dialogue: 0,0:18:57.34,0:18:59.51,Default,,0000,0000,0000,,そんな私をめとるために
Dialogue: 0,0:18:59.51,0:19:03.78,Default,,0000,0000,0000,,旦那様は 父も母も きょうだいも隣人も
Dialogue: 0,0:19:03.78,0:19:06.45,Default,,0000,0000,0000,,互いの顔と名前を知るだけの 村の人も
Dialogue: 0,0:19:06.45,0:19:10.95,Default,,0000,0000,0000,,1人残らず 根絶やしにした
Dialogue: 0,0:19:06.45,0:19:10.95,Default,,0000,0000,0000,,えっ
Dialogue: 0,0:19:10.95,0:19:14.45,Default,,0000,0000,0000,,彼の妻は 全員 同じ境遇です
Dialogue: 0,0:19:14.45,0:19:18.96,Default,,0000,0000,0000,,えっ あっ あっ んっ
Dialogue: 0,0:19:18.96,0:19:21.63,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:21.63,0:19:23.96,Default,,0000,0000,0000,,あ あ!
Dialogue: 0,0:19:21.63,0:19:23.96,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:19:23.96,0:19:26.47,Default,,0000,0000,0000,,えっと これで ちゃんと みんなに
Dialogue: 0,0:19:26.47,0:19:29.30,Default,,0000,0000,0000,,声が聞こえてるのか?
Dialogue: 0,0:19:29.30,0:19:31.30,Default,,0000,0000,0000,,スバル?
Dialogue: 0,0:19:31.30,0:19:35.14,Default,,0000,0000,0000,,マイクテスト マイクテスト 1 2 1 2!
Dialogue: 0,0:19:35.14,0:19:37.14,Default,,0000,0000,0000,,よし
Dialogue: 0,0:19:37.14,0:19:39.14,Default,,0000,0000,0000,,聞こえてるみたいで助かる
Dialogue: 0,0:19:39.14,0:19:43.15,Default,,0000,0000,0000,,あ で まずは 最初に 驚かせて ごめん
Dialogue: 0,0:19:43.15,0:19:45.48,Default,,0000,0000,0000,,今度は 何 言われんだって 不安になった人が
Dialogue: 0,0:19:45.48,0:19:48.49,Default,,0000,0000,0000,,大勢いたと思うけど 安心してくれ
Dialogue: 0,0:19:48.49,0:19:52.49,Default,,0000,0000,0000,,今 この放送をしてる俺は 魔女教の人間じゃない
Dialogue: 0,0:19:52.49,0:19:54.66,Default,,0000,0000,0000,,先に それを伝えておく
Dialogue: 0,0:19:52.49,0:19:54.66,Default,,0000,0000,0000,,魔女教じゃない?
Dialogue: 0,0:19:54.66,0:19:59.16,Default,,0000,0000,0000,,じゃ じゃあ 助かったのか?
Dialogue: 0,0:19:54.66,0:19:59.16,Default,,0000,0000,0000,,あいつら 追い出してくれたの?
Dialogue: 0,0:19:59.16,0:20:01.50,Default,,0000,0000,0000,,期待させて悪いんだが
Dialogue: 0,0:20:01.50,0:20:04.34,Default,,0000,0000,0000,,魔女教の脅威は まだ 去ってない
Dialogue: 0,0:20:04.34,0:20:06.34,Default,,0000,0000,0000,,都市庁舎は取り戻したけど
Dialogue: 0,0:20:06.34,0:20:09.51,Default,,0000,0000,0000,,制御塔は やつらの手に落ちたまんまだ
Dialogue: 0,0:20:09.51,0:20:14.51,Default,,0000,0000,0000,,都市が水没する危険もやつらの要求も まだ 生きてる
Dialogue: 0,0:20:14.51,0:20:19.85,Default,,0000,0000,0000,,それも伝えておく ごめんな
Dialogue: 0,0:20:14.51,0:20:19.85,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:20:19.85,0:20:24.02,Default,,0000,0000,0000,,今 みんなは この放送を どこで聞いてる?
Dialogue: 0,0:20:24.02,0:20:26.69,Default,,0000,0000,0000,,避難所にいる人たちや ひょっとすると
Dialogue: 0,0:20:26.69,0:20:29.19,Default,,0000,0000,0000,,避難所に逃げ込めない人たちも いると思う
Dialogue: 0,0:20:29.19,0:20:32.36,Default,,0000,0000,0000,,みんな 不安で いっぱいなはずだ
Dialogue: 0,0:20:32.36,0:20:36.54,Default,,0000,0000,0000,,だってのに わざわざ 変に みんなの期待を あおるようなまねをして
Dialogue: 0,0:20:36.54,0:20:40.71,Default,,0000,0000,0000,,俺を何様だって 思ってる人もいるはずだ
Dialogue: 0,0:20:40.71,0:20:44.38,Default,,0000,0000,0000,,俺は 何様でも 何者でもないよ
Dialogue: 0,0:20:44.38,0:20:47.71,Default,,0000,0000,0000,,みんなと同じ 状況に振り回されて
Dialogue: 0,0:20:47.71,0:20:51.72,Default,,0000,0000,0000,,理不尽に押し潰されそうで ビビって 足が震えてる
Dialogue: 0,0:20:51.72,0:20:53.89,Default,,0000,0000,0000,,そんなやつだ
Dialogue: 0,0:20:53.89,0:20:56.22,Default,,0000,0000,0000,,こうして みんなに呼びかける役目も
Dialogue: 0,0:20:56.22,0:20:59.73,Default,,0000,0000,0000,,俺には 荷が勝ち過ぎてるって 思ってるよ
Dialogue: 0,0:20:59.73,0:21:03.16,Default,,0000,0000,0000,,ほんとなら もっと こうして みんなに話しかけるのに
Dialogue: 0,0:21:03.16,0:21:07.17,Default,,0000,0000,0000,,ふさわしい人は 他にいるんだ
Dialogue: 0,0:21:03.16,0:21:07.17,Default,,0000,0000,0000,,きっと そうだ
Dialogue: 0,0:21:07.17,0:21:10.67,Default,,0000,0000,0000,,だけど 今 こうして 俺が話してる
Dialogue: 0,0:21:10.67,0:21:13.01,Default,,0000,0000,0000,,俺なんかより よっぽど すごい人たちが
Dialogue: 0,0:21:13.01,0:21:16.84,Default,,0000,0000,0000,,俺が やるべきだって そう言ってくれてる
Dialogue: 0,0:21:16.84,0:21:19.34,Default,,0000,0000,0000,,そうすることに 意味があるんだって
Dialogue: 0,0:21:19.34,0:21:23.18,Default,,0000,0000,0000,,俺の声 震えてないか?
Dialogue: 0,0:21:23.18,0:21:25.85,Default,,0000,0000,0000,,人前に立つなんて 俺のキャラじゃないんだよ
Dialogue: 0,0:21:25.85,0:21:27.85,Default,,0000,0000,0000,,立派なことも言えないし
Dialogue: 0,0:21:27.85,0:21:31.19,Default,,0000,0000,0000,,みんなを引っ張ってく カリスマだって 俺にはない
Dialogue: 0,0:21:31.19,0:21:35.69,Default,,0000,0000,0000,,弱くて どうしようもなくて こんな大一番 今だって
Dialogue: 0,0:21:35.69,0:21:37.70,Default,,0000,0000,0000,,逃げたくて しょうがなくて
Dialogue: 0,0:21:35.69,0:21:37.70,Default,,0000,0000,0000,,お姉ちゃん
Dialogue: 0,0:21:37.70,0:21:41.20,Default,,0000,0000,0000,,何ができるかなんて わからなくて
Dialogue: 0,0:21:41.20,0:21:45.04,Default,,0000,0000,0000,,耳を塞いで 頭を抱えて 自分が うずくまってる間に
Dialogue: 0,0:21:45.04,0:21:49.37,Default,,0000,0000,0000,,全部 解決してくれればなんて 他力本願を願って
Dialogue: 0,0:21:49.37,0:21:51.38,Default,,0000,0000,0000,,やだ
Dialogue: 0,0:21:53.38,0:21:56.05,Default,,0000,0000,0000,,それでも 逃げられないから戦う
Dialogue: 0,0:21:56.05,0:21:59.05,Default,,0000,0000,0000,,俺は それだけのやつだ
Dialogue: 0,0:21:59.05,0:22:01.82,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:21:59.05,0:22:01.82,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:22:01.82,0:22:04.32,Default,,0000,0000,0000,,もう一度 聞かせてくれ
Dialogue: 0,0:22:04.32,0:22:07.16,Default,,0000,0000,0000,,この声を聞いてる人は 今 どこにいる?
Dialogue: 0,0:22:07.16,0:22:09.49,Default,,0000,0000,0000,,避難所に逃げ込めてるか?
Dialogue: 0,0:22:09.49,0:22:11.66,Default,,0000,0000,0000,,自分の家に隠れてるのか?
Dialogue: 0,0:22:11.66,0:22:16.50,Default,,0000,0000,0000,,1人で震えてたりしないか?
Dialogue: 0,0:22:11.66,0:22:16.50,Default,,0000,0000,0000,,誰かと一緒にいられてるか?
Dialogue: 0,0:22:16.50,0:22:19.67,Default,,0000,0000,0000,,一緒にいるのは 大切な人か?
Dialogue: 0,0:22:19.67,0:22:23.84,Default,,0000,0000,0000,,知らない顔でも この数時間で 見知った顔になったか?
Dialogue: 0,0:22:23.84,0:22:27.68,Default,,0000,0000,0000,,勝手な話だし 難しいかもしれないけど
Dialogue: 0,0:22:27.68,0:22:30.18,Default,,0000,0000,0000,,お願いだから 1人にならないでくれ
Dialogue: 0,0:22:30.18,0:22:34.69,Default,,0000,0000,0000,,1人でいると つまらない考えばっかり 浮かんでくるんだ
Dialogue: 0,0:22:34.69,0:22:37.69,Default,,0000,0000,0000,,経験則だ わかるよ
Dialogue: 0,0:22:37.69,0:22:40.19,Default,,0000,0000,0000,,だから 1人にならないでくれ
Dialogue: 0,0:22:40.19,0:22:43.36,Default,,0000,0000,0000,,誰かと一緒にいてくれ
Dialogue: 0,0:22:40.19,0:22:43.36,Default,,0000,0000,0000,,そして
Dialogue: 0,0:22:43.36,0:22:49.53,Default,,0000,0000,0000,,そして できるなら
Dialogue: 0,0:22:43.36,0:22:49.53,Default,,0000,0000,0000,,一緒にいる誰かの顔を見てくれ
Dialogue: 0,0:22:49.53,0:22:51.87,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:22:51.87,0:22:54.21,Default,,0000,0000,0000,,今 誰の顔を見た?
Dialogue: 0,0:22:54.21,0:22:57.21,Default,,0000,0000,0000,,大切な人か?
Dialogue: 0,0:22:54.21,0:22:57.21,Default,,0000,0000,0000,,それとも この数時間を
Dialogue: 0,0:22:57.21,0:23:00.15,Default,,0000,0000,0000,,一緒に過ごした知らない相手か?
Dialogue: 0,0:23:00.15,0:23:02.81,Default,,0000,0000,0000,,たぶん ひでえ顔してるだろ
Dialogue: 0,0:23:02.81,0:23:05.65,Default,,0000,0000,0000,,泣き顔だったり つらそうだったり
Dialogue: 0,0:23:05.65,0:23:08.32,Default,,0000,0000,0000,,笑ってる顔はないと思う
Dialogue: 0,0:23:08.32,0:23:11.82,Default,,0000,0000,0000,,それが許せるかよ
Dialogue: 0,0:23:08.32,0:23:11.82,Default,,0000,0000,0000,,やだよ
Dialogue: 0,0:23:11.82,0:23:14.83,Default,,0000,0000,0000,,俺は許せない 許したくない
Dialogue: 0,0:23:14.83,0:23:19.00,Default,,0000,0000,0000,,俺にも大切な人がいる
Dialogue: 0,0:23:14.83,0:23:19.00,Default,,0000,0000,0000,,大事な仲間がいる
Dialogue: 0,0:23:19.00,0:23:21.67,Default,,0000,0000,0000,,俺は その大切な人たちに
Dialogue: 0,0:23:21.67,0:23:25.17,Default,,0000,0000,0000,,つらい顔や悲しい顔を させてるやつらが 許せない!
Dialogue: 0,0:23:25.17,0:23:29.01,Default,,0000,0000,0000,,ふざけんじゃねえ
Dialogue: 0,0:23:25.17,0:23:29.01,Default,,0000,0000,0000,,ばかにすんなよ!
Dialogue: 0,0:23:29.01,0:23:31.01,Default,,0000,0000,0000,,俺の知ってる この子の笑顔は
Dialogue: 0,0:23:31.01,0:23:34.85,Default,,0000,0000,0000,,ほんとは もっと かわいいんだぜ って言ってやりてえ
Dialogue: 0,0:23:34.85,0:23:37.18,Default,,0000,0000,0000,,負けっぱなしじゃいられねえ
Dialogue: 0,0:23:37.18,0:23:39.35,Default,,0000,0000,0000,,投げっぱなしじゃ かっこがつかねえ
Dialogue: 0,0:23:39.35,0:23:42.02,Default,,0000,0000,0000,,やられっぱなしでいいわけがねえ
Dialogue: 0,0:23:42.02,0:23:44.69,Default,,0000,0000,0000,,間違ってるのは あいつらだ
Dialogue: 0,0:23:44.69,0:23:47.69,Default,,0000,0000,0000,,間違ってるやつらに負けるなんて 我慢ならねえ
Dialogue: 0,0:23:47.69,0:23:52.20,Default,,0000,0000,0000,,あんなやつらに 負けを認めるなんて 俺はしたくない!
Dialogue: 0,0:23:52.20,0:23:55.70,Default,,0000,0000,0000,,だから 戦う
Dialogue: 0,0:23:52.20,0:23:55.70,Default,,0000,0000,0000,,弱いのも 頭が悪いのも
Dialogue: 0,0:23:55.70,0:23:58.37,Default,,0000,0000,0000,,全部 わかってるけど 戦ってやる!
Dialogue: 0,0:23:58.37,0:24:00.47,Default,,0000,0000,0000,,あいつらが間違ってる
Dialogue: 0,0:24:00.47,0:24:03.14,Default,,0000,0000,0000,,俺の好きな人たちに 泣きそうな顔をさせる
Dialogue: 0,0:24:03.14,0:24:06.14,Default,,0000,0000,0000,,あいつらが間違ってる
Dialogue: 0,0:24:03.14,0:24:06.14,Default,,0000,0000,0000,,だから 戦う
Dialogue: 0,0:24:06.14,0:24:08.15,Default,,0000,0000,0000,,俺は戦う!
Dialogue: 0,0:24:08.15,0:24:11.15,Default,,0000,0000,0000,,みんなにも戦ってほしい
Dialogue: 0,0:24:08.15,0:24:11.15,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:24:11.15,0:24:13.15,Default,,0000,0000,0000,,勘違いしないでくれ
Dialogue: 0,0:24:13.15,0:24:15.99,Default,,0000,0000,0000,,なにも 棒で殴りかかれ って話じゃない
Dialogue: 0,0:24:15.99,0:24:18.16,Default,,0000,0000,0000,,俺が みんなに望むことは
Dialogue: 0,0:24:18.16,0:24:21.49,Default,,0000,0000,0000,,下を向かないでほしい ってことなんだ
Dialogue: 0,0:24:21.49,0:24:23.50,Default,,0000,0000,0000,,下を向かない
Dialogue: 0,0:24:23.50,0:24:27.17,Default,,0000,0000,0000,,足元 じっと にらみつけてても なんも変わらねえよ
Dialogue: 0,0:24:27.17,0:24:30.67,Default,,0000,0000,0000,,だから 顔を上げて 前を向いてくれ
Dialogue: 0,0:24:30.67,0:24:34.84,Default,,0000,0000,0000,,周り 見渡してみたら きっと 誰かと目が合う
Dialogue: 0,0:24:34.84,0:24:38.34,Default,,0000,0000,0000,,それは 同じ 不安を抱えてる誰かだけど
Dialogue: 0,0:24:38.34,0:24:42.18,Default,,0000,0000,0000,,同じ 負けたくないって 気持ちを抱えた誰かでもある
Dialogue: 0,0:24:42.18,0:24:44.68,Default,,0000,0000,0000,,信じさせてくれよ
Dialogue: 0,0:24:44.68,0:24:48.69,Default,,0000,0000,0000,,弱くて どうしようもない俺が まだ 諦められねえんだ
Dialogue: 0,0:24:48.69,0:24:52.02,Default,,0000,0000,0000,,諦めの悪い弱虫が 俺だけじゃないって
Dialogue: 0,0:24:52.02,0:24:54.53,Default,,0000,0000,0000,,そう信じさせてくれよ
Dialogue: 0,0:24:54.53,0:24:57.86,Default,,0000,0000,0000,,それとも 俺だけなのか?
Dialogue: 0,0:24:57.86,0:25:00.47,Default,,0000,0000,0000,,違う
Dialogue: 0,0:25:00.47,0:25:03.30,Default,,0000,0000,0000,,ううん そんなことないよ
Dialogue: 0,0:25:03.30,0:25:05.80,Default,,0000,0000,0000,,まだ やれるって
Dialogue: 0,0:25:03.30,0:25:05.80,Default,,0000,0000,0000,,まだ 戦えるって
Dialogue: 0,0:25:05.80,0:25:08.64,Default,,0000,0000,0000,,そう思ってるのは 俺だけなのか?
Dialogue: 0,0:25:08.64,0:25:11.64,Default,,0000,0000,0000,,違う!
Dialogue: 0,0:25:08.64,0:25:11.64,Default,,0000,0000,0000,,そうだ 違う!
Dialogue: 0,0:25:08.64,0:25:11.64,Default,,0000,0000,0000,,違うぞ!
Dialogue: 0,0:25:11.64,0:25:16.15,Default,,0000,0000,0000,,ううん 大丈夫
Dialogue: 0,0:25:11.64,0:25:16.15,Default,,0000,0000,0000,,私も まだ 頑張れるから
Dialogue: 0,0:25:16.15,0:25:19.48,Default,,0000,0000,0000,,違うよな?
Dialogue: 0,0:25:16.15,0:25:19.48,Default,,0000,0000,0000,,違う!
Dialogue: 0,0:25:19.48,0:25:24.66,Default,,0000,0000,0000,,うん 違う 絶対の絶対に
Dialogue: 0,0:25:19.48,0:25:24.66,Default,,0000,0000,0000,,心の底から 全然 違うから
Dialogue: 0,0:25:24.66,0:25:28.99,Default,,0000,0000,0000,,まだ みんなも戦ってるよな?
Dialogue: 0,0:25:24.66,0:25:28.99,Default,,0000,0000,0000,,弱さに のまれやしなよな?
Dialogue: 0,0:25:28.99,0:25:32.00,Default,,0000,0000,0000,,負けない 負けたくない!
Dialogue: 0,0:25:28.99,0:25:32.00,Default,,0000,0000,0000,,負けないぞ!
Dialogue: 0,0:25:28.99,0:25:32.00,Default,,0000,0000,0000,,当たり前だ!
Dialogue: 0,0:25:32.00,0:25:35.33,Default,,0000,0000,0000,,あなたの声が聞こえるから 大丈夫
Dialogue: 0,0:25:35.33,0:25:37.34,Default,,0000,0000,0000,,なんにも怖くないわ
Dialogue: 0,0:25:40.67,0:25:45.51,Default,,0000,0000,0000,,そばにいるのが大切な人なら その手を握って信じてくれ
Dialogue: 0,0:25:45.51,0:25:47.51,Default,,0000,0000,0000,,隣り合うのが知らない誰かなら
Dialogue: 0,0:25:47.51,0:25:50.52,Default,,0000,0000,0000,,一緒に頑張ろうって うなずきかけてくれ!
Dialogue: 0,0:25:50.52,0:25:55.52,Default,,0000,0000,0000,,自分も その人も 負けも折れもしないで 戦えるんだって
Dialogue: 0,0:25:55.52,0:26:00.46,Default,,0000,0000,0000,,みんなが 折れずにいてくれるなら 俺も諦めないで戦う
Dialogue: 0,0:26:00.46,0:26:04.96,Default,,0000,0000,0000,,戦って 戦って 勝ってみせる!
Dialogue: 0,0:26:04.96,0:26:07.63,Default,,0000,0000,0000,,俺の名前は ナツキ・スバル!
Dialogue: 0,0:26:07.63,0:26:11.80,Default,,0000,0000,0000,,魔女教大罪司教 怠惰を倒した 精霊使いだ!
Dialogue: 0,0:26:11.80,0:26:15.31,Default,,0000,0000,0000,,魔女教は 俺と仲間たちが どうにかする
Dialogue: 0,0:26:15.31,0:26:18.31,Default,,0000,0000,0000,,だから みんなは信じて戦ってくれ
Dialogue: 0,0:26:18.31,0:26:20.48,Default,,0000,0000,0000,,大切な人の手を握って
Dialogue: 0,0:26:20.48,0:26:23.48,Default,,0000,0000,0000,,負けそうになる弱い心を ぶっ飛ばしてくれ!
Dialogue: 0,0:26:23.48,0:26:29.99,Default,,0000,0000,0000,,そしたら あとのことは
Dialogue: 0,0:26:23.48,0:26:29.99,Default,,0000,0000,0000,,全部 この俺に任せておけ!
Dialogue: 0,0:26:29.99,0:26:32.82,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:26:32.82,0:26:35.66,Default,,0000,0000,0000,,今の声は
Dialogue: 0,0:26:35.66,0:26:40.00,Default,,0000,0000,0000,,私の騎士様
Dialogue: 0,0:26:35.66,0:26:40.00,Default,,0000,0000,0000,,すごく頑張り屋さんなの
Dialogue: 0,0:26:40.00,0:26:43.00,Default,,0000,0000,0000,,私 逃げないわ
Dialogue: 0,0:26:43.00,0:26:45.50,Default,,0000,0000,0000,,あなたたちを置いて どこかに行ったりしない
Dialogue: 0,0:26:45.50,0:26:48.84,Default,,0000,0000,0000,,どうして
Dialogue: 0,0:26:48.84,0:26:51.84,Default,,0000,0000,0000,,怖い気持ちで いっぱいだったはずなのに
Dialogue: 0,0:26:51.84,0:26:55.01,Default,,0000,0000,0000,,それでも あなたは 私を助けようとしてくれた
Dialogue: 0,0:26:55.01,0:26:57.68,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:26:55.01,0:26:59.68,Default,,0000,0000,0000,,あなたにも 他の子たちにも 幸せになってもらいたい
Dialogue: 0,0:26:59.68,0:27:04.96,Default,,0000,0000,0000,,結婚って 大切な人と一緒に
Dialogue: 0,0:26:59.68,0:27:04.96,Default,,0000,0000,0000,,幸せになるための儀式だもの
Dialogue: 0,0:27:04.96,0:27:07.96,Default,,0000,0000,0000,,花嫁さんは 幸せでなきゃだめなの
Dialogue: 0,0:27:10.96,0:27:14.13,Default,,0000,0000,0000,,好き合ってるのに 結婚できなかった人たちを
Dialogue: 0,0:27:14.13,0:27:16.13,Default,,0000,0000,0000,,私は知ってる
Dialogue: 0,0:27:16.13,0:27:20.47,Default,,0000,0000,0000,,今も まだ 2人のことを思うと胸が痛む
Dialogue: 0,0:27:20.47,0:27:25.31,Default,,0000,0000,0000,,結婚しているのに 幸せになれないなんてそんな関係 私は嫌だわ
Dialogue: 0,0:27:25.31,0:27:28.15,Default,,0000,0000,0000,,かっ 考えは ご立派ですが
Dialogue: 0,0:27:28.15,0:27:30.48,Default,,0000,0000,0000,,何かするなら あなた お1人で
Dialogue: 0,0:27:30.48,0:27:34.65,Default,,0000,0000,0000,,私1人で ううん そうじゃない
Dialogue: 0,0:27:34.65,0:27:38.49,Default,,0000,0000,0000,,私 ずっと 1人じゃなかった
Dialogue: 0,0:27:38.49,0:27:41.33,Default,,0000,0000,0000,,危ない
Dialogue: 0,0:27:38.49,0:27:41.33,Default,,0000,0000,0000,,勘違いしちゃうところだった
Dialogue: 0,0:27:41.33,0:27:43.63,Default,,0000,0000,0000,,どうされるつもりですか?
Dialogue: 0,0:27:47.83,0:27:49.83,Default,,0000,0000,0000,,結婚式をしましょう
Dialogue: 0,0:27:54.67,0:27:58.51,Default,,0000,0000,0000,,ハァ 終わった しんどかった
Dialogue: 0,0:27:58.51,0:28:00.51,Default,,0000,0000,0000,,ナツキ君
Dialogue: 0,0:27:58.51,0:28:00.51,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:28:02.95,0:28:06.95,Default,,0000,0000,0000,,うひゃ! あっ ごめんなさい!
Dialogue: 0,0:28:02.95,0:28:06.95,Default,,0000,0000,0000,,次は もっと うまくやります!
Dialogue: 0,0:28:06.95,0:28:10.62,Default,,0000,0000,0000,,なんで謝るん? 変な子やね
Dialogue: 0,0:28:06.95,0:28:10.62,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:28:10.62,0:28:13.29,Default,,0000,0000,0000,,すばらしい演説だった
Dialogue: 0,0:28:13.29,0:28:15.96,Default,,0000,0000,0000,,大将は やっぱり 大将だぜ!
Dialogue: 0,0:28:15.96,0:28:17.96,Default,,0000,0000,0000,,いんや 恐れ入ったわ!
Dialogue: 0,0:28:17.96,0:28:22.63,Default,,0000,0000,0000,,嬢ちゃんらに 幼女に 地竜まで たぶらかした 面目躍如やないか!
Dialogue: 0,0:28:22.63,0:28:25.14,Default,,0000,0000,0000,,ナツキ君は 天性の扇動者やね
Dialogue: 0,0:28:25.14,0:28:27.31,Default,,0000,0000,0000,,たぶらかしてねえし 扇動者って
Dialogue: 0,0:28:27.31,0:28:30.31,Default,,0000,0000,0000,,人聞き悪いよ!
Dialogue: 0,0:28:30.31,0:28:32.31,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:28:35.98,0:28:39.32,Default,,0000,0000,0000,,少しは 街の人たちを 励ませたかな?
Dialogue: 0,0:28:39.32,0:28:43.49,Default,,0000,0000,0000,,んっ あとは 原因そのものの排除やね
Dialogue: 0,0:28:43.49,0:28:47.66,Default,,0000,0000,0000,,ああ そのためには 制御塔の 4か所 同時攻略か
Dialogue: 0,0:28:47.66,0:28:52.16,Default,,0000,0000,0000,,それなら 鬼札が 1枚 加わるのは いかがですか?
Dialogue: 0,0:28:52.16,0:28:55.00,Default,,0000,0000,0000,,オットー!
Dialogue: 0,0:28:55.00,0:28:58.00,Default,,0000,0000,0000,,オットー兄ィ! 無事だったっかよ!
Dialogue: 0,0:28:58.00,0:29:01.44,Default,,0000,0000,0000,,命からがら どうにかこうにかでは ありましたが
Dialogue: 0,0:29:01.44,0:29:05.44,Default,,0000,0000,0000,,それと お連れしました
Dialogue: 0,0:29:05.44,0:29:08.45,Default,,0000,0000,0000,,んっ? お連れした?
Dialogue: 0,0:29:08.45,0:29:12.12,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:29:12.12,0:29:14.12,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:29:17.29,0:29:19.29,Default,,0000,0000,0000,,遅れて すまない
Dialogue: 0,0:29:21.29,0:29:23.60,Default,,0000,0000,0000,,ラインハルト・ヴァン・アストレア
Dialogue: 0,0:29:25.96,0:29:28.97,Default,,0000,0000,0000,,遅ればせながら 合流する
