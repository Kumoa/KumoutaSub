Dialogue: 0,0:00:02.00,0:00:05.67,Default,,0000,0000,0000,,実は 一目ぼれだったんです なんて知ったら
Dialogue: 0,0:00:05.67,0:00:09.88,Default,,0000,0000,0000,,あなたは どのくらい驚いてくれましたか?
Dialogue: 0,0:00:16.52,0:00:18.52,Default,,0000,0000,0000,,見ない顔だな
Dialogue: 0,0:00:18.52,0:00:22.02,Default,,0000,0000,0000,,女が朝っぱらから こんなとこで 何してやがんだよ
Dialogue: 0,0:00:22.02,0:00:24.02,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:26.53,0:00:30.20,Default,,0000,0000,0000,,うん まあ いいから いいから
Dialogue: 0,0:00:30.20,0:00:33.53,Default,,0000,0000,0000,,おいで おいで
Dialogue: 0,0:00:30.20,0:00:33.53,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:45.05,0:00:47.05,Default,,0000,0000,0000,,ねえ
Dialogue: 0,0:00:45.05,0:00:47.05,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:50.05,0:00:52.05,Default,,0000,0000,0000,,花は好き?
Dialogue: 0,0:01:04.33,0:01:07.13,Default,,0000,0000,0000,,くっ! うっ うっ!
Dialogue: 0,0:01:09.17,0:01:11.34,Default,,0000,0000,0000,,はぁ!
Dialogue: 0,0:01:11.34,0:01:14.64,Default,,0000,0000,0000,,フッ! フッ! ぬっ! んっ
Dialogue: 0,0:01:16.68,0:01:22.02,Default,,0000,0000,0000,,剣を握る前に悩んでも
Dialogue: 0,0:01:16.68,0:01:22.02,Default,,0000,0000,0000,,剣を握ってからは悩まない
Dialogue: 0,0:01:22.02,0:01:26.02,Default,,0000,0000,0000,,お前は よほど 私より わかっている女だった
Dialogue: 0,0:01:26.02,0:01:28.35,Default,,0000,0000,0000,,んっ ハッ!
Dialogue: 0,0:01:28.35,0:01:31.86,Default,,0000,0000,0000,,んっ! ハァ
Dialogue: 0,0:01:36.36,0:01:40.07,Default,,0000,0000,0000,,別れ際を覚えているか?
Dialogue: 0,0:01:40.07,0:01:44.20,Default,,0000,0000,0000,,大征伐の折 お前は 止める私を振りほどいて
Dialogue: 0,0:01:44.20,0:01:47.21,Default,,0000,0000,0000,,この肩に癒えない傷を刻んだ
Dialogue: 0,0:01:47.21,0:01:52.11,Default,,0000,0000,0000,,あのときの言葉を 私は 一語一句 忘れていない
Dialogue: 0,0:01:57.38,0:02:01.69,Default,,0000,0000,0000,,あの日の約束を果たしに来たぞ!
Dialogue: 0,0:02:01.69,0:02:03.69,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:02:03.69,0:02:05.86,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:02:05.86,0:02:08.19,Default,,0000,0000,0000,,くっ!
Dialogue: 0,0:02:08.19,0:02:12.57,Default,,0000,0000,0000,,てあっ! ぬあ!
Dialogue: 0,0:02:15.54,0:02:17.67,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:02:17.67,0:02:20.71,Default,,0000,0000,0000,,あっ! ぬお!
Dialogue: 0,0:02:20.71,0:02:23.38,Default,,0000,0000,0000,,フッ! ハッ! うっ!
Dialogue: 0,0:02:23.38,0:02:26.71,Default,,0000,0000,0000,,フッ! ハッ!
Dialogue: 0,0:02:23.38,0:02:26.71,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:26.71,0:02:29.22,Default,,0000,0000,0000,,んっ! フッ!
Dialogue: 0,0:02:29.22,0:02:31.22,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:02:29.22,0:02:31.22,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:02:31.22,0:02:33.72,Default,,0000,0000,0000,,んっ テレシア!
Dialogue: 0,0:02:33.72,0:02:37.72,Default,,0000,0000,0000,,おやじ!
Dialogue: 0,0:02:33.72,0:02:37.72,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:02:37.72,0:02:41.56,Default,,0000,0000,0000,,ぐあっ! がっ! あ!
Dialogue: 0,0:02:41.56,0:02:43.56,Default,,0000,0000,0000,,あっ ハッ
Dialogue: 0,0:02:43.56,0:02:47.03,Default,,0000,0000,0000,,まっ まだだ
Dialogue: 0,0:02:49.04,0:02:52.54,Default,,0000,0000,0000,,テレシア 私は ハァ
Dialogue: 0,0:02:52.54,0:02:56.04,Default,,0000,0000,0000,,あっ テレシア?
Dialogue: 0,0:02:56.04,0:02:58.04,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:02:58.04,0:03:00.81,Default,,0000,0000,0000,,まっ 待て! 待ってくれ!
Dialogue: 0,0:03:00.81,0:03:03.65,Default,,0000,0000,0000,,やめろ テレシア! そんなことが
Dialogue: 0,0:03:03.65,0:03:06.82,Default,,0000,0000,0000,,そんなことが 許されると思うのか!?
Dialogue: 0,0:03:03.65,0:03:06.82,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:03:06.82,0:03:09.32,Default,,0000,0000,0000,,あっ うそだろ?
Dialogue: 0,0:03:09.32,0:03:11.82,Default,,0000,0000,0000,,おお おふくろのはずねえ
Dialogue: 0,0:03:11.82,0:03:14.99,Default,,0000,0000,0000,,そうじゃなくても おっ おやじが負けるわけ
Dialogue: 0,0:03:14.99,0:03:18.16,Default,,0000,0000,0000,,ハインケル! お前には無理だ!
Dialogue: 0,0:03:14.99,0:03:18.16,Default,,0000,0000,0000,,今すぐ 逃げろ!
Dialogue: 0,0:03:18.16,0:03:20.17,Default,,0000,0000,0000,,だぁ!
Dialogue: 0,0:03:23.87,0:03:25.84,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:03:25.84,0:03:31.84,Default,,0000,0000,0000,,やっ やめて やめてくれよ
Dialogue: 0,0:03:25.84,0:03:31.84,Default,,0000,0000,0000,,かっ 母さん
Dialogue: 0,0:03:35.18,0:03:39.72,Default,,0000,0000,0000,,テレシア 私と戦え! 私を
Dialogue: 0,0:03:39.72,0:03:44.22,Default,,0000,0000,0000,,俺を見ろ! 俺を 俺を見ろ!
Dialogue: 0,0:03:44.22,0:03:46.36,Default,,0000,0000,0000,,テレシアー!
Dialogue: 0,0:03:44.22,0:03:46.36,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:03:46.36,0:03:48.36,Default,,0000,0000,0000,,そこまでだ
Dialogue: 0,0:03:58.74,0:04:01.21,Default,,0000,0000,0000,,ライン ハルト
Dialogue: 0,0:04:03.48,0:04:05.98,Default,,0000,0000,0000,,なっ なんなんだよ?
Dialogue: 0,0:04:05.98,0:04:10.98,Default,,0000,0000,0000,,なんで 俺が
Dialogue: 0,0:04:05.98,0:04:10.98,Default,,0000,0000,0000,,俺が何したってんだよ!
Dialogue: 0,0:04:18.02,0:04:20.49,Default,,0000,0000,0000,,ラインハルト
Dialogue: 0,0:04:18.02,0:04:20.49,Default,,0000,0000,0000,,死者は動かない
Dialogue: 0,0:04:20.49,0:04:22.66,Default,,0000,0000,0000,,死者に その先はない
Dialogue: 0,0:04:22.66,0:04:25.50,Default,,0000,0000,0000,,僕は その不条理を許さない
Dialogue: 0,0:04:39.01,0:04:41.01,Default,,0000,0000,0000,,あっ! くっ
Dialogue: 0,0:04:41.01,0:04:43.85,Default,,0000,0000,0000,,やっ やめろ! ぐっ
Dialogue: 0,0:04:43.85,0:04:46.85,Default,,0000,0000,0000,,やめてくれ! あっ うわっ!
Dialogue: 0,0:04:46.85,0:04:50.19,Default,,0000,0000,0000,,くっ 殺さないでくれ!
Dialogue: 0,0:04:50.19,0:04:53.19,Default,,0000,0000,0000,,それは それは 俺の
Dialogue: 0,0:04:53.19,0:04:56.40,Default,,0000,0000,0000,,俺のテレシアなんだ!
Dialogue: 0,0:04:58.40,0:05:02.17,Default,,0000,0000,0000,,おばあ様は 15年前に 僕が殺した
Dialogue: 0,0:05:09.34,0:05:12.31,Default,,0000,0000,0000,,ここにいるのは ただの偽者だ
Dialogue: 0,0:05:23.69,0:05:27.03,Default,,0000,0000,0000,,剣聖の加護が この身に宿ったのは
Dialogue: 0,0:05:27.03,0:05:30.10,Default,,0000,0000,0000,,私が 12歳のころだった
Dialogue: 0,0:05:41.51,0:05:45.35,Default,,0000,0000,0000,,んっ ハァ
Dialogue: 0,0:05:45.35,0:05:48.05,Default,,0000,0000,0000,,あっ ハッ
Dialogue: 0,0:05:56.36,0:05:58.36,Default,,0000,0000,0000,,授かった?
Dialogue: 0,0:06:05.67,0:06:08.30,Default,,0000,0000,0000,,ぐっ! くっ
Dialogue: 0,0:06:08.30,0:06:10.80,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:08.30,0:06:10.80,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:06:10.80,0:06:14.67,Default,,0000,0000,0000,,あっ えっ?
Dialogue: 0,0:06:14.67,0:06:18.64,Default,,0000,0000,0000,,やはり 間違いない
Dialogue: 0,0:06:14.67,0:06:18.64,Default,,0000,0000,0000,,次の剣聖は お前だ
Dialogue: 0,0:06:18.64,0:06:20.65,Default,,0000,0000,0000,,あっ えっ!
Dialogue: 0,0:06:24.15,0:06:26.65,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:24.15,0:06:26.65,Default,,0000,0000,0000,,あっ ああ
Dialogue: 0,0:06:26.65,0:06:29.66,Default,,0000,0000,0000,,剣を持ちなさい
Dialogue: 0,0:06:26.65,0:06:29.66,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:06:29.66,0:06:31.66,Default,,0000,0000,0000,,テレシア
Dialogue: 0,0:06:34.99,0:06:40.20,Default,,0000,0000,0000,,兄さんは
Dialogue: 0,0:06:34.99,0:06:40.20,Default,,0000,0000,0000,,私の何倍も努力していた
Dialogue: 0,0:06:40.20,0:06:45.37,Default,,0000,0000,0000,,1日だって 剣の鍛錬を
Dialogue: 0,0:06:40.20,0:06:45.37,Default,,0000,0000,0000,,怠ったことはなかった
Dialogue: 0,0:06:45.37,0:06:51.84,Default,,0000,0000,0000,,そうやって 頑張る兄さんが
Dialogue: 0,0:06:45.37,0:06:51.84,Default,,0000,0000,0000,,私は 大好きだった
Dialogue: 0,0:06:58.05,0:07:03.12,Default,,0000,0000,0000,,兄さんの夢を
Dialogue: 0,0:06:58.05,0:07:03.12,Default,,0000,0000,0000,,私が壊した
Dialogue: 0,0:07:06.33,0:07:08.49,Default,,0000,0000,0000,,初陣は それから 2年後
Dialogue: 0,0:07:08.49,0:07:15.50,Default,,0000,0000,0000,,王国最大にして 最悪の内戦
Dialogue: 0,0:07:08.49,0:07:15.50,Default,,0000,0000,0000,,亜人戦争のとき
Dialogue: 0,0:07:15.50,0:07:18.67,Default,,0000,0000,0000,,おい そっち 持ってくれ!
Dialogue: 0,0:07:15.50,0:07:18.67,Default,,0000,0000,0000,,わかった!
Dialogue: 0,0:07:28.65,0:07:30.65,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:07:38.69,0:07:41.36,Default,,0000,0000,0000,,テレシア 怖いのかい?
Dialogue: 0,0:07:38.69,0:07:41.36,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:07:45.67,0:07:50.67,Default,,0000,0000,0000,,わかるよ だって お前は 虫も殺せないような
Dialogue: 0,0:07:50.67,0:07:53.01,Default,,0000,0000,0000,,優しい子だったから
Dialogue: 0,0:07:50.67,0:07:53.01,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:07:53.01,0:07:57.84,Default,,0000,0000,0000,,2年前 お前に負けて悔しかった
Dialogue: 0,0:07:57.84,0:08:01.78,Default,,0000,0000,0000,,でも 俺は やっぱり 剣が好きだったんだよ
Dialogue: 0,0:08:01.78,0:08:05.28,Default,,0000,0000,0000,,アストレア家に生まれて 弟たちがいて
Dialogue: 0,0:08:05.28,0:08:10.96,Default,,0000,0000,0000,,妹のお前がいて 感謝している
Dialogue: 0,0:08:05.28,0:08:10.96,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:08:10.96,0:08:13.63,Default,,0000,0000,0000,,剣に感謝しているんだ
Dialogue: 0,0:08:13.63,0:08:16.13,Default,,0000,0000,0000,,兄さん
Dialogue: 0,0:08:16.13,0:08:21.97,Default,,0000,0000,0000,,お前が嫌だって 怖いって
Dialogue: 0,0:08:16.13,0:08:21.97,Default,,0000,0000,0000,,思うんなら 俺が守ってやる
Dialogue: 0,0:08:21.97,0:08:24.14,Default,,0000,0000,0000,,あっ! あっ
Dialogue: 0,0:08:24.14,0:08:27.14,Default,,0000,0000,0000,,俺は お前の兄貴なんだから
Dialogue: 0,0:08:27.14,0:08:30.64,Default,,0000,0000,0000,,うっ うん
Dialogue: 0,0:08:30.64,0:08:35.65,Default,,0000,0000,0000,,お前が戦う必要なんて
Dialogue: 0,0:08:30.64,0:08:35.65,Default,,0000,0000,0000,,どこにもないんだよ
Dialogue: 0,0:08:35.65,0:08:38.85,Default,,0000,0000,0000,,ごめんなさい ごめんなさい
Dialogue: 0,0:08:40.99,0:08:46.16,Default,,0000,0000,0000,,その初陣で 私は
Dialogue: 0,0:08:40.99,0:08:46.16,Default,,0000,0000,0000,,剣を 一度も振らなかった
Dialogue: 0,0:08:46.16,0:08:49.16,Default,,0000,0000,0000,,振ることができなかった
Dialogue: 0,0:08:49.16,0:08:53.17,Default,,0000,0000,0000,,それどころか 戦場に立つことさえも
Dialogue: 0,0:08:56.00,0:09:00.81,Default,,0000,0000,0000,,そして 兄さんは 私の代わりに先陣を切り
Dialogue: 0,0:09:00.81,0:09:04.31,Default,,0000,0000,0000,,死んだ
Dialogue: 0,0:09:04.31,0:09:09.82,Default,,0000,0000,0000,,それでも 私が 剣聖の座から
Dialogue: 0,0:09:04.31,0:09:09.82,Default,,0000,0000,0000,,降りることは許されなかった
Dialogue: 0,0:09:09.82,0:09:15.29,Default,,0000,0000,0000,,剣聖の存在は
Dialogue: 0,0:09:09.82,0:09:15.29,Default,,0000,0000,0000,,王国の精神的な支柱だ
Dialogue: 0,0:09:15.29,0:09:22.16,Default,,0000,0000,0000,,私の敵前逃亡の事実は隠蔽され
Dialogue: 0,0:09:15.29,0:09:22.16,Default,,0000,0000,0000,,戦いは続いた
Dialogue: 0,0:09:22.16,0:09:25.63,Default,,0000,0000,0000,,カルラン カジレス
Dialogue: 0,0:09:25.63,0:09:31.50,Default,,0000,0000,0000,,私の兄弟も
Dialogue: 0,0:09:25.63,0:09:31.50,Default,,0000,0000,0000,,先代の剣聖だった叔父様も
Dialogue: 0,0:09:31.50,0:09:35.64,Default,,0000,0000,0000,,戦場で 命を落とした
Dialogue: 0,0:09:39.98,0:09:43.15,Default,,0000,0000,0000,,嫌!
Dialogue: 0,0:09:43.15,0:09:46.15,Default,,0000,0000,0000,,あっ えっ?
Dialogue: 0,0:09:48.65,0:09:51.52,Default,,0000,0000,0000,,あっ あっ うっ
Dialogue: 0,0:09:51.52,0:09:54.03,Default,,0000,0000,0000,,あのとき お前は思ったはずだ
Dialogue: 0,0:09:54.03,0:09:57.20,Default,,0000,0000,0000,,なんて隙だらけなんだと
Dialogue: 0,0:10:01.20,0:10:05.67,Default,,0000,0000,0000,,剣を持ちなさい テレシア
Dialogue: 0,0:10:15.18,0:10:19.02,Default,,0000,0000,0000,,剣を持ちなさい テレシア
Dialogue: 0,0:10:19.02,0:10:24.52,Default,,0000,0000,0000,,私が 剣に
Dialogue: 0,0:10:19.02,0:10:24.52,Default,,0000,0000,0000,,私が 剣を持たなきゃ
Dialogue: 0,0:10:30.73,0:10:34.90,Default,,0000,0000,0000,,女が朝っぱらからこんなとこで 何してやがんだよ
Dialogue: 0,0:10:41.74,0:10:43.74,Default,,0000,0000,0000,,俺の勝ちだ
Dialogue: 0,0:10:43.74,0:10:47.75,Default,,0000,0000,0000,,俺より弱いお前に 剣を持つ理由は もうない
Dialogue: 0,0:10:47.75,0:10:52.25,Default,,0000,0000,0000,,私が持たないなら 誰が
Dialogue: 0,0:10:52.25,0:10:57.39,Default,,0000,0000,0000,,お前が剣を振る理由は
Dialogue: 0,0:10:52.25,0:10:57.39,Default,,0000,0000,0000,,俺が継ぐ
Dialogue: 0,0:10:57.39,0:11:02.90,Default,,0000,0000,0000,,お前は
Dialogue: 0,0:10:57.39,0:11:02.90,Default,,0000,0000,0000,,俺が剣を振る理由になればいい
Dialogue: 0,0:11:07.17,0:11:10.67,Default,,0000,0000,0000,,ねえ 花は好き?
Dialogue: 0,0:11:10.67,0:11:12.67,Default,,0000,0000,0000,,嫌いじゃなくなった
Dialogue: 0,0:11:12.67,0:11:15.37,Default,,0000,0000,0000,,どうして 剣を振るの?
Dialogue: 0,0:11:20.51,0:11:24.12,Default,,0000,0000,0000,,お前を守るために
Dialogue: 0,0:11:27.35,0:11:31.19,Default,,0000,0000,0000,,私のこと 愛してる?
Dialogue: 0,0:11:31.19,0:11:33.69,Default,,0000,0000,0000,,わかれ
Dialogue: 0,0:11:33.69,0:11:36.36,Default,,0000,0000,0000,,言葉にしてほしいことだって あるのよ
Dialogue: 0,0:11:36.36,0:11:42.37,Default,,0000,0000,0000,,んっ あ
Dialogue: 0,0:11:36.36,0:11:42.37,Default,,0000,0000,0000,,いつか 気が向いたときにな
Dialogue: 0,0:11:44.37,0:11:46.87,Default,,0000,0000,0000,,結局 その質問だけは
Dialogue: 0,0:11:46.87,0:11:49.58,Default,,0000,0000,0000,,かたくなに 答えてくれなかったけれど
Dialogue: 0,0:11:54.21,0:12:00.69,Default,,0000,0000,0000,,それからは
Dialogue: 0,0:11:54.21,0:12:00.69,Default,,0000,0000,0000,,ずっと 幸せで 幸せで
Dialogue: 0,0:12:00.69,0:12:03.36,Default,,0000,0000,0000,,いろいろなことがあったけれど
Dialogue: 0,0:12:03.36,0:12:07.36,Default,,0000,0000,0000,,それでも 間違いなく 幸せだった
Dialogue: 0,0:12:07.36,0:12:11.50,Default,,0000,0000,0000,,私は反対だ!
Dialogue: 0,0:12:07.36,0:12:11.50,Default,,0000,0000,0000,,お前は 何を考えている!
Dialogue: 0,0:12:11.50,0:12:13.83,Default,,0000,0000,0000,,もう 決めたことよ
Dialogue: 0,0:12:13.83,0:12:15.84,Default,,0000,0000,0000,,ハインケルか
Dialogue: 0,0:12:15.84,0:12:18.34,Default,,0000,0000,0000,,あの ばか野郎 くだらない入れ知恵で
Dialogue: 0,0:12:18.34,0:12:21.51,Default,,0000,0000,0000,,それを 私や あなたに 言う資格はないわ
Dialogue: 0,0:12:21.51,0:12:26.01,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:12:21.51,0:12:26.01,Default,,0000,0000,0000,,突然 現れた 白鯨の討伐
Dialogue: 0,0:12:26.01,0:12:31.35,Default,,0000,0000,0000,,でも 王女様が誘拐されている今
Dialogue: 0,0:12:26.01,0:12:31.35,Default,,0000,0000,0000,,近衛騎士団長の
Dialogue: 0,0:12:31.35,0:12:35.02,Default,,0000,0000,0000,,剣鬼のあなたが 動くわけにはいかない
Dialogue: 0,0:12:35.02,0:12:39.19,Default,,0000,0000,0000,,だから 剣聖である私が動く
Dialogue: 0,0:12:39.19,0:12:42.53,Default,,0000,0000,0000,,あの子の言うことも 理にかなっている
Dialogue: 0,0:12:42.53,0:12:46.20,Default,,0000,0000,0000,,剣聖の称号など お飾りだろう
Dialogue: 0,0:12:46.20,0:12:49.70,Default,,0000,0000,0000,,そうね
Dialogue: 0,0:12:46.20,0:12:49.70,Default,,0000,0000,0000,,あなたが そうしてくれた
Dialogue: 0,0:12:49.70,0:12:55.74,Default,,0000,0000,0000,,ヴィルヘルム 私のこと 愛してる?
Dialogue: 0,0:12:49.70,0:12:55.74,Default,,0000,0000,0000,,なっ
Dialogue: 0,0:12:55.74,0:12:58.38,Default,,0000,0000,0000,,ウフッ
Dialogue: 0,0:12:58.38,0:13:01.31,Default,,0000,0000,0000,,うっ あっ
Dialogue: 0,0:13:01.31,0:13:04.15,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:04.15,0:13:06.15,Default,,0000,0000,0000,,テレシア
Dialogue: 0,0:13:12.16,0:13:14.16,Default,,0000,0000,0000,,死神の加護
Dialogue: 0,0:13:14.16,0:13:17.50,Default,,0000,0000,0000,,これで あなたは 私を追ってこれない
Dialogue: 0,0:13:17.50,0:13:21.33,Default,,0000,0000,0000,,それをしたら 傷が塞がらないんだから
Dialogue: 0,0:13:21.33,0:13:24.84,Default,,0000,0000,0000,,私は 血が止まらなくても お前を追うぞ
Dialogue: 0,0:13:24.84,0:13:28.01,Default,,0000,0000,0000,,それをされたら 意味がなくなるじゃない
Dialogue: 0,0:13:28.01,0:13:32.34,Default,,0000,0000,0000,,大丈夫 私を 誰だと思ってるの?
Dialogue: 0,0:13:32.34,0:13:35.51,Default,,0000,0000,0000,,あなたの次に強い 最強の剣士よ
Dialogue: 0,0:13:35.51,0:13:38.52,Default,,0000,0000,0000,,たとえ お飾りでもね
Dialogue: 0,0:13:38.52,0:13:41.85,Default,,0000,0000,0000,,50近くにもなって 若者に張り合っても
Dialogue: 0,0:13:41.85,0:13:46.03,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:41.85,0:13:46.03,Default,,0000,0000,0000,,余計なことは言わないの
Dialogue: 0,0:13:46.03,0:13:48.36,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:13:46.03,0:13:48.36,Default,,0000,0000,0000,,んっ!
Dialogue: 0,0:13:48.36,0:13:52.87,Default,,0000,0000,0000,,愛してるわ ヴィルヘルム
Dialogue: 0,0:13:48.36,0:13:52.87,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:52.87,0:13:56.20,Default,,0000,0000,0000,,ええ それでいいの
Dialogue: 0,0:13:56.20,0:14:00.64,Default,,0000,0000,0000,,その答えは 次に
Dialogue: 0,0:13:56.20,0:14:00.64,Default,,0000,0000,0000,,次?
Dialogue: 0,0:14:00.64,0:14:02.98,Default,,0000,0000,0000,,戻ってきたら
Dialogue: 0,0:14:02.98,0:14:07.28,Default,,0000,0000,0000,,あの日 聞けなかった言葉を 聞かせてくださいね
Dialogue: 0,0:14:25.00,0:14:29.17,Default,,0000,0000,0000,,うわ!
Dialogue: 0,0:14:29.17,0:14:32.67,Default,,0000,0000,0000,,うっ くっ あっ
Dialogue: 0,0:14:36.51,0:14:38.51,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:14:42.01,0:14:48.19,Default,,0000,0000,0000,,私に続け!
Dialogue: 0,0:14:42.01,0:14:48.19,Default,,0000,0000,0000,,お!
Dialogue: 0,0:14:48.19,0:14:50.19,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:14:50.19,0:14:55.36,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:14:50.19,0:14:55.36,Default,,0000,0000,0000,,やぁ!
Dialogue: 0,0:14:58.36,0:15:00.57,Default,,0000,0000,0000,,たっ 退避!
Dialogue: 0,0:15:10.68,0:15:13.31,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:15:10.68,0:15:13.31,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:13.31,0:15:15.31,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:15:13.31,0:15:15.31,Default,,0000,0000,0000,,あっ ハァ
Dialogue: 0,0:15:15.31,0:15:18.35,Default,,0000,0000,0000,,うっ うぅ
Dialogue: 0,0:15:18.35,0:15:22.82,Default,,0000,0000,0000,,うっ ぐっ ハァ
Dialogue: 0,0:15:22.82,0:15:26.66,Default,,0000,0000,0000,,ハァ うっ
Dialogue: 0,0:15:26.66,0:15:29.50,Default,,0000,0000,0000,,剣聖の加護が
Dialogue: 0,0:15:29.50,0:15:32.16,Default,,0000,0000,0000,,ラインハルト
Dialogue: 0,0:15:32.16,0:15:36.34,Default,,0000,0000,0000,,あら? こんな所に 女性が1人
Dialogue: 0,0:15:36.34,0:15:38.64,Default,,0000,0000,0000,,ずいぶんと勇ましいのですね
Dialogue: 0,0:15:40.84,0:15:43.84,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:15:40.84,0:15:43.84,Default,,0000,0000,0000,,嫌われてしまいましたね
Dialogue: 0,0:15:46.85,0:15:49.21,Default,,0000,0000,0000,,縛られなくてもいいの
Dialogue: 0,0:15:49.21,0:15:54.72,Default,,0000,0000,0000,,願わくば 剣以外にも
Dialogue: 0,0:15:49.21,0:15:54.72,Default,,0000,0000,0000,,出会いがある人生を
Dialogue: 0,0:15:54.72,0:15:56.69,Default,,0000,0000,0000,,私のように
Dialogue: 0,0:15:59.89,0:16:02.80,Default,,0000,0000,0000,,あなたを
Dialogue: 0,0:15:59.89,0:16:02.80,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:16:02.80,0:16:05.80,Default,,0000,0000,0000,,理解したいのです
Dialogue: 0,0:16:09.13,0:16:12.97,Default,,0000,0000,0000,,ヴィルヘルム
Dialogue: 0,0:16:12.97,0:16:16.08,Default,,0000,0000,0000,,んっ んっ
Dialogue: 0,0:16:21.65,0:16:25.48,Default,,0000,0000,0000,,あっ 情けない 顔
Dialogue: 0,0:16:25.48,0:16:29.32,Default,,0000,0000,0000,,テレシア 私は
Dialogue: 0,0:16:29.32,0:16:31.82,Default,,0000,0000,0000,,ねえ ヴィルヘルム
Dialogue: 0,0:16:34.33,0:16:36.33,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:16:36.33,0:16:42.67,Default,,0000,0000,0000,,お前に 言わなくては
Dialogue: 0,0:16:36.33,0:16:42.67,Default,,0000,0000,0000,,ならないことが ある
Dialogue: 0,0:16:42.67,0:16:46.84,Default,,0000,0000,0000,,んっ 私は口下手で
Dialogue: 0,0:16:46.84,0:16:50.01,Default,,0000,0000,0000,,自分の考えも うまく伝えられず
Dialogue: 0,0:16:50.01,0:16:52.01,Default,,0000,0000,0000,,お前にも苦労を
Dialogue: 0,0:16:54.01,0:17:00.12,Default,,0000,0000,0000,,だから
Dialogue: 0,0:16:54.01,0:17:00.12,Default,,0000,0000,0000,,20年以上も お前に 一度も
Dialogue: 0,0:17:03.29,0:17:08.13,Default,,0000,0000,0000,,20年 不安にさせたかもしれん
Dialogue: 0,0:17:08.13,0:17:10.83,Default,,0000,0000,0000,,だが 私は
Dialogue: 0,0:17:13.63,0:17:15.63,Default,,0000,0000,0000,,ばかな人
Dialogue: 0,0:17:15.63,0:17:20.31,Default,,0000,0000,0000,,ハッ
Dialogue: 0,0:17:15.63,0:17:20.31,Default,,0000,0000,0000,,本当に 気付いてなかったの?
Dialogue: 0,0:17:20.31,0:17:24.61,Default,,0000,0000,0000,,あなたは ずっと言ってくれていたわ
Dialogue: 0,0:17:28.15,0:17:30.48,Default,,0000,0000,0000,,あなたの目が
Dialogue: 0,0:17:30.48,0:17:35.65,Default,,0000,0000,0000,,あなたの声が あなたの態度が
Dialogue: 0,0:17:35.65,0:17:39.16,Default,,0000,0000,0000,,あなたの行いが ずっと
Dialogue: 0,0:17:39.16,0:17:42.16,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:17:42.16,0:17:46.17,Default,,0000,0000,0000,,私は お前を
Dialogue: 0,0:17:46.17,0:17:50.00,Default,,0000,0000,0000,,あなたは 私を
Dialogue: 0,0:17:50.00,0:17:52.00,Default,,0000,0000,0000,,愛してる
Dialogue: 0,0:17:56.68,0:17:58.68,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:18:02.82,0:18:08.49,Default,,0000,0000,0000,,最初から最後まで
Dialogue: 0,0:18:02.82,0:18:08.49,Default,,0000,0000,0000,,きっと 恵まれた人生だったわ
Dialogue: 0,0:18:08.49,0:18:11.82,Default,,0000,0000,0000,,たくさんの人たちに助けられて
Dialogue: 0,0:18:11.82,0:18:13.99,Default,,0000,0000,0000,,あなたと出会って
Dialogue: 0,0:18:13.99,0:18:18.66,Default,,0000,0000,0000,,あなたたちなら大丈夫って 信じてるから
Dialogue: 0,0:18:18.66,0:18:23.17,Default,,0000,0000,0000,,ずっと ずっと 愛しているから
Dialogue: 0,0:18:23.17,0:18:26.34,Default,,0000,0000,0000,,最後に 1つだけ
Dialogue: 0,0:18:26.34,0:18:31.01,Default,,0000,0000,0000,,聞けなくて 心残りなことがあったの
Dialogue: 0,0:18:31.01,0:18:36.01,Default,,0000,0000,0000,,実は 一目ぼれだったんです なんて知ったら
Dialogue: 0,0:18:36.01,0:18:40.09,Default,,0000,0000,0000,,あなたは どのくらい 驚いてくれましたか?
Dialogue: 0,0:20:14.85,0:20:18.85,Default,,0000,0000,0000,,これで満足か?
Dialogue: 0,0:20:14.85,0:20:18.85,Default,,0000,0000,0000,,満足とは?
Dialogue: 0,0:20:18.85,0:20:22.02,Default,,0000,0000,0000,,とぼけるなよ!
Dialogue: 0,0:20:18.85,0:20:22.02,Default,,0000,0000,0000,,見たままだろうが!
Dialogue: 0,0:20:22.02,0:20:25.52,Default,,0000,0000,0000,,これで 名実ともに 剣聖の座は お前のものだよ!
Dialogue: 0,0:20:25.52,0:20:27.53,Default,,0000,0000,0000,,おめでとう!
Dialogue: 0,0:20:27.53,0:20:30.86,Default,,0000,0000,0000,,先代を死なせて 加護を奪ったって うわさも
Dialogue: 0,0:20:30.86,0:20:33.87,Default,,0000,0000,0000,,疑いようのない事実ってわけだ
Dialogue: 0,0:20:33.87,0:20:35.87,Default,,0000,0000,0000,,なあ 満足か?
Dialogue: 0,0:20:35.87,0:20:38.37,Default,,0000,0000,0000,,満足だろ? おい!
Dialogue: 0,0:20:38.37,0:20:42.87,Default,,0000,0000,0000,,何を おっしゃられているのか 意味が よくわかりません
Dialogue: 0,0:20:42.87,0:20:47.71,Default,,0000,0000,0000,,くっ! すかした顔 してるんじゃねえぞ くそがきが!
Dialogue: 0,0:20:47.71,0:20:51.38,Default,,0000,0000,0000,,くっ 図に乗るんじゃねえぞ
Dialogue: 0,0:20:51.38,0:20:55.05,Default,,0000,0000,0000,,お前が 何を言ったところで 俺が見たものは変わらねえ
Dialogue: 0,0:20:55.05,0:20:57.06,Default,,0000,0000,0000,,お前が おふくろを
Dialogue: 0,0:20:57.06,0:21:00.86,Default,,0000,0000,0000,,テレシア・ヴァン・アストレアを ぶった斬ったってのは事実だ
Dialogue: 0,0:21:00.86,0:21:03.53,Default,,0000,0000,0000,,公表するぞ
Dialogue: 0,0:21:00.86,0:21:03.53,Default,,0000,0000,0000,,世間に言い触らして
Dialogue: 0,0:21:03.53,0:21:09.00,Default,,0000,0000,0000,,誰も お前を剣聖だなんて
Dialogue: 0,0:21:03.53,0:21:09.00,Default,,0000,0000,0000,,認めないようにしてやる!
Dialogue: 0,0:21:09.00,0:21:12.17,Default,,0000,0000,0000,,なんのかんの言って お前は 剣聖って名誉が
Dialogue: 0,0:21:12.17,0:21:14.17,Default,,0000,0000,0000,,手放せねえだろうが
Dialogue: 0,0:21:14.17,0:21:19.01,Default,,0000,0000,0000,,肉親を斬り殺しておいて 剣聖?
Dialogue: 0,0:21:14.17,0:21:19.01,Default,,0000,0000,0000,,王国の剣?
Dialogue: 0,0:21:19.01,0:21:23.18,Default,,0000,0000,0000,,ハハッ! 笑わせるな この人殺しが!
Dialogue: 0,0:21:23.18,0:21:27.69,Default,,0000,0000,0000,,副団長 何度 おっしゃられても 意味が わかりません
Dialogue: 0,0:21:27.69,0:21:30.86,Default,,0000,0000,0000,,勘違いです
Dialogue: 0,0:21:27.69,0:21:30.86,Default,,0000,0000,0000,,くっ あっ
Dialogue: 0,0:21:30.86,0:21:35.39,Default,,0000,0000,0000,,今の敵は 秘術によって 動かされていただけの しかばねです
Dialogue: 0,0:21:35.39,0:21:37.56,Default,,0000,0000,0000,,先代剣聖
Dialogue: 0,0:21:37.56,0:21:40.07,Default,,0000,0000,0000,,おばあ様であったはずが ありません
Dialogue: 0,0:21:40.07,0:21:45.54,Default,,0000,0000,0000,,じゃあ じゃあ
Dialogue: 0,0:21:40.07,0:21:45.54,Default,,0000,0000,0000,,最後のあれは なんだ?
Dialogue: 0,0:21:45.54,0:21:47.54,Default,,0000,0000,0000,,俺や お前を 恨めしそうに にらんで
Dialogue: 0,0:21:47.54,0:21:49.54,Default,,0000,0000,0000,,あれが おふくろで
Dialogue: 0,0:21:49.54,0:21:53.05,Default,,0000,0000,0000,,母上でないなら!
Dialogue: 0,0:21:49.54,0:21:53.05,Default,,0000,0000,0000,,もう やめろ ハインケル
Dialogue: 0,0:21:53.05,0:21:58.05,Default,,0000,0000,0000,,やめろって おやじ
Dialogue: 0,0:21:58.05,0:22:00.82,Default,,0000,0000,0000,,あんた それでいいのかよ?
Dialogue: 0,0:21:58.05,0:22:00.82,Default,,0000,0000,0000,,こいつは
Dialogue: 0,0:22:00.82,0:22:03.32,Default,,0000,0000,0000,,やめろ
Dialogue: 0,0:22:00.82,0:22:03.32,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:22:03.32,0:22:07.16,Default,,0000,0000,0000,,やめろ ハインケル やめろ
Dialogue: 0,0:22:07.16,0:22:09.16,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:22:14.00,0:22:17.50,Default,,0000,0000,0000,,来るな!
Dialogue: 0,0:22:14.00,0:22:17.50,Default,,0000,0000,0000,,あっ ハッ
Dialogue: 0,0:22:17.50,0:22:20.17,Default,,0000,0000,0000,,ラインハルト
Dialogue: 0,0:22:17.50,0:22:20.17,Default,,0000,0000,0000,,はい
Dialogue: 0,0:22:20.17,0:22:26.68,Default,,0000,0000,0000,,祖母を テレシアを斬ったことを
Dialogue: 0,0:22:26.68,0:22:29.18,Default,,0000,0000,0000,,後悔しているか?
Dialogue: 0,0:22:29.18,0:22:32.35,Default,,0000,0000,0000,,いいえ
Dialogue: 0,0:22:32.35,0:22:35.19,Default,,0000,0000,0000,,僕は正しいことをした
Dialogue: 0,0:22:35.19,0:22:37.69,Default,,0000,0000,0000,,そのことを悔やんだりはしない
Dialogue: 0,0:22:37.69,0:22:41.53,Default,,0000,0000,0000,,そうだな
Dialogue: 0,0:22:41.53,0:22:43.53,Default,,0000,0000,0000,,そのとおりだ
Dialogue: 0,0:22:45.86,0:22:50.20,Default,,0000,0000,0000,,お前は正しい 私が間違っている
Dialogue: 0,0:22:50.20,0:22:54.37,Default,,0000,0000,0000,,だから お前と話すことは もう 何もない
Dialogue: 0,0:22:54.37,0:22:58.54,Default,,0000,0000,0000,,この戦い あなたの力が必要な場面は
Dialogue: 0,0:22:58.54,0:23:00.48,Default,,0000,0000,0000,,他にも ありましょう
Dialogue: 0,0:23:00.48,0:23:04.98,Default,,0000,0000,0000,,どうか 剣聖ラインハルト殿
Dialogue: 0,0:23:11.36,0:23:13.66,Default,,0000,0000,0000,,あっ おやじ殿 1人でなんて
Dialogue: 0,0:23:13.66,0:23:16.66,Default,,0000,0000,0000,,私の心配は不要だ
Dialogue: 0,0:23:16.66,0:23:21.00,Default,,0000,0000,0000,,お前は 自分の安全だけ 考えていればいい
Dialogue: 0,0:23:21.00,0:23:23.00,Default,,0000,0000,0000,,それでいい
Dialogue: 0,0:23:23.00,0:23:26.17,Default,,0000,0000,0000,,なん だよ なんだよ!
Dialogue: 0,0:23:26.17,0:23:29.84,Default,,0000,0000,0000,,なんだよ!
Dialogue: 0,0:23:26.17,0:23:29.84,Default,,0000,0000,0000,,なんだ! なんだ! くそっ!
Dialogue: 0,0:23:29.84,0:23:31.84,Default,,0000,0000,0000,,なんなんだよ!
Dialogue: 0,0:23:31.84,0:23:35.05,Default,,0000,0000,0000,,くそっ! くそっ!
Dialogue: 0,0:23:31.84,0:23:35.05,Default,,0000,0000,0000,,くそっ! くそっ!
Dialogue: 0,0:23:35.05,0:23:37.68,Default,,0000,0000,0000,,どいつも こいつも
Dialogue: 0,0:23:37.68,0:23:41.35,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:23:41.35,0:23:44.52,Default,,0000,0000,0000,,どいつも こいつも 死んじまえ!
Dialogue: 0,0:23:44.52,0:23:47.13,Default,,0000,0000,0000,,死んじまえ!
