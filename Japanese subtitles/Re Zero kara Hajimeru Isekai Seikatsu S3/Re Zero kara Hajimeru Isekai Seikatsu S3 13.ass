Dialogue: 0,0:00:07.84,0:00:14.68,Default,,0000,0000,0000,,がぁ!
Dialogue: 0,0:00:14.68,0:00:19.59,Default,,0000,0000,0000,,ハァハァハァ
Dialogue: 0,0:00:22.69,0:00:26.03,Default,,0000,0000,0000,,ぐっ
Dialogue: 0,0:00:26.03,0:00:29.86,Default,,0000,0000,0000,,ガァー!
Dialogue: 0,0:00:26.03,0:00:29.86,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:00:29.86,0:00:32.37,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:35.70,0:00:37.70,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:45.38,0:00:47.55,Default,,0000,0000,0000,,くっ!
Dialogue: 0,0:00:47.55,0:00:50.72,Default,,0000,0000,0000,,ガァー!
Dialogue: 0,0:00:47.55,0:00:50.72,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:00:50.72,0:00:52.72,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:00:57.89,0:00:59.89,Default,,0000,0000,0000,,ぐっ
Dialogue: 0,0:01:02.50,0:01:05.00,Default,,0000,0000,0000,,ぐっ
Dialogue: 0,0:01:05.00,0:01:07.53,Default,,0000,0000,0000,,あ!!
Dialogue: 0,0:01:07.53,0:01:11.04,Default,,0000,0000,0000,,うぅ!
Dialogue: 0,0:01:11.04,0:01:13.84,Default,,0000,0000,0000,,あっ! がっ! うっ ぐっ
Dialogue: 0,0:01:13.84,0:01:17.34,Default,,0000,0000,0000,,うっ! あ!
Dialogue: 0,0:01:17.34,0:01:20.35,Default,,0000,0000,0000,,うおっ! うわ!
Dialogue: 0,0:01:22.68,0:01:25.89,Default,,0000,0000,0000,,うっ! ハッ!
Dialogue: 0,0:01:25.89,0:01:27.85,Default,,0000,0000,0000,,ぐあ!
Dialogue: 0,0:03:14.36,0:03:18.83,Default,,0000,0000,0000,,所詮 この世は 暴飲暴食
Dialogue: 0,0:03:18.83,0:03:21.37,Default,,0000,0000,0000,,いただきます!
Dialogue: 0,0:03:21.37,0:03:25.14,Default,,0000,0000,0000,,商人との商談は 最後まで聞くものですよ!
Dialogue: 0,0:03:28.54,0:03:33.01,Default,,0000,0000,0000,,絶対に 切り札があるから
Dialogue: 0,0:03:33.01,0:03:35.05,Default,,0000,0000,0000,,ああ? うっ うわ!
Dialogue: 0,0:03:35.05,0:03:38.35,Default,,0000,0000,0000,,水竜の狩りは 残酷ですよ
Dialogue: 0,0:03:46.73,0:03:48.73,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:03:48.73,0:03:51.20,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:03:48.73,0:03:51.20,Default,,0000,0000,0000,,すげえな おい!
Dialogue: 0,0:03:51.20,0:03:54.03,Default,,0000,0000,0000,,あれ お前が やらかしたのかよ!
Dialogue: 0,0:03:54.03,0:03:57.70,Default,,0000,0000,0000,,助けられたな 面目ない
Dialogue: 0,0:03:57.70,0:04:01.31,Default,,0000,0000,0000,,どうやって操ったか 詳しくは聞かないが
Dialogue: 0,0:04:01.31,0:04:03.81,Default,,0000,0000,0000,,そうしてくれると助かります
Dialogue: 0,0:04:03.81,0:04:07.31,Default,,0000,0000,0000,,それで フェルト様は なぜ ここに?
Dialogue: 0,0:04:03.81,0:04:07.31,Default,,0000,0000,0000,,ハインケルさんは
Dialogue: 0,0:04:07.31,0:04:10.82,Default,,0000,0000,0000,,あの くそおやじなら カンバリーに見張らせてある
Dialogue: 0,0:04:10.82,0:04:14.15,Default,,0000,0000,0000,,私らは 宿に置いた物を 取りに行く途中だったんだ
Dialogue: 0,0:04:14.15,0:04:17.16,Default,,0000,0000,0000,,宿に置いた物ですか?
Dialogue: 0,0:04:17.16,0:04:22.00,Default,,0000,0000,0000,,おう 私んとこの 魔法使いがくれた 秘密兵器でな
Dialogue: 0,0:04:22.00,0:04:25.33,Default,,0000,0000,0000,,どうも 結構な力があるミーティア って話なんだが
Dialogue: 0,0:04:25.33,0:04:28.33,Default,,0000,0000,0000,,待ってください
Dialogue: 0,0:04:25.33,0:04:28.33,Default,,0000,0000,0000,,あっ んっ?
Dialogue: 0,0:04:47.52,0:04:50.52,Default,,0000,0000,0000,,チッ!
Dialogue: 0,0:04:47.52,0:04:50.52,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:04:50.52,0:04:54.69,Default,,0000,0000,0000,,フェルト様 そのミーティアは 信用が置けますか?
Dialogue: 0,0:04:54.69,0:04:59.97,Default,,0000,0000,0000,,ロム爺たちの話じゃ ラインハルトだって
Dialogue: 0,0:04:54.69,0:04:59.97,Default,,0000,0000,0000,,無事じゃ済まねえらしいぜ?
Dialogue: 0,0:04:59.97,0:05:03.64,Default,,0000,0000,0000,,ハッハハ
Dialogue: 0,0:04:59.97,0:05:03.64,Default,,0000,0000,0000,,指標として わかりやすいですね
Dialogue: 0,0:05:03.64,0:05:07.64,Default,,0000,0000,0000,,わかりました
Dialogue: 0,0:05:03.64,0:05:07.64,Default,,0000,0000,0000,,ここは 僕たちで時間を稼ぎます
Dialogue: 0,0:05:07.64,0:05:09.68,Default,,0000,0000,0000,,うん
Dialogue: 0,0:05:09.68,0:05:13.85,Default,,0000,0000,0000,,その間に ミーティアを 回収ってか できんのかよ?
Dialogue: 0,0:05:13.85,0:05:17.35,Default,,0000,0000,0000,,フェルト様の足の速さしだい ってところでしょうか
Dialogue: 0,0:05:17.35,0:05:19.85,Default,,0000,0000,0000,,その挑発 乗ってやるぜ
Dialogue: 0,0:05:19.85,0:05:22.49,Default,,0000,0000,0000,,ガストンを預けっから うまく使ってくれ
Dialogue: 0,0:05:22.49,0:05:25.36,Default,,0000,0000,0000,,俺もかよ!
Dialogue: 0,0:05:25.36,0:05:29.86,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:25.36,0:05:29.86,Default,,0000,0000,0000,,思ったより やるみたいだけどさ
Dialogue: 0,0:05:29.86,0:05:34.03,Default,,0000,0000,0000,,ただの水とかげってのは 頂けないよね
Dialogue: 0,0:05:34.03,0:05:39.37,Default,,0000,0000,0000,,美食家の僕たちとしちゃ
Dialogue: 0,0:05:34.03,0:05:39.37,Default,,0000,0000,0000,,前菜にも こだわりたいしさ
Dialogue: 0,0:05:39.37,0:05:43.18,Default,,0000,0000,0000,,ガストン!
Dialogue: 0,0:05:39.37,0:05:43.18,Default,,0000,0000,0000,,これで死んだら 化けて出るからな!
Dialogue: 0,0:05:43.18,0:05:46.88,Default,,0000,0000,0000,,ヘヘッ! フッ! ハハッ!
Dialogue: 0,0:05:46.88,0:05:49.18,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:05:49.18,0:05:53.02,Default,,0000,0000,0000,,邪魔するんじゃ あっ?
Dialogue: 0,0:05:53.02,0:05:57.52,Default,,0000,0000,0000,,流法か!
Dialogue: 0,0:05:53.02,0:05:57.52,Default,,0000,0000,0000,,でくの坊が やるじゃないか!
Dialogue: 0,0:05:57.52,0:06:00.13,Default,,0000,0000,0000,,でくの坊は余計だろうが
Dialogue: 0,0:06:00.13,0:06:03.63,Default,,0000,0000,0000,,おら!
Dialogue: 0,0:06:03.63,0:06:06.47,Default,,0000,0000,0000,,へぇ なるほど
Dialogue: 0,0:06:06.47,0:06:09.77,Default,,0000,0000,0000,,そういう作戦を立ててきたわけだ
Dialogue: 0,0:06:11.80,0:06:16.31,Default,,0000,0000,0000,,余裕ですね? 今のところ いいところなしですよ
Dialogue: 0,0:06:18.81,0:06:26.82,Default,,0000,0000,0000,,さっきの子が抜けたら
Dialogue: 0,0:06:18.81,0:06:26.82,Default,,0000,0000,0000,,ルイが喜びそうなのは 3人かな
Dialogue: 0,0:06:26.82,0:06:29.32,Default,,0000,0000,0000,,うっ この1年
Dialogue: 0,0:06:29.32,0:06:35.33,Default,,0000,0000,0000,,下手な武闘派より戦わされてるの
Dialogue: 0,0:06:29.32,0:06:35.33,Default,,0000,0000,0000,,商人として どうなんですかね
Dialogue: 0,0:06:47.34,0:06:51.51,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:06:47.34,0:06:51.51,Default,,0000,0000,0000,,ギャー!
Dialogue: 0,0:06:47.34,0:06:51.51,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:06:51.51,0:06:54.85,Default,,0000,0000,0000,,ああ あっ かっ
Dialogue: 0,0:06:54.85,0:06:58.35,Default,,0000,0000,0000,,うっ 最高に気持ち悪いな それ
Dialogue: 0,0:06:58.35,0:07:01.29,Default,,0000,0000,0000,,俺 グロいの あんまり得意じゃねえんだわ
Dialogue: 0,0:07:01.29,0:07:05.46,Default,,0000,0000,0000,,キャハハハハハ! 女に 気持ち悪いとか
Dialogue: 0,0:07:05.46,0:07:08.80,Default,,0000,0000,0000,,言葉を飾れねえ男は モテやしねえですよ
Dialogue: 0,0:07:08.80,0:07:11.63,Default,,0000,0000,0000,,やっぱり 裏で暗躍するようなやつは
Dialogue: 0,0:07:11.63,0:07:15.47,Default,,0000,0000,0000,,そんなのばっかりなんですかね?
Dialogue: 0,0:07:11.63,0:07:15.47,Default,,0000,0000,0000,,あん?
Dialogue: 0,0:07:15.47,0:07:19.31,Default,,0000,0000,0000,,私 ずっと考えてたんですよ
Dialogue: 0,0:07:19.31,0:07:21.31,Default,,0000,0000,0000,,水門を ちょっぴり開けて
Dialogue: 0,0:07:21.31,0:07:26.51,Default,,0000,0000,0000,,街の半分ぐれえを
Dialogue: 0,0:07:21.31,0:07:26.51,Default,,0000,0000,0000,,水浸しにした野郎の正体を
Dialogue: 0,0:07:26.51,0:07:30.18,Default,,0000,0000,0000,,あれがなけりゃ あの時点で この街の すう勢は
Dialogue: 0,0:07:30.18,0:07:33.35,Default,,0000,0000,0000,,決まってた みてえなもんですからね
Dialogue: 0,0:07:33.35,0:07:35.32,Default,,0000,0000,0000,,フフフフ
Dialogue: 0,0:07:35.32,0:07:38.83,Default,,0000,0000,0000,,なんの話だか さっぱり わからねえな
Dialogue: 0,0:07:38.83,0:07:43.86,Default,,0000,0000,0000,,お・ま・け・に
Dialogue: 0,0:07:38.83,0:07:43.86,Default,,0000,0000,0000,,私が欲しがっている 魔女の遺骨
Dialogue: 0,0:07:43.86,0:07:46.53,Default,,0000,0000,0000,,その在りかを 知ってやがる連中が
Dialogue: 0,0:07:46.53,0:07:52.37,Default,,0000,0000,0000,,どうも次々と 私と無関係に
Dialogue: 0,0:07:46.53,0:07:52.37,Default,,0000,0000,0000,,死にやがったみてえなんですが?
Dialogue: 0,0:07:52.37,0:07:55.04,Default,,0000,0000,0000,,そいつは ご愁傷さまだ
Dialogue: 0,0:07:55.04,0:07:59.05,Default,,0000,0000,0000,,こんな混乱した状況じゃ 不運なこともあるだろうよ
Dialogue: 0,0:07:59.05,0:08:02.45,Default,,0000,0000,0000,,キャハ! とぼけやがるんですか?
Dialogue: 0,0:08:02.45,0:08:05.45,Default,,0000,0000,0000,,いいですよ そんな てめえでも
Dialogue: 0,0:08:05.45,0:08:10.66,Default,,0000,0000,0000,,私の雄大な愛は
Dialogue: 0,0:08:05.45,0:08:10.66,Default,,0000,0000,0000,,優しく包み込みます
Dialogue: 0,0:08:10.66,0:08:18.13,Default,,0000,0000,0000,,そのかぶと 外して 素顔を見せて
Dialogue: 0,0:08:10.66,0:08:18.13,Default,,0000,0000,0000,,私を抱いて愛してくれるなら
Dialogue: 0,0:08:18.13,0:08:22.13,Default,,0000,0000,0000,,ごめんなさい
Dialogue: 0,0:08:18.13,0:08:22.13,Default,,0000,0000,0000,,気持ちは うれしいけど
Dialogue: 0,0:08:22.13,0:08:25.14,Default,,0000,0000,0000,,お互いのこと まだよく知らないし
Dialogue: 0,0:08:25.14,0:08:27.31,Default,,0000,0000,0000,,それに 友達に うわさとかされたら
Dialogue: 0,0:08:27.31,0:08:30.84,Default,,0000,0000,0000,,恥ずかしいから お断りするわ
Dialogue: 0,0:08:30.84,0:08:36.32,Default,,0000,0000,0000,,女に振り回されるのが好きな
Dialogue: 0,0:08:30.84,0:08:36.32,Default,,0000,0000,0000,,マゾ気質の雄肉の性癖なら
Dialogue: 0,0:08:36.32,0:08:39.99,Default,,0000,0000,0000,,私も悪くねえと思うんですが
Dialogue: 0,0:08:39.99,0:08:45.32,Default,,0000,0000,0000,,ああ? 何 言っ
Dialogue: 0,0:08:39.99,0:08:45.32,Default,,0000,0000,0000,,きつい目つきに 肉感的な体つき
Dialogue: 0,0:08:45.32,0:08:48.66,Default,,0000,0000,0000,,性格は 傍若無人で 気分屋で
Dialogue: 0,0:08:48.66,0:08:53.33,Default,,0000,0000,0000,,よく しゃべるけど 頭はいい
Dialogue: 0,0:08:48.66,0:08:53.33,Default,,0000,0000,0000,,そんなとこ?
Dialogue: 0,0:08:53.33,0:08:55.67,Default,,0000,0000,0000,,髪の長さは
Dialogue: 0,0:08:55.67,0:08:58.84,Default,,0000,0000,0000,,おっと 金髪じゃねえっぽい?
Dialogue: 0,0:08:58.84,0:09:03.44,Default,,0000,0000,0000,,赤 じゃねえですね
Dialogue: 0,0:08:58.84,0:09:03.44,Default,,0000,0000,0000,,だいだい色だ
Dialogue: 0,0:09:03.44,0:09:08.95,Default,,0000,0000,0000,,年齢は
Dialogue: 0,0:09:03.44,0:09:08.95,Default,,0000,0000,0000,,おっと このくれえですか
Dialogue: 0,0:09:08.95,0:09:11.28,Default,,0000,0000,0000,,声は どうです?
Dialogue: 0,0:09:11.28,0:09:14.62,Default,,0000,0000,0000,,チッ 胸くそ悪いことしやがる
Dialogue: 0,0:09:14.62,0:09:17.29,Default,,0000,0000,0000,,どこで 姫さんを見かけてやがった?
Dialogue: 0,0:09:17.29,0:09:20.79,Default,,0000,0000,0000,,見たことも 意識したこともねえですけど
Dialogue: 0,0:09:20.79,0:09:25.30,Default,,0000,0000,0000,,てめえの顔以外の しぐさ 反応 態度
Dialogue: 0,0:09:25.30,0:09:30.97,Default,,0000,0000,0000,,一挙手一投足 見逃さねえで
Dialogue: 0,0:09:25.30,0:09:30.97,Default,,0000,0000,0000,,全力で尽くすのが私
Dialogue: 0,0:09:30.97,0:09:35.14,Default,,0000,0000,0000,,私を見ろ 私だけを見てろ
Dialogue: 0,0:09:35.14,0:09:40.15,Default,,0000,0000,0000,,顔と 体と 声と しぐさと
Dialogue: 0,0:09:35.14,0:09:40.15,Default,,0000,0000,0000,,全部 全部
Dialogue: 0,0:09:40.15,0:09:44.05,Default,,0000,0000,0000,,てめえの好み ど真ん中のはずだろうが!
Dialogue: 0,0:09:45.99,0:09:50.99,Default,,0000,0000,0000,,悪いが その愛し方は 人類には まだ早すぎるわ
Dialogue: 0,0:09:50.99,0:09:53.83,Default,,0000,0000,0000,,どうして拒みやがるんです?
Dialogue: 0,0:09:53.83,0:09:58.16,Default,,0000,0000,0000,,私のどこが
Dialogue: 0,0:09:53.83,0:09:58.16,Default,,0000,0000,0000,,何が 気に入らねえんです?
Dialogue: 0,0:09:58.16,0:10:02.84,Default,,0000,0000,0000,,勘違いすんな 俺は お前のこと 好きでも嫌いでもねえ
Dialogue: 0,0:10:02.84,0:10:06.51,Default,,0000,0000,0000,,どうでもいい あっ ごめん うそ
Dialogue: 0,0:10:06.51,0:10:10.51,Default,,0000,0000,0000,,やっぱり お前 気持ち悪いから嫌いだわ
Dialogue: 0,0:10:10.51,0:10:13.68,Default,,0000,0000,0000,,息が目に染みる
Dialogue: 0,0:10:10.51,0:10:13.68,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:10:13.68,0:10:17.68,Default,,0000,0000,0000,,この浮気性の腐れくず肉が!
Dialogue: 0,0:10:13.68,0:10:17.68,Default,,0000,0000,0000,,おっと
Dialogue: 0,0:10:17.68,0:10:20.19,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:10:20.19,0:10:22.52,Default,,0000,0000,0000,,よっと お!
Dialogue: 0,0:10:22.52,0:10:24.52,Default,,0000,0000,0000,,ドーナ!
Dialogue: 0,0:10:28.03,0:10:30.03,Default,,0000,0000,0000,,チッ!
Dialogue: 0,0:10:34.03,0:10:36.04,Default,,0000,0000,0000,,えっ?
Dialogue: 0,0:10:38.04,0:10:40.37,Default,,0000,0000,0000,,汚え花火になりやがれ
Dialogue: 0,0:10:40.37,0:10:42.38,Default,,0000,0000,0000,,エル・ドーナ!
Dialogue: 0,0:10:49.05,0:10:54.22,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:10:54.22,0:10:56.22,Default,,0000,0000,0000,,どうだ?
Dialogue: 0,0:10:54.22,0:10:56.22,Default,,0000,0000,0000,,こんだけ やってやりゃあ
Dialogue: 0,0:10:56.22,0:11:01.66,Default,,0000,0000,0000,,ひでえもんじゃねえですか
Dialogue: 0,0:10:56.22,0:11:01.66,Default,,0000,0000,0000,,うっ くそっ!
Dialogue: 0,0:11:01.66,0:11:06.53,Default,,0000,0000,0000,,ここまで やんなくても いいでしょうに
Dialogue: 0,0:11:06.53,0:11:09.00,Default,,0000,0000,0000,,いくらなんでも反則だろ
Dialogue: 0,0:11:09.00,0:11:12.84,Default,,0000,0000,0000,,やん! そんなに つらそうなのに 引かねえとか
Dialogue: 0,0:11:12.84,0:11:15.01,Default,,0000,0000,0000,,けなげじゃねえですか!
Dialogue: 0,0:11:15.01,0:11:19.01,Default,,0000,0000,0000,,好感度 爆上がり! キャハハハハハハハ!
Dialogue: 0,0:11:19.01,0:11:21.68,Default,,0000,0000,0000,,あいにく こっちは しっかりやれって
Dialogue: 0,0:11:21.68,0:11:24.18,Default,,0000,0000,0000,,姫さんに 尻 たたかれてんだよ
Dialogue: 0,0:11:24.18,0:11:27.19,Default,,0000,0000,0000,,体が ぐねぐね変わる女も おっかねえが
Dialogue: 0,0:11:27.19,0:11:31.02,Default,,0000,0000,0000,,俺は 姫さんの ご機嫌 損ねるほうが 怖え
Dialogue: 0,0:11:31.02,0:11:34.53,Default,,0000,0000,0000,,まだ 他の女の話をしやがるとか
Dialogue: 0,0:11:34.53,0:11:36.56,Default,,0000,0000,0000,,これは 本格的に
Dialogue: 0,0:11:36.56,0:11:40.90,Default,,0000,0000,0000,,しつけてやらねえとならねえ みてえじゃねえですか
Dialogue: 0,0:11:40.90,0:11:46.17,Default,,0000,0000,0000,,ああ 全く
Dialogue: 0,0:11:40.90,0:11:46.17,Default,,0000,0000,0000,,今日は なんて星の悪い日だよ!
Dialogue: 0,0:11:54.38,0:11:59.99,Default,,0000,0000,0000,,うぅ あっ ここは
Dialogue: 0,0:11:59.99,0:12:02.82,Default,,0000,0000,0000,,あっ うぅ
Dialogue: 0,0:12:02.82,0:12:04.82,Default,,0000,0000,0000,,ハッ んっ
Dialogue: 0,0:12:08.03,0:12:10.66,Default,,0000,0000,0000,,うぅっ!
Dialogue: 0,0:12:10.66,0:12:15.33,Default,,0000,0000,0000,,で どんなやつなんだ?
Dialogue: 0,0:12:10.66,0:12:15.33,Default,,0000,0000,0000,,八つ腕のクルガンって
Dialogue: 0,0:12:15.33,0:12:19.84,Default,,0000,0000,0000,,ひと言で言や 生きる伝説ってやつだ
Dialogue: 0,0:12:19.84,0:12:22.51,Default,,0000,0000,0000,,伝説?
Dialogue: 0,0:12:19.84,0:12:22.51,Default,,0000,0000,0000,,ああ
Dialogue: 0,0:12:22.51,0:12:28.18,Default,,0000,0000,0000,,普通 俺たち 亜人族ってえのは
Dialogue: 0,0:12:22.51,0:12:28.18,Default,,0000,0000,0000,,魔法への適正が高えんだが
Dialogue: 0,0:12:28.18,0:12:32.85,Default,,0000,0000,0000,,多腕族は そん中でも 例外的に低い種族だ
Dialogue: 0,0:12:32.85,0:12:36.22,Default,,0000,0000,0000,,だっから 亜人族の立場が保証されってる
Dialogue: 0,0:12:36.22,0:12:41.39,Default,,0000,0000,0000,,ヴォラキア帝国ん中でも
Dialogue: 0,0:12:36.22,0:12:41.39,Default,,0000,0000,0000,,差別されて ばかにされってた
Dialogue: 0,0:12:41.39,0:12:44.06,Default,,0000,0000,0000,,それを見返したのが クルガンだ
Dialogue: 0,0:12:44.06,0:12:47.73,Default,,0000,0000,0000,,自分たちを殺そうとした 領主の兵隊どもを
Dialogue: 0,0:12:47.73,0:12:50.24,Default,,0000,0000,0000,,たった1人で返り討ちにっして
Dialogue: 0,0:12:50.24,0:12:54.24,Default,,0000,0000,0000,,逆に 領主に 自分たち多腕族を認めっさせた
Dialogue: 0,0:12:54.24,0:12:56.41,Default,,0000,0000,0000,,通常 多腕族は
Dialogue: 0,0:12:56.41,0:12:59.75,Default,,0000,0000,0000,,4本から5本の腕を持って 生まれますが
Dialogue: 0,0:12:59.75,0:13:02.65,Default,,0000,0000,0000,,8本もの腕を持つ クルガンは
Dialogue: 0,0:13:02.65,0:13:05.99,Default,,0000,0000,0000,,幼少のころから気味悪がられ 部族の中でも
Dialogue: 0,0:13:05.99,0:13:08.49,Default,,0000,0000,0000,,つまはじきにされていたと 聞きます
Dialogue: 0,0:13:08.49,0:13:12.49,Default,,0000,0000,0000,,それでも 彼は 部族のために 剣を取った
Dialogue: 0,0:13:12.49,0:13:15.16,Default,,0000,0000,0000,,鬼包丁だろ
Dialogue: 0,0:13:15.16,0:13:20.50,Default,,0000,0000,0000,,ええ クルガンは 鬼包丁と呼ばれる
Dialogue: 0,0:13:15.16,0:13:20.50,Default,,0000,0000,0000,,複数の剣を操る
Dialogue: 0,0:13:20.50,0:13:24.70,Default,,0000,0000,0000,,ですが 認めた相手にしか それは使わず
Dialogue: 0,0:13:24.70,0:13:27.71,Default,,0000,0000,0000,,その すべての剣を抜かせれば
Dialogue: 0,0:13:27.71,0:13:31.71,Default,,0000,0000,0000,,それだけで 戦士の名誉だと 言われたほどです
Dialogue: 0,0:13:31.71,0:13:38.02,Default,,0000,0000,0000,,つまり
Dialogue: 0,0:13:31.71,0:13:38.02,Default,,0000,0000,0000,,まだ がき扱いってわけかよ
Dialogue: 0,0:13:38.02,0:13:40.72,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:13:40.72,0:13:44.56,Default,,0000,0000,0000,,おら! うっ! くっ
Dialogue: 0,0:13:44.56,0:13:46.56,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:13:46.56,0:13:49.90,Default,,0000,0000,0000,,あっ! うっ
Dialogue: 0,0:13:49.90,0:13:54.07,Default,,0000,0000,0000,,うら! ブッ! がっ!
Dialogue: 0,0:13:54.07,0:13:57.74,Default,,0000,0000,0000,,ぐっ! がっ! ぐはっ! ハァ
Dialogue: 0,0:13:57.74,0:14:00.14,Default,,0000,0000,0000,,ハッ! うっ!
Dialogue: 0,0:14:00.14,0:14:03.98,Default,,0000,0000,0000,,うっ おら!
Dialogue: 0,0:14:03.98,0:14:08.81,Default,,0000,0000,0000,,なめってんらねえぞ おら!
Dialogue: 0,0:14:08.81,0:14:10.82,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:14:19.83,0:14:21.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:24.00,0:14:28.67,Default,,0000,0000,0000,,んっ ぐあ! ぐぅ!
Dialogue: 0,0:14:28.67,0:14:30.67,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:34.17,0:14:37.51,Default,,0000,0000,0000,,うぐっ
Dialogue: 0,0:14:37.51,0:14:41.18,Default,,0000,0000,0000,,あっ おら!
Dialogue: 0,0:14:41.18,0:14:44.85,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:14:41.18,0:14:44.85,Default,,0000,0000,0000,,ぐっ かっ くくくく
Dialogue: 0,0:14:44.85,0:14:46.85,Default,,0000,0000,0000,,がっ くくくく
Dialogue: 0,0:14:46.85,0:14:52.19,Default,,0000,0000,0000,,ああ あっ がっ
Dialogue: 0,0:14:52.19,0:14:56.90,Default,,0000,0000,0000,,んっ うぅ おら!
Dialogue: 0,0:15:01.33,0:15:03.30,Default,,0000,0000,0000,,ぶはっ! うぅっ!
Dialogue: 0,0:15:17.68,0:15:21.69,Default,,0000,0000,0000,,ゴホゴホ ゴホゴホッ! ゴホゴホ ゴホゴホッ!
Dialogue: 0,0:15:21.69,0:15:23.82,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:15:23.82,0:15:28.49,Default,,0000,0000,0000,,避難所? なんで
Dialogue: 0,0:15:28.49,0:15:30.80,Default,,0000,0000,0000,,ゴージャス・タイガー?
Dialogue: 0,0:15:28.49,0:15:30.80,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:15:40.84,0:15:42.84,Default,,0000,0000,0000,,ゴージャス・タイガー
Dialogue: 0,0:15:42.84,0:15:46.21,Default,,0000,0000,0000,,キャー!
Dialogue: 0,0:15:42.84,0:15:46.21,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:15:49.05,0:15:51.52,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:15:51.52,0:15:54.72,Default,,0000,0000,0000,,キャッ!
Dialogue: 0,0:15:51.52,0:15:54.72,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:54.72,0:15:59.09,Default,,0000,0000,0000,,うっ あっ! あっ あっ あっ
Dialogue: 0,0:16:08.30,0:16:12.00,Default,,0000,0000,0000,,ハッ! あっ
Dialogue: 0,0:16:14.14,0:16:17.04,Default,,0000,0000,0000,,くっ お!
Dialogue: 0,0:16:26.82,0:16:31.82,Default,,0000,0000,0000,,俺は 愛してねえ お前は
Dialogue: 0,0:16:31.82,0:16:33.83,Default,,0000,0000,0000,,あの女じゃねえ
Dialogue: 0,0:16:39.67,0:16:41.67,Default,,0000,0000,0000,,ハァ あっ
Dialogue: 0,0:16:44.34,0:16:46.34,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:16:48.34,0:16:50.84,Default,,0000,0000,0000,,あっ ありがとう
Dialogue: 0,0:16:50.84,0:16:54.01,Default,,0000,0000,0000,,フッ んっ
Dialogue: 0,0:16:54.01,0:16:56.32,Default,,0000,0000,0000,,離れってろ
Dialogue: 0,0:17:10.16,0:17:12.80,Default,,0000,0000,0000,,ゴージャス・タイガー!
Dialogue: 0,0:17:10.16,0:17:12.80,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:17:12.80,0:17:16.14,Default,,0000,0000,0000,,ゴージャス・タイガー!
Dialogue: 0,0:17:12.80,0:17:16.14,Default,,0000,0000,0000,,おい チビ お前 何を
Dialogue: 0,0:17:16.14,0:17:18.47,Default,,0000,0000,0000,,ゴージャス・タイガー!
Dialogue: 0,0:17:18.47,0:17:22.47,Default,,0000,0000,0000,,ゴッ ゴージャス・タイガー!
Dialogue: 0,0:17:18.47,0:17:22.47,Default,,0000,0000,0000,,いいから じっとしとっけ
Dialogue: 0,0:17:22.47,0:17:24.64,Default,,0000,0000,0000,,ゴージャス・タイガー!
Dialogue: 0,0:17:22.47,0:17:24.64,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:17:24.64,0:17:27.35,Default,,0000,0000,0000,,勝ってくれ!
Dialogue: 0,0:17:24.64,0:17:27.35,Default,,0000,0000,0000,,ゴージャス・タイガー!
Dialogue: 0,0:17:27.35,0:17:29.85,Default,,0000,0000,0000,,見てるしかできない けど
Dialogue: 0,0:17:29.85,0:17:32.82,Default,,0000,0000,0000,,戦って勝って!
Dialogue: 0,0:17:29.85,0:17:32.82,Default,,0000,0000,0000,,いや いいから
Dialogue: 0,0:17:29.85,0:17:32.82,Default,,0000,0000,0000,,頑張れ タイガー!
Dialogue: 0,0:17:32.82,0:17:36.49,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:17:32.82,0:17:36.49,Default,,0000,0000,0000,,お願い!
Dialogue: 0,0:17:32.82,0:17:36.49,Default,,0000,0000,0000,,頑張れ!
Dialogue: 0,0:17:36.49,0:17:41.49,Default,,0000,0000,0000,,大将 やっぱり 演説が 効きっ過ぎちまってんだよ
Dialogue: 0,0:17:41.49,0:17:44.33,Default,,0000,0000,0000,,フン! 悪いな
Dialogue: 0,0:17:44.33,0:17:48.33,Default,,0000,0000,0000,,果たし合いにしちゃあ 騒がし過ぎるっだろうが
Dialogue: 0,0:17:48.33,0:17:54.34,Default,,0000,0000,0000,,特に いちばん うるせえの
Dialogue: 0,0:17:48.33,0:17:54.34,Default,,0000,0000,0000,,あいつら 俺の弟と妹っなんだよ
Dialogue: 0,0:17:54.34,0:17:57.84,Default,,0000,0000,0000,,あとで ちゃんと 言い聞かせておくからよ
Dialogue: 0,0:17:57.84,0:18:02.78,Default,,0000,0000,0000,,いけ! タイガー!
Dialogue: 0,0:18:02.78,0:18:06.45,Default,,0000,0000,0000,,ゴージャス・タイガー 頑張れ!
Dialogue: 0,0:18:02.78,0:18:06.45,Default,,0000,0000,0000,,頑張ってくれ!
Dialogue: 0,0:18:06.45,0:18:09.46,Default,,0000,0000,0000,,見せてやれ!
Dialogue: 0,0:18:06.45,0:18:09.46,Default,,0000,0000,0000,,頑張れ!
Dialogue: 0,0:18:14.83,0:18:16.80,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:18:25.34,0:18:30.48,Default,,0000,0000,0000,,ハッ! ありがとうよ 俺は
Dialogue: 0,0:18:30.48,0:18:33.08,Default,,0000,0000,0000,,あっ フッ
Dialogue: 0,0:18:35.48,0:18:39.32,Default,,0000,0000,0000,,俺様は 超最強の盾
Dialogue: 0,0:18:39.32,0:18:44.62,Default,,0000,0000,0000,,いいや
Dialogue: 0,0:18:39.32,0:18:44.62,Default,,0000,0000,0000,,ゴージャス・タイガー ガーフィール・ティンゼルだ!
Dialogue: 0,0:18:46.66,0:18:49.36,Default,,0000,0000,0000,,うぅ!
Dialogue: 0,0:18:49.36,0:18:51.33,Default,,0000,0000,0000,,せい! ぐはっ!
Dialogue: 0,0:18:54.37,0:18:56.64,Default,,0000,0000,0000,,はぁ!
Dialogue: 0,0:19:00.61,0:19:04.44,Default,,0000,0000,0000,,うっ! ハッ! フッ! フッ! ハッ!
Dialogue: 0,0:19:04.44,0:19:09.62,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:19:04.44,0:19:09.62,Default,,0000,0000,0000,,うわっ! ぐっ はぁ!
Dialogue: 0,0:19:09.62,0:19:11.82,Default,,0000,0000,0000,,うら!
Dialogue: 0,0:19:14.45,0:19:17.96,Default,,0000,0000,0000,,はぁ!
Dialogue: 0,0:19:17.96,0:19:20.46,Default,,0000,0000,0000,,あっ うわっ! かっ
Dialogue: 0,0:19:25.30,0:19:29.13,Default,,0000,0000,0000,,うっ うぅ! うお!
Dialogue: 0,0:19:29.13,0:19:32.14,Default,,0000,0000,0000,,うっ うっ うっ! うぅ!
Dialogue: 0,0:19:32.14,0:19:35.47,Default,,0000,0000,0000,,ハァハァ
Dialogue: 0,0:19:35.47,0:19:37.64,Default,,0000,0000,0000,,くっ! うっ うっ!
Dialogue: 0,0:19:50.66,0:19:52.66,Default,,0000,0000,0000,,うぅっ! くっ
Dialogue: 0,0:19:54.66,0:19:57.00,Default,,0000,0000,0000,,うぅ!
Dialogue: 0,0:19:57.00,0:20:03.34,Default,,0000,0000,0000,,がぁ!
Dialogue: 0,0:20:03.34,0:20:07.67,Default,,0000,0000,0000,,がぁ!!
Dialogue: 0,0:20:07.67,0:20:10.68,Default,,0000,0000,0000,,ハァ ぐっ うっ
Dialogue: 0,0:20:10.68,0:20:16.52,Default,,0000,0000,0000,,んっ うぅ ペッ!
Dialogue: 0,0:20:38.20,0:20:40.21,Default,,0000,0000,0000,,見事
Dialogue: 0,0:22:15.33,0:22:17.34,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:22:19.67,0:22:23.51,Default,,0000,0000,0000,,潔いなんて話じゃねえぞ
Dialogue: 0,0:22:23.51,0:22:25.51,Default,,0000,0000,0000,,ゴージャス・タイガー
Dialogue: 0,0:22:23.51,0:22:25.51,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:22:29.35,0:22:31.52,Default,,0000,0000,0000,,泣いてんじゃねえよ
Dialogue: 0,0:22:31.52,0:22:37.52,Default,,0000,0000,0000,,ばっ ばかじゃないの?
Dialogue: 0,0:22:31.52,0:22:37.52,Default,,0000,0000,0000,,うちが泣くわけないし!
Dialogue: 0,0:22:37.52,0:22:40.36,Default,,0000,0000,0000,,いいから寝てなさいよ!
Dialogue: 0,0:22:40.36,0:22:43.70,Default,,0000,0000,0000,,すぐに 誰か 治癒師さんを呼んでもらって
Dialogue: 0,0:22:43.70,0:22:48.37,Default,,0000,0000,0000,,うっ! ああ くそ やべえ
Dialogue: 0,0:22:43.70,0:22:48.37,Default,,0000,0000,0000,,ゴージャス・タイガー?
Dialogue: 0,0:22:48.37,0:22:51.70,Default,,0000,0000,0000,,ゴージャス・タイガー! しっかりして!
Dialogue: 0,0:22:48.37,0:22:51.70,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:22:51.70,0:22:53.71,Default,,0000,0000,0000,,誰か! 治癒師さんを呼んできて!
Dialogue: 0,0:22:53.71,0:22:55.71,Default,,0000,0000,0000,,ゴージャス・タイガー!
Dialogue: 0,0:22:53.71,0:22:55.71,Default,,0000,0000,0000,,誰か!
Dialogue: 0,0:22:55.71,0:22:59.11,Default,,0000,0000,0000,,あっち 無事なのかよ
Dialogue: 0,0:23:06.02,0:23:09.52,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:23:09.52,0:23:12.16,Default,,0000,0000,0000,,死神の加護
Dialogue: 0,0:23:12.16,0:23:16.66,Default,,0000,0000,0000,,もとより 長く戦えるとは思っていない
Dialogue: 0,0:23:16.66,0:23:20.17,Default,,0000,0000,0000,,迷って出たなどとは思わん
Dialogue: 0,0:23:20.17,0:23:23.00,Default,,0000,0000,0000,,天の差配にも期待はない
Dialogue: 0,0:23:23.00,0:23:26.84,Default,,0000,0000,0000,,逢瀬なら いずれ 天上で いくらでも果たせる
Dialogue: 0,0:23:26.84,0:23:29.84,Default,,0000,0000,0000,,夢など見ない
Dialogue: 0,0:23:29.84,0:23:32.01,Default,,0000,0000,0000,,これは現実だ
Dialogue: 0,0:23:32.01,0:23:36.35,Default,,0000,0000,0000,,テレシア お前は美しい
Dialogue: 0,0:23:36.35,0:23:40.65,Default,,0000,0000,0000,,だから お前は ここにいてはならない!
Dialogue: 0,0:23:43.89,0:23:47.66,Default,,0000,0000,0000,,フッ! んっ うぅ
