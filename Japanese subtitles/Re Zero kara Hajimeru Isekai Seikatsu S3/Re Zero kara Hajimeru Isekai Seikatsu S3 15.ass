Dialogue: 0,0:01:40.37,0:01:42.87,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:01:40.37,0:01:42.87,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:01:42.87,0:01:44.87,Default,,0000,0000,0000,,相手は たった1人の がきだ!
Dialogue: 0,0:01:44.87,0:01:46.87,Default,,0000,0000,0000,,囲んで しとめろ!
Dialogue: 0,0:01:44.87,0:01:46.87,Default,,0000,0000,0000,,逃がすんじゃない!
Dialogue: 0,0:01:46.87,0:01:49.71,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:01:46.87,0:01:49.71,Default,,0000,0000,0000,,ハッ! よっ
Dialogue: 0,0:01:49.71,0:01:53.21,Default,,0000,0000,0000,,そうそう たった1人の がきだよ
Dialogue: 0,0:01:53.21,0:01:56.72,Default,,0000,0000,0000,,捕まえて 八つ裂きにしてごらんよ!
Dialogue: 0,0:01:56.72,0:01:59.05,Default,,0000,0000,0000,,チッ こうなりゃ やけだ!
Dialogue: 0,0:01:56.72,0:01:59.05,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:01:59.05,0:02:03.16,Default,,0000,0000,0000,,おら! うら! くそっ! この!
Dialogue: 0,0:02:03.16,0:02:05.66,Default,,0000,0000,0000,,拳王の掌
Dialogue: 0,0:02:07.66,0:02:09.66,Default,,0000,0000,0000,,うっ ごはっ!
Dialogue: 0,0:02:12.37,0:02:16.20,Default,,0000,0000,0000,,ドーナ!
Dialogue: 0,0:02:16.20,0:02:19.51,Default,,0000,0000,0000,,予想以上に 決定打に欠けますね
Dialogue: 0,0:02:19.51,0:02:22.04,Default,,0000,0000,0000,,いい大人が寄ってたかって
Dialogue: 0,0:02:22.04,0:02:25.55,Default,,0000,0000,0000,,こんな がき1匹 捕まえらんないの?
Dialogue: 0,0:02:25.55,0:02:32.05,Default,,0000,0000,0000,,だめだ だめだよ だめだろ
Dialogue: 0,0:02:25.55,0:02:32.05,Default,,0000,0000,0000,,だめじゃない だめしかない!
Dialogue: 0,0:02:32.05,0:02:35.05,Default,,0000,0000,0000,,手当たりしだい悪食の ロイに比べたら
Dialogue: 0,0:02:35.05,0:02:40.06,Default,,0000,0000,0000,,僕たちなんか
Dialogue: 0,0:02:35.05,0:02:40.06,Default,,0000,0000,0000,,かわいいもんだけどね
Dialogue: 0,0:02:35.05,0:02:40.06,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:02:40.06,0:02:44.90,Default,,0000,0000,0000,,いいさ いいよ いいとも いいかも!
Dialogue: 0,0:02:44.90,0:02:49.04,Default,,0000,0000,0000,,いいだろう いいじゃないか いいだろうからこそ!
Dialogue: 0,0:02:49.04,0:02:52.57,Default,,0000,0000,0000,,暴飲暴食!
Dialogue: 0,0:02:52.57,0:02:55.54,Default,,0000,0000,0000,,精霊騎士 ユリウス・ユークリウス!
Dialogue: 0,0:02:55.54,0:02:57.58,Default,,0000,0000,0000,,油断はしない!
Dialogue: 0,0:02:55.54,0:02:57.58,Default,,0000,0000,0000,,おら!
Dialogue: 0,0:02:57.58,0:03:02.02,Default,,0000,0000,0000,,アルクラウゼリア!
Dialogue: 0,0:03:02.02,0:03:05.85,Default,,0000,0000,0000,,本当 兄様は 想像どおりで
Dialogue: 0,0:03:05.85,0:03:09.36,Default,,0000,0000,0000,,すてきだね
Dialogue: 0,0:03:05.85,0:03:09.36,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:03:09.36,0:03:11.32,Default,,0000,0000,0000,,ヘヘッ
Dialogue: 0,0:03:09.36,0:03:11.32,Default,,0000,0000,0000,,何?
Dialogue: 0,0:03:14.03,0:03:16.36,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:03:16.36,0:03:23.20,Default,,0000,0000,0000,,僕たちの憧れだった兄様が
Dialogue: 0,0:03:16.36,0:03:23.20,Default,,0000,0000,0000,,必死に努力して編み出した魔法
Dialogue: 0,0:03:23.20,0:03:27.71,Default,,0000,0000,0000,,俺たちが 知らないわけないじゃないか!
Dialogue: 0,0:03:27.71,0:03:31.71,Default,,0000,0000,0000,,ぐだっぐだ うるさいんじゃ ぼけ!
Dialogue: 0,0:03:27.71,0:03:31.71,Default,,0000,0000,0000,,ワオ!
Dialogue: 0,0:03:31.71,0:03:34.88,Default,,0000,0000,0000,,ほら 犬肉に串刺し!
Dialogue: 0,0:03:31.71,0:03:34.88,Default,,0000,0000,0000,,うっ あっ!
Dialogue: 0,0:03:34.88,0:03:37.55,Default,,0000,0000,0000,,硬くて筋張ったお肉は 突き刺して
Dialogue: 0,0:03:37.55,0:03:42.39,Default,,0000,0000,0000,,軟らかくして 食べやすくして 肥やしにしやすくして
Dialogue: 0,0:03:42.39,0:03:46.06,Default,,0000,0000,0000,,循環 循環 食物連鎖!
Dialogue: 0,0:03:46.06,0:03:48.90,Default,,0000,0000,0000,,ねっ? リカードさん!
Dialogue: 0,0:03:46.06,0:03:48.90,Default,,0000,0000,0000,,うぅっ! がっ
Dialogue: 0,0:03:48.90,0:03:51.06,Default,,0000,0000,0000,,下がれ! イア! アロ!
Dialogue: 0,0:03:53.40,0:03:55.74,Default,,0000,0000,0000,,なっ!
Dialogue: 0,0:03:53.40,0:03:55.74,Default,,0000,0000,0000,,はい その連携
Dialogue: 0,0:03:55.74,0:03:59.71,Default,,0000,0000,0000,,僕たち お見通しでした!
Dialogue: 0,0:03:55.74,0:03:59.71,Default,,0000,0000,0000,,ぐっ! うっ
Dialogue: 0,0:03:59.71,0:04:01.64,Default,,0000,0000,0000,,いいね いいね!
Dialogue: 0,0:04:01.64,0:04:06.15,Default,,0000,0000,0000,,兄様とリカードさんを相手に 俺たちが大健闘!
Dialogue: 0,0:04:06.15,0:04:09.32,Default,,0000,0000,0000,,これが 僕たちの諦めてた世界
Dialogue: 0,0:04:09.32,0:04:13.65,Default,,0000,0000,0000,,ああ ずるい ずるい ずるいな!
Dialogue: 0,0:04:13.65,0:04:17.49,Default,,0000,0000,0000,,何を抜かしとんじゃ 気色悪い がきやな
Dialogue: 0,0:04:17.49,0:04:20.49,Default,,0000,0000,0000,,それに なんで わいの名前 知っとるんや?
Dialogue: 0,0:04:20.49,0:04:24.16,Default,,0000,0000,0000,,君は 血が止まるまで おとなしくしていたまえ
Dialogue: 0,0:04:24.16,0:04:26.50,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:04:24.16,0:04:26.50,Default,,0000,0000,0000,,フン!
Dialogue: 0,0:04:24.16,0:04:26.50,Default,,0000,0000,0000,,ハッハー! このぐらい
Dialogue: 0,0:04:26.50,0:04:31.17,Default,,0000,0000,0000,,おっ? うっ!
Dialogue: 0,0:04:26.50,0:04:31.17,Default,,0000,0000,0000,,これは 初見だろう?
Dialogue: 0,0:04:31.17,0:04:33.67,Default,,0000,0000,0000,,ウヒヒ! さっすが!
Dialogue: 0,0:04:33.67,0:04:37.01,Default,,0000,0000,0000,,努力の天才 最優の騎士!
Dialogue: 0,0:04:37.01,0:04:39.01,Default,,0000,0000,0000,,俺たちも知らない魅力が
Dialogue: 0,0:04:39.01,0:04:43.68,Default,,0000,0000,0000,,まだまだ 満載でいらっしゃるのね
Dialogue: 0,0:04:43.68,0:04:46.69,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:04:43.68,0:04:46.69,Default,,0000,0000,0000,,月食
Dialogue: 0,0:04:43.68,0:04:46.69,Default,,0000,0000,0000,,ぐっ!
Dialogue: 0,0:04:46.69,0:04:50.02,Default,,0000,0000,0000,,ぐっ うっ うっ
Dialogue: 0,0:04:50.02,0:04:53.53,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:04:50.02,0:04:53.53,Default,,0000,0000,0000,,色男ばっかり
Dialogue: 0,0:04:53.53,0:04:57.86,Default,,0000,0000,0000,,88人も殴り殺した 僕たちの拳打
Dialogue: 0,0:04:57.86,0:05:03.00,Default,,0000,0000,0000,,兄様の骨の髄まで
Dialogue: 0,0:04:57.86,0:05:03.00,Default,,0000,0000,0000,,ズシンと響いてくれたかしらん?
Dialogue: 0,0:05:03.00,0:05:07.07,Default,,0000,0000,0000,,ぐっ ゲホッ! ゲホッ! うっ
Dialogue: 0,0:05:03.00,0:05:07.07,Default,,0000,0000,0000,,んっ おんどりゃあ
Dialogue: 0,0:05:10.01,0:05:13.35,Default,,0000,0000,0000,,おかえんなさい!
Dialogue: 0,0:05:10.01,0:05:13.35,Default,,0000,0000,0000,,なっ
Dialogue: 0,0:05:13.35,0:05:18.35,Default,,0000,0000,0000,,ご飯にする? ごちそうにする?
Dialogue: 0,0:05:13.35,0:05:18.35,Default,,0000,0000,0000,,それとも
Dialogue: 0,0:05:18.35,0:05:22.86,Default,,0000,0000,0000,,ば・ん・さ・ん?
Dialogue: 0,0:05:22.86,0:05:24.86,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:05:24.86,0:05:28.36,Default,,0000,0000,0000,,剣技に武技に 今度は魔法かい
Dialogue: 0,0:05:28.36,0:05:30.86,Default,,0000,0000,0000,,おんどれ なんやねん!
Dialogue: 0,0:05:30.86,0:05:33.87,Default,,0000,0000,0000,,俺たちは しがない無名の魔法使い
Dialogue: 0,0:05:33.87,0:05:37.54,Default,,0000,0000,0000,,家族にも誇れぬ日陰者です
Dialogue: 0,0:05:37.54,0:05:40.21,Default,,0000,0000,0000,,なんてね!
Dialogue: 0,0:05:40.21,0:05:43.08,Default,,0000,0000,0000,,うぅ はぁ!
Dialogue: 0,0:05:45.88,0:05:48.05,Default,,0000,0000,0000,,ニッ
Dialogue: 0,0:05:48.05,0:05:51.22,Default,,0000,0000,0000,,ワーオ! すごい! すごい すごい!
Dialogue: 0,0:05:51.22,0:05:54.05,Default,,0000,0000,0000,,しのがれたのって 久しぶりじゃない?
Dialogue: 0,0:05:54.05,0:05:57.89,Default,,0000,0000,0000,,久々に きっつい
Dialogue: 0,0:05:54.05,0:05:57.89,Default,,0000,0000,0000,,くそったれが!
Dialogue: 0,0:05:57.89,0:06:02.80,Default,,0000,0000,0000,,剣も 武術も 魔法すらも それだけのものを 修めていながら
Dialogue: 0,0:06:02.80,0:06:04.96,Default,,0000,0000,0000,,どうして 悪に染まった?
Dialogue: 0,0:06:04.96,0:06:08.13,Default,,0000,0000,0000,,それだけの力があれ
Dialogue: 0,0:06:04.96,0:06:08.13,Default,,0000,0000,0000,,言うと思った!
Dialogue: 0,0:06:08.13,0:06:11.30,Default,,0000,0000,0000,,そう言うと思ったよ 兄様
Dialogue: 0,0:06:11.30,0:06:16.31,Default,,0000,0000,0000,,僕たちの知ってる兄様なら
Dialogue: 0,0:06:11.30,0:06:16.31,Default,,0000,0000,0000,,俺たちの信じる兄様なら
Dialogue: 0,0:06:16.31,0:06:20.48,Default,,0000,0000,0000,,そう言いだすと思ったさ 思ってたよ!
Dialogue: 0,0:06:20.48,0:06:23.98,Default,,0000,0000,0000,,覚えているかい?
Dialogue: 0,0:06:20.48,0:06:23.98,Default,,0000,0000,0000,,子どものころを!
Dialogue: 0,0:06:23.98,0:06:27.82,Default,,0000,0000,0000,,病気がちな僕たちが 調子を崩して
Dialogue: 0,0:06:27.82,0:06:32.99,Default,,0000,0000,0000,,兄様に 庭の木になったリンガを
Dialogue: 0,0:06:27.82,0:06:32.99,Default,,0000,0000,0000,,ねだったときのことを!
Dialogue: 0,0:06:32.99,0:06:37.50,Default,,0000,0000,0000,,まだ俺たちも 兄様も小さかったし
Dialogue: 0,0:06:37.50,0:06:41.17,Default,,0000,0000,0000,,兄様も 最初は 無理だって言ったんだよ!
Dialogue: 0,0:06:41.17,0:06:46.67,Default,,0000,0000,0000,,覚えてる? 覚えてないかな!?
Dialogue: 0,0:06:46.67,0:06:51.18,Default,,0000,0000,0000,,何を 何を言っている?
Dialogue: 0,0:06:51.18,0:06:55.85,Default,,0000,0000,0000,,そんなこと 私は知らない
Dialogue: 0,0:06:51.18,0:06:55.85,Default,,0000,0000,0000,,知らない!
Dialogue: 0,0:06:55.85,0:07:00.99,Default,,0000,0000,0000,,ずっと ずっと 思ってたよ
Dialogue: 0,0:06:55.85,0:07:00.99,Default,,0000,0000,0000,,ずっと ずっと 感じてたよ
Dialogue: 0,0:07:00.99,0:07:05.46,Default,,0000,0000,0000,,違うってことを
Dialogue: 0,0:07:00.99,0:07:05.46,Default,,0000,0000,0000,,お荷物だってことを
Dialogue: 0,0:07:05.46,0:07:08.96,Default,,0000,0000,0000,,それが どうだ? 今は どうだ?
Dialogue: 0,0:07:08.96,0:07:12.63,Default,,0000,0000,0000,,いい気分だ!
Dialogue: 0,0:07:08.96,0:07:12.63,Default,,0000,0000,0000,,こんな気分だったのか!
Dialogue: 0,0:07:12.63,0:07:15.97,Default,,0000,0000,0000,,ああ 気持ちよかったろうさ
Dialogue: 0,0:07:15.97,0:07:21.47,Default,,0000,0000,0000,,僕たちも 俺たちも
Dialogue: 0,0:07:15.97,0:07:21.47,Default,,0000,0000,0000,,やっと わかったよ
Dialogue: 0,0:07:21.47,0:07:26.85,Default,,0000,0000,0000,,ぐっ! 私には 何1つ
Dialogue: 0,0:07:21.47,0:07:26.85,Default,,0000,0000,0000,,貴様のことは わからない!
Dialogue: 0,0:07:26.85,0:07:29.85,Default,,0000,0000,0000,,フン! フッ! うぅ! くっ
Dialogue: 0,0:07:29.85,0:07:31.85,Default,,0000,0000,0000,,フッ! うっ! うっ! フッ!
Dialogue: 0,0:07:29.85,0:07:31.85,Default,,0000,0000,0000,,ヘヘヘヘ んっ?
Dialogue: 0,0:07:31.85,0:07:35.19,Default,,0000,0000,0000,,我が蕾たちよ!
Dialogue: 0,0:07:31.85,0:07:35.19,Default,,0000,0000,0000,,ユリウス!
Dialogue: 0,0:07:35.19,0:07:37.16,Default,,0000,0000,0000,,これで 最後だ!
Dialogue: 0,0:07:40.36,0:07:44.03,Default,,0000,0000,0000,,兄様は リンガを取ってくれた
Dialogue: 0,0:07:44.03,0:07:48.60,Default,,0000,0000,0000,,だから 僕たちは 兄様が憎かったのさ
Dialogue: 0,0:07:56.68,0:08:02.78,Default,,0000,0000,0000,,さてさて あと何回やったら
Dialogue: 0,0:07:56.68,0:08:02.78,Default,,0000,0000,0000,,私を 本気で殺せますかね?
Dialogue: 0,0:08:02.78,0:08:08.12,Default,,0000,0000,0000,,確かに 俺が100回 死んでも
Dialogue: 0,0:08:02.78,0:08:08.12,Default,,0000,0000,0000,,てめえを殺せるか怪しいとこだ
Dialogue: 0,0:08:08.12,0:08:10.96,Default,,0000,0000,0000,,けど てめえこそ 考えが甘えんじゃねえのか?
Dialogue: 0,0:08:10.96,0:08:12.96,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:08:12.96,0:08:15.63,Default,,0000,0000,0000,,てめえが来るのは お見通しだったんだ
Dialogue: 0,0:08:15.63,0:08:18.97,Default,,0000,0000,0000,,てことは おもてなしの準備は万端
Dialogue: 0,0:08:18.97,0:08:22.47,Default,,0000,0000,0000,,世にも奇妙で恐ろしい 必殺の一撃が
Dialogue: 0,0:08:22.47,0:08:26.64,Default,,0000,0000,0000,,てめえの魂を粉々
Dialogue: 0,0:08:22.47,0:08:26.64,Default,,0000,0000,0000,,じゃあ やったらいいじゃねえですか
Dialogue: 0,0:08:26.64,0:08:30.14,Default,,0000,0000,0000,,せっかくの おもてなし せっかくの準備
Dialogue: 0,0:08:30.14,0:08:34.81,Default,,0000,0000,0000,,それって 全部 てめえらが 私のために してくれたことでしょ?
Dialogue: 0,0:08:34.81,0:08:36.85,Default,,0000,0000,0000,,それを足蹴にするとか
Dialogue: 0,0:08:36.85,0:08:40.35,Default,,0000,0000,0000,,私の主義主張が 許しやがりませんし!
Dialogue: 0,0:08:40.35,0:08:42.99,Default,,0000,0000,0000,,待て待て! 本気で死ぬぜ?
Dialogue: 0,0:08:42.99,0:08:44.99,Default,,0000,0000,0000,,死ぬのって痛えし 怖えぞ?
Dialogue: 0,0:08:44.99,0:08:48.49,Default,,0000,0000,0000,,初めてだったら なおさらだ
Dialogue: 0,0:08:44.99,0:08:48.49,Default,,0000,0000,0000,,やめとけよ
Dialogue: 0,0:08:48.49,0:08:53.70,Default,,0000,0000,0000,,初体験は 本当に大事なときまで
Dialogue: 0,0:08:48.49,0:08:53.70,Default,,0000,0000,0000,,取っとけって
Dialogue: 0,0:08:53.70,0:08:57.70,Default,,0000,0000,0000,,わざわざ下品な言葉に 合わせてくれるなんて!
Dialogue: 0,0:08:57.70,0:09:00.94,Default,,0000,0000,0000,,私を思ってくれてるのね!
Dialogue: 0,0:09:00.94,0:09:06.11,Default,,0000,0000,0000,,そうじゃなく
Dialogue: 0,0:09:00.94,0:09:06.11,Default,,0000,0000,0000,,私をだます うそだってんなら
Dialogue: 0,0:09:06.11,0:09:09.62,Default,,0000,0000,0000,,絶対に許さねえんですけど!
Dialogue: 0,0:09:12.62,0:09:18.96,Default,,0000,0000,0000,,ねっ? てめえは 一体
Dialogue: 0,0:09:12.62,0:09:18.96,Default,,0000,0000,0000,,どんな私が好き?
Dialogue: 0,0:09:18.96,0:09:20.96,Default,,0000,0000,0000,,ハァ
Dialogue: 0,0:09:24.30,0:09:27.60,Default,,0000,0000,0000,,俺は 誰も愛さねえよ
Dialogue: 0,0:09:31.14,0:09:33.81,Default,,0000,0000,0000,,ほんとに わなが! あっ!
Dialogue: 0,0:09:33.81,0:09:36.81,Default,,0000,0000,0000,,てめえのこと考えて 一生懸命 準備したよ
Dialogue: 0,0:09:36.81,0:09:41.48,Default,,0000,0000,0000,,普通に 愛じゃなくて 敵意で
Dialogue: 0,0:09:41.48,0:09:43.98,Default,,0000,0000,0000,,フッ!
Dialogue: 0,0:09:43.98,0:09:48.15,Default,,0000,0000,0000,,やだ 私のためだなんて
Dialogue: 0,0:09:48.15,0:09:50.82,Default,,0000,0000,0000,,これ 絶対に
Dialogue: 0,0:09:50.82,0:09:52.83,Default,,0000,0000,0000,,愛じゃねえですか?
Dialogue: 0,0:10:09.04,0:10:13.21,Default,,0000,0000,0000,,ブハッ! ハァハァハァ
Dialogue: 0,0:10:13.21,0:10:15.18,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:10:15.18,0:10:17.18,Default,,0000,0000,0000,,別に 遠慮せんでもええんちゃう?
Dialogue: 0,0:10:17.18,0:10:20.02,Default,,0000,0000,0000,,おっと
Dialogue: 0,0:10:17.18,0:10:20.02,Default,,0000,0000,0000,,気にしたりせえへんのに
Dialogue: 0,0:10:20.02,0:10:22.02,Default,,0000,0000,0000,,自意識過剰でな
Dialogue: 0,0:10:22.02,0:10:24.69,Default,,0000,0000,0000,,あとで 俺の顔が みんなの話題に なったらと思うと
Dialogue: 0,0:10:24.69,0:10:27.36,Default,,0000,0000,0000,,気が気じゃねえ
Dialogue: 0,0:10:24.69,0:10:27.36,Default,,0000,0000,0000,,そう?
Dialogue: 0,0:10:27.36,0:10:31.53,Default,,0000,0000,0000,,まさか ほんとに崩すことになるなんて
Dialogue: 0,0:10:31.53,0:10:35.07,Default,,0000,0000,0000,,アルさんが無事で 一安心やったわ
Dialogue: 0,0:10:35.07,0:10:38.24,Default,,0000,0000,0000,,こっそり 3回は潰れてた感があるけどな
Dialogue: 0,0:10:38.24,0:10:40.37,Default,,0000,0000,0000,,猫耳のおねにいちゃんは?
Dialogue: 0,0:10:40.37,0:10:42.38,Default,,0000,0000,0000,,ご心配 ありがと
Dialogue: 0,0:10:40.37,0:10:42.38,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:10:42.38,0:10:44.38,Default,,0000,0000,0000,,平気だよ
Dialogue: 0,0:10:44.38,0:10:46.38,Default,,0000,0000,0000,,色欲は?
Dialogue: 0,0:10:46.38,0:10:50.05,Default,,0000,0000,0000,,下敷きになったのは間違いねえよ
Dialogue: 0,0:10:46.38,0:10:50.05,Default,,0000,0000,0000,,ただ
Dialogue: 0,0:10:50.05,0:10:54.55,Default,,0000,0000,0000,,そのまま死んでくれた なんて 期待するだけ無駄だよね
Dialogue: 0,0:10:54.55,0:10:57.56,Default,,0000,0000,0000,,アナスタシア様の魔法で 顔が吹っ飛んでも
Dialogue: 0,0:10:57.56,0:11:01.66,Default,,0000,0000,0000,,ピンピンしてたくらいだし
Dialogue: 0,0:10:57.56,0:11:01.66,Default,,0000,0000,0000,,魔法?
Dialogue: 0,0:11:01.66,0:11:05.50,Default,,0000,0000,0000,,戦えないって お話だったのに 人が悪いよね
Dialogue: 0,0:11:05.50,0:11:08.17,Default,,0000,0000,0000,,ちょ ちょっと 何?
Dialogue: 0,0:11:08.17,0:11:13.51,Default,,0000,0000,0000,,冗談やったら笑えんのやけど
Dialogue: 0,0:11:08.17,0:11:13.51,Default,,0000,0000,0000,,アルさん どないしたん?
Dialogue: 0,0:11:13.51,0:11:16.18,Default,,0000,0000,0000,,どうしたも こうしたもねえよ
Dialogue: 0,0:11:16.18,0:11:19.85,Default,,0000,0000,0000,,アナスタシア・ホーシンが できねえはずのことをした
Dialogue: 0,0:11:19.85,0:11:23.02,Default,,0000,0000,0000,,てめえは 何を たくらんでやがる?
Dialogue: 0,0:11:23.02,0:11:25.85,Default,,0000,0000,0000,,いいかげんにして!
Dialogue: 0,0:11:23.02,0:11:25.85,Default,,0000,0000,0000,,なんなの? これは!
Dialogue: 0,0:11:25.85,0:11:27.85,Default,,0000,0000,0000,,おいおい なんのつもりだよ?
Dialogue: 0,0:11:27.85,0:11:31.36,Default,,0000,0000,0000,,今 味方同士で言い争ってる 場合じゃないって わからない?
Dialogue: 0,0:11:31.36,0:11:36.03,Default,,0000,0000,0000,,まだ何も終わってない!
Dialogue: 0,0:11:31.36,0:11:36.03,Default,,0000,0000,0000,,けんかしてる暇なんて
Dialogue: 0,0:11:36.03,0:11:38.86,Default,,0000,0000,0000,,わかったから 危ねえまねすんな!
Dialogue: 0,0:11:38.86,0:11:40.87,Default,,0000,0000,0000,,なんだ
Dialogue: 0,0:11:38.86,0:11:40.87,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:11:40.87,0:11:44.04,Default,,0000,0000,0000,,殺し合いに 発展したりしねえんですか?
Dialogue: 0,0:11:44.04,0:11:46.04,Default,,0000,0000,0000,,チュチュ
Dialogue: 0,0:11:46.04,0:11:48.04,Default,,0000,0000,0000,,チュー
Dialogue: 0,0:11:53.05,0:11:55.05,Default,,0000,0000,0000,,チッ!
Dialogue: 0,0:11:53.05,0:11:55.05,Default,,0000,0000,0000,,ひっ!
Dialogue: 0,0:11:59.72,0:12:02.52,Default,,0000,0000,0000,,ジャジャジャジャーン! おっ?
Dialogue: 0,0:12:02.52,0:12:04.59,Default,,0000,0000,0000,,チュチュ チュチュ チュチュ
Dialogue: 0,0:12:06.69,0:12:09.70,Default,,0000,0000,0000,,あっ ああ
Dialogue: 0,0:12:06.69,0:12:09.70,Default,,0000,0000,0000,,キャハハハハハハハハ!
Dialogue: 0,0:12:09.70,0:12:13.83,Default,,0000,0000,0000,,カペラちゃん 再登場です!
Dialogue: 0,0:12:13.83,0:12:19.00,Default,,0000,0000,0000,,ハッ! 殺せたとは思ってなかったが
Dialogue: 0,0:12:13.83,0:12:19.00,Default,,0000,0000,0000,,ノーダメージってのは こたえんな
Dialogue: 0,0:12:19.00,0:12:24.34,Default,,0000,0000,0000,,いやいやいや
Dialogue: 0,0:12:19.00,0:12:24.34,Default,,0000,0000,0000,,さすがの私も死を覚悟した
Dialogue: 0,0:12:24.34,0:12:29.01,Default,,0000,0000,0000,,なんてことはねえですが 胸は キュンキュンしましたよ?
Dialogue: 0,0:12:29.01,0:12:33.85,Default,,0000,0000,0000,,だって あんなにも熱烈に 私を思ってくれてたんですから
Dialogue: 0,0:12:33.85,0:12:36.02,Default,,0000,0000,0000,,当然でしょうが!
Dialogue: 0,0:12:36.02,0:12:38.86,Default,,0000,0000,0000,,あ 早合点しねえでくださいます?
Dialogue: 0,0:12:38.86,0:12:41.19,Default,,0000,0000,0000,,そんな 状況の見えねえ 読めねえ
Dialogue: 0,0:12:41.19,0:12:44.53,Default,,0000,0000,0000,,愚かな てめえらが いとおしいですけど
Dialogue: 0,0:12:44.53,0:12:49.03,Default,,0000,0000,0000,,私 今日は これで 引き揚げますから
Dialogue: 0,0:12:44.53,0:12:49.03,Default,,0000,0000,0000,,はっ?
Dialogue: 0,0:12:49.03,0:12:53.24,Default,,0000,0000,0000,,だから もう やらねえんですって
Dialogue: 0,0:12:53.24,0:12:57.08,Default,,0000,0000,0000,,おおよそ 私の やりてえことは 済んだし?
Dialogue: 0,0:12:57.08,0:13:00.48,Default,,0000,0000,0000,,かわいい かわいい てめえらの面も覚えましたし
Dialogue: 0,0:13:00.48,0:13:03.82,Default,,0000,0000,0000,,何より
Dialogue: 0,0:13:00.48,0:13:03.82,Default,,0000,0000,0000,,福音書が そう指示した
Dialogue: 0,0:13:03.82,0:13:06.32,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:13:03.82,0:13:06.32,Default,,0000,0000,0000,,んっ あっ
Dialogue: 0,0:13:06.32,0:13:09.49,Default,,0000,0000,0000,,ハァ 指示なんて言われると
Dialogue: 0,0:13:09.49,0:13:14.16,Default,,0000,0000,0000,,私が 本の言いなりみてえで 気に食わねえんですけど
Dialogue: 0,0:13:14.16,0:13:19.83,Default,,0000,0000,0000,,私が てめえらを思う気持ちは
Dialogue: 0,0:13:14.16,0:13:19.83,Default,,0000,0000,0000,,本の指示じゃなくて 本物
Dialogue: 0,0:13:19.83,0:13:22.54,Default,,0000,0000,0000,,純愛なんで
Dialogue: 0,0:13:22.54,0:13:24.87,Default,,0000,0000,0000,,くっ 何が純愛
Dialogue: 0,0:13:24.87,0:13:29.18,Default,,0000,0000,0000,,いっそ あいつを殺したら そうすれば クルシュ様のお体だって
Dialogue: 0,0:13:29.18,0:13:34.18,Default,,0000,0000,0000,,希望と幻想を履き違えるのって ばかのやることですよ?
Dialogue: 0,0:13:31.51,0:13:34.18,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:34.18,0:13:37.68,Default,,0000,0000,0000,,私と龍の血は 別問題
Dialogue: 0,0:13:37.68,0:13:40.35,Default,,0000,0000,0000,,私が死んでも
Dialogue: 0,0:13:37.68,0:13:40.35,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:40.35,0:13:45.02,Default,,0000,0000,0000,,血は消えねえっての!
Dialogue: 0,0:13:40.35,0:13:45.02,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:13:45.02,0:13:49.03,Default,,0000,0000,0000,,それでも私を追いたいってんなら しかたねえですね
Dialogue: 0,0:13:52.03,0:13:55.87,Default,,0000,0000,0000,,んっ マジかよ!
Dialogue: 0,0:13:52.03,0:13:55.87,Default,,0000,0000,0000,,亜獣
Dialogue: 0,0:13:55.87,0:13:59.87,Default,,0000,0000,0000,,へぇ 何それ?
Dialogue: 0,0:13:55.87,0:13:59.87,Default,,0000,0000,0000,,悪くねえ名前じゃねえですか
Dialogue: 0,0:13:59.87,0:14:05.81,Default,,0000,0000,0000,,半端で 醜くて 生きてて 死んでて
Dialogue: 0,0:13:59.87,0:14:05.81,Default,,0000,0000,0000,,ってとこがいいですね
Dialogue: 0,0:14:05.81,0:14:10.65,Default,,0000,0000,0000,,なんで あんたは こんなことができるの?
Dialogue: 0,0:14:10.65,0:14:14.49,Default,,0000,0000,0000,,どうして こんな残酷なことが
Dialogue: 0,0:14:14.49,0:14:16.66,Default,,0000,0000,0000,,うん
Dialogue: 0,0:14:16.66,0:14:20.83,Default,,0000,0000,0000,,死体で遊ぶななんて 教わってねえからですかね?
Dialogue: 0,0:14:20.83,0:14:24.33,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:14:20.83,0:14:24.33,Default,,0000,0000,0000,,ばか!
Dialogue: 0,0:14:20.83,0:14:24.33,Default,,0000,0000,0000,,挑発に乗んな! 逃げんだよ!
Dialogue: 0,0:14:24.33,0:14:27.00,Default,,0000,0000,0000,,こっちや!
Dialogue: 0,0:14:27.00,0:14:29.17,Default,,0000,0000,0000,,くそが!
Dialogue: 0,0:14:29.17,0:14:31.84,Default,,0000,0000,0000,,さあさ さあさ お逃げあそばせ!
Dialogue: 0,0:14:31.84,0:14:34.17,Default,,0000,0000,0000,,どんどん やらなきゃ 死体が増える!
Dialogue: 0,0:14:34.17,0:14:37.18,Default,,0000,0000,0000,,死体が増えたら 亜獣が増える!
Dialogue: 0,0:14:37.18,0:14:40.35,Default,,0000,0000,0000,,てめえら 気張って殺しまくって?
Dialogue: 0,0:14:40.35,0:14:45.85,Default,,0000,0000,0000,,アーハハハハハ! アハハハハハハハ!
Dialogue: 0,0:14:45.85,0:14:48.85,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:14:45.85,0:14:48.85,Default,,0000,0000,0000,,走れ走れ走れ!
Dialogue: 0,0:14:48.85,0:14:52.52,Default,,0000,0000,0000,,逃げきんだよ!
Dialogue: 0,0:14:48.85,0:14:52.52,Default,,0000,0000,0000,,ハァハァ ハァハァ
Dialogue: 0,0:14:52.52,0:14:55.19,Default,,0000,0000,0000,,誰か 誰か!
Dialogue: 0,0:14:55.19,0:14:57.20,Default,,0000,0000,0000,,わかったよ
Dialogue: 0,0:14:55.19,0:14:57.20,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:14:57.20,0:14:59.53,Default,,0000,0000,0000,,うわっ!
Dialogue: 0,0:14:57.20,0:14:59.53,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:14:57.20,0:14:59.53,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:14:59.53,0:15:04.00,Default,,0000,0000,0000,,フェリス 君の声 ちゃんと聞こえたよ
Dialogue: 0,0:15:04.00,0:15:06.67,Default,,0000,0000,0000,,ラインハルト!
Dialogue: 0,0:15:04.00,0:15:06.67,Default,,0000,0000,0000,,ぐっ この!
Dialogue: 0,0:15:06.67,0:15:11.34,Default,,0000,0000,0000,,殺して! 全部 全部 殺して!
Dialogue: 0,0:15:11.34,0:15:14.31,Default,,0000,0000,0000,,ちゃんと死なせてあげて!
Dialogue: 0,0:15:16.32,0:15:20.02,Default,,0000,0000,0000,,ああ 剣聖として 務めを果たす!
Dialogue: 0,0:15:22.19,0:15:26.16,Default,,0000,0000,0000,,うっ
Dialogue: 0,0:15:28.19,0:15:30.66,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:15:30.66,0:15:33.37,Default,,0000,0000,0000,,フゥ
Dialogue: 0,0:15:36.20,0:15:41.21,Default,,0000,0000,0000,,ダハハハハハハ!
Dialogue: 0,0:15:36.20,0:15:41.21,Default,,0000,0000,0000,,ほらほら 当ててごらんよ!
Dialogue: 0,0:15:41.21,0:15:45.68,Default,,0000,0000,0000,,大丈夫ですか?
Dialogue: 0,0:15:41.21,0:15:45.68,Default,,0000,0000,0000,,あのがき やたら戦うのが うめえ!
Dialogue: 0,0:15:45.68,0:15:49.21,Default,,0000,0000,0000,,戦うのが うまい?
Dialogue: 0,0:15:45.68,0:15:49.21,Default,,0000,0000,0000,,俺は ラインハルトのとこで
Dialogue: 0,0:15:49.21,0:15:51.88,Default,,0000,0000,0000,,庭師のじいさんに鍛えられたから わかる
Dialogue: 0,0:15:51.88,0:15:55.19,Default,,0000,0000,0000,,あいつの動きは 才能じゃねえ
Dialogue: 0,0:15:55.19,0:15:57.86,Default,,0000,0000,0000,,長年 鍛えたやつの動きだ
Dialogue: 0,0:15:57.86,0:16:00.79,Default,,0000,0000,0000,,鍛えた動き? あの若さで
Dialogue: 0,0:16:00.79,0:16:04.30,Default,,0000,0000,0000,,暴食の大罪司教
Dialogue: 0,0:16:04.30,0:16:06.80,Default,,0000,0000,0000,,まさか 食べた相手を
Dialogue: 0,0:16:06.80,0:16:10.97,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:16:06.80,0:16:10.97,Default,,0000,0000,0000,,がっ ぐふっ!
Dialogue: 0,0:16:10.97,0:16:17.31,Default,,0000,0000,0000,,今の反応からして 僕たちの種は
Dialogue: 0,0:16:10.97,0:16:17.31,Default,,0000,0000,0000,,割れちゃったってことかな?
Dialogue: 0,0:16:17.31,0:16:21.65,Default,,0000,0000,0000,,さあ なんのことか 全く心当たりがありませんが
Dialogue: 0,0:16:21.65,0:16:24.82,Default,,0000,0000,0000,,お兄さん 腹芸 向いてないね
Dialogue: 0,0:16:24.82,0:16:29.82,Default,,0000,0000,0000,,痛い目 見る前に 商人なんて辞めたらどうかな?
Dialogue: 0,0:16:29.82,0:16:33.16,Default,,0000,0000,0000,,ヒックス・ハルトマン
Dialogue: 0,0:16:33.16,0:16:36.50,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:16:36.50,0:16:39.83,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:16:36.50,0:16:39.83,Default,,0000,0000,0000,,ダイナスさん あそこで倒れているのは?
Dialogue: 0,0:16:39.83,0:16:42.67,Default,,0000,0000,0000,,うっ あっ あっ
Dialogue: 0,0:16:42.67,0:16:45.84,Default,,0000,0000,0000,,悲しい 悲しいね
Dialogue: 0,0:16:45.84,0:16:51.84,Default,,0000,0000,0000,,悲しいよ 悲しいさ
Dialogue: 0,0:16:45.84,0:16:51.84,Default,,0000,0000,0000,,悲しいとも 悲しいからこそ
Dialogue: 0,0:16:51.84,0:16:54.18,Default,,0000,0000,0000,,悲しすぎるからこそ!
Dialogue: 0,0:16:54.18,0:16:59.35,Default,,0000,0000,0000,,僕たちは この一方的な再会を
Dialogue: 0,0:16:54.18,0:16:59.35,Default,,0000,0000,0000,,平らげずにはいられないのさ!
Dialogue: 0,0:16:59.35,0:17:02.62,Default,,0000,0000,0000,,ダイナスさん あの人は誰ですか?
Dialogue: 0,0:16:59.35,0:17:02.62,Default,,0000,0000,0000,,誰なんですか!?
Dialogue: 0,0:17:02.62,0:17:06.49,Default,,0000,0000,0000,,わからない!
Dialogue: 0,0:17:02.62,0:17:06.49,Default,,0000,0000,0000,,見たこともない顔だ!
Dialogue: 0,0:17:06.49,0:17:10.30,Default,,0000,0000,0000,,見たことも ないはずだ!
Dialogue: 0,0:17:10.30,0:17:12.97,Default,,0000,0000,0000,,滑稽だな ダイナス
Dialogue: 0,0:17:10.30,0:17:12.97,Default,,0000,0000,0000,,あっ!
Dialogue: 0,0:17:12.97,0:17:15.47,Default,,0000,0000,0000,,古いつきあいじゃないか
Dialogue: 0,0:17:15.47,0:17:18.47,Default,,0000,0000,0000,,故郷の浄化も あと1歩ってとこなのに
Dialogue: 0,0:17:18.47,0:17:20.81,Default,,0000,0000,0000,,そんな言い方されたら 傷ついちまうだろ?
Dialogue: 0,0:17:20.81,0:17:23.14,Default,,0000,0000,0000,,あっ お前 どこで それを!
Dialogue: 0,0:17:23.14,0:17:26.18,Default,,0000,0000,0000,,俺たちは お前の頑張りを知ってるよ
Dialogue: 0,0:17:26.18,0:17:30.35,Default,,0000,0000,0000,,ミリアンも メィリィも 守れなかったのは お前のせいじゃない
Dialogue: 0,0:17:30.35,0:17:33.15,Default,,0000,0000,0000,,くっ
Dialogue: 0,0:17:30.35,0:17:33.15,Default,,0000,0000,0000,,ただ
Dialogue: 0,0:17:33.15,0:17:36.16,Default,,0000,0000,0000,,運が悪かっただけさ!
Dialogue: 0,0:17:36.16,0:17:40.16,Default,,0000,0000,0000,,黙れ! 黙れ! 黙れ!
Dialogue: 0,0:17:36.16,0:17:40.16,Default,,0000,0000,0000,,お前が 俺の何を知ってる!?
Dialogue: 0,0:17:40.16,0:17:44.03,Default,,0000,0000,0000,,この腐れ外道が! フッ!
Dialogue: 0,0:17:44.03,0:17:47.53,Default,,0000,0000,0000,,記憶を食らい その者の技術も習得する
Dialogue: 0,0:17:47.53,0:17:50.87,Default,,0000,0000,0000,,これが 名前を食べる 暴食の権能!
Dialogue: 0,0:17:50.87,0:17:53.21,Default,,0000,0000,0000,,いいね いいよ いいさ!
Dialogue: 0,0:17:53.21,0:17:55.54,Default,,0000,0000,0000,,いいとも いいかも いいじゃない!
Dialogue: 0,0:17:55.54,0:17:58.88,Default,,0000,0000,0000,,いいじゃないか いいだろうからこそ!
Dialogue: 0,0:17:58.88,0:18:02.48,Default,,0000,0000,0000,,暴飲暴食!
Dialogue: 0,0:17:58.88,0:18:02.48,Default,,0000,0000,0000,,あっ! ぐはっ! くっ
Dialogue: 0,0:18:02.48,0:18:07.29,Default,,0000,0000,0000,,強い感情ってのは いいよね
Dialogue: 0,0:18:02.48,0:18:07.29,Default,,0000,0000,0000,,芳醇だ
Dialogue: 0,0:18:07.29,0:18:10.49,Default,,0000,0000,0000,,ジュクジュクッと 甘い甘い香りがして
Dialogue: 0,0:18:10.49,0:18:14.99,Default,,0000,0000,0000,,全身が しびれる感じがする っていうかさ
Dialogue: 0,0:18:14.99,0:18:16.96,Default,,0000,0000,0000,,わかるでしょ?
Dialogue: 0,0:18:16.96,0:18:19.97,Default,,0000,0000,0000,,残念ですが 凡人なもので 人間相手に
Dialogue: 0,0:18:19.97,0:18:23.30,Default,,0000,0000,0000,,おいしそうみたいなことは 思わないですかね
Dialogue: 0,0:18:23.30,0:18:26.97,Default,,0000,0000,0000,,あっ んっ
Dialogue: 0,0:18:26.97,0:18:28.97,Default,,0000,0000,0000,,皆さんに お願いが!
Dialogue: 0,0:18:28.97,0:18:31.14,Default,,0000,0000,0000,,今後 僕の名前を 呼ばないでください!
Dialogue: 0,0:18:31.14,0:18:33.65,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:18:31.14,0:18:33.65,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:33.65,0:18:38.18,Default,,0000,0000,0000,,もしかすると ここまで僕たちに 反撃を許したことすら
Dialogue: 0,0:18:38.18,0:18:40.69,Default,,0000,0000,0000,,あなたにとっては 食事の準備を整えるための
Dialogue: 0,0:18:40.69,0:18:43.86,Default,,0000,0000,0000,,配膳みたいなもの だったとか?
Dialogue: 0,0:18:43.86,0:18:47.86,Default,,0000,0000,0000,,本当に 勘のいい相手は 始末に負えない
Dialogue: 0,0:18:47.86,0:18:52.83,Default,,0000,0000,0000,,その分 味がよければ許すって 言いたいとこだけどさ
Dialogue: 0,0:18:52.83,0:18:55.50,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:18:52.83,0:18:57.50,Default,,0000,0000,0000,,ですから 自分かわいさと 思われるの 承知で言います
Dialogue: 0,0:18:57.50,0:19:01.27,Default,,0000,0000,0000,,僕の名前を呼ぶのは 絶対に
Dialogue: 0,0:18:57.50,0:19:01.27,Default,,0000,0000,0000,,悪いな 兄ちゃん
Dialogue: 0,0:19:01.27,0:19:05.28,Default,,0000,0000,0000,,そもそも俺は 兄ちゃんの名前とか知らねえわ
Dialogue: 0,0:19:05.28,0:19:08.11,Default,,0000,0000,0000,,えっ? えっ?
Dialogue: 0,0:19:08.11,0:19:10.78,Default,,0000,0000,0000,,すまんな 内政官殿
Dialogue: 0,0:19:10.78,0:19:14.62,Default,,0000,0000,0000,,俺も 名前のほうは失念して
Dialogue: 0,0:19:10.78,0:19:14.62,Default,,0000,0000,0000,,くぅ くっ
Dialogue: 0,0:19:14.62,0:19:16.79,Default,,0000,0000,0000,,はいはいはい そうですよね!
Dialogue: 0,0:19:16.79,0:19:19.79,Default,,0000,0000,0000,,別に僕 そんな皆さんと 親しくないですし
Dialogue: 0,0:19:19.79,0:19:22.29,Default,,0000,0000,0000,,重要人物ってわけでも ないですもんね!
Dialogue: 0,0:19:22.29,0:19:24.46,Default,,0000,0000,0000,,やった! ちくしょう!
Dialogue: 0,0:19:24.46,0:19:27.47,Default,,0000,0000,0000,,ダイナスとガストン
Dialogue: 0,0:19:24.46,0:19:27.47,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:19:27.47,0:19:30.97,Default,,0000,0000,0000,,悪くはないけど メインじゃないんだよ
Dialogue: 0,0:19:30.97,0:19:35.14,Default,,0000,0000,0000,,フェルトちゃんが逃げて お兄さんまで 食いそびれるってのは
Dialogue: 0,0:19:35.14,0:19:37.81,Default,,0000,0000,0000,,ちょっと 無理だよな
Dialogue: 0,0:19:37.81,0:19:41.48,Default,,0000,0000,0000,,ルイにも ぼろくそ叱られちゃうしね
Dialogue: 0,0:19:41.48,0:19:45.82,Default,,0000,0000,0000,,また 知らない名前で 嫌な予感がするな
Dialogue: 0,0:19:45.82,0:19:48.65,Default,,0000,0000,0000,,いいですか? 皆さん
Dialogue: 0,0:19:45.82,0:19:48.65,Default,,0000,0000,0000,,手で触って食べる
Dialogue: 0,0:19:48.65,0:19:51.32,Default,,0000,0000,0000,,触られたら 終わりだと思ってください
Dialogue: 0,0:19:51.32,0:19:55.33,Default,,0000,0000,0000,,ご丁寧にお待ちいただいて どうも
Dialogue: 0,0:19:55.33,0:19:57.33,Default,,0000,0000,0000,,行儀が よろしいんですね
Dialogue: 0,0:19:57.33,0:20:01.50,Default,,0000,0000,0000,,配膳が済むのを待つのは 美食家の常だよ
Dialogue: 0,0:20:01.50,0:20:06.84,Default,,0000,0000,0000,,食のこだわり
Dialogue: 0,0:20:01.50,0:20:06.84,Default,,0000,0000,0000,,それが人生を豊かにするからね
Dialogue: 0,0:20:06.84,0:20:09.64,Default,,0000,0000,0000,,それじゃあ いただきます!
Dialogue: 0,0:20:12.84,0:20:14.85,Default,,0000,0000,0000,,ヘヘッ
Dialogue: 0,0:20:14.85,0:20:17.85,Default,,0000,0000,0000,,たぁ! がっ!
Dialogue: 0,0:20:17.85,0:20:20.19,Default,,0000,0000,0000,,お! せい!
Dialogue: 0,0:20:17.85,0:20:20.19,Default,,0000,0000,0000,,んっ
Dialogue: 0,0:20:20.19,0:20:25.19,Default,,0000,0000,0000,,へぇ やるじゃん! でもさ せっかく 隙を作っても
Dialogue: 0,0:20:22.69,0:20:25.19,Default,,0000,0000,0000,,うおりゃ!
Dialogue: 0,0:20:25.19,0:20:27.53,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:20:25.19,0:20:27.53,Default,,0000,0000,0000,,くっ! うっ! うわっ!
Dialogue: 0,0:20:27.53,0:20:29.86,Default,,0000,0000,0000,,うぅ
Dialogue: 0,0:20:29.86,0:20:32.70,Default,,0000,0000,0000,,何事も 適材適所!
Dialogue: 0,0:20:32.70,0:20:37.87,Default,,0000,0000,0000,,誰にだって 食卓に上がる順序
Dialogue: 0,0:20:32.70,0:20:37.87,Default,,0000,0000,0000,,ってもんがあるだろ お兄さん!
Dialogue: 0,0:20:37.87,0:20:39.87,Default,,0000,0000,0000,,それを無視しちゃあ
Dialogue: 0,0:20:39.87,0:20:42.37,Default,,0000,0000,0000,,台なしだとでも?
Dialogue: 0,0:20:39.87,0:20:42.37,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:20:42.37,0:20:45.38,Default,,0000,0000,0000,,フッ
Dialogue: 0,0:20:42.37,0:20:45.38,Default,,0000,0000,0000,,んっ?
Dialogue: 0,0:20:45.38,0:20:47.58,Default,,0000,0000,0000,,うわ すごいじゃん!
Dialogue: 0,0:20:54.05,0:20:57.39,Default,,0000,0000,0000,,ゲホッ! ゴホッ! ハァハァ
Dialogue: 0,0:20:57.39,0:21:00.66,Default,,0000,0000,0000,,今回も 不意打ちになったはずですが
Dialogue: 0,0:21:00.66,0:21:02.83,Default,,0000,0000,0000,,ハッ! あっ
Dialogue: 0,0:21:02.83,0:21:06.00,Default,,0000,0000,0000,,ああ 全く ひどいな
Dialogue: 0,0:21:06.00,0:21:11.00,Default,,0000,0000,0000,,僕たちの一張羅が 台なしじゃあないか
Dialogue: 0,0:21:11.00,0:21:16.38,Default,,0000,0000,0000,,その傷が 今 あなたが
Dialogue: 0,0:21:11.00,0:21:16.38,Default,,0000,0000,0000,,そうなってる理由なら
Dialogue: 0,0:21:16.38,0:21:20.05,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:21:16.38,0:21:20.05,Default,,0000,0000,0000,,同情とかしちゃうわけ?
Dialogue: 0,0:21:20.05,0:21:22.71,Default,,0000,0000,0000,,安っぽいね お兄さん!
Dialogue: 0,0:21:22.71,0:21:24.85,Default,,0000,0000,0000,,だったら 名前 教えてよ
Dialogue: 0,0:21:24.85,0:21:29.19,Default,,0000,0000,0000,,まあ 聞く方法は 他にもあるんだけどね
Dialogue: 0,0:21:29.19,0:21:31.22,Default,,0000,0000,0000,,うっ!
Dialogue: 0,0:21:31.22,0:21:34.89,Default,,0000,0000,0000,,1本ずつ いこうか?
Dialogue: 0,0:21:31.22,0:21:34.89,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:34.89,0:21:37.90,Default,,0000,0000,0000,,いただきます!
Dialogue: 0,0:21:40.03,0:21:43.04,Default,,0000,0000,0000,,まだ全員 テーブルに着いてないのに
Dialogue: 0,0:21:43.04,0:21:47.84,Default,,0000,0000,0000,,食事を始めるなんて 礼儀知らずなやつなのよ
Dialogue: 0,0:21:50.58,0:21:53.55,Default,,0000,0000,0000,,あっ
Dialogue: 0,0:21:50.58,0:21:53.55,Default,,0000,0000,0000,,あっ?
Dialogue: 0,0:22:04.82,0:22:06.83,Default,,0000,0000,0000,,指は 大丈夫かしら?
Dialogue: 0,0:22:06.83,0:22:10.16,Default,,0000,0000,0000,,ええ 歯形は付いていますが
Dialogue: 0,0:22:06.83,0:22:10.16,Default,,0000,0000,0000,,そう
Dialogue: 0,0:22:10.16,0:22:13.83,Default,,0000,0000,0000,,なら こんな くそがき とっとと片づけて
Dialogue: 0,0:22:13.83,0:22:16.17,Default,,0000,0000,0000,,スバルに だっこしてもらいに行くのよ
Dialogue: 0,0:22:16.17,0:22:20.34,Default,,0000,0000,0000,,そうですね 助かりました ベア
Dialogue: 0,0:22:20.34,0:22:25.18,Default,,0000,0000,0000,,どうして ベアトリス様が 外を 出歩いていらっしゃるんですか?
Dialogue: 0,0:22:25.18,0:22:28.18,Default,,0000,0000,0000,,ハッ!
Dialogue: 0,0:22:25.18,0:22:28.18,Default,,0000,0000,0000,,あれだけ かたくなに
Dialogue: 0,0:22:28.18,0:22:31.68,Default,,0000,0000,0000,,禁書庫の外へ 出ようと なさらなかったのに
Dialogue: 0,0:22:31.68,0:22:36.69,Default,,0000,0000,0000,,お食事のときや 大精霊様と
Dialogue: 0,0:22:31.68,0:22:36.69,Default,,0000,0000,0000,,ご一緒のとき以外は
Dialogue: 0,0:22:36.69,0:22:40.86,Default,,0000,0000,0000,,ああ 例外もあったんだったかな?
Dialogue: 0,0:22:40.86,0:22:45.20,Default,,0000,0000,0000,,わかったかしら
Dialogue: 0,0:22:40.86,0:22:45.20,Default,,0000,0000,0000,,そういう からくりなのよ
Dialogue: 0,0:22:45.20,0:22:50.20,Default,,0000,0000,0000,,お前 自分の中に どれだけの人間を ため込んでいやがるかしら
Dialogue: 0,0:22:50.20,0:22:52.70,Default,,0000,0000,0000,,さあ?
Dialogue: 0,0:22:50.20,0:22:52.70,Default,,0000,0000,0000,,まさか!
Dialogue: 0,0:22:52.70,0:22:58.21,Default,,0000,0000,0000,,ロズワール・L・メイザース辺境伯が
Dialogue: 0,0:22:52.70,0:22:58.21,Default,,0000,0000,0000,,使用人筆頭
Dialogue: 0,0:22:58.21,0:23:01.01,Default,,0000,0000,0000,,今は ただ1人の いとしい人
Dialogue: 0,0:23:01.01,0:23:04.52,Default,,0000,0000,0000,,いずれ 英雄となる 我が最愛の人
Dialogue: 0,0:23:04.52,0:23:08.02,Default,,0000,0000,0000,,ナツキ・スバルの介添人 レム
Dialogue: 0,0:23:08.02,0:23:11.69,Default,,0000,0000,0000,,だったかな?
Dialogue: 0,0:23:11.69,0:23:15.83,Default,,0000,0000,0000,,会わせてくれよ いとしの英雄様に!
Dialogue: 0,0:23:15.83,0:23:21.17,Default,,0000,0000,0000,,俺たちの英雄が 僕たちを
Dialogue: 0,0:23:15.83,0:23:21.17,Default,,0000,0000,0000,,裁きに来てくれたはずなんだよ!
Dialogue: 0,0:23:21.17,0:23:24.17,Default,,0000,0000,0000,,この 暴食の大罪司教
Dialogue: 0,0:23:24.17,0:23:28.01,Default,,0000,0000,0000,,ライ・バテンカイトスをさ!
Dialogue: 0,0:23:28.01,0:23:30.84,Default,,0000,0000,0000,,こいつは
Dialogue: 0,0:23:30.84,0:23:35.88,Default,,0000,0000,0000,,こいつだけは スバルに
Dialogue: 0,0:23:30.84,0:23:35.88,Default,,0000,0000,0000,,会わせるわけにはいかないのよ
Dialogue: 0,0:23:35.88,0:23:38.38,Default,,0000,0000,0000,,こいつと会えば スバルは傷つく
Dialogue: 0,0:23:38.38,0:23:40.39,Default,,0000,0000,0000,,きっと 取り返しのつかないくらい
Dialogue: 0,0:23:40.39,0:23:43.36,Default,,0000,0000,0000,,ヘヘッ
Dialogue: 0,0:23:40.39,0:23:43.36,Default,,0000,0000,0000,,だから
Dialogue: 0,0:23:43.36,0:23:48.16,Default,,0000,0000,0000,,ここで 僕たちだけで しとめましょう!
